@inherits LayoutComponentBase
@using System.Security.Claims
@using Microsoft.AspNetCore.Components.Authorization
@inject IHttpContextAccessor HttpContextAccessor
@inject AuthenticationStateProvider AuthStateProvider
@inject IJSRuntime JSRuntime
@using EventHotelBroker.Utils

<link href="/css/design-system.css" rel="stylesheet" />

<ToastContainer />

<div class="modern-layout home-layout">
    <!-- Modern App Bar (no sidebar toggle) -->
    <header class="modern-app-bar home-app-bar">
        <div class="app-bar-content">
            <a href="/" class="app-bar-brand" style="text-decoration:none;">
                <span class="brand-text">Safari Vents</span>
            </a>
            <div class="app-bar-actions">
                <a href="/chat" class="app-bar-btn" title="Messages">
                    <i class="bi bi-chat-dots"></i>
                    <span class="notification-badge">3</span>
                </a>
                <button class="app-bar-btn" title="Notifications">
                    <i class="bi bi-bell"></i>
                    <span class="notification-badge">5</span>
                </button>
                <button class="app-bar-btn" title="Toggle Theme" @onclick="ToggleTheme">
                    @if (isDarkMode)
                    {
                        <i class="bi bi-sun"></i>
                    }
                    else
                    {
                        <i class="bi bi-moon"></i>
                    }
                </button>
                <button class="app-bar-btn" title="Settings">
                    <i class="bi bi-gear"></i>
                </button>
                <!-- Debug: @isLoggedIn.ToString() -->
                @if (isLoggedIn)
                {
                    <div class="user-profile" style="cursor: pointer; position: relative;" @onclick="ToggleUserMenu">
                        <div class="user-avatar" style="background: linear-gradient(135deg, #667eea, #764ba2); color: white;">
                            <span style="font-size: 0.85rem; font-weight: 600;">@userInitials</span>
                        </div>
                        <span class="user-name">@userName</span>
                        <i class="bi bi-chevron-down" style="font-size: 0.7rem; margin-left: 4px; color: #6c757d;"></i>
                    </div>
                    @if (showUserMenu)
                    {
                        <div style="position: absolute; top: 50px; right: 16px; background: white; border-radius: 12px; box-shadow: 0 8px 32px rgba(0,0,0,0.12); min-width: 220px; z-index: 2000; overflow: hidden;">
                            <div style="padding: 16px; border-bottom: 1px solid #f0f0f0;">
                                <div style="font-weight: 600; color: #2A2A2A; font-size: 0.9rem;">@userName</div>
                                <div style="color: #6c757d; font-size: 0.78rem;">@userEmail</div>
                                <span style="display: inline-block; margin-top: 6px; padding: 2px 8px; border-radius: 4px; font-size: 0.7rem; font-weight: 600; background: rgba(102,126,234,0.1); color: #667eea;">@userRole</span>
                            </div>
                            <a href="/profile" style="display: flex; align-items: center; gap: 8px; padding: 10px 16px; color: #333; text-decoration: none; font-size: 0.85rem; transition: background 0.15s;" onmouseover="this.style.background='#f8f9fa'" onmouseout="this.style.background='transparent'">
                                <i class="bi bi-person"></i> My Profile
                            </a>
                            <a href="/settings" style="display: flex; align-items: center; gap: 8px; padding: 10px 16px; color: #333; text-decoration: none; font-size: 0.85rem; transition: background 0.15s;" onmouseover="this.style.background='#f8f9fa'" onmouseout="this.style.background='transparent'">
                                <i class="bi bi-gear"></i> Settings
                            </a>
                            <div style="border-top: 1px solid #f0f0f0;">
                                <button onclick="document.getElementById('logoutModalHome').style.display='flex'" style="display: flex; align-items: center; gap: 8px; padding: 10px 16px; color: #dc3545; background: none; border: none; width: 100%; text-align: left; font-size: 0.85rem; cursor: pointer; transition: background 0.15s;" onmouseover="this.style.background='#fff5f5'" onmouseout="this.style.background='transparent'">
                                    <i class="bi bi-box-arrow-right"></i> Sign Out
                                </button>
                            </div>
                        </div>
                    }
                }
                else
                {
                    <div class="user-profile" style="cursor: pointer;" onclick="window.location.href='/login'">
                        <div class="user-avatar">
                            <i class="bi bi-person-circle"></i>
                        </div>
                        <span class="user-name">Login / Register</span>
                    </div>
                }
            </div>
        </div>
    </header>

    <!-- Main Content (full width, no sidebar offset) -->
    <main class="home-main-content">
        @Body
    </main>

    <!-- Floating Chat Button -->
    <a href="/chat" class="floating-chat-btn" title="Open Messages">
        <i class="bi bi-chat-dots-fill"></i>
        <span class="chat-badge">3</span>
    </a>
</div>

<!-- Logout Confirmation Modal (JS-driven) -->
<div id="logoutModalHome" onclick="if(event.target===this)this.style.display='none'" style="display:none; position:fixed; inset:0; background:rgba(0,0,0,0.45); z-index:9999; align-items:center; justify-content:center;">
    <div style="background:white; border-radius:16px; padding:32px; max-width:380px; width:90%; box-shadow:0 20px 60px rgba(0,0,0,0.2); text-align:center;">
        <div style="width:56px; height:56px; border-radius:50%; background:#fff5f5; display:flex; align-items:center; justify-content:center; margin:0 auto 16px;">
            <i class="bi bi-box-arrow-right" style="font-size:1.5rem; color:#dc3545;"></i>
        </div>
        <h3 style="margin:0 0 8px; color:#2A2A2A; font-size:1.15rem;">Sign Out</h3>
        <p style="color:#6c757d; font-size:0.9rem; margin:0 0 24px;">Are you sure you want to sign out of your account?</p>
        <div style="display:flex; gap:12px; justify-content:center;">
            <button onclick="document.getElementById('logoutModalHome').style.display='none'" style="padding:10px 24px; border-radius:8px; border:1px solid #dee2e6; background:white; color:#333; font-size:0.9rem; cursor:pointer; font-weight:500;">Cancel</button>
            <button onclick="window.location.href='/logout'" style="padding:10px 24px; border-radius:8px; border:none; background:#dc3545; color:white; font-size:0.9rem; cursor:pointer; font-weight:500;">Sign Out</button>
        </div>
    </div>
</div>

<style>
    .home-layout {
        display: block !important;
        grid-template-columns: unset !important;
    }

    .home-app-bar {
        left: 0 !important;
        width: 100% !important;
    }

    .home-main-content {
        margin-left: 0 !important;
        padding-top: 60px;
        min-height: 100vh;
    }

    .floating-chat-btn {
        position: fixed;
        bottom: 2rem;
        right: 2rem;
        width: 52px;
        height: 52px;
        border-radius: 50%;
        background: #2A2A2A;
        color: white;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.25rem;
        box-shadow: 0 4px 16px rgba(42, 42, 42, 0.3);
        z-index: 1000;
        transition: all 0.2s;
        text-decoration: none;
    }

    .floating-chat-btn:hover {
        transform: scale(1.08);
        box-shadow: 0 6px 20px rgba(42, 42, 42, 0.4);
        background: #9E8B63;
        color: white;
    }

    .chat-badge {
        position: absolute;
        top: -4px;
        right: -4px;
        background: #9E8B63;
        color: white;
        width: 20px;
        height: 20px;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 0.65rem;
        font-weight: 600;
        border: 2px solid white;
    }
</style>

@if (isDarkMode)
{
    <style>
        body, html, .modern-layout.home-layout {
            background-color: #000000 !important;
            color: #d1d5db !important;
        }

        /* Hero / General Backgrounds */
        .modern-hero {
            background: linear-gradient(160deg, #111111 0%, #000000 40%, #050505 100%) !important;
        }
        .how-it-works-section, .explore-section, .cta-section, .featured-section {
            background-color: #000000 !important;
            color: #d1d5db !important;
        }
        
        /* Typography overrides */
        .hero-title, .stat-number, .stat-value, .section-title, .feature-title, .card-title, .venue-title,
        .price-amount, .equip-title-home, .hotel-name, .package-title, .cta-title {
            color: #f9fafb !important;
        }
        .hero-subtitle, .stat-label, .section-subtitle, .feature-text, .card-subtitle, 
        .venue-location, .cta-text, .hotel-description, .package-description, .equip-desc-home,
        .price-label, .price-period {
            color: #9ca3af !important;
        }

        /* Cards and Elements */
        .modern-app-bar.home-app-bar,
        .modern-card,
        #logoutModalHome > div,
        .search-box, 
        .floating-card, 
        .feature-card, 
        .venue-card, 
        .hotel-card, 
        .package-card-home, 
        .equip-card-home, 
        .cta-card, 
        .cta-stat {
            background-color: #111111 !important;
            border-color: #2a2a2a !important;
            color: #f9fafb !important;
            box-shadow: 0 4px 16px rgba(234, 88, 12, 0.05) !important;
            transition: all 0.3s ease;
        }
        
        .floating-card:hover, .feature-card:hover, .venue-card:hover, .hotel-card:hover, .package-card-home:hover, .equip-card-home:hover {
            border-color: #ea580c !important;
            box-shadow: 0 8px 24px rgba(234, 88, 12, 0.15) !important;
            transform: translateY(-4px);
        }

        .search-box input {
            color: #f9fafb !important;
        }
        .search-box input::placeholder {
            color: #6b7280 !important;
        }

        /* Tabs */
        .modern-tabs {
            background-color: transparent !important;
        }
        .modern-tabs .nav-link {
            background-color: #111111 !important;
            color: #9ca3af !important;
            border: 1px solid #2a2a2a !important;
        }
        .modern-tabs .nav-link:hover {
            color: #ea580c !important;
            border-color: #ea580c !important;
        }
        .modern-tabs .nav-link.active {
            color: #ffffff !important;
            background-color: #ea580c !important;
            border-color: #ea580c !important;
        }

        .venue-capacity, .venue-footer, .hotel-footer, .package-footer, .equip-footer-home {
            background-color: #0d0d0d !important;
            color: #d1d5db !important;
            border-top: 1px solid #2a2a2a !important;
        }
        
        /* App Bar specific */
        .app-bar-btn, .brand-text {
            color: #f9fafb !important;
            transition: color 0.2s;
        }
        .app-bar-btn:hover {
            color: #ea580c !important;
        }
        .user-profile {
            color: #f9fafb !important;
        }
        .hotel-meta-row .hotel-rating i,
        .hotel-location i, .package-meta i {
            color: #ea580c !important;
        }
    </style>
}

@code {
    private bool showUserMenu = false;
    private bool isLoggedIn = false;
    private string userName = "";
    private string userEmail = "";
    private string userRole = "";
    private string userInitials = "";
    private bool isDarkMode = false;


    protected override void OnInitialized()
    {
        AuthStateProvider.AuthenticationStateChanged += OnAuthenticationStateChanged;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await LoadUserFromCookieAsync();
        }
    }

    private async void OnAuthenticationStateChanged(Task<AuthenticationState> task)
    {
        await InvokeAsync(async () =>
        {
            await LoadUserFromAuthStateAsync();
            StateHasChanged();
        });
    }

    private async Task LoadUserFromCookieAsync()
    {
        try
        {
            var token = await JSRuntime.InvokeAsync<string>("authHelpers.getCookie", "JWToken");
            
            if (!string.IsNullOrEmpty(token))
            {
                var customAuth = (CustomAuthenticationStateProvider)AuthStateProvider;
                await customAuth.MarkUserAsAuthenticated(token);
                await LoadUserFromAuthStateAsync();
            }
            
            StateHasChanged();
        }
        catch (Exception ex)
        {
            System.Diagnostics.Debug.WriteLine($"[HomeLayout] Cookie read error: {ex.Message}");
        }
    }

    private async Task LoadUserFromAuthStateAsync()
    {
        try
        {
            var authState = await AuthStateProvider.GetAuthenticationStateAsync();
            
            if (authState?.User?.Identity?.IsAuthenticated == true)
            {
                var user = authState.User;
                
                userName = user.FindFirst(ClaimTypes.GivenName)?.Value ?? "User";
                userEmail = user.FindFirst(ClaimTypes.Email)?.Value ?? "";
                userRole = user.FindFirst("AccountType")?.Value ?? user.FindFirst(ClaimTypes.Role)?.Value ?? "User";

                var namePartsForInitials = userName.Split(' ', StringSplitOptions.RemoveEmptyEntries);
                userInitials = namePartsForInitials.Length >= 2
                    ? $"{namePartsForInitials[0][0]}{namePartsForInitials[^1][0]}".ToUpper()
                    : (userName.Length >= 2 ? userName[..2].ToUpper() : userName.ToUpper());

                isLoggedIn = true;
            }
            else
            {
                isLoggedIn = false;
                userName = "";
                userEmail = "";
                userRole = "";
                userInitials = "";
            }
        }
        catch (Exception ex)
        {
            isLoggedIn = false;
        }
    }

    private void ToggleUserMenu()
    {
        showUserMenu = !showUserMenu;
    }

    private void ToggleTheme()
    {
        isDarkMode = !isDarkMode;
    }

}
