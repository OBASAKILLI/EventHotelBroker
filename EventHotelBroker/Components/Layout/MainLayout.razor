@inherits LayoutComponentBase
@using System.Security.Claims
@using Microsoft.AspNetCore.Components.Authorization
@inject IHttpContextAccessor HttpContextAccessor
@inject AuthenticationStateProvider AuthStateProvider
@inject IJSRuntime JSRuntime
@using EventHotelBroker.Utils

<link href="/css/design-system.css" rel="stylesheet" />
<link href="/css/dark-mode.css" rel="stylesheet" />

<ToastContainer />

<div class="modern-layout">
    <!-- Modern Sidebar (before app bar so ~ selector works for collapsed) -->
    <aside class="modern-sidebar @(sidebarCollapsed ? "collapsed" : "")">
        <NavMenu />
    </aside>

    <!-- Modern App Bar -->
    <header class="modern-app-bar">
        <div class="app-bar-content">
            <button class="sidebar-toggle" @onclick="ToggleSidebar">
                <i class="bi bi-list"></i>
            </button>
            <div class="app-bar-brand">
                <span class="brand-text">Safari Vents</span>
            </div>
            <div class="app-bar-actions">
                <button class="app-bar-btn" title="Toggle Theme" @onclick="ToggleTheme">
                    @if (isDarkMode)
                    {
                        <i class="bi bi-sun"></i>
                    }
                    else
                    {
                        <i class="bi bi-moon"></i>
                    }
                </button>
                <a href="/chat" class="app-bar-btn" title="Messages">
                    <i class="bi bi-chat-dots"></i>
                    <span class="notification-badge">3</span>
                </a>
                <button class="app-bar-btn" title="Notifications">
                    <i class="bi bi-bell"></i>
                    <span class="notification-badge">5</span>
                </button>
                <button class="app-bar-btn" title="Settings">
                    <i class="bi bi-gear"></i>
                </button>
                <!-- Debug: @isLoggedIn.ToString() -->
                @if (isLoggedIn)
                {
                    <div class="user-profile" style="cursor: pointer; position: relative;" @onclick="ToggleUserMenu">
                        <div class="user-avatar" style="background: linear-gradient(135deg, #667eea, #764ba2); color: white;">
                            <span style="font-size: 0.85rem; font-weight: 600;">@userInitials</span>
                        </div>
                        <span class="user-name">@userName</span>
                        <i class="bi bi-chevron-down" style="font-size: 0.7rem; margin-left: 4px; color: #6c757d;"></i>
                    </div>
                    @if (showUserMenu)
                    {
                        <div style="position: absolute; top: 50px; right: 16px; background: white; border-radius: 12px; box-shadow: 0 8px 32px rgba(0,0,0,0.12); min-width: 220px; z-index: 2000; overflow: hidden;">
                            <div style="padding: 16px; border-bottom: 1px solid #f0f0f0;">
                                <div style="font-weight: 600; color: #2A2A2A; font-size: 0.9rem;">@userName</div>
                                <div style="color: #6c757d; font-size: 0.78rem;">@userEmail</div>
                                <span style="display: inline-block; margin-top: 6px; padding: 2px 8px; border-radius: 4px; font-size: 0.7rem; font-weight: 600; background: rgba(102,126,234,0.1); color: #667eea;">@userRole</span>
                            </div>
                            <a href="/profile" style="display: flex; align-items: center; gap: 8px; padding: 10px 16px; color: #333; text-decoration: none; font-size: 0.85rem; transition: background 0.15s;" onmouseover="this.style.background='#f8f9fa'" onmouseout="this.style.background='transparent'">
                                <i class="bi bi-person"></i> My Profile
                            </a>
                            <a href="/settings" style="display: flex; align-items: center; gap: 8px; padding: 10px 16px; color: #333; text-decoration: none; font-size: 0.85rem; transition: background 0.15s;" onmouseover="this.style.background='#f8f9fa'" onmouseout="this.style.background='transparent'">
                                <i class="bi bi-gear"></i> Settings
                            </a>
                            <div style="border-top: 1px solid #f0f0f0;">
                                <button onclick="document.getElementById('logoutModal').style.display='flex'" style="display: flex; align-items: center; gap: 8px; padding: 10px 16px; color: #dc3545; background: none; border: none; width: 100%; text-align: left; font-size: 0.85rem; cursor: pointer; transition: background 0.15s;" onmouseover="this.style.background='#fff5f5'" onmouseout="this.style.background='transparent'">
                                    <i class="bi bi-box-arrow-right"></i> Sign Out
                                </button>
                            </div>
                        </div>
                    }
                }
                else
                {
                    <div class="user-profile" style="cursor: pointer;" onclick="window.location.href='/login'">
                        <div class="user-avatar">
                            <i class="bi bi-person-circle"></i>
                        </div>
                        <span class="user-name">Login / Register</span>
                    </div>
                }
            </div>
        </div>
    </header>


    <!-- Main Content -->
    <main class="modern-main-content">
        <div class="content-wrapper">
            @Body
        </div>
    </main>

    <!-- Floating Chat Button -->
    <a href="/chat" class="floating-chat-btn" title="Open Messages">
        <i class="bi bi-chat-dots-fill"></i>
        <span class="chat-badge">3</span>
    </a>
</div>

<!-- Logout Confirmation Modal (JS-driven, works in static + interactive) -->
<div id="logoutModal" onclick="if(event.target===this)this.style.display='none'" style="display:none; position:fixed; inset:0; background:rgba(0,0,0,0.45); z-index:9999; align-items:center; justify-content:center;">
    <div style="background:white; border-radius:16px; padding:32px; max-width:380px; width:90%; box-shadow:0 20px 60px rgba(0,0,0,0.2); text-align:center;">
        <div style="width:56px; height:56px; border-radius:50%; background:#fff5f5; display:flex; align-items:center; justify-content:center; margin:0 auto 16px;">
            <i class="bi bi-box-arrow-right" style="font-size:1.5rem; color:#dc3545;"></i>
        </div>
        <h3 style="margin:0 0 8px; color:#2A2A2A; font-size:1.15rem;">Sign Out</h3>
        <p style="color:#6c757d; font-size:0.9rem; margin:0 0 24px;">Are you sure you want to sign out of your account?</p>
        <div style="display:flex; gap:12px; justify-content:center;">
            <button onclick="document.getElementById('logoutModal').style.display='none'" style="padding:10px 24px; border-radius:8px; border:1px solid #dee2e6; background:white; color:#333; font-size:0.9rem; cursor:pointer; font-weight:500;">Cancel</button>
            <button onclick="window.location.href='/logout'" style="padding:10px 24px; border-radius:8px; border:none; background:#dc3545; color:white; font-size:0.9rem; cursor:pointer; font-weight:500;">Sign Out</button>
        </div>
    </div>
</div>

<style>
    .floating-chat-btn {
        position: fixed;
        bottom: 2rem;
        right: 2rem;
        width: 52px;
        height: 52px;
        border-radius: 50%;
        background: #2A2A2A;
        color: white;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.25rem;
        box-shadow: 0 4px 16px rgba(42, 42, 42, 0.3);
        z-index: 1000;
        transition: all 0.2s;
        text-decoration: none;
    }

    .floating-chat-btn:hover {
        transform: scale(1.08);
        box-shadow: 0 6px 20px rgba(42, 42, 42, 0.4);
        background: #9E8B63;
        color: white;
    }

    .chat-badge {
        position: absolute;
        top: -4px;
        right: -4px;
        background: #9E8B63;
        color: white;
        width: 20px;
        height: 20px;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 0.65rem;
        font-weight: 600;
        border: 2px solid white;
    }
</style>

@code {
    private bool sidebarCollapsed = false;
    private bool showUserMenu = false;
    private bool isLoggedIn = false;
    private string userName = "";
    private string userEmail = "";
    private string userRole = "";
    private string userInitials = "";
    private bool isDarkMode = false;

    protected override void OnInitialized()
    {
        AuthStateProvider.AuthenticationStateChanged += OnAuthenticationStateChanged;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await LoadUserFromCookieAsync();
            await LoadThemePreference();
        }
    }

    private async void OnAuthenticationStateChanged(Task<AuthenticationState> task)
    {
        await InvokeAsync(async () =>
        {
            await LoadUserFromAuthStateAsync();
            StateHasChanged();
        });
    }

    private async Task LoadUserFromCookieAsync()
    {
        try
        {
            // Read JWT cookie via JS interop (works after circuit is established)
            var token = await JSRuntime.InvokeAsync<string>("authHelpers.getCookie", "JWToken");
            
            if (!string.IsNullOrEmpty(token))
            {
                // Cache token in auth state provider for this circuit
                var customAuth = (CustomAuthenticationStateProvider)AuthStateProvider;
                await customAuth.MarkUserAsAuthenticated(token);
                await LoadUserFromAuthStateAsync();
            }
            
            StateHasChanged();
        }
        catch (Exception ex)
        {
            System.Diagnostics.Debug.WriteLine($"[MainLayout] Cookie read error: {ex.Message}");
        }
    }

    private async Task LoadUserFromAuthStateAsync()
    {
        try
        {
            var authState = await AuthStateProvider.GetAuthenticationStateAsync();
            
            if (authState?.User?.Identity?.IsAuthenticated == true)
            {
                var user = authState.User;
                
                userName = user.FindFirst(ClaimTypes.GivenName)?.Value ?? "User";
                userEmail = user.FindFirst(ClaimTypes.Email)?.Value ?? "";
                userRole = user.FindFirst("AccountType")?.Value ?? user.FindFirst(ClaimTypes.Role)?.Value ?? "User";

                var namePartsForInitials = userName.Split(' ', StringSplitOptions.RemoveEmptyEntries);
                userInitials = namePartsForInitials.Length >= 2
                    ? $"{namePartsForInitials[0][0]}{namePartsForInitials[^1][0]}".ToUpper()
                    : (userName.Length >= 2 ? userName[..2].ToUpper() : userName.ToUpper());

                isLoggedIn = true;
            }
            else
            {
                isLoggedIn = false;
                userName = "";
                userEmail = "";
                userRole = "";
                userInitials = "";
            }
        }
        catch (Exception ex)
        {
            isLoggedIn = false;
        }
    }

    private void ToggleSidebar()
    {
        sidebarCollapsed = !sidebarCollapsed;
    }

    private void ToggleUserMenu()
    {
        showUserMenu = !showUserMenu;
    }

    private async Task ToggleTheme()
    {
        isDarkMode = !isDarkMode;
        // Save preference to localStorage for persistence
        await JSRuntime.InvokeVoidAsync("localStorage.setItem", "darkMode", isDarkMode.ToString());
        
        // Apply or remove dark-mode class on body
        if (isDarkMode)
        {
            await JSRuntime.InvokeVoidAsync("document.body.classList.add", "dark-mode");
        }
        else
        {
            await JSRuntime.InvokeVoidAsync("document.body.classList.remove", "dark-mode");
        }
        
        StateHasChanged();
    }

    private async Task LoadThemePreference()
    {
        try
        {
            var darkModeStr = await JSRuntime.InvokeAsync<string>("localStorage.getItem", "darkMode");
            if (!string.IsNullOrEmpty(darkModeStr))
            {
                isDarkMode = darkModeStr.ToLower() == "true";
                
                // Apply dark-mode class to body
                if (isDarkMode)
                {
                    await JSRuntime.InvokeVoidAsync("document.body.classList.add", "dark-mode");
                }
                
                StateHasChanged();
            }
        }
        catch
        {
            // Fallback to system preference if localStorage fails
            isDarkMode = await JSRuntime.InvokeAsync<bool>("window.matchMedia", "(prefers-color-scheme: dark)");
            
            if (isDarkMode)
            {
                await JSRuntime.InvokeVoidAsync("document.body.classList.add", "dark-mode");
            }
            
            StateHasChanged();
        }
    }

}

<div id="blazor-error-ui" class="modern-error-ui">
    <div class="error-content">
        <i class="bi bi-exclamation-triangle-fill"></i>
        <span>An unhandled error has occurred.</span>
        <a href="" class="reload">Reload</a>
        <a class="dismiss">×</a>
    </div>
</div>
