<!-- Enroll Confirmation Modal -->
@if (showEnrollModal)
{
    <div style="position:fixed;inset:0;background:rgba(0,0,0,0.5);z-index:9999;display:flex;align-items:center;justify-content:center;">
        <div style="background:white;border-radius:16px;padding:32px;max-width:420px;width:90%;box-shadow:0 20px 60px rgba(0,0,0,0.2);">
            <div style="text-align:center;margin-bottom:20px;">
                <div style="width:64px;height:64px;background:linear-gradient(135deg,#f59e0b,#d97706);border-radius:50%;display:flex;align-items:center;justify-content:center;margin:0 auto 16px;">
                    <i class="bi bi-shop" style="font-size:1.8rem;color:white;"></i>
                </div>
                <h4 style="font-weight:700;color:#1a1a1a;margin-bottom:8px;">Become a Business Owner</h4>
                <p style="color:#6c757d;font-size:0.9rem;line-height:1.5;">You're about to enroll as a Business Owner on Safari Vents. This will let you list hotels, venues, and equipment for clients to book.</p>
            </div>
            @if (!string.IsNullOrEmpty(enrollError))
            {
                <div style="background:#fff5f5;border:1px solid #fed7d7;border-radius:8px;padding:10px 14px;margin-bottom:16px;color:#c53030;font-size:0.85rem;">
                    <i class="bi bi-exclamation-circle me-2"></i>@enrollError
                </div>
            }
            <div style="display:flex;gap:10px;">
                <button @onclick="() => showEnrollModal = false" style="flex:1;padding:12px;border:1px solid #e2e8f0;border-radius:10px;background:white;color:#4a5568;font-weight:600;cursor:pointer;">Cancel</button>
                <button @onclick="ConfirmEnroll" disabled="@isEnrolling"
                    style="flex:1;padding:12px;border:none;border-radius:10px;background:linear-gradient(135deg,#f59e0b,#d97706);color:white;font-weight:600;cursor:pointer;">
                    @if (isEnrolling)
                    { <span class="spinner-border spinner-border-sm me-1"></span> }
                    Enroll Now
                </button>
            </div>
        </div>
    </div>
}

<style>
    .nav-section-label {
        font-size: 0.68rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.08em;
        color: #9e8b63;
        padding: 16px 20px 6px;
    }

    .nav-enroll-cta {
        display: flex;
        align-items: center;
        gap: 12px;
        margin: 16px 12px 8px;
        padding: 14px 16px;
        background: linear-gradient(135deg, rgba(245,158,11,0.08), rgba(217,119,6,0.12));
        border: 1px dashed rgba(245,158,11,0.4);
        border-radius: 12px;
        cursor: pointer;
        transition: all 0.2s ease;
    }

    .nav-enroll-cta:hover {
        background: linear-gradient(135deg, rgba(245,158,11,0.15), rgba(217,119,6,0.2));
        border-color: rgba(245,158,11,0.7);
        transform: translateX(2px);
    }

    .nav-enroll-icon {
        width: 40px;
        height: 40px;
        background: linear-gradient(135deg, #f59e0b, #d97706);
        border-radius: 10px;
        display: flex;
        align-items: center;
        justify-content: center;
        flex-shrink: 0;
        color: white;
        font-size: 1.1rem;
    }

    .nav-enroll-text {
        flex: 1;
        display: flex;
        flex-direction: column;
        gap: 2px;
    }

    .nav-enroll-title {
        font-size: 0.85rem;
        font-weight: 700;
        color: #1a1a1a;
    }

    .nav-enroll-subtitle {
        font-size: 0.72rem;
        color: #6c757d;
        line-height: 1.3;
    }

    .nav-enroll-arrow {
        color: #f59e0b;
        font-size: 0.8rem;
    }
</style>

@code {
    private bool isOwner = false;
    private bool isAdmin = false;
    private bool showEnrollModal = false;
    private bool isEnrolling = false;
    private string enrollError = "";
    private string currentUserId = "";

    protected override async Task OnInitializedAsync()
    {
        await LoadUserRoles();
    }

    private async Task LoadUserRoles()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        var user = authState.User;

        if (user.Identity?.IsAuthenticated == true)
        {
            // The Name claim contains "userId,AccountType,TwoFAEnabled"
            var nameClaim = user.FindFirst(ClaimTypes.Name)?.Value ?? "";
            var parts = nameClaim.Split(',');
            currentUserId = parts.Length > 0 ? parts[0] : "";
            var accountType = parts.Length > 1 ? parts[1] : "";

            // Also check dedicated AccountType claim
            var accountTypeClaim = user.FindFirst("AccountType")?.Value ?? accountType;

            isAdmin = accountTypeClaim.Contains("Admin", StringComparison.OrdinalIgnoreCase);
            isOwner = accountTypeClaim.Contains("HotelOwner", StringComparison.OrdinalIgnoreCase) ||
                      accountTypeClaim.Contains("Owner", StringComparison.OrdinalIgnoreCase);
        }
    }

    private void EnrollAsOwner()
    {
        enrollError = "";
        showEnrollModal = true;
    }

    private async Task ConfirmEnroll()
    {
        isEnrolling = true;
        enrollError = "";
        StateHasChanged();

        try
        {
            Navigation.NavigateTo($"/enroll-as-owner?userId={currentUserId}", forceLoad: true);
        }
        catch (Exception ex)
        {
            enrollError = $"An error occurred: {ex.Message}";
            isEnrolling = false;
            StateHasChanged();
        }
    }
}
