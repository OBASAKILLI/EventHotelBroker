@page "/my-bookings"
@rendermode InteractiveServer
@using EventHotelBroker.Models
@using EventHotelBroker.Services
@using EventHotelBroker.Utils
@using System.Security.Claims
@using Microsoft.AspNetCore.Components.Authorization
@inject IBookingService BookingService
@inject NavigationManager Navigation
@inject IJSRuntime JSRuntime
@inject AuthenticationStateProvider AuthStateProvider

<PageTitle>My Bookings - EventHotelBroker</PageTitle>

<link href="/css/my-bookings.css" rel="stylesheet" />

<div class="bookings-page">
    <div class="bookings-header">
        <div class="bookings-header-left">
            <h1><i class="bi bi-calendar-check"></i> My Bookings</h1>
            <p>Track and manage your hotel reservations</p>
        </div>
        <a href="/search" class="bookings-new-btn">
            <i class="bi bi-plus-circle"></i> New Booking
        </a>
    </div>

    @if (isLoading)
    {
        <div class="bookings-loading">
            <div class="spinner-border" role="status">
                <span class="visually-hidden">Loading...</span>
            </div>
            <p>Loading your bookings...</p>
        </div>
    }
    else
    {
        <div class="bookings-stats">
            <div class="stat-card">
                <div>
                    <div class="stat-value">@bookings.Count()</div>
                    <div class="stat-label">Total Bookings</div>
                </div>
                <div class="stat-icon total"><i class="bi bi-calendar-event"></i></div>
            </div>
            <div class="stat-card">
                <div>
                    <div class="stat-value">@bookings.Count(b => b.Status == BookingStatus.Pending)</div>
                    <div class="stat-label">Pending</div>
                </div>
                <div class="stat-icon pending"><i class="bi bi-clock-history"></i></div>
            </div>
            <div class="stat-card">
                <div>
                    <div class="stat-value">@bookings.Count(b => b.Status == BookingStatus.Confirmed)</div>
                    <div class="stat-label">Confirmed</div>
                </div>
                <div class="stat-icon confirmed"><i class="bi bi-check-circle"></i></div>
            </div>
            <div class="stat-card">
                <div>
                    <div class="stat-value">@upcomingBookings</div>
                    <div class="stat-label">Upcoming</div>
                </div>
                <div class="stat-icon upcoming"><i class="bi bi-calendar3"></i></div>
            </div>
        </div>

        <div class="bookings-search-bar">
            <div class="search-input-wrap">
                <i class="bi bi-search"></i>
                <input type="text" placeholder="Search by hotel name, city, or notes..." @bind="searchTerm" @bind:event="oninput" @bind:after="ApplyFilters" />
            </div>
            <div class="search-filters">
                <select class="filter-select" @bind="statusFilter" @bind:after="ApplyFilters">
                    <option value="">All Statuses</option>
                    <option value="Pending">Pending</option>
                    <option value="Confirmed">Confirmed</option>
                    <option value="Cancelled">Cancelled</option>
                    <option value="Rejected">Rejected</option>
                </select>
                <span class="filter-count">@filteredBookings.Count() results</span>
            </div>
        </div>

        @if (pagedBookings.Any())
        {
            <div class="bookings-table-card">
                <div class="table-responsive-wrap">
                    <table class="bookings-table">
                        <thead>
                            <tr>
                                <th>ID</th>
                                <th>Hotel</th>
                                <th>Location</th>
                                <th>Check-in</th>
                                <th>Check-out</th>
                                <th>Guests</th>
                                <th>Price/Night</th>
                                <th>Status</th>
                                <th>Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var booking in pagedBookings)
                            {
                                <tr>
                                    <td>
                                        <span class="cell-id">#@booking.Id</span>
                                    </td>
                                    <td>
                                        <div class="cell-hotel-name">@booking.Hotel?.Name</div>
                                        @if (!string.IsNullOrEmpty(booking.Notes))
                                        {
                                            <span class="cell-hotel-note">@(booking.Notes.Length > 35 ? booking.Notes.Substring(0, 35) + "..." : booking.Notes)</span>
                                        }
                                    </td>
                                    <td>
                                        <span class="cell-location"><i class="bi bi-geo-alt-fill"></i> @booking.Hotel?.City</span>
                                    </td>
                                    <td>
                                        <span class="cell-date"><i class="bi bi-box-arrow-in-right" style="color:#059669"></i> @booking.StartDate.ToString("MMM dd, yyyy")</span>
                                    </td>
                                    <td>
                                        <span class="cell-date"><i class="bi bi-box-arrow-right" style="color:#dc2626"></i> @booking.EndDate.ToString("MMM dd, yyyy")</span>
                                    </td>
                                    <td>
                                        <span class="cell-guests"><i class="bi bi-people-fill"></i> @booking.HeadCount</span>
                                    </td>
                                    <td>
                                        <span class="cell-price">@booking.Hotel?.Currency @((booking.Hotel?.PricePerNight ?? 0).ToString("N0"))</span>
                                    </td>
                                    <td>
                                        <span class="status-badge @GetStatusClass(booking.Status)">
                                            <i class="bi @GetStatusIcon(booking.Status)"></i>
                                            @booking.Status
                                        </span>
                                        @if (booking.Status == BookingStatus.Rejected && !string.IsNullOrEmpty(booking.RejectionReason))
                                        {
                                            <div class="rejection-info-inline">
                                                <i class="bi bi-info-circle"></i>
                                                <span>@(booking.RejectionReason.Length > 40 ? booking.RejectionReason.Substring(0, 40) + "..." : booking.RejectionReason)</span>
                                            </div>
                                        }
                                        @if (booking.Status == BookingStatus.Rejected && booking.RejectedAt.HasValue)
                                        {
                                            <div class="rejection-date-inline">@booking.RejectedAt.Value.ToString("MMM dd, yyyy")</div>
                                        }
                                    </td>
                                    <td>
                                        <div class="cell-actions">
                                            <a href="/booking/details/@booking.Id" class="action-btn-sm view" title="View">
                                                <i class="bi bi-eye"></i>
                                            </a>
                                            @if (booking.Status == BookingStatus.Pending)
                                            {
                                                <button class="action-btn-sm cancel" title="Cancel">
                                                    <i class="bi bi-x-lg"></i>
                                                </button>
                                            }
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>

            @if (totalPages > 1)
            {
                <div class="bookings-pagination">
                    <button class="page-btn" disabled="@(currentPage == 1)" @onclick="() => GoToPage(currentPage - 1)">
                        <i class="bi bi-chevron-left"></i>
                    </button>
                    @for (int p = 1; p <= totalPages; p++)
                    {
                        var pageNum = p;
                        <button class="page-btn @(pageNum == currentPage ? "active" : "")" @onclick="() => GoToPage(pageNum)">
                            @pageNum
                        </button>
                    }
                    <button class="page-btn" disabled="@(currentPage == totalPages)" @onclick="() => GoToPage(currentPage + 1)">
                        <i class="bi bi-chevron-right"></i>
                    </button>
                    <span class="page-info">Page @currentPage of @totalPages</span>
                </div>
            }
        }
        else
        {
            <div class="bookings-empty">
                <i class="bi bi-calendar-x"></i>
                <h4>No Bookings Found</h4>
                <p>@(string.IsNullOrEmpty(searchTerm) && string.IsNullOrEmpty(statusFilter) ? "Start planning your perfect event today!" : "Try adjusting your search or filters.")</p>
                @if (string.IsNullOrEmpty(searchTerm) && string.IsNullOrEmpty(statusFilter))
                {
                    <a href="/search" class="bookings-new-btn">
                        <i class="bi bi-plus-circle"></i> Browse Hotels
                    </a>
                }
            </div>
        }
    }
</div>

@code {
    private bool isLoading = true;
    private List<Booking> bookings = new();
    private string? currentUserId;
    private int upcomingBookings = 0;

    // Search & filter
    private string searchTerm = "";
    private string statusFilter = "";

    // Pagination
    private int currentPage = 1;
    private int pageSize = 10;

    private IEnumerable<Booking> filteredBookings => bookings
        .Where(b =>
            (string.IsNullOrEmpty(searchTerm) ||
             (b.Hotel?.Name?.Contains(searchTerm, StringComparison.OrdinalIgnoreCase) == true) ||
             (b.Hotel?.City?.Contains(searchTerm, StringComparison.OrdinalIgnoreCase) == true) ||
             (b.Notes?.Contains(searchTerm, StringComparison.OrdinalIgnoreCase) == true))
            &&
            (string.IsNullOrEmpty(statusFilter) || b.Status.ToString() == statusFilter)
        )
        .OrderByDescending(b => b.StartDate);

    private int totalPages => Math.Max(1, (int)Math.Ceiling((double)filteredBookings.Count() / pageSize));

    private IEnumerable<Booking> pagedBookings => filteredBookings
        .Skip((currentPage - 1) * pageSize)
        .Take(pageSize);

    private void ApplyFilters()
    {
        currentPage = 1;
    }

    private void GoToPage(int page)
    {
        if (page >= 1 && page <= totalPages)
            currentPage = page;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await LoadBookings();
            StateHasChanged();
        }
    }

    private async Task LoadBookings()
    {
        try
        {
            currentUserId = await GetCurrentUserIdAsync();
            if (!string.IsNullOrEmpty(currentUserId))
            {
                bookings = (await BookingService.GetBookingsByUserAsync(currentUserId)).ToList();
            }
            upcomingBookings = bookings.Count(b => b.StartDate >= DateTime.Today && 
                                                   (b.Status == BookingStatus.Confirmed || b.Status == BookingStatus.Pending));
        }
        catch (Exception)
        {
            bookings = new List<Booking>();
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task<string?> GetCurrentUserIdAsync()
    {
        try
        {
            string? token = null;
            try { token = await JSRuntime.InvokeAsync<string>("authHelpers.getCookie", "JWToken"); } catch { }
            if (!string.IsNullOrEmpty(token))
            {
                var customAuth = (CustomAuthenticationStateProvider)AuthStateProvider;
                await customAuth.MarkUserAsAuthenticated(token);
            }
            var authState = await AuthStateProvider.GetAuthenticationStateAsync();
            var user = authState?.User;
            if (user?.Identity?.IsAuthenticated == true)
            {
                var nameClaim = user.FindFirst(ClaimTypes.Name)?.Value;
                if (!string.IsNullOrEmpty(nameClaim))
                {
                    var parts = nameClaim.Split(',');
                    if (parts.Length > 0) return parts[0];
                }
            }
        }
        catch { }
        return null;
    }

    private string GetStatusColor(BookingStatus status)
    {
        return status switch
        {
            BookingStatus.Pending => "warning",
            BookingStatus.Confirmed => "success",
            BookingStatus.Rejected => "danger",
            BookingStatus.Cancelled => "secondary",
            _ => "secondary"
        };
    }

    private string GetStatusClass(BookingStatus status)
    {
        return status switch
        {
            BookingStatus.Pending => "pending",
            BookingStatus.Confirmed => "confirmed",
            BookingStatus.Rejected => "rejected",
            BookingStatus.Cancelled => "rejected",
            _ => ""
        };
    }

    private string GetStatusIcon(BookingStatus status)
    {
        return status switch
        {
            BookingStatus.Pending => "bi-clock-history",
            BookingStatus.Confirmed => "bi-check-circle-fill",
            BookingStatus.Rejected => "bi-x-circle-fill",
            BookingStatus.Cancelled => "bi-dash-circle-fill",
            _ => "bi-circle"
        };
    }
}
