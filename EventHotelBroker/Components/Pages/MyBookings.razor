                EndDate = DateTime.Now.AddDays(33),
                HeadCount = 100,
                Status = BookingStatus.Pending,
                Notes = "Beach wedding ceremony and reception. Need setup for 100 guests.",
                CreatedAt = DateTime.Now.AddDays(-3)
            },
            new Booking
            {
                Id = 3,
                UserId = currentUserId,
                HotelId = 3,
                Hotel = new Hotel
                {
                    Id = 3,
                    Name = "Mount Kenya Safari Lodge",
                    City = "Nanyuki",
                    Country = "Kenya",
                    PricePerNight = 18000,
                    Currency = "KES"
                },
                StartDate = DateTime.Now.AddDays(-10),
                EndDate = DateTime.Now.AddDays(-8),
                HeadCount = 50,
                Status = BookingStatus.Confirmed,
                Notes = "Team building retreat for 50 employees.",
                CreatedAt = DateTime.Now.AddDays(-20)
            },
            new Booking
            {
                Id = 4,
                UserId = currentUserId,
                HotelId = 4,
                Hotel = new Hotel
                {
                    Id = 4,
                    Name = "Westlands Conference Center",
                    City = "Nairobi",
                    Country = "Kenya",
                    PricePerNight = 50000,
                    Currency = "KES"
                },
                StartDate = DateTime.Now.AddDays(7),
                EndDate = DateTime.Now.AddDays(7),
                HeadCount = 300,
                Status = BookingStatus.Pending,
                Notes = "Product launch event. Full day conference.",
                CreatedAt = DateTime.Now.AddDays(-2)
            },
            new Booking
            {
                Id = 5,
                UserId = currentUserId,
                HotelId = 5,
                Hotel = new Hotel
                {
                    Id = 5,
                    Name = "Lake Nakuru View Hotel",
                    City = "Nakuru",
                    Country = "Kenya",
                    PricePerNight = 15000,
                    Currency = "KES"
                },
                StartDate = DateTime.Now.AddDays(-30),
                EndDate = DateTime.Now.AddDays(-28),
                HeadCount = 40,
                Status = BookingStatus.Cancelled,
                Notes = "Weekend getaway for family reunion. Cancelled due to schedule conflict.",
                CreatedAt = DateTime.Now.AddDays(-45)
            },
            new Booking
            {
                Id = 6,
                UserId = currentUserId,
                HotelId = 1,
                Hotel = new Hotel
                {
                    Id = 1,
                    Name = "Grand Plaza Hotel Nairobi",
                    City = "Nairobi",
                    Country = "Kenya",
                    PricePerNight = 25000,
                    Currency = "KES"
                },
                StartDate = DateTime.Now.AddDays(45),
                EndDate = DateTime.Now.AddDays(46),
                HeadCount = 200,
                Status = BookingStatus.Confirmed,
                Notes = "Annual gala dinner and awards ceremony.",
                CreatedAt = DateTime.Now.AddDays(-1)
            }
        };
    }

    private string GetStatusColor(BookingStatus status)
    {
        return status switch
        {
            BookingStatus.Pending => "warning",
            BookingStatus.Confirmed => "success",
            BookingStatus.Rejected => "danger",
            BookingStatus.Cancelled => "secondary",
            _ => "secondary"
        };
    }

    private string GetStatusClass(BookingStatus status)
    {
        return status switch
        {
            BookingStatus.Pending => "pending",
            BookingStatus.Confirmed => "confirmed",
            BookingStatus.Rejected => "rejected",
            BookingStatus.Cancelled => "rejected",
            _ => ""
        };
    }

    private string GetStatusIcon(BookingStatus status)
    {
        return status switch
        {
            BookingStatus.Pending => "bi-clock-history",
            BookingStatus.Confirmed => "bi-check-circle-fill",
            BookingStatus.Rejected => "bi-x-circle-fill",
            BookingStatus.Cancelled => "bi-dash-circle-fill",
            _ => "bi-circle"
        };
    }
}
