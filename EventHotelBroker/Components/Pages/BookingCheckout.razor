@page "/booking/checkout/{hotelId:int}"
@rendermode InteractiveServer
@inject NavigationManager Navigation
@inject IHotelService HotelService
@using EventHotelBroker.Services
@using EventHotelBroker.Models

<PageTitle>Checkout - EventHotelBroker</PageTitle>

<link href="/css/booking-checkout.css" rel="stylesheet" />

<div class="checkout-page">
    @if (isLoading)
    {
        <div class="co-loading">
            <div class="spinner-border" role="status">
                <span class="visually-hidden">Loading...</span>
            </div>
        </div>
    }
    else if (hotel != null)
    {
        <!-- Step Indicator -->
        <div class="co-steps">
            <div class="co-step @(currentStep >= 1 ? "completed" : "") @(currentStep == 1 ? "active" : "")">
                <div class="co-step-circle">@(currentStep > 1 ? "" : "1")<i class="bi @(currentStep > 1 ? "bi-check" : "")"></i></div>
                <span class="co-step-label">Booking Details</span>
            </div>
            <div class="co-step-line @(currentStep > 1 ? "completed" : "")"></div>
            <div class="co-step @(currentStep >= 2 ? "completed" : "") @(currentStep == 2 ? "active" : "")">
                <div class="co-step-circle">@(currentStep > 2 ? "" : "2")<i class="bi @(currentStep > 2 ? "bi-check" : "")"></i></div>
                <span class="co-step-label">Payment</span>
            </div>
            <div class="co-step-line @(currentStep > 2 ? "completed" : "")"></div>
            <div class="co-step @(currentStep >= 3 ? "completed" : "") @(currentStep == 3 ? "active" : "")">
                <div class="co-step-circle">3</div>
                <span class="co-step-label">Confirmation</span>
            </div>
        </div>

        <div class="checkout-layout">
            <div class="checkout-main">
                @if (currentStep == 1)
                {
                    <div class="co-card">
                        <div class="co-card-header"><i class="bi bi-building"></i> Booking Details</div>
                        <div class="co-card-body">
                            <div class="co-hotel-info">
                                <div>
                                    <h4>@hotel.Name</h4>
                                    <p class="co-hotel-loc"><i class="bi bi-geo-alt"></i> @hotel.Address, @hotel.City</p>
                                    <p class="co-hotel-cap"><i class="bi bi-people"></i> Capacity: @hotel.Capacity guests</p>
                                </div>
                                <div class="co-hotel-price">
                                    <div class="co-price-amt">@hotel.Currency @hotel.PricePerNight.ToString("N0")</div>
                                    <div class="co-price-per">per night</div>
                                </div>
                            </div>

                            <div class="co-form-grid">
                                <div class="co-form-group">
                                    <label class="co-form-label">Check-In Date</label>
                                    <input type="date" class="co-form-input" @bind="checkInDate" min="@DateTime.Today.ToString("yyyy-MM-dd")" />
                                </div>
                                <div class="co-form-group">
                                    <label class="co-form-label">Check-Out Date</label>
                                    <input type="date" class="co-form-input" @bind="checkOutDate" min="@checkInDate.ToString("yyyy-MM-dd")" />
                                </div>
                                <div class="co-form-group">
                                    <label class="co-form-label">Number of Guests</label>
                                    <input type="number" class="co-form-input" @bind="numberOfGuests" min="1" max="@hotel.Capacity" />
                                </div>
                                <div class="co-form-group">
                                    <label class="co-form-label">Number of Nights</label>
                                    <input type="number" class="co-form-input" value="@numberOfNights" disabled />
                                </div>
                                <div class="co-form-group full">
                                    <label class="co-form-label">Special Requests (Optional)</label>
                                    <textarea class="co-form-input" @bind="specialRequests" rows="3" placeholder="Any special requirements..."></textarea>
                                </div>
                            </div>

                            <div class="co-price-summary">
                                <div class="co-price-row">
                                    <span>@hotel.Currency @hotel.PricePerNight.ToString("N0") × @numberOfNights nights</span>
                                    <strong>@hotel.Currency @totalAmount.ToString("N0")</strong>
                                </div>
                                <div class="co-price-divider"></div>
                                <div class="co-price-total">
                                    <span>Total Amount</span>
                                    <span>@hotel.Currency @totalAmount.ToString("N0")</span>
                                </div>
                            </div>
                        </div>
                        <div class="co-card-footer">
                            <button type="button" class="co-btn-primary" @onclick="ProceedToPayment" disabled="@(numberOfNights <= 0)">
                                Proceed to Payment <i class="bi bi-arrow-right"></i>
                            </button>
                        </div>
                    </div>
                }
                else if (currentStep == 2)
                {
                    <div class="co-card">
                        <div class="co-card-header payment"><i class="bi bi-credit-card"></i> Select Payment Method</div>
                        <div class="co-card-body">
                            <div class="co-secure-note">
                                <i class="bi bi-shield-check"></i> Your payment is secure and encrypted
                            </div>

                            <div class="co-payment-option @(selectedPayment == "mpesa" ? "selected" : "")" @onclick='() => SelectPayment("mpesa")'>
                                <div class="co-pay-icon mpesa"><i class="bi bi-phone"></i></div>
                                <div class="co-pay-info">
                                    <h6>M-Pesa</h6>
                                    <small>Pay with your mobile money</small>
                                </div>
                                <div class="co-pay-check">
                                    <i class="bi @(selectedPayment == "mpesa" ? "bi-check-circle-fill checked" : "bi-circle unchecked")"></i>
                                </div>
                            </div>

                            <div class="co-payment-option @(selectedPayment == "card" ? "selected" : "")" @onclick='() => SelectPayment("card")'>
                                <div class="co-pay-icon card"><i class="bi bi-credit-card"></i></div>
                                <div class="co-pay-info">
                                    <h6>Credit/Debit Card</h6>
                                    <small>Visa, Mastercard, Amex</small>
                                </div>
                                <div class="co-pay-check">
                                    <i class="bi @(selectedPayment == "card" ? "bi-check-circle-fill checked" : "bi-circle unchecked")"></i>
                                </div>
                            </div>

                            <div class="co-payment-option @(selectedPayment == "paypal" ? "selected" : "")" @onclick='() => SelectPayment("paypal")'>
                                <div class="co-pay-icon paypal"><i class="bi bi-paypal"></i></div>
                                <div class="co-pay-info">
                                    <h6>PayPal</h6>
                                    <small>Pay with your PayPal account</small>
                                </div>
                                <div class="co-pay-check">
                                    <i class="bi @(selectedPayment == "paypal" ? "bi-check-circle-fill checked" : "bi-circle unchecked")"></i>
                                </div>
                            </div>

                            @if (!string.IsNullOrEmpty(selectedPayment))
                            {
                                @if (selectedPayment == "mpesa")
                                {
                                    <div class="co-pay-details">
                                        <h6>Enter M-Pesa Details</h6>
                                        <div class="co-form-group">
                                            <label class="co-form-label">Phone Number</label>
                                            <input type="tel" class="co-form-input" @bind="phoneNumber" placeholder="254712345678" />
                                        </div>
                                        <div class="co-pay-alert" style="margin-top: 0.75rem;">
                                            <i class="bi bi-info-circle"></i> You will receive an STK push to complete payment
                                        </div>
                                    </div>
                                }
                                else if (selectedPayment == "card")
                                {
                                    <div class="co-pay-details">
                                        <h6>Enter Card Details</h6>
                                        <div class="co-form-group" style="margin-bottom: 0.5rem;">
                                            <label class="co-form-label">Card Number</label>
                                            <input type="text" class="co-form-input" @bind="cardNumber" placeholder="1234 5678 9012 3456" maxlength="19" />
                                        </div>
                                        <div class="co-form-grid">
                                            <div class="co-form-group">
                                                <label class="co-form-label">Expiry Date</label>
                                                <input type="text" class="co-form-input" @bind="expiryDate" placeholder="MM/YY" maxlength="5" />
                                            </div>
                                            <div class="co-form-group">
                                                <label class="co-form-label">CVV</label>
                                                <input type="text" class="co-form-input" @bind="cvv" placeholder="123" maxlength="3" />
                                            </div>
                                        </div>
                                        <div class="co-form-group">
                                            <label class="co-form-label">Cardholder Name</label>
                                            <input type="text" class="co-form-input" @bind="cardholderName" placeholder="John Doe" />
                                        </div>
                                    </div>
                                }
                                else if (selectedPayment == "paypal")
                                {
                                    <div class="co-pay-details">
                                        <div class="co-pay-alert">
                                            <i class="bi bi-info-circle"></i> You will be redirected to PayPal to complete your payment
                                        </div>
                                    </div>
                                }
                            }
                        </div>
                        <div class="co-card-footer">
                            <div class="co-footer-grid">
                                <button type="button" class="co-btn-outline" @onclick="() => currentStep = 1">
                                    <i class="bi bi-arrow-left"></i> Back
                                </button>
                                <button type="button" class="co-btn-success" @onclick="ProcessPayment" disabled="@(string.IsNullOrEmpty(selectedPayment))">
                                    Pay @hotel.Currency @totalAmount.ToString("N0") <i class="bi bi-lock-fill"></i>
                                </button>
                            </div>
                        </div>
                    </div>
                }
                else if (currentStep == 3)
                {
                    <div class="co-card">
                        <div class="co-card-body">
                            @if (!paymentComplete)
                            {
                                <div class="co-processing">
                                    <div class="spinner-border" role="status">
                                        <span class="visually-hidden">Processing...</span>
                                    </div>
                                    <h4>Processing Your Payment</h4>
                                    <p>Please wait while we confirm your payment...</p>
                                    @if (selectedPayment == "mpesa")
                                    {
                                        <div class="co-pay-alert">
                                            <i class="bi bi-phone"></i> Check your phone for M-Pesa prompt
                                        </div>
                                    }
                                </div>
                            }
                            else
                            {
                                <div class="co-success">
                                    <div class="co-success-icon"><i class="bi bi-check-circle-fill"></i></div>
                                    <h2>Booking Confirmed!</h2>
                                    <p class="co-success-sub">Your payment was successful</p>

                                    <div class="co-confirm-card">
                                        <div class="co-confirm-row">
                                            <div class="co-confirm-item">
                                                <small>Booking Reference</small>
                                                <div class="co-confirm-val">BK-@bookingReference</div>
                                            </div>
                                            <div class="co-confirm-item right">
                                                <small>Amount Paid</small>
                                                <div class="co-confirm-val success">@hotel.Currency @totalAmount.ToString("N0")</div>
                                            </div>
                                        </div>
                                        <div class="co-confirm-divider"></div>
                                        <div class="co-confirm-row">
                                            <div class="co-confirm-item">
                                                <small>Check-In</small>
                                                <div class="co-confirm-val">@checkInDate.ToString("MMM dd, yyyy")</div>
                                            </div>
                                            <div class="co-confirm-item right">
                                                <small>Check-Out</small>
                                                <div class="co-confirm-val">@checkOutDate.ToString("MMM dd, yyyy")</div>
                                            </div>
                                        </div>
                                    </div>

                                    <div class="co-email-note">
                                        <i class="bi bi-envelope"></i> A confirmation email has been sent to your email address
                                    </div>

                                    <div class="co-success-actions">
                                        <button type="button" class="co-btn-primary" @onclick="ViewBookings">
                                            <i class="bi bi-eye"></i> View My Bookings
                                        </button>
                                        <button type="button" class="co-btn-outline" @onclick="GoHome">
                                            <i class="bi bi-house"></i> Back to Home
                                        </button>
                                    </div>
                                </div>
                            }
                        </div>
                    </div>
                }
            </div>

            <!-- Booking Summary Sidebar -->
            @if (currentStep < 3)
            {
                <div class="co-summary">
                    <div class="co-summary-header">
                        <h5>Booking Summary</h5>
                        <p>@hotel.Name</p>
                    </div>
                    <div class="co-summary-body">
                        <div class="co-summary-item">
                            <div class="co-summary-icon"><i class="bi bi-calendar-check"></i></div>
                            <div>
                                <div class="co-summary-label">Check-In</div>
                                <div class="co-summary-value">@checkInDate.ToString("MMM dd, yyyy")</div>
                            </div>
                        </div>
                        <div class="co-summary-item">
                            <div class="co-summary-icon"><i class="bi bi-calendar-x"></i></div>
                            <div>
                                <div class="co-summary-label">Check-Out</div>
                                <div class="co-summary-value">@checkOutDate.ToString("MMM dd, yyyy")</div>
                            </div>
                        </div>
                        <div class="co-summary-item">
                            <div class="co-summary-icon"><i class="bi bi-moon-stars"></i></div>
                            <div>
                                <div class="co-summary-label">Duration</div>
                                <div class="co-summary-value">@numberOfNights Night@(numberOfNights != 1 ? "s" : "")</div>
                            </div>
                        </div>
                        <div class="co-summary-item">
                            <div class="co-summary-icon"><i class="bi bi-people"></i></div>
                            <div>
                                <div class="co-summary-label">Guests</div>
                                <div class="co-summary-value">@numberOfGuests Guest@(numberOfGuests != 1 ? "s" : "")</div>
                            </div>
                        </div>
                    </div>
                    <div class="co-summary-footer">
                        <div class="co-breakdown-title">Price Details</div>
                        <div class="co-breakdown-item">
                            <span><i class="bi bi-moon"></i> @hotel.Currency @hotel.PricePerNight.ToString("N0") × @numberOfNights night@(numberOfNights != 1 ? "s" : "")</span>
                            <span>@hotel.Currency @(hotel.PricePerNight * numberOfNights).ToString("N0")</span>
                        </div>
                        <div class="co-breakdown-item">
                            <span><i class="bi bi-shield-check"></i> Service Fee</span>
                            <span>@hotel.Currency @serviceFee.ToString("N0")</span>
                        </div>
                        <div class="co-breakdown-item">
                            <span><i class="bi bi-receipt"></i> Taxes</span>
                            <span>@hotel.Currency @taxes.ToString("N0")</span>
                        </div>
                        @if (discount > 0)
                        {
                            <div class="co-breakdown-item discount">
                                <span><i class="bi bi-tag"></i> Discount</span>
                                <span>-@hotel.Currency @discount.ToString("N0")</span>
                            </div>
                        }
                        <div class="co-breakdown-divider"></div>
                        <div class="co-breakdown-total">
                            <span>Total Amount</span>
                            <span>@hotel.Currency @totalAmount.ToString("N0")</span>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>

@code {
    [Parameter]
    public int HotelId { get; set; }

    private bool isLoading = true;
    private Hotel? hotel;
    private int currentStep = 1;

    // Booking details
    private DateTime checkInDate = DateTime.Today.AddDays(7);
    private DateTime checkOutDate = DateTime.Today.AddDays(10);
    private int numberOfGuests = 2;
    private string specialRequests = "";

    // Payment details
    private string selectedPayment = "";
    private string phoneNumber = "";
    private string cardNumber = "";
    private string expiryDate = "";
    private string cvv = "";
    private string cardholderName = "";

    // Calculated values
    private int numberOfNights => (checkOutDate - checkInDate).Days;
    private decimal baseAmount => hotel != null ? hotel.PricePerNight * numberOfNights : 0;
    private decimal serviceFee => baseAmount * 0.05m; // 5% service fee
    private decimal taxes => baseAmount * 0.16m; // 16% VAT
    private decimal discount => 0; // Can be dynamic based on promo codes
    private decimal totalAmount => baseAmount + serviceFee + taxes - discount;

    // Payment status
    private bool paymentComplete = false;
    private string bookingReference = "";

    protected override async Task OnInitializedAsync()
    {
        try
        {
            hotel = await HotelService.GetHotelByIdAsync(HotelId);
        }
        catch
        {
            // Handle error
        }
        finally
        {
            isLoading = false;
        }

        bookingReference = $"{DateTime.Now:yyyyMMdd}{new Random().Next(1000, 9999)}";
    }

    private void ProceedToPayment()
    {
        currentStep = 2;
    }

    private void SelectPayment(string method)
    {
        selectedPayment = method;
    }

    private async Task ProcessPayment()
    {
        currentStep = 3;
        
        // Simulate payment processing
        await Task.Delay(3000);
        
        paymentComplete = true;
    }

    private void ViewBookings()
    {
        Navigation.NavigateTo("/my-bookings");
    }

    private void GoHome()
    {
        Navigation.NavigateTo("/");
    }
}
