@page "/events/package/{id:int}"
@rendermode InteractiveServer
@using EventHotelBroker.Models
@using EventHotelBroker.Services
@using Microsoft.AspNetCore.Components.Authorization
@inject IEventService EventService
@inject NavigationManager Navigation
@inject AuthenticationStateProvider AuthStateProvider

<PageTitle>@(package?.Name ?? "Package Details") - EventHotelBroker</PageTitle>

<link href="/css/event-package-details.css" rel="stylesheet" />

<div class="epd">
    @if (isLoading)
    {
        <div class="epd-empty">
            <i class="bi bi-arrow-repeat spin"></i>
            <div class="epd-empty-title">Loading...</div>
        </div>
    }
    else if (package == null)
    {
        <div class="epd-empty">
            <i class="bi bi-exclamation-triangle"></i>
            <div class="epd-empty-title">Package Not Found</div>
            <div class="epd-empty-text">The package you're looking for doesn't exist or has been removed.</div>
            <a href="/events" class="epd-btn epd-btn-primary" style="width: auto; margin-top: 0.75rem; display: inline-flex;">
                <i class="bi bi-arrow-left"></i> Back to Events
            </a>
        </div>
    }
    else
    {
        <Breadcrumb Items="@breadcrumbItems" />

        <!-- Hero Banner -->
        <div class="epd-hero">
            @if (!string.IsNullOrEmpty(package.ImageUrl))
            {
                <img src="@package.ImageUrl" alt="@package.Name" />
            }
            else
            {
                <div class="epd-hero-placeholder"><i class="bi bi-gift"></i></div>
            }
            <div class="epd-hero-overlay">
                <div>
                    <div class="epd-hero-title">@package.Name</div>
                    <div class="epd-hero-badges">
                        <span class="epd-badge epd-badge-type"><i class="bi bi-tag-fill"></i> @package.PackageType</span>
                        @if (package.IsFeatured)
                        {
                            <span class="epd-badge epd-badge-featured"><i class="bi bi-star-fill"></i> Featured</span>
                        }
                        @if (package.IsCustomizable)
                        {
                            <span class="epd-badge epd-badge-custom"><i class="bi bi-sliders"></i> Customizable</span>
                        }
                    </div>
                </div>
                <div class="epd-hero-price">
                    @if (package.DiscountedPrice.HasValue)
                    {
                        <div class="epd-price-old">KES @package.TotalPrice.ToString("N2")</div>
                        <div class="epd-price-main">KES @package.DiscountedPrice.Value.ToString("N2")</div>
                        <div class="epd-price-save"><i class="bi bi-tag-fill"></i> Save KES @((package.TotalPrice - package.DiscountedPrice.Value).ToString("N2"))</div>
                    }
                    else
                    {
                        <div class="epd-price-main">KES @package.TotalPrice.ToString("N2")</div>
                    }
                </div>
            </div>
        </div>

        <div class="row g-3">
            <!-- ── Left Column ── -->
            <div class="col-lg-8">

                <!-- Description -->
                <div class="epd-card">
                    <div class="epd-card-head">
                        <span class="epd-card-title"><i class="bi bi-info-circle"></i> About This Package</span>
                    </div>
                    <div class="epd-card-body">
                        <div class="epd-desc">@package.Description</div>
                    </div>
                </div>

                <!-- Guest Capacity -->
                <div class="epd-card">
                    <div class="epd-card-head">
                        <span class="epd-card-title"><i class="bi bi-people"></i> Guest Capacity</span>
                    </div>
                    <div class="epd-card-body">
                        <div class="epd-stats">
                            <div class="epd-stat">
                                <div class="epd-stat-icon epd-icon-teal"><i class="bi bi-person-check"></i></div>
                                <div>
                                    <div class="epd-stat-value">@package.MinGuests</div>
                                    <div class="epd-stat-label">Minimum</div>
                                </div>
                            </div>
                            <div class="epd-stat">
                                <div class="epd-stat-icon epd-icon-terracotta"><i class="bi bi-people-fill"></i></div>
                                <div>
                                    <div class="epd-stat-value">@package.MaxGuests</div>
                                    <div class="epd-stat-label">Maximum</div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Features -->
                @if (!string.IsNullOrEmpty(package.Features))
                {
                    <div class="epd-card">
                        <div class="epd-card-head">
                            <span class="epd-card-title"><i class="bi bi-check-circle"></i> What's Included</span>
                        </div>
                        <div class="epd-card-body">
                            <div class="epd-features">
                                @foreach (var feature in GetFeatures())
                                {
                                    <div class="epd-feature">
                                        <i class="bi bi-check-circle-fill"></i>
                                        <span>@feature</span>
                                    </div>
                                }
                            </div>
                            <div class="epd-info">
                                <div class="epd-info-icon"><i class="bi bi-shield-check"></i></div>
                                <div class="epd-info-text"><strong>Professional Service</strong> — Provided by verified event professionals with years of experience.</div>
                            </div>
                        </div>
                    </div>
                }

                <!-- Important Information (Accordion) -->
                <div class="epd-card">
                    <div class="epd-card-head">
                        <span class="epd-card-title"><i class="bi bi-question-circle"></i> Important Information</span>
                    </div>
                    <div class="epd-card-body">
                        <div class="epd-accordion">
                            <div class="epd-acc-item @(openAccordion == 0 ? "open" : "")">
                                <button class="epd-acc-header" @onclick="() => ToggleAccordion(0)">
                                    <i class="bi bi-calendar-check"></i> Booking Process
                                    <i class="bi bi-chevron-down epd-acc-chevron"></i>
                                </button>
                                <div class="epd-acc-body" style="@(openAccordion == 0 ? "display:block" : "display:none")">
                                    <ol>
                                        <li>Select your event date and provide details</li>
                                        <li>Submit your booking request</li>
                                        <li>Our team will review and confirm availability</li>
                                        <li>Pay the deposit to secure your booking</li>
                                        <li>Finalize details closer to your event date</li>
                                    </ol>
                                </div>
                            </div>
                            <div class="epd-acc-item @(openAccordion == 1 ? "open" : "")">
                                <button class="epd-acc-header" @onclick="() => ToggleAccordion(1)">
                                    <i class="bi bi-sliders"></i> Customization Options
                                    <i class="bi bi-chevron-down epd-acc-chevron"></i>
                                </button>
                                <div class="epd-acc-body" style="@(openAccordion == 1 ? "display:block" : "display:none")">
                                    @if (package.IsCustomizable)
                                    {
                                        <p>This package can be customized to meet your specific needs:</p>
                                        <ul>
                                            <li>Add or remove equipment items</li>
                                            <li>Adjust quantities based on guest count</li>
                                            <li>Include additional services</li>
                                            <li>Modify setup and delivery times</li>
                                        </ul>
                                        <p style="margin-bottom:0"><strong>Note:</strong> Customizations may affect the final price.</p>
                                    }
                                    else
                                    {
                                        <p style="margin-bottom:0">This is a fixed package. For custom requirements, please contact us directly.</p>
                                    }
                                </div>
                            </div>
                            <div class="epd-acc-item @(openAccordion == 2 ? "open" : "")">
                                <button class="epd-acc-header" @onclick="() => ToggleAccordion(2)">
                                    <i class="bi bi-x-circle"></i> Cancellation Policy
                                    <i class="bi bi-chevron-down epd-acc-chevron"></i>
                                </button>
                                <div class="epd-acc-body" style="@(openAccordion == 2 ? "display:block" : "display:none")">
                                    <ul>
                                        <li><strong>30+ days before event:</strong> Full refund minus processing fee</li>
                                        <li><strong>15-29 days before:</strong> 50% refund</li>
                                        <li><strong>Less than 15 days:</strong> No refund, but can reschedule</li>
                                    </ul>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- ── Right Column ── -->
            <div class="col-lg-4">

                <!-- Booking Card -->
                <div class="epd-card" style="position: sticky; top: 1rem;">
                    <div class="epd-card-head">
                        <span class="epd-card-title"><i class="bi bi-calendar-check"></i> Book This Package</span>
                    </div>
                    <div class="epd-card-body">
                        <div class="epd-book-price">
                            <span>Package Price</span>
                            @if (package.DiscountedPrice.HasValue)
                            {
                                <span style="font-weight:700; color:#C87941;">KES @package.DiscountedPrice.Value.ToString("N2")</span>
                            }
                            else
                            {
                                <span style="font-weight:700; color:#C87941;">KES @package.TotalPrice.ToString("N2")</span>
                            }
                        </div>
                        @if (package.DiscountedPrice.HasValue)
                        {
                            var savings = package.TotalPrice - package.DiscountedPrice.Value;
                            var percentage = (savings / package.TotalPrice) * 100;
                            <div class="epd-save-tag">
                                <i class="bi bi-tag-fill"></i> You save KES @savings.ToString("N2") (@percentage.ToString("N0")% off)
                            </div>
                        }

                        <button type="button" class="epd-btn epd-btn-accent" style="margin-bottom: 0.5rem;" @onclick="HandleBookNow">
                            <i class="bi bi-calendar-check"></i> Book Now
                        </button>
                        <button class="epd-btn epd-btn-outline" @onclick="ContactProvider">
                            <i class="bi bi-chat-dots"></i> Contact Provider
                        </button>

                        <hr class="epd-divider" />

                        <div class="epd-trust">
                            <div class="epd-trust-item">
                                <div class="epd-trust-icon epd-icon-teal"><i class="bi bi-shield-check"></i></div>
                                <span>Verified Provider</span>
                            </div>
                            <div class="epd-trust-item">
                                <div class="epd-trust-icon epd-icon-bronze"><i class="bi bi-clock-history"></i></div>
                                <span>Quick Response Time</span>
                            </div>
                            <div class="epd-trust-item">
                                <div class="epd-trust-icon epd-icon-terracotta"><i class="bi bi-award"></i></div>
                                <span>Quality Guaranteed</span>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Quick Actions -->
                <div class="epd-card">
                    <div class="epd-card-head">
                        <span class="epd-card-title"><i class="bi bi-lightning"></i> Quick Actions</span>
                    </div>
                    <div class="epd-card-body" style="padding: 0.5rem;">
                        <div class="epd-qa-stack">
                            <div class="epd-qa" @onclick="SharePackage">
                                <div class="epd-qa-icon epd-icon-teal"><i class="bi bi-share"></i></div>
                                <span class="epd-qa-text">Share Package</span>
                                <i class="bi bi-chevron-right epd-qa-arrow"></i>
                            </div>
                            <div class="epd-qa" @onclick='() => Navigation.NavigateTo("/events")'>
                                <div class="epd-qa-icon epd-icon-bronze"><i class="bi bi-grid"></i></div>
                                <span class="epd-qa-text">Browse All Packages</span>
                                <i class="bi bi-chevron-right epd-qa-arrow"></i>
                            </div>
                            <div class="epd-qa" @onclick="ContactProvider">
                                <div class="epd-qa-icon epd-icon-terracotta"><i class="bi bi-headset"></i></div>
                                <span class="epd-qa-text">Contact Support</span>
                                <i class="bi bi-chevron-right epd-qa-arrow"></i>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    }
</div>

@code {
    [Parameter]
    public int Id { get; set; }

    private EventPackage? package;
    private bool isLoading = true;
    private int openAccordion = 0;
    private bool isAuthenticated = false;

    private List<BreadcrumbItem> breadcrumbItems = new()
    {
        new BreadcrumbItem { Text = "Home", Url = "/" },
        new BreadcrumbItem { Text = "Events", Url = "/events" },
        new BreadcrumbItem { Text = "Package Details", IsActive = true }
    };

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        isAuthenticated = authState.User.Identity?.IsAuthenticated == true;

        await LoadPackage();
    }

    private async Task LoadPackage()
    {
        isLoading = true;
        try
        {
            package = await EventService.GetPackageByIdAsync(Id);
        }
        catch (Exception)
        {
            package = null;
        }
        finally
        {
            isLoading = false;
        }
    }

    private List<string> GetFeatures()
    {
        if (string.IsNullOrEmpty(package?.Features))
            return new List<string>();

        try
        {
            return System.Text.Json.JsonSerializer.Deserialize<List<string>>(package.Features) ?? new List<string>();
        }
        catch
        {
            return new List<string>();
        }
    }

    private void ToggleAccordion(int index)
    {
        openAccordion = openAccordion == index ? -1 : index;
    }

    private void HandleBookNow()
    {
        if (package == null) return;

        if (!isAuthenticated)
        {
            var returnUrl = Uri.EscapeDataString($"/book-event?packageId={package.Id}");
            Navigation.NavigateTo($"/login?returnUrl={returnUrl}");
            return;
        }
        Navigation.NavigateTo($"/book-event?packageId={package.Id}");
    }

    private void ContactProvider()
    {
        if (package == null) return;

        if (!isAuthenticated)
        {
            var returnUrl = Uri.EscapeDataString($"/book-event?packageId={package.Id}");
            Navigation.NavigateTo($"/login?returnUrl={returnUrl}");
            return;
        }
        // In production, implement contact functionality
        Navigation.NavigateTo($"/book-event?packageId={package.Id}");
    }

    private void SharePackage()
    {
        // In production, implement share functionality
    }
}
