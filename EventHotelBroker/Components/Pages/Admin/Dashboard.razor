@page "/admin/dashboard"
@rendermode InteractiveServer
@using EventHotelBroker.Models
@using EventHotelBroker.Repositories
@using EventHotelBroker.Services
@using EventHotelBroker.Data
@using Microsoft.EntityFrameworkCore
@inject IUnitOfWork UnitOfWork
@inject ApplicationDbContext DbContext
@inject IEventService EventService

<PageTitle>Admin Dashboard - EventHotelBroker</PageTitle>

<link href="/css/admin-dashboard.css?v=1" rel="stylesheet" />

<div class="ad">
    <Breadcrumb Items="@breadcrumbItems" />

    <!-- Header -->
    <div class="ad-header">
        <div>
            <h1 class="ad-header-title"><i class="bi bi-speedometer2"></i> Admin Dashboard</h1>
            <p class="ad-header-sub">Monitor and manage your platform</p>
        </div>
        <span class="ad-header-date">
            <i class="bi bi-calendar3"></i> @DateTime.Now.ToString("MMMM dd, yyyy")
        </span>
    </div>

    @if (isLoading)
    {
        <div class="ad-card">
            <div class="ad-loading">
                <div class="ad-spinner"></div>
                <div class="ad-loading-text">Loading dashboard...</div>
            </div>
        </div>
    }
    else
    {
        <!-- Stats -->
        <div class="ad-stats">
            <div class="ad-stat">
                <div>
                    <div class="ad-stat-value">@stats.TotalUsers</div>
                    <div class="ad-stat-label">Users</div>
                </div>
                <div class="ad-stat-icon ad-icon-terracotta"><i class="bi bi-people"></i></div>
            </div>
            <div class="ad-stat">
                <div>
                    <div class="ad-stat-value">@stats.TotalHotels</div>
                    <div class="ad-stat-label">Hotels</div>
                </div>
                <div class="ad-stat-icon ad-icon-teal"><i class="bi bi-building"></i></div>
            </div>
            <div class="ad-stat">
                <div>
                    <div class="ad-stat-value">@stats.TotalEventEquipments</div>
                    <div class="ad-stat-label">Equipments</div>
                </div>
                <div class="ad-stat-icon ad-icon-bronze"><i class="bi bi-box-seam"></i></div>
            </div>
            <div class="ad-stat">
                <div>
                    <div class="ad-stat-value">@stats.TotalEventPackages</div>
                    <div class="ad-stat-label">Packages</div>
                </div>
                <div class="ad-stat-icon ad-icon-olive"><i class="bi bi-gift"></i></div>
            </div>
            <div class="ad-stat">
                <div>
                    <div class="ad-stat-value">@stats.TotalEventBookings</div>
                    <div class="ad-stat-label">Event Bookings</div>
                </div>
                <div class="ad-stat-icon ad-icon-charcoal"><i class="bi bi-calendar-event"></i></div>
            </div>
            <div class="ad-stat">
                <div>
                    <div class="ad-stat-value">@stats.PendingApprovals</div>
                    <div class="ad-stat-label">Pending</div>
                </div>
                <div class="ad-stat-icon ad-icon-terracotta"><i class="bi bi-clock-history"></i></div>
            </div>
        </div>

        <!-- Search -->
        <div class="ad-search-bar">
            <div class="ad-search-wrap">
                <i class="bi bi-search"></i>
                <input type="text" class="ad-search-input" placeholder="Search hotels, bookings, or users..." @bind="dashboardSearch" @bind:event="oninput" />
            </div>
            <span class="ad-search-count">@filteredHotels.Count() hotels · @filteredBookings.Count() bookings · @filteredDashUsers.Count() users</span>
        </div>

        <div class="row g-3">
            <!-- Hotels Pending Approval -->
            <div class="col-lg-6">
                <div class="ad-card">
                    <div class="ad-card-header">
                        <h5 class="ad-card-title"><i class="bi bi-clock-history"></i> Hotels Pending Approval</h5>
                    </div>
                    <div class="ad-card-body">
                        @if (filteredHotels.Any())
                        {
                            @foreach (var hotel in filteredHotels.Take(5))
                            {
                                <div class="ad-list-item">
                                    <div>
                                        <div class="ad-list-name">@hotel.Name</div>
                                        <span class="ad-list-sub">@hotel.City, @hotel.Country</span>
                                    </div>
                                    <a href="/admin/hotels" class="ad-btn ad-btn-sm ad-btn-review">
                                        <i class="bi bi-eye"></i> Review
                                    </a>
                                </div>
                            }
                            @if (filteredHotels.Count() > 5)
                            {
                                <div style="text-align:center;padding-top:0.5rem;">
                                    <a href="/admin/hotels" class="ad-link">View All (@filteredHotels.Count())</a>
                                </div>
                            }
                        }
                        else
                        {
                            <div class="ad-empty">No pending approvals</div>
                        }
                    </div>
                </div>
            </div>

            <!-- Recent Bookings -->
            <div class="col-lg-6">
                <div class="ad-card">
                    <div class="ad-card-header">
                        <h5 class="ad-card-title"><i class="bi bi-calendar-check"></i> Recent Bookings</h5>
                    </div>
                    <div class="ad-card-body">
                        @if (filteredBookings.Any())
                        {
                            @foreach (var booking in filteredBookings.Take(5))
                            {
                                <div class="ad-list-item">
                                    <div>
                                        <div class="ad-list-name">Booking #@booking.Id</div>
                                        <span class="ad-list-sub">@booking.StartDate.ToString("MMM dd") - @booking.EndDate.ToString("MMM dd, yyyy")</span>
                                    </div>
                                    <span class="ad-badge @GetAdBadgeClass(booking.Status)">
                                        <i class="bi @GetStatusIcon(booking.Status)"></i> @booking.Status
                                    </span>
                                </div>
                            }
                            @if (filteredBookings.Count() > 5)
                            {
                                <div style="text-align:center;padding-top:0.5rem;">
                                    <a href="/admin/bookings" class="ad-link">View All (@filteredBookings.Count())</a>
                                </div>
                            }
                        }
                        else
                        {
                            <div class="ad-empty">No bookings match</div>
                        }
                    </div>
                </div>
            </div>

            <!-- Recent Users -->
            <div class="col-lg-6">
                <div class="ad-card">
                    <div class="ad-card-header">
                        <h5 class="ad-card-title"><i class="bi bi-people"></i> Recent Users</h5>
                    </div>
                    <div class="ad-card-body">
                        @if (filteredDashUsers.Any())
                        {
                            @foreach (var user in filteredDashUsers.Take(5))
                            {
                                <div class="ad-list-item">
                                    <div>
                                        <div class="ad-list-name">@user.FullName</div>
                                        <span class="ad-list-sub">@user.Email</span>
                                    </div>
                                    <span class="ad-badge ad-badge-role">
                                        <i class="bi bi-person-badge"></i> @user.Role
                                    </span>
                                </div>
                            }
                            <div style="text-align:center;padding-top:0.5rem;">
                                <a href="/admin/users" class="ad-link">View All Users</a>
                            </div>
                        }
                        else
                        {
                            <div class="ad-empty">No users match</div>
                        }
                    </div>
                </div>
            </div>

            <!-- Quick Actions -->
            <div class="col-lg-6">
                <div class="ad-card">
                    <div class="ad-card-header">
                        <h5 class="ad-card-title"><i class="bi bi-lightning"></i> Quick Actions</h5>
                    </div>
                    <div class="ad-card-body">
                        <div class="ad-actions-grid">
                            <a href="/admin/users" class="ad-action">
                                <div class="ad-action-icon ad-icon-terracotta"><i class="bi bi-people"></i></div>
                                Manage Users
                            </a>
                            <a href="/admin/hotels" class="ad-action">
                                <div class="ad-action-icon ad-icon-teal"><i class="bi bi-building"></i></div>
                                Manage Hotels
                            </a>
                            <a href="/admin/event-equipments" class="ad-action">
                                <div class="ad-action-icon ad-icon-bronze"><i class="bi bi-box-seam"></i></div>
                                Event Equipments
                            </a>
                            <a href="/admin/event-packages" class="ad-action">
                                <div class="ad-action-icon ad-icon-olive"><i class="bi bi-gift"></i></div>
                                Event Packages
                            </a>
                            <a href="/admin/event-bookings" class="ad-action">
                                <div class="ad-action-icon ad-icon-charcoal"><i class="bi bi-calendar-event"></i></div>
                                Event Bookings
                            </a>
                            <a href="/admin/audit-logs" class="ad-action">
                                <div class="ad-action-icon ad-icon-charcoal"><i class="bi bi-file-text"></i></div>
                                Audit Logs
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    }
</div>

@code {
    private bool isLoading = true;
    private DashboardStats stats = new();
    private IEnumerable<Hotel> pendingHotels = new List<Hotel>();
    private IEnumerable<Booking> recentBookings = new List<Booking>();
    private List<EventHotelBroker.Models.Users> recentUsers = new();
    private string dashboardSearch = "";

    private IEnumerable<Hotel> filteredHotels => string.IsNullOrWhiteSpace(dashboardSearch)
        ? pendingHotels
        : pendingHotels.Where(h =>
        {
            var term = dashboardSearch.Trim().ToLower();
            return (h.Name?.ToLower().Contains(term) ?? false)
                || (h.City?.ToLower().Contains(term) ?? false)
                || (h.Country?.ToLower().Contains(term) ?? false);
        });

    private IEnumerable<Booking> filteredBookings => string.IsNullOrWhiteSpace(dashboardSearch)
        ? recentBookings
        : recentBookings.Where(b =>
        {
            var term = dashboardSearch.Trim().ToLower();
            return b.Id.ToString().Contains(term)
                || b.Status.ToString().ToLower().Contains(term);
        });

    private IEnumerable<EventHotelBroker.Models.Users> filteredDashUsers => string.IsNullOrWhiteSpace(dashboardSearch)
        ? recentUsers
        : recentUsers.Where(u =>
        {
            var term = dashboardSearch.Trim().ToLower();
            return (u.FullName?.ToLower().Contains(term) ?? false)
                || (u.Email?.ToLower().Contains(term) ?? false)
                || (u.Role?.ToLower().Contains(term) ?? false);
        });

    private List<BreadcrumbItem> breadcrumbItems = new()
    {
        new BreadcrumbItem { Text = "Home", Url = "/" },
        new BreadcrumbItem { Text = "Admin Dashboard", IsActive = true }
    };

    protected override async Task OnInitializedAsync()
    {
        try
        {
            // Load statistics
            var allUsers = await DbContext.Users.ToListAsync();
            stats.TotalUsers = allUsers.Count;
            stats.TotalHotels = await UnitOfWork.Hotels.CountAsync();
            stats.PendingApprovals = await UnitOfWork.Hotels.CountAsync(h => !h.IsApproved && h.IsPublished);
            stats.TotalBookings = await UnitOfWork.Bookings.CountAsync();
            
            // Load event statistics
            stats.TotalEventEquipments = await EventService.GetTotalEquipmentsCountAsync();
            stats.TotalEventPackages = await EventService.GetTotalPackagesCountAsync();
            stats.TotalEventBookings = await EventService.GetTotalBookingsCountAsync();

            // Load pending hotels
            pendingHotels = await UnitOfWork.Hotels.FindAsync(h => !h.IsApproved && h.IsPublished);

            // Load recent bookings
            var allBookings = await UnitOfWork.Bookings.GetAllAsync();
            recentBookings = allBookings.OrderByDescending(b => b.CreatedAt).Take(10);

            // Load recent users
            recentUsers = allUsers.OrderByDescending(u => u.CreatedAt).Take(10).ToList();
        }
        catch (Exception ex)
        {
            // Log error
        }
        finally
        {
            isLoading = false;
        }
    }

    private string GetStatusColor(BookingStatus status)
    {
        return status switch
        {
            BookingStatus.Pending => "warning",
            BookingStatus.Confirmed => "success",
            BookingStatus.Rejected => "danger",
            BookingStatus.Cancelled => "secondary",
            _ => "secondary"
        };
    }

    private string GetAdBadgeClass(BookingStatus status)
    {
        return status switch
        {
            BookingStatus.Pending => "ad-badge-pending",
            BookingStatus.Confirmed => "ad-badge-confirmed",
            BookingStatus.Rejected => "ad-badge-rejected",
            BookingStatus.Cancelled => "ad-badge-cancelled",
            _ => "ad-badge-cancelled"
        };
    }

    private string GetStatusIcon(BookingStatus status)
    {
        return status switch
        {
            BookingStatus.Pending => "bi-clock-history",
            BookingStatus.Confirmed => "bi-check-circle",
            BookingStatus.Rejected => "bi-x-circle",
            BookingStatus.Cancelled => "bi-dash-circle",
            _ => "bi-circle"
        };
    }

    private class DashboardStats
    {
        public int TotalUsers { get; set; }
        public int TotalHotels { get; set; }
        public int PendingApprovals { get; set; }
        public int TotalBookings { get; set; }
        public int TotalEventEquipments { get; set; }
        public int TotalEventPackages { get; set; }
        public int TotalEventBookings { get; set; }
    }
}
