@page "/admin/add-admin"
@using EventHotelBroker.Services
@using EventHotelBroker.Utils
@using Microsoft.AspNetCore.Components.Authorization
@using System.Security.Claims
@inject IAuthService AuthService
@inject AuthenticationStateProvider AuthStateProvider
@inject ToastService ToastService
@rendermode InteractiveServer

<PageTitle>Add Admin - Safari Vents</PageTitle>

<link href="/css/auth-register.css?v=2" rel="stylesheet" />

<div style="max-width:640px;margin:40px auto;padding:0 16px;">
    <div style="margin-bottom:28px;">
        <h1 style="font-size:1.6rem;font-weight:800;color:#1a1a1a;margin-bottom:4px;">Add New Administrator</h1>
        <p style="color:#6c757d;font-size:0.9rem;">Create an admin account. Login credentials will be sent to the new admin's email.</p>
    </div>

    @if (!isAdmin)
    {
        <div style="background:#fff5f5;border:1px solid #fed7d7;border-radius:14px;padding:32px;text-align:center;">
            <i class="bi bi-shield-x" style="font-size:3rem;color:#dc3545;display:block;margin-bottom:12px;"></i>
            <h4 style="color:#c53030;font-weight:700;">Access Denied</h4>
            <p style="color:#6c757d;">Only administrators can access this page.</p>
        </div>
    }
    else
    {
        <div style="background:white;border-radius:16px;padding:36px;box-shadow:0 4px 24px rgba(0,0,0,0.07);">

            @if (!string.IsNullOrEmpty(successMessage))
            {
                <div style="background:#f0fdf4;border:1px solid #bbf7d0;border-radius:10px;padding:14px 18px;margin-bottom:24px;color:#166534;font-size:0.9rem;">
                    <i class="bi bi-check-circle me-2"></i>@successMessage
                </div>
            }
            @if (!string.IsNullOrEmpty(errorMessage))
            {
                <div style="background:#fff5f5;border:1px solid #fed7d7;border-radius:10px;padding:14px 18px;margin-bottom:24px;color:#c53030;font-size:0.9rem;">
                    <i class="bi bi-exclamation-circle me-2"></i>@errorMessage
                </div>
            }

            <div style="margin-bottom:20px;">
                <label style="display:block;font-weight:600;color:#374151;font-size:0.88rem;margin-bottom:6px;">Full Name <span style="color:#dc3545;">*</span></label>
                <input type="text" @bind="fullName" placeholder="e.g. John Doe"
                    style="width:100%;padding:12px 16px;border:1.5px solid #e2e8f0;border-radius:10px;font-size:0.9rem;outline:none;box-sizing:border-box;" />
            </div>

            <div style="margin-bottom:20px;">
                <label style="display:block;font-weight:600;color:#374151;font-size:0.88rem;margin-bottom:6px;">Email Address <span style="color:#dc3545;">*</span></label>
                <input type="email" @bind="email" placeholder="admin@safarivents.com"
                    style="width:100%;padding:12px 16px;border:1.5px solid #e2e8f0;border-radius:10px;font-size:0.9rem;outline:none;box-sizing:border-box;" />
            </div>

            <div style="margin-bottom:20px;">
                <label style="display:block;font-weight:600;color:#374151;font-size:0.88rem;margin-bottom:6px;">Phone Number</label>
                <input type="tel" @bind="phone" placeholder="+254 712 345 678"
                    style="width:100%;padding:12px 16px;border:1.5px solid #e2e8f0;border-radius:10px;font-size:0.9rem;outline:none;box-sizing:border-box;" />
            </div>

            <div style="display:grid;grid-template-columns:1fr 1fr;gap:16px;margin-bottom:28px;">
                <div>
                    <label style="display:block;font-weight:600;color:#374151;font-size:0.88rem;margin-bottom:6px;">Password <span style="color:#dc3545;">*</span></label>
                    <input type="password" @bind="password" placeholder="Strong password"
                        style="width:100%;padding:12px 16px;border:1.5px solid #e2e8f0;border-radius:10px;font-size:0.9rem;outline:none;box-sizing:border-box;" />
                </div>
                <div>
                    <label style="display:block;font-weight:600;color:#374151;font-size:0.88rem;margin-bottom:6px;">Confirm Password <span style="color:#dc3545;">*</span></label>
                    <input type="password" @bind="confirmPassword" placeholder="Repeat password"
                        style="width:100%;padding:12px 16px;border:1.5px solid #e2e8f0;border-radius:10px;font-size:0.9rem;outline:none;box-sizing:border-box;" />
                </div>
            </div>

            <div style="background:#fefce8;border:1px solid #fde68a;border-radius:10px;padding:14px 18px;margin-bottom:28px;font-size:0.85rem;color:#92400e;">
                <i class="bi bi-info-circle me-2"></i>
                An email with these credentials will be sent automatically to the new administrator. They should change their password after first login.
            </div>

            <button @onclick="HandleCreateAdmin" disabled="@isSubmitting"
                style="width:100%;padding:14px;border:none;border-radius:12px;background:linear-gradient(135deg,#dc3545,#b02a37);color:white;font-weight:700;font-size:1rem;cursor:pointer;transition:opacity 0.2s;">
                @if (isSubmitting)
                {
                    <span class="spinner-border spinner-border-sm me-2"></span>
                }
                <i class="bi bi-person-plus me-2"></i>Create Admin Account
            </button>
        </div>
    }
</div>

@code {
    private bool isAdmin = false;
    private string currentAdminId = "";

    private string fullName = "";
    private string email = "";
    private string phone = "";
    private string password = "";
    private string confirmPassword = "";

    private bool isSubmitting = false;
    private string successMessage = "";
    private string errorMessage = "";

    protected override async Task OnInitializedAsync()
    {
        var auth = await AuthStateProvider.GetAuthenticationStateAsync();
        var user = auth.User;

        if (user.Identity?.IsAuthenticated == true)
        {
            var nameClaim = user.FindFirst(ClaimTypes.Name)?.Value ?? "";
            var parts = nameClaim.Split(',');
            currentAdminId = parts.Length > 0 ? parts[0] : "";
            var accountType = user.FindFirst("AccountType")?.Value ?? (parts.Length > 1 ? parts[1] : "");
            isAdmin = accountType.Contains("Admin", StringComparison.OrdinalIgnoreCase);
        }
    }

    private async Task HandleCreateAdmin()
    {
        successMessage = "";
        errorMessage = "";

        if (string.IsNullOrWhiteSpace(fullName) || string.IsNullOrWhiteSpace(email) || string.IsNullOrWhiteSpace(password))
        {
            errorMessage = "Full name, email, and password are required.";
            return;
        }

        if (password != confirmPassword)
        {
            errorMessage = "Passwords do not match.";
            return;
        }

        if (password.Length < 8)
        {
            errorMessage = "Password must be at least 8 characters long.";
            return;
        }

        isSubmitting = true;
        StateHasChanged();

        var result = await AuthService.CreateAdminAsync(fullName, email, phone, password, currentAdminId);

        if (result.Success)
        {
            successMessage = result.Message;
            fullName = email = phone = password = confirmPassword = "";
            ToastService.ShowSuccess("Admin Created", result.Message);
        }
        else
        {
            errorMessage = result.Message;
        }

        isSubmitting = false;
        StateHasChanged();
    }
}
