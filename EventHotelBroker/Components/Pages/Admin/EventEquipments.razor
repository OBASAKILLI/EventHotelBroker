@page "/admin/event-equipments"
@rendermode InteractiveServer
@using EventHotelBroker.Models
@using EventHotelBroker.Services
@inject IEventService EventService
@inject NavigationManager Navigation

<PageTitle>Event Equipments - Admin</PageTitle>

<link href="/css/admin-event-equipments.css?v=1" rel="stylesheet" />

<div class="ae">
    <Breadcrumb Items="@breadcrumbItems" />

    <!-- Header -->
    <div class="ae-header">
        <div>
            <h1 class="ae-header-title"><i class="bi bi-box-seam"></i> Event Equipments</h1>
            <p class="ae-header-sub">Manage event equipment inventory</p>
        </div>
        <button class="ae-btn ae-btn-refresh" @onclick="RefreshData">
            <i class="bi bi-arrow-clockwise"></i> Refresh
        </button>
    </div>

    @if (isLoading)
    {
        <div class="ae-card">
            <div class="ae-loading">
                <div class="ae-spinner"></div>
                <div class="ae-loading-text">Loading equipments...</div>
            </div>
        </div>
    }
    else
    {
        <!-- Stats -->
        <div class="ae-stats">
            <div class="ae-stat">
                <div>
                    <div class="ae-stat-value">@equipments.Count()</div>
                    <div class="ae-stat-label">Total Equipment</div>
                </div>
                <div class="ae-stat-icon ae-icon-terracotta"><i class="bi bi-box-seam"></i></div>
            </div>
            <div class="ae-stat">
                <div>
                    <div class="ae-stat-value">@equipments.Count(e => e.IsApproved)</div>
                    <div class="ae-stat-label">Approved</div>
                </div>
                <div class="ae-stat-icon ae-icon-teal"><i class="bi bi-check-circle"></i></div>
            </div>
            <div class="ae-stat">
                <div>
                    <div class="ae-stat-value">@equipments.Count(e => !e.IsApproved)</div>
                    <div class="ae-stat-label">Pending</div>
                </div>
                <div class="ae-stat-icon ae-icon-bronze"><i class="bi bi-clock-history"></i></div>
            </div>
            <div class="ae-stat">
                <div>
                    <div class="ae-stat-value">@equipments.Count(e => e.IsAvailable)</div>
                    <div class="ae-stat-label">Available</div>
                </div>
                <div class="ae-stat-icon ae-icon-charcoal"><i class="bi bi-check2-square"></i></div>
            </div>
        </div>

        <!-- Search & Filter -->
        <div class="ae-search-bar">
            <div class="ae-search-wrap">
                <i class="bi bi-search"></i>
                <input type="text" class="ae-search-input" placeholder="Search by name, description, or provider..." @bind="searchTerm" @bind:event="oninput" />
            </div>
            <select class="ae-filter-select" @bind="selectedCategory" @bind:after="FilterEquipments">
                <option value="">All Categories</option>
                <option value="Tents">Tents</option>
                <option value="Chairs">Chairs</option>
                <option value="Sound System">Sound System</option>
                <option value="Lighting">Lighting</option>
                <option value="Catering">Catering</option>
                <option value="Decoration">Decoration</option>
            </select>
            <span class="ae-search-count">@searchedEquipments.Count() of @equipments.Count()</span>
        </div>

        <!-- Equipment Table -->
        <div class="ae-card">
            <div class="ae-card-header">
                <h5 class="ae-card-title"><i class="bi bi-table"></i> Equipment Inventory</h5>
                <span class="ae-card-count">@searchedEquipments.Count() items</span>
            </div>
            @if (searchedEquipments.Any())
            {
                <div style="overflow-x:auto;">
                    <table class="ae-table">
                        <thead>
                            <tr>
                                <th>Name</th>
                                <th>Category</th>
                                <th>Price/Unit</th>
                                <th>Qty</th>
                                <th>Provider</th>
                                <th>Status</th>
                                <th>Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var equipment in searchedEquipments)
                            {
                                <tr>
                                    <td>
                                        <div class="ae-equip-name">@equipment.Name</div>
                                        <div class="ae-equip-desc">@equipment.Description</div>
                                    </td>
                                    <td><span class="ae-badge ae-badge-category"><i class="bi bi-tag"></i> @equipment.Category</span></td>
                                    <td>
                                        <div class="ae-price">$@equipment.PricePerUnit.ToString("N2")</div>
                                        <div class="ae-price-unit">per @equipment.Unit</div>
                                    </td>
                                    <td><span class="ae-badge ae-badge-qty">@equipment.AvailableQuantity @equipment.Unit</span></td>
                                    <td><span class="ae-provider">@equipment.Provider?.FullName</span></td>
                                    <td>
                                        @if (equipment.IsApproved)
                                        {
                                            <span class="ae-badge ae-badge-approved"><i class="bi bi-check-circle"></i> Approved</span>
                                        }
                                        else
                                        {
                                            <span class="ae-badge ae-badge-pending"><i class="bi bi-clock-history"></i> Pending</span>
                                        }
                                        @if (!equipment.IsAvailable)
                                        {
                                            <span class="ae-badge ae-badge-unavailable" style="margin-left:0.25rem;"><i class="bi bi-x-circle"></i> Unavail</span>
                                        }
                                    </td>
                                    <td>
                                        <div class="ae-actions">
                                            @if (!equipment.IsApproved)
                                            {
                                                <button class="ae-btn ae-btn-sm ae-btn-approve" @onclick="() => ShowApproveModal(equipment)" title="Approve">
                                                    <i class="bi bi-check-lg"></i>
                                                </button>
                                                <button class="ae-btn ae-btn-sm ae-btn-reject" @onclick="() => ShowRejectModal(equipment)" title="Reject">
                                                    <i class="bi bi-x-lg"></i>
                                                </button>
                                            }
                                            else
                                            {
                                                <button class="ae-btn ae-btn-sm ae-btn-reject" @onclick="() => ShowRejectModal(equipment)" title="Revoke Approval">
                                                    <i class="bi bi-x-lg"></i>
                                                </button>
                                            }
                                            <button class="ae-btn ae-btn-sm ae-btn-delete" @onclick="() => ShowDeleteModal(equipment)" title="Delete">
                                                <i class="bi bi-trash"></i>
                                            </button>
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
            else
            {
                <div class="ae-empty">
                    <div class="ae-empty-icon"><i class="bi bi-inbox"></i></div>
                    <div class="ae-empty-title">No Equipment Found</div>
                    <div class="ae-empty-text">No equipment matches your criteria.</div>
                </div>
            }
        </div>
    }
</div>

@* --- Confirmation Modals --- *@
@if (modalVisible)
{
    <div style="position:fixed;inset:0;background:rgba(0,0,0,0.45);z-index:1050;display:flex;align-items:center;justify-content:center;animation:fadeIn .2s ease;"
         @onclick="CloseModal">
        <div style="background:#fff;border-radius:14px;padding:1.75rem;max-width:420px;width:92%;box-shadow:0 12px 40px rgba(0,0,0,0.18);animation:scaleIn .2s ease;"
             @onclick:stopPropagation="true">
            <div style="text-align:center;">
                <div style="width:56px;height:56px;border-radius:50%;display:flex;align-items:center;justify-content:center;margin:0 auto 1rem;font-size:1.5rem;background:@modalIconBg;color:@modalIconColor;">
                    <i class="bi @modalIcon"></i>
                </div>
                <h5 style="margin:0 0 0.4rem;font-size:1rem;color:#2A2A2A;font-weight:700;">@modalTitle</h5>
                <p style="font-size:0.8rem;color:#8a8177;margin:0 0 0.25rem;">@modalMessage</p>
                @if (selectedEquipment != null)
                {
                    <div style="background:#faf8f5;border-radius:8px;padding:0.6rem 0.75rem;margin:0.75rem 0;text-align:left;border:1px solid #f0ebe4;">
                        <div style="font-size:0.75rem;font-weight:700;color:#2A2A2A;">@selectedEquipment.Name</div>
                        <div style="font-size:0.65rem;color:#8a8177;margin-top:2px;">@selectedEquipment.Category &middot; $@selectedEquipment.PricePerUnit.ToString("N2")/@selectedEquipment.Unit &middot; @selectedEquipment.AvailableQuantity units</div>
                    </div>
                }
            </div>
            <div style="display:flex;gap:0.5rem;justify-content:center;margin-top:1.25rem;">
                <button style="padding:0.45rem 1.1rem;border-radius:8px;border:1px solid #dee2e6;background:#fff;color:#5c5550;font-size:0.78rem;font-weight:600;cursor:pointer;" @onclick="CloseModal">
                    Cancel
                </button>
                <button style="padding:0.45rem 1.1rem;border-radius:8px;border:none;background:@modalBtnBg;color:#fff;font-size:0.78rem;font-weight:600;cursor:pointer;display:flex;align-items:center;gap:6px;"
                        disabled="@isProcessing" @onclick="ConfirmAction">
                    @if (isProcessing)
                    {
                        <span class="ae-spinner" style="width:14px;height:14px;border-width:2px;"></span>
                    }
                    else
                    {
                        <i class="bi @modalBtnIcon"></i>
                    }
                    @modalBtnText
                </button>
            </div>
        </div>
    </div>
}

@code {
    private bool isLoading = true;
    private List<EventEquipment> equipments = new();
    private List<EventEquipment> filteredEquipments = new();
    private string selectedCategory = "";
    private string searchTerm = "";

    private List<BreadcrumbItem> breadcrumbItems = new()
    {
        new BreadcrumbItem { Text = "Home", Url = "/" },
        new BreadcrumbItem { Text = "Admin Dashboard", Url = "/admin/dashboard" },
        new BreadcrumbItem { Text = "Event Equipments", IsActive = true }
    };

    private IEnumerable<EventEquipment> searchedEquipments => string.IsNullOrWhiteSpace(searchTerm)
        ? filteredEquipments
        : filteredEquipments.Where(e =>
        {
            var term = searchTerm.Trim().ToLower();
            return (e.Name?.ToLower().Contains(term) ?? false)
                || (e.Description?.ToLower().Contains(term) ?? false)
                || (e.Provider?.FullName?.ToLower().Contains(term) ?? false);
        });

    protected override async Task OnInitializedAsync()
    {
        await LoadData();
    }

    private async Task LoadData()
    {
        isLoading = true;
        try
        {
            var allEquipments = await EventService.GetAllEquipmentsAsync();
            equipments = allEquipments.ToList();
            FilterEquipments();
        }
        catch (Exception ex)
        {
            // Log error
        }
        finally
        {
            isLoading = false;
        }
    }

    private void FilterEquipments()
    {
        if (string.IsNullOrEmpty(selectedCategory))
        {
            filteredEquipments = equipments;
        }
        else
        {
            filteredEquipments = equipments.Where(e => e.Category == selectedCategory).ToList();
        }
    }

    // Modal state
    private bool modalVisible = false;
    private bool isProcessing = false;
    private EventEquipment? selectedEquipment;
    private string modalAction = "";
    private string modalTitle = "";
    private string modalMessage = "";
    private string modalIcon = "";
    private string modalIconBg = "";
    private string modalIconColor = "";
    private string modalBtnBg = "";
    private string modalBtnText = "";
    private string modalBtnIcon = "";

    private void ShowApproveModal(EventEquipment eq)
    {
        selectedEquipment = eq;
        modalAction = "approve";
        modalTitle = "Approve Equipment?";
        modalMessage = "This equipment will become visible to all customers.";
        modalIcon = "bi-check-circle";
        modalIconBg = "rgba(72,140,130,0.12)";
        modalIconColor = "#488C82";
        modalBtnBg = "#488C82";
        modalBtnText = "Approve";
        modalBtnIcon = "bi-check-lg";
        modalVisible = true;
    }

    private void ShowRejectModal(EventEquipment eq)
    {
        selectedEquipment = eq;
        modalAction = "reject";
        modalTitle = eq.IsApproved ? "Revoke Approval?" : "Reject Equipment?";
        modalMessage = eq.IsApproved
            ? "This equipment will be removed from public listings."
            : "This equipment will remain hidden from customers.";
        modalIcon = "bi-x-circle";
        modalIconBg = "rgba(200,121,65,0.12)";
        modalIconColor = "#C87941";
        modalBtnBg = "#C87941";
        modalBtnText = eq.IsApproved ? "Revoke" : "Reject";
        modalBtnIcon = "bi-x-lg";
        modalVisible = true;
    }

    private void ShowDeleteModal(EventEquipment eq)
    {
        selectedEquipment = eq;
        modalAction = "delete";
        modalTitle = "Delete Equipment?";
        modalMessage = "This action cannot be undone. The equipment and all its data will be permanently removed.";
        modalIcon = "bi-trash";
        modalIconBg = "rgba(220,53,69,0.1)";
        modalIconColor = "#dc3545";
        modalBtnBg = "#dc3545";
        modalBtnText = "Delete";
        modalBtnIcon = "bi-trash";
        modalVisible = true;
    }

    private void CloseModal()
    {
        modalVisible = false;
        selectedEquipment = null;
        isProcessing = false;
    }

    private async Task ConfirmAction()
    {
        if (selectedEquipment == null) return;
        isProcessing = true;

        try
        {
            switch (modalAction)
            {
                case "approve":
                    await EventService.ApproveEquipmentAsync(selectedEquipment.Id);
                    break;
                case "reject":
                    await EventService.RejectEquipmentAsync(selectedEquipment.Id);
                    break;
                case "delete":
                    await EventService.DeleteEquipmentAsync(selectedEquipment.Id);
                    break;
            }
            await LoadData();
        }
        catch (Exception ex)
        {
            System.Diagnostics.Debug.WriteLine($"[AdminEquipments] Error: {ex.Message}");
        }
        finally
        {
            CloseModal();
        }
    }

    private async Task RefreshData()
    {
        await LoadData();
    }
}
