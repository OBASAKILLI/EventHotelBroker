@page "/admin/event-packages"
@rendermode InteractiveServer
@using EventHotelBroker.Models
@using EventHotelBroker.Services
@inject IEventService EventService

<PageTitle>Event Packages - Admin</PageTitle>

<link href="/css/admin-event-packages.css?v=1" rel="stylesheet" />

<div class="ap">
    <Breadcrumb Items="@breadcrumbItems" />

    <!-- Header -->
    <div class="ap-header">
        <div>
            <h1 class="ap-header-title"><i class="bi bi-gift"></i> Event Packages</h1>
            <p class="ap-header-sub">Manage event packages and deals</p>
        </div>
        <button class="ap-btn ap-btn-refresh" @onclick="RefreshData">
            <i class="bi bi-arrow-clockwise"></i> Refresh
        </button>
    </div>

    @if (isLoading)
    {
        <div class="ap-card">
            <div class="ap-loading">
                <div class="ap-spinner"></div>
                <div class="ap-loading-text">Loading packages...</div>
            </div>
        </div>
    }
    else
    {
        <!-- Stats -->
        <div class="ap-stats">
            <div class="ap-stat">
                <div>
                    <div class="ap-stat-value">@packages.Count()</div>
                    <div class="ap-stat-label">Total Packages</div>
                </div>
                <div class="ap-stat-icon ap-icon-terracotta"><i class="bi bi-gift"></i></div>
            </div>
            <div class="ap-stat">
                <div>
                    <div class="ap-stat-value">@packages.Count(p => p.IsApproved)</div>
                    <div class="ap-stat-label">Approved</div>
                </div>
                <div class="ap-stat-icon ap-icon-teal"><i class="bi bi-check-circle"></i></div>
            </div>
            <div class="ap-stat">
                <div>
                    <div class="ap-stat-value">@packages.Count(p => p.IsFeatured)</div>
                    <div class="ap-stat-label">Featured</div>
                </div>
                <div class="ap-stat-icon ap-icon-bronze"><i class="bi bi-star"></i></div>
            </div>
            <div class="ap-stat">
                <div>
                    <div class="ap-stat-value">@packages.Count(p => p.IsActive)</div>
                    <div class="ap-stat-label">Active</div>
                </div>
                <div class="ap-stat-icon ap-icon-charcoal"><i class="bi bi-check2-square"></i></div>
            </div>
        </div>

        <!-- Search & Filter -->
        <div class="ap-search-bar">
            <div class="ap-search-wrap">
                <i class="bi bi-search"></i>
                <input type="text" class="ap-search-input" placeholder="Search by name or description..." @bind="searchTerm" @bind:event="oninput" />
            </div>
            <select class="ap-filter-select" @bind="selectedType" @bind:after="FilterPackages">
                <option value="">All Types</option>
                <option value="Wedding">Wedding</option>
                <option value="Corporate">Corporate</option>
                <option value="Birthday">Birthday</option>
                <option value="Conference">Conference</option>
                <option value="Party">Party</option>
            </select>
            <span class="ap-search-count">@searchedPackages.Count() of @packages.Count()</span>
        </div>

        <!-- Packages Grid -->
        <div class="ap-card">
            <div class="ap-card-header">
                <h5 class="ap-card-title"><i class="bi bi-grid-3x2-gap"></i> Package Inventory</h5>
                <span class="ap-card-count">@searchedPackages.Count() items</span>
            </div>
            @if (searchedPackages.Any())
            {
                <div class="ap-grid">
                    @foreach (var package in searchedPackages)
                    {
                        <div class="ap-item">
                            <div class="ap-item-img">
                                @if (package.IsFeatured)
                                {
                                    <span class="ap-featured"><i class="bi bi-star-fill"></i> Featured</span>
                                }
                                @if (!string.IsNullOrEmpty(package.ImageUrl))
                                {
                                    <img src="@package.ImageUrl" alt="@package.Name" />
                                }
                                else
                                {
                                    <div class="ap-item-img-placeholder"><i class="bi bi-gift"></i></div>
                                }
                            </div>
                            <div class="ap-item-body">
                                <div class="ap-badges">
                                    <span class="ap-badge ap-badge-type">@package.PackageType</span>
                                    @if (package.IsApproved)
                                    {
                                        <span class="ap-badge ap-badge-approved">Approved</span>
                                    }
                                    else
                                    {
                                        <span class="ap-badge ap-badge-pending">Pending</span>
                                    }
                                    @if (package.IsActive)
                                    {
                                        <span class="ap-badge ap-badge-active">Active</span>
                                    }
                                    else
                                    {
                                        <span class="ap-badge ap-badge-inactive">Inactive</span>
                                    }
                                </div>
                                <h6 class="ap-item-name">@package.Name</h6>
                                <p class="ap-item-desc">@package.Description</p>

                                <div class="ap-price-row">
                                    <div>
                                        @if (package.DiscountedPrice.HasValue)
                                        {
                                            <span class="ap-price-old">$@package.TotalPrice.ToString("N2")</span>
                                            <span class="ap-price">$@package.DiscountedPrice.Value.ToString("N2")</span>
                                        }
                                        else
                                        {
                                            <span class="ap-price">$@package.TotalPrice.ToString("N2")</span>
                                        }
                                    </div>
                                    <span class="ap-guests"><i class="bi bi-people"></i> @package.MinGuests-@package.MaxGuests</span>
                                </div>

                                <div class="ap-actions">
                                    @if (!package.IsApproved)
                                    {
                                        <button class="ap-btn ap-btn-sm ap-btn-approve" @onclick="() => ShowApproveModal(package)">
                                            <i class="bi bi-check-lg"></i> Approve
                                        </button>
                                        <button class="ap-btn ap-btn-sm ap-btn-reject" @onclick="() => ShowRejectModal(package)">
                                            <i class="bi bi-x-lg"></i> Reject
                                        </button>
                                    }
                                    else
                                    {
                                        <button class="ap-btn ap-btn-sm ap-btn-reject" @onclick="() => ShowRejectModal(package)">
                                            <i class="bi bi-x-lg"></i> Revoke
                                        </button>
                                    }
                                    <button class="ap-btn ap-btn-sm ap-btn-delete" @onclick="() => ShowDeleteModal(package)">
                                        <i class="bi bi-trash"></i>
                                    </button>
                                </div>
                            </div>
                        </div>
                    }
                </div>
            }
            else
            {
                <div class="ap-empty">
                    <div class="ap-empty-icon"><i class="bi bi-inbox"></i></div>
                    <div class="ap-empty-title">No Packages Found</div>
                    <div class="ap-empty-text">No packages match your criteria.</div>
                </div>
            }
        </div>
    }
</div>

@* --- Confirmation Modals --- *@
@if (modalVisible)
{
    <div style="position:fixed;inset:0;background:rgba(0,0,0,0.45);z-index:1050;display:flex;align-items:center;justify-content:center;"
         @onclick="CloseModal">
        <div style="background:#fff;border-radius:14px;padding:1.75rem;max-width:420px;width:92%;box-shadow:0 12px 40px rgba(0,0,0,0.18);"
             @onclick:stopPropagation="true">
            <div style="text-align:center;">
                <div style="width:56px;height:56px;border-radius:50%;display:flex;align-items:center;justify-content:center;margin:0 auto 1rem;font-size:1.5rem;background:@modalIconBg;color:@modalIconColor;">
                    <i class="bi @modalIcon"></i>
                </div>
                <h5 style="margin:0 0 0.4rem;font-size:1rem;color:#2A2A2A;font-weight:700;">@modalTitle</h5>
                <p style="font-size:0.8rem;color:#8a8177;margin:0 0 0.25rem;">@modalMessage</p>
                @if (selectedPackage != null)
                {
                    <div style="background:#faf8f5;border-radius:8px;padding:0.6rem 0.75rem;margin:0.75rem 0;text-align:left;border:1px solid #f0ebe4;">
                        <div style="font-size:0.75rem;font-weight:700;color:#2A2A2A;">@selectedPackage.Name</div>
                        <div style="font-size:0.65rem;color:#8a8177;margin-top:2px;">@selectedPackage.PackageType &middot; $@selectedPackage.TotalPrice.ToString("N2") &middot; @selectedPackage.MinGuests-@selectedPackage.MaxGuests guests</div>
                    </div>
                }
            </div>
            <div style="display:flex;gap:0.5rem;justify-content:center;margin-top:1.25rem;">
                <button style="padding:0.45rem 1.1rem;border-radius:8px;border:1px solid #dee2e6;background:#fff;color:#5c5550;font-size:0.78rem;font-weight:600;cursor:pointer;" @onclick="CloseModal">
                    Cancel
                </button>
                <button style="padding:0.45rem 1.1rem;border-radius:8px;border:none;background:@modalBtnBg;color:#fff;font-size:0.78rem;font-weight:600;cursor:pointer;display:flex;align-items:center;gap:6px;"
                        disabled="@isProcessing" @onclick="ConfirmAction">
                    @if (isProcessing)
                    {
                        <span class="ap-spinner" style="width:14px;height:14px;border-width:2px;"></span>
                    }
                    else
                    {
                        <i class="bi @modalBtnIcon"></i>
                    }
                    @modalBtnText
                </button>
            </div>
        </div>
    </div>
}

@code {
    private bool isLoading = true;
    private List<EventPackage> packages = new();
    private List<EventPackage> filteredPackages = new();
    private string selectedType = "";
    private string searchTerm = "";

    private List<BreadcrumbItem> breadcrumbItems = new()
    {
        new BreadcrumbItem { Text = "Home", Url = "/" },
        new BreadcrumbItem { Text = "Admin Dashboard", Url = "/admin/dashboard" },
        new BreadcrumbItem { Text = "Event Packages", IsActive = true }
    };

    private IEnumerable<EventPackage> searchedPackages => string.IsNullOrWhiteSpace(searchTerm)
        ? filteredPackages
        : filteredPackages.Where(p =>
        {
            var term = searchTerm.Trim().ToLower();
            return (p.Name?.ToLower().Contains(term) ?? false)
                || (p.Description?.ToLower().Contains(term) ?? false);
        });

    protected override async Task OnInitializedAsync()
    {
        await LoadData();
    }

    private async Task LoadData()
    {
        isLoading = true;
        try
        {
            var allPackages = await EventService.GetAllPackagesAsync();
            packages = allPackages.ToList();
            FilterPackages();
        }
        catch (Exception ex)
        {
            // Log error
        }
        finally
        {
            isLoading = false;
        }
    }

    private void FilterPackages()
    {
        if (string.IsNullOrEmpty(selectedType))
        {
            filteredPackages = packages;
        }
        else
        {
            filteredPackages = packages.Where(p => p.PackageType == selectedType).ToList();
        }
    }

    // Modal state
    private bool modalVisible = false;
    private bool isProcessing = false;
    private EventPackage? selectedPackage;
    private string modalAction = "";
    private string modalTitle = "";
    private string modalMessage = "";
    private string modalIcon = "";
    private string modalIconBg = "";
    private string modalIconColor = "";
    private string modalBtnBg = "";
    private string modalBtnText = "";
    private string modalBtnIcon = "";

    private void ShowApproveModal(EventPackage pkg)
    {
        selectedPackage = pkg;
        modalAction = "approve";
        modalTitle = "Approve Package?";
        modalMessage = "This package will become visible to all customers.";
        modalIcon = "bi-check-circle";
        modalIconBg = "rgba(72,140,130,0.12)";
        modalIconColor = "#488C82";
        modalBtnBg = "#488C82";
        modalBtnText = "Approve";
        modalBtnIcon = "bi-check-lg";
        modalVisible = true;
    }

    private void ShowRejectModal(EventPackage pkg)
    {
        selectedPackage = pkg;
        modalAction = "reject";
        modalTitle = pkg.IsApproved ? "Revoke Approval?" : "Reject Package?";
        modalMessage = pkg.IsApproved
            ? "This package will be removed from public listings."
            : "This package will remain hidden from customers.";
        modalIcon = "bi-x-circle";
        modalIconBg = "rgba(200,121,65,0.12)";
        modalIconColor = "#C87941";
        modalBtnBg = "#C87941";
        modalBtnText = pkg.IsApproved ? "Revoke" : "Reject";
        modalBtnIcon = "bi-x-lg";
        modalVisible = true;
    }

    private void ShowDeleteModal(EventPackage pkg)
    {
        selectedPackage = pkg;
        modalAction = "delete";
        modalTitle = "Delete Package?";
        modalMessage = "This action cannot be undone. The package and all its data will be permanently removed.";
        modalIcon = "bi-trash";
        modalIconBg = "rgba(220,53,69,0.1)";
        modalIconColor = "#dc3545";
        modalBtnBg = "#dc3545";
        modalBtnText = "Delete";
        modalBtnIcon = "bi-trash";
        modalVisible = true;
    }

    private void CloseModal()
    {
        modalVisible = false;
        selectedPackage = null;
        isProcessing = false;
    }

    private async Task ConfirmAction()
    {
        if (selectedPackage == null) return;
        isProcessing = true;

        try
        {
            switch (modalAction)
            {
                case "approve":
                    await EventService.ApprovePackageAsync(selectedPackage.Id);
                    break;
                case "reject":
                    await EventService.RejectPackageAsync(selectedPackage.Id);
                    break;
                case "delete":
                    await EventService.DeletePackageAsync(selectedPackage.Id);
                    break;
            }
            await LoadData();
        }
        catch (Exception ex)
        {
            System.Diagnostics.Debug.WriteLine($"[AdminPackages] Error: {ex.Message}");
        }
        finally
        {
            CloseModal();
        }
    }

    private async Task RefreshData()
    {
        await LoadData();
    }
}
