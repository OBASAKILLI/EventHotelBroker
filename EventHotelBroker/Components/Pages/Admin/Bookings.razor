@page "/admin/bookings"
@rendermode InteractiveServer
@using EventHotelBroker.Models
@using EventHotelBroker.Services
@inject IBookingService BookingService

<PageTitle>All Bookings - Admin</PageTitle>

<link href="/css/admin-bookings.css?v=3" rel="stylesheet" />

<div class="ab">
    <Breadcrumb Items="@breadcrumbItems" />

    <!-- Header -->
    <div class="ab-header">
        <div>
            <h1 class="ab-header-title"><i class="bi bi-calendar-check"></i> Booking Management</h1>
            <p class="ab-header-sub">Monitor and manage all hotel bookings</p>
        </div>
        <button class="ab-btn ab-btn-refresh" @onclick="LoadBookings">
            <i class="bi bi-arrow-clockwise"></i> Refresh
        </button>
    </div>

    <!-- Stats -->
    <div class="ab-stats">
        <div class="ab-stat">
            <div>
                <div class="ab-stat-value">@bookings.Count</div>
                <div class="ab-stat-label">Total Bookings</div>
            </div>
            <div class="ab-stat-icon ab-icon-terracotta"><i class="bi bi-calendar-check"></i></div>
        </div>
        <div class="ab-stat">
            <div>
                <div class="ab-stat-value">@bookings.Count(b => b.Status == BookingStatus.Pending)</div>
                <div class="ab-stat-label">Pending</div>
            </div>
            <div class="ab-stat-icon ab-icon-bronze"><i class="bi bi-clock-history"></i></div>
        </div>
        <div class="ab-stat">
            <div>
                <div class="ab-stat-value">@bookings.Count(b => b.Status == BookingStatus.Confirmed)</div>
                <div class="ab-stat-label">Confirmed</div>
            </div>
            <div class="ab-stat-icon ab-icon-teal"><i class="bi bi-check-circle"></i></div>
        </div>
        <div class="ab-stat">
            <div>
                <div class="ab-stat-value">@bookings.Count(b => b.Status == BookingStatus.Cancelled || b.Status == BookingStatus.Rejected)</div>
                <div class="ab-stat-label">Cancelled / Rejected</div>
            </div>
            <div class="ab-stat-icon ab-icon-charcoal"><i class="bi bi-x-circle"></i></div>
        </div>
    </div>

    <!-- Search & Filter -->
    <div class="ab-search-bar">
        <div class="ab-search-wrap">
            <i class="bi bi-search"></i>
            <input type="text" class="ab-search-input" placeholder="Search by hotel, guest, or booking ID..." @bind="searchTerm" @bind:event="oninput" />
        </div>
        <select class="ab-filter-select" @bind="statusFilter" @bind:event="onchange">
            <option value="">All Status</option>
            <option value="Pending">Pending</option>
            <option value="Confirmed">Confirmed</option>
            <option value="Rejected">Rejected</option>
            <option value="Cancelled">Cancelled</option>
        </select>
        <select class="ab-filter-select" @bind="categoryFilter" @bind:event="onchange">
            <option value="">All Categories</option>
            <option value="Hotel">Hotels</option>
            <option value="Airbnb">Airbnb</option>
            <option value="Restaurant">Restaurants</option>
            <option value="Venue">Venues</option>
            <option value="Resort">Resorts</option>
            <option value="Lodge">Lodges</option>
            <option value="Guest House">Guest Houses</option>
            <option value="Apartment">Apartments</option>
        </select>
        <span class="ab-search-count">@filteredBookings.Count() of @bookings.Count</span>
    </div>

    @if (isLoading)
    {
        <div class="ab-card">
            <div class="ab-loading">
                <div class="ab-spinner"></div>
                <div class="ab-loading-text">Loading bookings...</div>
            </div>
        </div>
    }
    else if (!bookings.Any())
    {
        <div class="ab-card">
            <div class="ab-empty">
                <div class="ab-empty-icon"><i class="bi bi-calendar-x"></i></div>
                <div class="ab-empty-title">No Bookings Found</div>
                <div class="ab-empty-text">There are no bookings in the system yet.</div>
            </div>
        </div>
    }
    else if (!filteredBookings.Any())
    {
        <div class="ab-card">
            <div class="ab-empty">
                <div class="ab-empty-icon"><i class="bi bi-search"></i></div>
                <div class="ab-empty-title">No Results</div>
                <div class="ab-empty-text">No bookings match your search criteria.</div>
            </div>
        </div>
    }
    else
    {
        <div class="ab-card">
            <div class="ab-card-header">
                <h5 class="ab-card-title"><i class="bi bi-table"></i> All Bookings</h5>
                <span class="ab-card-count">@filteredBookings.Count() records</span>
            </div>
            <div style="overflow-x:auto;">
                <table class="ab-table">
                    <thead>
                        <tr>
                            <th>ID</th>
                            <th>Hotel</th>
                            <th>Guest</th>
                            <th>Dates</th>
                            <th>Guests</th>
                            <th>Status</th>
                            <th>Booked On</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var booking in filteredBookings)
                        {
                            <tr>
                                <td><span class="ab-id">#@booking.Id</span></td>
                                <td>
                                    <div class="ab-hotel-cell">
                                        <div class="ab-hotel-icon"><i class="bi bi-building"></i></div>
                                        <div>
                                            <div class="ab-hotel-name">@(booking.Hotel?.Name ?? "N/A")</div>
                                            <div class="ab-hotel-sub">@(booking.Hotel?.City ?? "")</div>
                                        </div>
                                    </div>
                                </td>
                                <td><span class="ab-guest"><i class="bi bi-person"></i> @(booking.User?.FullName ?? "N/A")</span></td>
                                <td>
                                    <div class="ab-date-range">
                                        <span class="ab-date">@booking.StartDate.ToString("MMM dd")</span>
                                        <i class="bi bi-arrow-right" style="font-size:0.6rem;color:#b5ac9e;"></i>
                                        <span class="ab-date">@booking.EndDate.ToString("MMM dd, yyyy")</span>
                                    </div>
                                </td>
                                <td><span class="ab-badge ab-badge-guests"><i class="bi bi-people"></i> @booking.HeadCount</span></td>
                                <td>
                                    <span class="ab-badge @GetAbStatusBadge(booking.Status)">
                                        <i class="bi @GetStatusIcon(booking.Status)"></i> @booking.Status
                                    </span>
                                </td>
                                <td><span class="ab-date"><i class="bi bi-calendar3"></i> @booking.CreatedAt.ToString("MMM dd, yyyy")</span></td>
                                <td>
                                    <div class="ab-actions">
                                        <button class="ab-btn ab-btn-sm ab-btn-view" @onclick="() => ViewBooking(booking)" title="View Details">
                                            <i class="bi bi-eye"></i>
                                        </button>
                                        @if (booking.Status == BookingStatus.Pending)
                                        {
                                            <button class="ab-btn ab-btn-sm ab-btn-confirm" @onclick="() => OpenConfirmModal(booking)" title="Confirm">
                                                <i class="bi bi-check-lg"></i>
                                            </button>
                                            <button class="ab-btn ab-btn-sm ab-btn-reject" @onclick="() => OpenRejectModal(booking)" title="Reject">
                                                <i class="bi bi-x-lg"></i>
                                            </button>
                                        }
                                        else if (booking.Status == BookingStatus.Confirmed)
                                        {
                                            <button class="ab-btn ab-btn-sm ab-btn-reject" @onclick="() => OpenRejectModal(booking)" title="Reject">
                                                <i class="bi bi-x-lg"></i>
                                            </button>
                                        }
                                        else if (booking.Status == BookingStatus.Rejected)
                                        {
                                            <button class="ab-btn ab-btn-sm ab-btn-confirm" @onclick="() => OpenConfirmModal(booking)" title="Approve">
                                                <i class="bi bi-check-lg"></i>
                                            </button>
                                        }
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }

    @if (!string.IsNullOrEmpty(message))
    {
        <div class="ab-toast @(messageType == "success" ? "ab-toast-success" : "ab-toast-error")">
            <div class="ab-toast-header">
                <span class="ab-toast-label">@(messageType == "success" ? "Success" : "Error")</span>
                <button class="ab-toast-close" @onclick="() => message = null"><i class="bi bi-x"></i></button>
            </div>
            <div class="ab-toast-body">@message</div>
        </div>
    }
</div>

@* ── Modals (outside .ab container to avoid overflow clip) ── *@

@if (showViewModal && selectedBooking != null)
{
    <div class="bk-backdrop" @onclick="CloseModals"></div>
    <div class="bk-modal-wrap">
        <div class="bk-modal bk-modal-lg">
            <div class="bk-modal-header">
                <h5><i class="bi bi-eye"></i> Booking Details</h5>
                <button type="button" class="bk-close-btn" @onclick="CloseModals"><i class="bi bi-x-lg"></i></button>
            </div>
            <div class="bk-modal-body">
                <div class="detail-grid">
                    <div class="detail-item">
                        <span class="detail-label">Booking ID</span>
                        <span class="detail-value">#@selectedBooking.Id</span>
                    </div>
                    <div class="detail-item">
                        <span class="detail-label">Status</span>
                        <span class="ab-badge @GetAbStatusBadge(selectedBooking.Status)"><i class="bi @GetStatusIcon(selectedBooking.Status)"></i> @selectedBooking.Status</span>
                    </div>
                    <div class="detail-item">
                        <span class="detail-label">Hotel</span>
                        <span class="detail-value">@(selectedBooking.Hotel?.Name ?? "N/A")</span>
                    </div>
                    <div class="detail-item">
                        <span class="detail-label">Location</span>
                        <span class="detail-value">@(selectedBooking.Hotel?.City ?? "N/A"), @(selectedBooking.Hotel?.Country ?? "")</span>
                    </div>
                    <div class="detail-item">
                        <span class="detail-label">Guest</span>
                        <span class="detail-value">@(selectedBooking.User?.FullName ?? "N/A")</span>
                    </div>
                    <div class="detail-item">
                        <span class="detail-label">Email</span>
                        <span class="detail-value">@(selectedBooking.User?.Email ?? "N/A")</span>
                    </div>
                    <div class="detail-item">
                        <span class="detail-label">Check-In</span>
                        <span class="detail-value">@selectedBooking.StartDate.ToString("MMM dd, yyyy")</span>
                    </div>
                    <div class="detail-item">
                        <span class="detail-label">Check-Out</span>
                        <span class="detail-value">@selectedBooking.EndDate.ToString("MMM dd, yyyy")</span>
                    </div>
                    <div class="detail-item">
                        <span class="detail-label">Guests</span>
                        <span class="detail-value">@selectedBooking.HeadCount</span>
                    </div>
                    <div class="detail-item">
                        <span class="detail-label">Booked On</span>
                        <span class="detail-value">@selectedBooking.CreatedAt.ToString("MMM dd, yyyy HH:mm")</span>
                    </div>
                </div>
                @if (!string.IsNullOrEmpty(selectedBooking.Notes))
                {
                    <div class="detail-notes">
                        <span class="detail-label">Notes</span>
                        <p style="word-break: break-word; white-space: pre-wrap;">@selectedBooking.Notes</p>
                    </div>
                }
                @if (selectedBooking.Status == BookingStatus.Rejected)
                {
                    <div class="detail-rejection">
                        <span class="detail-label"><i class="bi bi-x-circle"></i> Rejection Info</span>
                        <p class="rejection-reason" style="word-break: break-word; white-space: pre-wrap;">@(selectedBooking.RejectionReason ?? "No reason provided")</p>
                        @if (selectedBooking.RejectedAt.HasValue)
                        {
                            <small class="rejection-date">Rejected on @selectedBooking.RejectedAt.Value.ToString("MMM dd, yyyy HH:mm")</small>
                        }
                    </div>
                }
            </div>
            <div class="bk-modal-footer">
                <button type="button" class="ab-btn ab-btn-outline" @onclick="CloseModals">Close</button>
            </div>
        </div>
    </div>
}

@if (showConfirmModal && selectedBooking != null)
{
    <div class="bk-backdrop" @onclick="CloseModals"></div>
    <div class="bk-modal-wrap">
        <div class="bk-modal">
            <div class="bk-modal-body text-center">
                <div class="bk-modal-icon bk-icon-confirm"><i class="bi bi-check-circle"></i></div>
                <h4 class="bk-modal-title">Confirm Booking?</h4>
                <p class="bk-modal-sub">You are about to confirm the booking for:</p>
                <div class="bk-modal-detail">
                    <strong>@(selectedBooking.Hotel?.Name ?? "N/A")</strong><br/>
                    <span>@(selectedBooking.User?.FullName ?? "Guest") &middot; @(selectedBooking.StartDate.ToString("MMM dd")) - @(selectedBooking.EndDate.ToString("MMM dd, yyyy"))</span>
                </div>
            </div>
            <div class="bk-modal-footer">
                <button type="button" class="ab-btn ab-btn-outline" @onclick="CloseModals">Cancel</button>
                <button type="button" class="ab-btn ab-btn-confirm" @onclick="ConfirmBooking" disabled="@isProcessing">
                    @if (isProcessing) { <span class="spinner-border spinner-border-sm me-1"></span> }
                    <i class="bi bi-check-lg"></i> Confirm
                </button>
            </div>
        </div>
    </div>
}

@if (showRejectModal && selectedBooking != null)
{
    <div class="bk-backdrop" @onclick="CloseModals"></div>
    <div class="bk-modal-wrap">
        <div class="bk-modal">
            <div class="bk-modal-body text-center">
                <div class="bk-modal-icon bk-icon-reject"><i class="bi bi-x-circle"></i></div>
                <h4 class="bk-modal-title">Reject Booking?</h4>
                <p class="bk-modal-sub">You are about to reject the booking for:</p>
                <div class="bk-modal-detail">
                    <strong>@(selectedBooking.Hotel?.Name ?? "N/A")</strong><br/>
                    <span>@(selectedBooking.User?.FullName ?? "Guest") &middot; @(selectedBooking.StartDate.ToString("MMM dd")) - @(selectedBooking.EndDate.ToString("MMM dd, yyyy"))</span>
                </div>
                <div style="text-align:left; margin-top:1rem;">
                    <label class="detail-label">Reason for rejection (optional)</label>
                    <textarea class="modal-textarea" @bind="rejectionReason" @bind:event="oninput" placeholder="Enter reason for rejection..."></textarea>
                </div>
            </div>
            <div class="bk-modal-footer">
                <button type="button" class="ab-btn ab-btn-outline" @onclick="CloseModals">Cancel</button>
                <button type="button" class="ab-btn ab-btn-reject" @onclick="RejectBooking" disabled="@isProcessing">
                    @if (isProcessing) { <span class="spinner-border spinner-border-sm me-1"></span> }
                    <i class="bi bi-x-lg"></i> Reject
                </button>
            </div>
        </div>
    </div>
}

@code {
    private bool isLoading = true;
    private List<Booking> bookings = new();
    private string searchTerm = "";
    private string statusFilter = "";
    private string categoryFilter = "";

    // Modal state
    private bool showViewModal = false;
    private bool showConfirmModal = false;
    private bool showRejectModal = false;
    private Booking? selectedBooking;
    private string rejectionReason = "";
    private bool isProcessing = false;
    private string? message;
    private string messageType = "success";

    private List<BreadcrumbItem> breadcrumbItems = new()
    {
        new BreadcrumbItem { Text = "Home", Url = "/" },
        new BreadcrumbItem { Text = "Admin Dashboard", Url = "/admin/dashboard" },
        new BreadcrumbItem { Text = "Bookings", IsActive = true }
    };

    private IEnumerable<Booking> filteredBookings => bookings.Where(b =>
    {
        if (!string.IsNullOrEmpty(statusFilter) && Enum.TryParse<BookingStatus>(statusFilter, out var s) && b.Status != s)
            return false;
        if (!string.IsNullOrWhiteSpace(searchTerm))
        {
            var term = searchTerm.Trim().ToLower();
            return b.Id.ToString().Contains(term)
                || (b.Hotel?.Name?.ToLower().Contains(term) ?? false)
                || (b.User?.FullName?.ToLower().Contains(term) ?? false);
        }
        if (!string.IsNullOrWhiteSpace(categoryFilter))
        {
            return b.Hotel?.Category == categoryFilter;
        }
        return true;
    });

    protected override async Task OnInitializedAsync()
    {
        await LoadBookings();
    }

    private async Task LoadBookings()
    {
        isLoading = true;
        try
        {
            bookings = await BookingService.GetAllBookingsAsync();
        }
        catch (Exception)
        {
            // Handle error
        }
        finally
        {
            isLoading = false;
        }
    }

    private void ViewBooking(Booking booking)
    {
        selectedBooking = booking;
        showViewModal = true;
    }

    private void OpenConfirmModal(Booking booking)
    {
        selectedBooking = booking;
        showConfirmModal = true;
    }

    private void OpenRejectModal(Booking booking)
    {
        selectedBooking = booking;
        rejectionReason = "";
        showRejectModal = true;
    }

    private async Task CloseModals()
    {
        showViewModal = false;
        showConfirmModal = false;
        showRejectModal = false;
        selectedBooking = null;
        rejectionReason = "";
        await InvokeAsync(StateHasChanged);
    }

    private async Task ConfirmBooking()
    {
        if (selectedBooking == null) return;
        isProcessing = true;
        try
        {
            var result = await BookingService.ConfirmBookingAsync(selectedBooking.Id);
            if (result)
            {
                message = "Booking confirmed successfully!";
                messageType = "success";
                CloseModals();
                await LoadBookings();
            }
            else
            {
                message = "Failed to confirm booking.";
                messageType = "error";
            }
        }
        catch (Exception ex)
        {
            message = $"Error: {ex.Message}";
            messageType = "error";
        }
        finally { isProcessing = false; }
    }

    private async Task RejectBooking()
    {
        if (selectedBooking == null) return;
        isProcessing = true;
        try
        {
            var result = await BookingService.RejectBookingAsync(selectedBooking.Id, string.IsNullOrWhiteSpace(rejectionReason) ? null : rejectionReason.Trim());
            if (result)
            {
                message = "Booking rejected.";
                messageType = "success";
                CloseModals();
                await LoadBookings();
            }
            else
            {
                message = "Failed to reject booking.";
                messageType = "error";
            }
        }
        catch (Exception ex)
        {
            message = $"Error: {ex.Message}";
            messageType = "error";
        }
        finally { isProcessing = false; }
    }

    private void ShowMessage(string msg, string type)
    {
        message = msg;
        messageType = type;
    }

    private string GetAbStatusBadge(BookingStatus status)
    {
        return status switch
        {
            BookingStatus.Pending => "ab-badge-pending",
            BookingStatus.Confirmed => "ab-badge-confirmed",
            BookingStatus.Rejected => "ab-badge-rejected",
            BookingStatus.Cancelled => "ab-badge-cancelled",
            _ => "ab-badge-cancelled"
        };
    }

    private string GetStatusIcon(BookingStatus status)
    {
        return status switch
        {
            BookingStatus.Pending => "bi-clock-history",
            BookingStatus.Confirmed => "bi-check-circle",
            BookingStatus.Rejected => "bi-x-circle",
            BookingStatus.Cancelled => "bi-dash-circle",
            _ => "bi-circle"
        };
    }
}
