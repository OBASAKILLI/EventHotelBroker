@page "/admin/bookings"
@rendermode InteractiveServer
@using EventHotelBroker.Models
@using EventHotelBroker.Repositories
@inject IUnitOfWork UnitOfWork

<PageTitle>All Bookings - Admin</PageTitle>

<link href="/css/admin-bookings.css?v=1" rel="stylesheet" />

<div class="ab">
    <Breadcrumb Items="@breadcrumbItems" />

    <!-- Header -->
    <div class="ab-header">
        <div>
            <h1 class="ab-header-title"><i class="bi bi-calendar-check"></i> Booking Management</h1>
            <p class="ab-header-sub">Monitor and manage all hotel bookings</p>
        </div>
        <button class="ab-btn ab-btn-refresh" @onclick="LoadBookings">
            <i class="bi bi-arrow-clockwise"></i> Refresh
        </button>
    </div>

    <!-- Stats -->
    <div class="ab-stats">
        <div class="ab-stat">
            <div>
                <div class="ab-stat-value">@bookings.Count</div>
                <div class="ab-stat-label">Total Bookings</div>
            </div>
            <div class="ab-stat-icon ab-icon-terracotta"><i class="bi bi-calendar-check"></i></div>
        </div>
        <div class="ab-stat">
            <div>
                <div class="ab-stat-value">@bookings.Count(b => b.Status == BookingStatus.Pending)</div>
                <div class="ab-stat-label">Pending</div>
            </div>
            <div class="ab-stat-icon ab-icon-bronze"><i class="bi bi-clock-history"></i></div>
        </div>
        <div class="ab-stat">
            <div>
                <div class="ab-stat-value">@bookings.Count(b => b.Status == BookingStatus.Confirmed)</div>
                <div class="ab-stat-label">Confirmed</div>
            </div>
            <div class="ab-stat-icon ab-icon-teal"><i class="bi bi-check-circle"></i></div>
        </div>
        <div class="ab-stat">
            <div>
                <div class="ab-stat-value">@bookings.Count(b => b.Status == BookingStatus.Cancelled || b.Status == BookingStatus.Rejected)</div>
                <div class="ab-stat-label">Cancelled / Rejected</div>
            </div>
            <div class="ab-stat-icon ab-icon-charcoal"><i class="bi bi-x-circle"></i></div>
        </div>
    </div>

    <!-- Search & Filter -->
    <div class="ab-search-bar">
        <div class="ab-search-wrap">
            <i class="bi bi-search"></i>
            <input type="text" class="ab-search-input" placeholder="Search by hotel, guest, or booking ID..." @bind="searchTerm" @bind:event="oninput" />
        </div>
        <select class="ab-filter-select" @bind="statusFilter" @bind:event="onchange">
            <option value="">All Status</option>
            <option value="Pending">Pending</option>
            <option value="Confirmed">Confirmed</option>
            <option value="Rejected">Rejected</option>
            <option value="Cancelled">Cancelled</option>
        </select>
        <span class="ab-search-count">@filteredBookings.Count() of @bookings.Count</span>
    </div>

    @if (isLoading)
    {
        <div class="ab-card">
            <div class="ab-loading">
                <div class="ab-spinner"></div>
                <div class="ab-loading-text">Loading bookings...</div>
            </div>
        </div>
    }
    else if (!bookings.Any())
    {
        <div class="ab-card">
            <div class="ab-empty">
                <div class="ab-empty-icon"><i class="bi bi-calendar-x"></i></div>
                <div class="ab-empty-title">No Bookings Found</div>
                <div class="ab-empty-text">There are no bookings in the system yet.</div>
            </div>
        </div>
    }
    else if (!filteredBookings.Any())
    {
        <div class="ab-card">
            <div class="ab-empty">
                <div class="ab-empty-icon"><i class="bi bi-search"></i></div>
                <div class="ab-empty-title">No Results</div>
                <div class="ab-empty-text">No bookings match your search criteria.</div>
            </div>
        </div>
    }
    else
    {
        <div class="ab-card">
            <div class="ab-card-header">
                <h5 class="ab-card-title"><i class="bi bi-table"></i> All Bookings</h5>
                <span class="ab-card-count">@filteredBookings.Count() records</span>
            </div>
            <div style="overflow-x:auto;">
                <table class="ab-table">
                    <thead>
                        <tr>
                            <th>ID</th>
                            <th>Hotel</th>
                            <th>Guest</th>
                            <th>Check-in</th>
                            <th>Check-out</th>
                            <th>Guests</th>
                            <th>Status</th>
                            <th>Booked On</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var booking in filteredBookings)
                        {
                            <tr>
                                <td><span class="ab-id">#@booking.Id</span></td>
                                <td>
                                    <div class="ab-hotel-cell">
                                        <div class="ab-hotel-icon"><i class="bi bi-building"></i></div>
                                        <div>
                                            <div class="ab-hotel-name">@(booking.Hotel?.Name ?? "N/A")</div>
                                            <div class="ab-hotel-sub">ID: @booking.HotelId</div>
                                        </div>
                                    </div>
                                </td>
                                <td><span class="ab-guest"><i class="bi bi-person"></i> @(booking.User?.FullName ?? "N/A")</span></td>
                                <td><span class="ab-date"><i class="bi bi-calendar-event"></i> @booking.StartDate.ToString("MMM dd, yyyy")</span></td>
                                <td><span class="ab-date"><i class="bi bi-calendar-event"></i> @booking.EndDate.ToString("MMM dd, yyyy")</span></td>
                                <td><span class="ab-badge ab-badge-guests"><i class="bi bi-people"></i> @booking.HeadCount</span></td>
                                <td>
                                    <span class="ab-badge @GetAbStatusBadge(booking.Status)">
                                        <i class="bi @GetStatusIcon(booking.Status)"></i> @booking.Status
                                    </span>
                                </td>
                                <td><span class="ab-date"><i class="bi bi-calendar3"></i> @booking.CreatedAt.ToString("MMM dd, yyyy")</span></td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }
</div>

@code {
    private bool isLoading = true;
    private List<Booking> bookings = new();
    private string searchTerm = "";
    private string statusFilter = "";

    private List<BreadcrumbItem> breadcrumbItems = new()
    {
        new BreadcrumbItem { Text = "Home", Url = "/" },
        new BreadcrumbItem { Text = "Admin Dashboard", Url = "/admin/dashboard" },
        new BreadcrumbItem { Text = "Bookings", IsActive = true }
    };

    private IEnumerable<Booking> filteredBookings => bookings.Where(b =>
    {
        if (!string.IsNullOrEmpty(statusFilter) && Enum.TryParse<BookingStatus>(statusFilter, out var s) && b.Status != s)
            return false;
        if (!string.IsNullOrWhiteSpace(searchTerm))
        {
            var term = searchTerm.Trim().ToLower();
            return b.Id.ToString().Contains(term)
                || (b.Hotel?.Name?.ToLower().Contains(term) ?? false)
                || (b.User?.FullName?.ToLower().Contains(term) ?? false);
        }
        return true;
    });

    protected override async Task OnInitializedAsync()
    {
        await LoadBookings();
    }

    private async Task LoadBookings()
    {
        isLoading = true;
        try
        {
            var allBookings = await UnitOfWork.Bookings.GetAllAsync();
            bookings = allBookings.OrderByDescending(b => b.CreatedAt).ToList();
        }
        catch (Exception)
        {
            // Handle error
        }
        finally
        {
            isLoading = false;
        }
    }

    private string GetAbStatusBadge(BookingStatus status)
    {
        return status switch
        {
            BookingStatus.Pending => "ab-badge-pending",
            BookingStatus.Confirmed => "ab-badge-confirmed",
            BookingStatus.Rejected => "ab-badge-rejected",
            BookingStatus.Cancelled => "ab-badge-cancelled",
            _ => "ab-badge-cancelled"
        };
    }

    private string GetStatusIcon(BookingStatus status)
    {
        return status switch
        {
            BookingStatus.Pending => "bi-clock-history",
            BookingStatus.Confirmed => "bi-check-circle",
            BookingStatus.Rejected => "bi-x-circle",
            BookingStatus.Cancelled => "bi-dash-circle",
            _ => "bi-circle"
        };
    }
}
