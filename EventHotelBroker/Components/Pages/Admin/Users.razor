@page "/admin/users"
@rendermode InteractiveServer
@using EventHotelBroker.Models
@using EventHotelBroker.Data
@using Microsoft.EntityFrameworkCore
@inject ApplicationDbContext DbContext

<PageTitle>Manage Users - Admin</PageTitle>

<link href="/css/admin-users.css?v=1" rel="stylesheet" />

<div class="au">
    <Breadcrumb Items="@breadcrumbItems" />

    <!-- Header -->
    <div class="au-header">
        <div>
            <h1 class="au-header-title"><i class="bi bi-people"></i> User Management</h1>
            <p class="au-header-sub">Manage all platform users and their roles</p>
        </div>
        <button class="au-btn au-btn-refresh" @onclick="LoadUsers">
            <i class="bi bi-arrow-clockwise"></i> Refresh
        </button>
    </div>

    <!-- Stats -->
    <div class="au-stats">
        <div class="au-stat">
            <div>
                <div class="au-stat-value">@users.Count</div>
                <div class="au-stat-label">Total Users</div>
            </div>
            <div class="au-stat-icon au-icon-terracotta"><i class="bi bi-people"></i></div>
        </div>
        <div class="au-stat">
            <div>
                <div class="au-stat-value">@users.Count(u => u.Role == "Admin")</div>
                <div class="au-stat-label">Admins</div>
            </div>
            <div class="au-stat-icon au-icon-charcoal"><i class="bi bi-shield-check"></i></div>
        </div>
        <div class="au-stat">
            <div>
                <div class="au-stat-value">@users.Count(u => u.Role == "HotelOwner")</div>
                <div class="au-stat-label">Hotel Owners</div>
            </div>
            <div class="au-stat-icon au-icon-teal"><i class="bi bi-building"></i></div>
        </div>
        <div class="au-stat">
            <div>
                <div class="au-stat-value">@users.Count(u => u.Role == "User")</div>
                <div class="au-stat-label">Clients</div>
            </div>
            <div class="au-stat-icon au-icon-bronze"><i class="bi bi-person"></i></div>
        </div>
    </div>

    <!-- Search & Filter -->
    <div class="au-search-bar">
        <div class="au-search-wrap">
            <i class="bi bi-search"></i>
            <input type="text" class="au-search-input" placeholder="Search by name, email, phone, or business..." @bind="searchTerm" @bind:event="oninput" />
        </div>
        <select class="au-filter-select" @bind="roleFilter" @bind:event="onchange">
            <option value="">All Roles</option>
            <option value="Admin">Admin</option>
            <option value="HotelOwner">Hotel Owner</option>
            <option value="ServiceProvider">Service Provider</option>
            <option value="User">Client</option>
        </select>
        <span class="au-search-count">@filteredUsers.Count() of @users.Count</span>
    </div>

    @if (isLoading)
    {
        <div class="au-card">
            <div class="au-loading">
                <div class="au-spinner"></div>
                <div class="au-loading-text">Loading users...</div>
            </div>
        </div>
    }
    else if (!users.Any())
    {
        <div class="au-card">
            <div class="au-empty">
                <div class="au-empty-icon"><i class="bi bi-people"></i></div>
                <div class="au-empty-title">No Users Found</div>
                <div class="au-empty-text">There are no users in the system yet.</div>
            </div>
        </div>
    }
    else if (!filteredUsers.Any())
    {
        <div class="au-card">
            <div class="au-empty">
                <div class="au-empty-icon"><i class="bi bi-search"></i></div>
                <div class="au-empty-title">No Results</div>
                <div class="au-empty-text">No users match your search criteria.</div>
            </div>
        </div>
    }
    else
    {
        <div class="au-card">
            <div class="au-card-header">
                <h5 class="au-card-title"><i class="bi bi-table"></i> All Users</h5>
                <span class="au-card-count">@filteredUsers.Count() records</span>
            </div>
            <div style="overflow-x:auto;">
                <table class="au-table">
                    <thead>
                        <tr>
                            <th>ID</th>
                            <th>User</th>
                            <th>Contact</th>
                            <th>Role</th>
                            <th>Business</th>
                            <th>Joined</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var user in filteredUsers)
                        {
                            <tr>
                                <td><span class="au-id">#@user.Id</span></td>
                                <td>
                                    <div class="au-user-cell">
                                        <div class="au-avatar">@user.FullName?.Substring(0, 1).ToUpper()</div>
                                        <div>
                                            <div class="au-user-name">@user.FullName</div>
                                            <div class="au-user-email">@user.Email</div>
                                        </div>
                                    </div>
                                </td>
                                <td>
                                    <span class="au-contact">
                                        <i class="bi bi-telephone"></i> @(user.PhoneNumber ?? "N/A")
                                    </span>
                                </td>
                                <td>
                                    <span class="au-badge @GetAuRoleBadge(user.Role)">
                                        <i class="bi @GetRoleIcon(user.Role)"></i> @user.Role
                                    </span>
                                </td>
                                <td>
                                    @if (!string.IsNullOrEmpty(user.BusinessName))
                                    {
                                        <span class="au-business"><i class="bi bi-briefcase"></i> @user.BusinessName</span>
                                    }
                                    else
                                    {
                                        <span class="au-business" style="color:#c4b99a;">-</span>
                                    }
                                </td>
                                <td>
                                    <span class="au-date"><i class="bi bi-calendar3"></i> @user.CreatedAt.ToString("MMM dd, yyyy")</span>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }
</div>

@code {
    private bool isLoading = true;
    private List<EventHotelBroker.Models.Users> users = new();
    private string searchTerm = "";
    private string roleFilter = "";

    private IEnumerable<EventHotelBroker.Models.Users> filteredUsers => users.Where(u =>
    {
        if (!string.IsNullOrEmpty(roleFilter) && u.Role != roleFilter)
            return false;
        if (!string.IsNullOrWhiteSpace(searchTerm))
        {
            var term = searchTerm.Trim().ToLower();
            return (u.FullName?.ToLower().Contains(term) ?? false)
                || (u.Email?.ToLower().Contains(term) ?? false)
                || (u.PhoneNumber?.ToLower().Contains(term) ?? false)
                || (u.BusinessName?.ToLower().Contains(term) ?? false);
        }
        return true;
    });

    private List<BreadcrumbItem> breadcrumbItems = new()
    {
        new BreadcrumbItem { Text = "Home", Url = "/" },
        new BreadcrumbItem { Text = "Admin Dashboard", Url = "/admin/dashboard" },
        new BreadcrumbItem { Text = "Users", IsActive = true }
    };

    protected override async Task OnInitializedAsync()
    {
        await LoadUsers();
    }

    private async Task LoadUsers()
    {
        isLoading = true;
        try
        {
            users = await DbContext.Users
                .OrderByDescending(u => u.CreatedAt)
                .ToListAsync();
        }
        catch (Exception)
        {
            // Handle error
        }
        finally
        {
            isLoading = false;
        }
    }

    private string GetRoleColor(string role)
    {
        return role switch
        {
            "Admin" => "danger",
            "HotelOwner" => "primary",
            "ServiceProvider" => "info",
            "User" => "secondary",
            _ => "secondary"
        };
    }

    private string GetAuRoleBadge(string role)
    {
        return role switch
        {
            "Admin" => "au-badge-admin",
            "HotelOwner" => "au-badge-owner",
            "ServiceProvider" => "au-badge-provider",
            "User" => "au-badge-user",
            _ => "au-badge-user"
        };
    }

    private string GetRoleIcon(string role)
    {
        return role switch
        {
            "Admin" => "bi-shield-check",
            "HotelOwner" => "bi-building",
            "ServiceProvider" => "bi-briefcase",
            "User" => "bi-person",
            _ => "bi-person"
        };
    }
}
