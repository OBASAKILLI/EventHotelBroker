@page "/admin/advertisement"
@rendermode InteractiveServer
@using EventHotelBroker.Services
@inject IEmailService EmailService
@inject ToastService ToastService

<PageTitle>Advertisement & Invites - Safari Vents</PageTitle>

<link href="/css/design-system.css" rel="stylesheet" />

<div class="ud-shell adv-shell">
    <div class="adv-container">
        <!-- Hero Section -->
        <div class="adv-hero">
            <div class="adv-hero-content">
                <h1 class="adv-title">Grow Our Network</h1>
                <p class="adv-subtitle">Invite prestigious hotels and spectacular event venues to join Safari Vents.</p>
            </div>
            <div class="adv-hero-icon">
                <i class="bi bi-megaphone-fill"></i>
            </div>
        </div>

        <!-- Dynamic Glass Form -->
        <div class="adv-card">
            <div class="adv-card-header">
                <div class="adv-icon-bg">
                    <i class="bi bi-envelope-paper-heart"></i>
                </div>
                <h3>Send an Explicit Invitation</h3>
                <p>An elegant, informative email will be dispatched to this address containing everything they need to seamlessly enroll their property as a partner on our platform.</p>
            </div>
            
            <div class="adv-card-body">
                <div class="adv-form-group">
                    <label class="adv-label">Partner Email Address</label>
                    <div class="adv-input-wrapper">
                        <i class="bi bi-envelope adv-input-icon"></i>
                        <input type="email" class="adv-input" @bind="targetEmail" placeholder="e.g. partnerships@grandhotel.com" />
                    </div>
                </div>

                <button class="adv-btn" @onclick="DispatchInvite" disabled="@isSending">
                    @if (isSending)
                    {
                        <span class="spinner-border spinner-border-sm me-2"></span>
                        <span>Dispatching...</span>
                    }
                    else
                    {
                        <span>Send Official Invite</span>
                        <i class="bi bi-send-fill ms-2"></i>
                    }
                </button>
            </div>
        </div>

        <div class="adv-preview-info">
            <i class="bi bi-info-circle me-2"></i> Invitations naturally bypass the standard registration and link directly to the premium hotel creation flow.
        </div>
    </div>
</div>

<style>
    /* ── Shell & Alignment ── */
    .adv-shell {
        display: flex;
        justify-content: center;
        align-items: flex-start;
        padding-top: 3rem !important;
        background: radial-gradient(circle at 10% 20%, rgba(200, 121, 65, 0.1) 0%, transparent 50%), radial-gradient(circle at 90% 80%, rgba(72, 140, 130, 0.1) 0%, transparent 50%), linear-gradient(135deg, #f5f3ef 0%, #ebe6dd 100%) !important;
    }
    
    .adv-container {
        width: 100%;
        max-width: 600px;
        position: relative;
    }

    /* ── Hero ── */
    .adv-hero {
        display: flex;
        align-items: center;
        justify-content: space-between;
        margin-bottom: 2rem;
        padding: 0 1rem;
    }
    .adv-title {
        font-size: 2rem;
        font-weight: 800;
        color: #2A2A2A;
        margin: 0 0 0.5rem 0;
        letter-spacing: -0.03em;
    }
    .adv-subtitle {
        font-size: 0.95rem;
        color: #8a8177;
        margin: 0;
        max-width: 400px;
        line-height: 1.5;
    }
    .adv-hero-icon {
        width: 64px;
        height: 64px;
        background: linear-gradient(135deg, #C87941 0%, #B86530 100%);
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.75rem;
        color: #fff;
        box-shadow: 0 12px 32px rgba(200, 121, 65, 0.3);
    }

    /* ── Glass Card ── */
    .adv-card {
        background: rgba(255, 255, 255, 0.9);
        backdrop-filter: blur(20px);
        border: 1px solid rgba(158, 139, 99, 0.15);
        border-radius: 20px;
        box-shadow: 0 24px 64px rgba(42, 42, 42, 0.08); /* Deep elegant drop shadow */
        overflow: hidden;
        margin-bottom: 1.5rem;
    }
    .adv-card-header {
        text-align: center;
        padding: 3rem 2rem 2rem;
        background: linear-gradient(180deg, rgba(255, 255, 255, 1) 0%, rgba(255, 255, 255, 0) 100%);
    }
    .adv-icon-bg {
        width: 72px;
        height: 72px;
        margin: 0 auto 1.5rem;
        background: rgba(158, 139, 99, 0.1);
        border-radius: 24px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 2rem;
        color: #9E8B63;
        transform: rotate(-5deg);
    }
    .adv-card-header h3 {
        font-size: 1.5rem;
        font-weight: 700;
        color: #2A2A2A;
        margin: 0 0 0.75rem 0;
    }
    .adv-card-header p {
        font-size: 0.875rem;
        color: #6c757d;
        line-height: 1.6;
        margin: 0;
    }

    .adv-card-body {
        padding: 0 2.5rem 3rem;
    }

    /* ── Forms ── */
    .adv-form-group {
        margin-bottom: 1.75rem;
    }
    .adv-label {
        display: block;
        font-size: 0.75rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.05em;
        color: #2A2A2A;
        margin-bottom: 0.75rem;
    }
    .adv-input-wrapper {
        position: relative;
        display: flex;
        align-items: center;
    }
    .adv-input-icon {
        position: absolute;
        left: 1.25rem;
        font-size: 1.1rem;
        color: #9E8B63;
    }
    .adv-input {
        width: 100%;
        padding: 1rem 1rem 1rem 3.5rem;
        font-size: 1rem;
        font-family: inherit;
        border: 2px solid rgba(158, 139, 99, 0.2);
        border-radius: 12px;
        background: #faf9f7;
        color: #2A2A2A;
        outline: none;
        transition: all 0.25s ease;
    }
    .adv-input::placeholder {
        color: #b5a98a;
    }
    .adv-input:focus {
        border-color: #C87941;
        background: #fff;
        box-shadow: 0 0 0 4px rgba(200, 121, 65, 0.1);
    }

    /* ── Button ── */
    .adv-btn {
        width: 100%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.1rem;
        font-weight: 700;
        font-family: inherit;
        padding: 1rem;
        border-radius: 12px;
        border: none;
        background: linear-gradient(135deg, #2A2A2A 0%, #1a1a1a 100%);
        color: #fff;
        cursor: pointer;
        transition: all 0.25s ease;
        box-shadow: 0 8px 24px rgba(42, 42, 42, 0.2);
    }
    .adv-btn:hover {
        transform: translateY(-2px);
        background: linear-gradient(135deg, #C87941 0%, #9E8B63 100%);
        box-shadow: 0 12px 32px rgba(200, 121, 65, 0.3);
    }
    .adv-btn:active {
        transform: translateY(0);
    }
    .adv-btn:disabled {
        opacity: 0.7;
        cursor: not-allowed;
        transform: none;
        background: #8a8177;
        box-shadow: none;
    }

    /* ── Info Bar ── */
    .adv-preview-info {
        text-align: center;
        font-size: 0.8rem;
        font-weight: 500;
        color: #8a8177;
        padding: 1rem;
    }

    /* ── Dark Mode Overrides ── */
    .dark-mode .adv-shell {
        background: radial-gradient(circle at 10% 20%, rgba(200, 121, 65, 0.05) 0%, transparent 50%), radial-gradient(circle at 90% 80%, rgba(72, 140, 130, 0.05) 0%, transparent 50%), linear-gradient(135deg, #0a0a0a 0%, #111111 100%) !important;
    }
    .dark-mode .adv-title { color: #f9fafb; }
    .dark-mode .adv-card {
        background: rgba(26, 26, 26, 0.95);
        border-color: rgba(255, 255, 255, 0.1);
        box-shadow: 0 24px 64px rgba(0, 0, 0, 0.4);
    }
    .dark-mode .adv-card-header {
        background: linear-gradient(180deg, rgba(26, 26, 26, 1) 0%, rgba(26, 26, 26, 0) 100%);
    }
    .dark-mode .adv-card-header h3 { color: #f9fafb; }
    .dark-mode .adv-card-header p { color: #9ca3af; }
    .dark-mode .adv-label { color: #f9fafb; }
    .dark-mode .adv-input {
        background: rgba(255, 255, 255, 0.05);
        border-color: rgba(255, 255, 255, 0.1);
        color: #f9fafb;
    }
    .dark-mode .adv-input:focus {
        background: rgba(255, 255, 255, 0.1);
        border-color: #C87941;
    }
    .dark-mode .adv-btn {
        background: linear-gradient(135deg, #C87941 0%, #9E8B63 100%);
    }

</style>

@code {
    private string targetEmail = "";
    private bool isSending = false;

    private async Task DispatchInvite()
    {
        if (string.IsNullOrWhiteSpace(targetEmail) || !targetEmail.Contains("@"))
        {
            ToastService.ShowWarning("Invalid Address", "Please provide a valid email address before dispatching the invitation.");
            return;
        }

        isSending = true;
        StateHasChanged();

        try
        {
            await EmailService.SendHotelInviteAsync(targetEmail);
            ToastService.ShowSuccess("Success", $"An exclusive invitation was dispatched to {targetEmail}");
            targetEmail = ""; // Clear form
        }
        catch (Exception ex)
        {
            ToastService.ShowError("Error", $"Failed to explicitly invite partner: {ex.Message}");
        }
        finally
        {
            isSending = false;
            StateHasChanged();
        }
    }
}
