@page "/admin/audit-logs"
@rendermode InteractiveServer
@using EventHotelBroker.Models
@using EventHotelBroker.Repositories
@inject IUnitOfWork UnitOfWork

<PageTitle>Audit Logs - Admin</PageTitle>

<link href="/css/admin-audit-logs.css?v=1" rel="stylesheet" />

<div class="al">
    <Breadcrumb Items="@breadcrumbItems" />

    <!-- Header -->
    <div class="al-header">
        <div>
            <h1 class="al-header-title"><i class="bi bi-journal-text"></i> Audit Logs</h1>
            <p class="al-header-sub">Track all system activity and user actions</p>
        </div>
        <button class="al-btn al-btn-refresh" @onclick="LoadLogs">
            <i class="bi bi-arrow-clockwise"></i> Refresh
        </button>
    </div>

    <!-- Stats -->
    <div class="al-stats">
        <div class="al-stat">
            <div>
                <div class="al-stat-value">@logs.Count</div>
                <div class="al-stat-label">Total Logs</div>
            </div>
            <div class="al-stat-icon al-icon-terracotta"><i class="bi bi-journal-text"></i></div>
        </div>
        <div class="al-stat">
            <div>
                <div class="al-stat-value">@logs.Count(l => l.ActionType?.ToLower() == "create")</div>
                <div class="al-stat-label">Creates</div>
            </div>
            <div class="al-stat-icon al-icon-teal"><i class="bi bi-plus-circle"></i></div>
        </div>
        <div class="al-stat">
            <div>
                <div class="al-stat-value">@logs.Count(l => l.ActionType?.ToLower() == "login")</div>
                <div class="al-stat-label">Logins</div>
            </div>
            <div class="al-stat-icon al-icon-bronze"><i class="bi bi-box-arrow-in-right"></i></div>
        </div>
        <div class="al-stat">
            <div>
                <div class="al-stat-value">@logs.Count(l => l.ActionType?.ToLower() == "delete")</div>
                <div class="al-stat-label">Deletes</div>
            </div>
            <div class="al-stat-icon al-icon-charcoal"><i class="bi bi-trash"></i></div>
        </div>
    </div>

    <!-- Search & Filter -->
    <div class="al-search-bar">
        <div class="al-search-wrap">
            <i class="bi bi-search"></i>
            <input type="text" class="al-search-input" placeholder="Search by user, action, details, or IP..." @bind="searchTerm" @bind:event="oninput" />
        </div>
        <select class="al-filter-select" @bind="actionFilter" @bind:event="onchange">
            <option value="">All Actions</option>
            <option value="create">Create</option>
            <option value="update">Update</option>
            <option value="delete">Delete</option>
            <option value="login">Login</option>
            <option value="logout">Logout</option>
        </select>
        <span class="al-search-count">@filteredLogs.Count() of @logs.Count</span>
    </div>

    @if (isLoading)
    {
        <div class="al-card">
            <div class="al-loading">
                <div class="al-spinner"></div>
                <div class="al-loading-text">Loading audit logs...</div>
            </div>
        </div>
    }
    else if (!logs.Any())
    {
        <div class="al-card">
            <div class="al-empty">
                <div class="al-empty-icon"><i class="bi bi-journal-x"></i></div>
                <div class="al-empty-title">No Audit Logs</div>
                <div class="al-empty-text">There are no audit logs recorded yet.</div>
            </div>
        </div>
    }
    else if (!filteredLogs.Any())
    {
        <div class="al-card">
            <div class="al-empty">
                <div class="al-empty-icon"><i class="bi bi-search"></i></div>
                <div class="al-empty-title">No Results</div>
                <div class="al-empty-text">No logs match your search criteria.</div>
            </div>
        </div>
    }
    else
    {
        <div class="al-card">
            <div class="al-card-header">
                <h5 class="al-card-title"><i class="bi bi-table"></i> Activity Log</h5>
                <span class="al-card-count">@filteredLogs.Count() entries</span>
            </div>
            <div style="overflow-x:auto;">
                <table class="al-table">
                    <thead>
                        <tr>
                            <th>ID</th>
                            <th>User</th>
                            <th>Action</th>
                            <th>Details</th>
                            <th>IP Address</th>
                            <th>Timestamp</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var log in filteredLogs)
                        {
                            <tr>
                                <td><span class="al-id">#@log.Id</span></td>
                                <td>
                                    @if (!string.IsNullOrEmpty(log.UserId))
                                    {
                                        <span class="al-user"><i class="bi bi-person"></i> @(log.User?.FullName ?? log.UserId)</span>
                                    }
                                    else
                                    {
                                        <span class="al-user al-user-system"><i class="bi bi-gear"></i> System</span>
                                    }
                                </td>
                                <td>
                                    <span class="al-badge @GetAlBadgeClass(log.ActionType)">
                                        <i class="bi @GetActionIcon(log.ActionType)"></i> @log.ActionType
                                    </span>
                                </td>
                                <td>
                                    @if (!string.IsNullOrEmpty(log.Details))
                                    {
                                        <div class="al-details">@log.Details</div>
                                    }
                                </td>
                                <td>
                                    @if (!string.IsNullOrEmpty(log.IpAddress))
                                    {
                                        <span class="al-ip"><i class="bi bi-globe"></i> @log.IpAddress</span>
                                    }
                                </td>
                                <td>
                                    <div class="al-time"><i class="bi bi-clock"></i> @log.CreatedAt.ToString("MMM dd, yyyy")</div>
                                    <div class="al-time-ago">@log.CreatedAt.ToString("HH:mm:ss")</div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }
</div>

@code {
    private bool isLoading = true;
    private List<AuditLog> logs = new();
    private string searchTerm = "";
    private string actionFilter = "";

    private List<BreadcrumbItem> breadcrumbItems = new()
    {
        new BreadcrumbItem { Text = "Home", Url = "/" },
        new BreadcrumbItem { Text = "Admin Dashboard", Url = "/admin/dashboard" },
        new BreadcrumbItem { Text = "Audit Logs", IsActive = true }
    };

    private IEnumerable<AuditLog> filteredLogs => logs.Where(l =>
    {
        if (!string.IsNullOrEmpty(actionFilter) && !(l.ActionType?.ToLower() == actionFilter))
            return false;
        if (!string.IsNullOrWhiteSpace(searchTerm))
        {
            var term = searchTerm.Trim().ToLower();
            return (l.UserId?.ToLower().Contains(term) ?? false)
                || (l.User?.FullName?.ToLower().Contains(term) ?? false)
                || (l.ActionType?.ToLower().Contains(term) ?? false)
                || (l.Details?.ToLower().Contains(term) ?? false)
                || (l.IpAddress?.ToLower().Contains(term) ?? false)
                || l.Id.ToString().Contains(term);
        }
        return true;
    });

    protected override async Task OnInitializedAsync()
    {
        await LoadLogs();
    }

    private async Task LoadLogs()
    {
        isLoading = true;
        try
        {
            var allLogs = await UnitOfWork.AuditLogs.GetAllAsync();
            logs = allLogs.OrderByDescending(l => l.CreatedAt).Take(100).ToList();
        }
        catch (Exception)
        {
            // Handle error
        }
        finally
        {
            isLoading = false;
        }
    }

    private string GetAlBadgeClass(string action)
    {
        return action?.ToLower() switch
        {
            "create" => "al-badge-create",
            "update" => "al-badge-update",
            "delete" => "al-badge-delete",
            "login" => "al-badge-login",
            "logout" => "al-badge-logout",
            _ => "al-badge-default"
        };
    }

    private string GetActionIcon(string action)
    {
        return action?.ToLower() switch
        {
            "create" => "bi-plus-circle",
            "update" => "bi-pencil",
            "delete" => "bi-trash",
            "login" => "bi-box-arrow-in-right",
            "logout" => "bi-box-arrow-right",
            _ => "bi-circle"
        };
    }
}
