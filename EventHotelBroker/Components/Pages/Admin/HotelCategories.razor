@page "/admin/hotel-categories"
@rendermode InteractiveServer
@using EventHotelBroker.Models
@using EventHotelBroker.Data
@using Microsoft.EntityFrameworkCore
@inject ApplicationDbContext DbContext

<PageTitle>Hotel Categories - Admin</PageTitle>

<div class="hc">
    <Breadcrumb Items="@breadcrumbItems" />

    <div class="hc-header" style="display:flex;align-items:flex-start;justify-content:space-between;gap:1rem;flex-wrap:wrap;">
        <div>
            <h1 style="margin:0;"><i class="bi bi-tags"></i> Hotel Categories</h1>
            <p style="margin:0.25rem 0 0;color:#6c757d;">Manage service fees by hotel category</p>
        </div>
        <div style="display:flex;gap:0.5rem;">
            <button class="btn btn-outline-secondary" @onclick="LoadData" disabled="@isLoading">
                <i class="bi bi-arrow-clockwise"></i> Refresh
            </button>
            <button class="btn btn-primary" @onclick="NewCategory">
                <i class="bi bi-plus-lg"></i> New Category
            </button>
        </div>
    </div>

    @if (!string.IsNullOrWhiteSpace(errorMessage))
    {
        <div class="alert alert-danger mt-3">@errorMessage</div>
    }

    @if (!string.IsNullOrWhiteSpace(successMessage))
    {
        <div class="alert alert-success mt-3">@successMessage</div>
    }

    <div class="mt-3" style="display:flex;align-items:center;justify-content:space-between;gap:0.75rem;flex-wrap:wrap;">
        <div style="display:flex;align-items:center;gap:0.5rem;">
            <i class="bi bi-search"></i>
            <input class="form-control" style="min-width:260px;" placeholder="Search by name or rating..." @bind="searchTerm" @bind:event="oninput" />
        </div>
        <label style="display:flex;align-items:center;gap:0.5rem;margin:0;">
            <input type="checkbox" class="form-check-input" @bind="showInactive" />
            <span>Show inactive</span>
        </label>
    </div>

    @if (isLoading)
    {
        <div class="card mt-3">
            <div class="card-body">Loading categories...</div>
        </div>
    }
    else
    {
        <div class="card mt-3">
            <div class="table-responsive">
                <table class="table table-striped mb-0">
                    <thead>
                        <tr>
                            <th style="width:80px;">ID</th>
                            <th>Name</th>
                            <th>Rating</th>
                            <th style="width:180px;">Service Fee (KES)</th>
                            <th>Status</th>
                            <th style="width:220px;">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (!FilteredCategories.Any())
                        {
                            <tr>
                                <td colspan="6" class="text-center" style="padding:1rem;">No categories found.</td>
                            </tr>
                        }
                        else
                        {
                            @foreach (var c in FilteredCategories)
                            {
                                <tr>
                                    <td>#@c.Id</td>
                                    <td>
                                        <div style="font-weight:600;">@c.Name</div>
                                        @if (!string.IsNullOrWhiteSpace(c.Description))
                                        {
                                            <div style="color:#6c757d;font-size:0.875rem;">@c.Description</div>
                                        }
                                    </td>
                                    <td>@c.Rating</td>
                                    <td>@c.ServiceFee.ToString("N0")</td>
                                    <td>
                                        @if (c.IsActive)
                                        {
                                            <span class="badge bg-success">Active</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-secondary">Inactive</span>
                                        }
                                    </td>
                                    <td>
                                        <div style="display:flex;gap:0.5rem;flex-wrap:wrap;">
                                            <button class="btn btn-sm btn-outline-primary" @onclick="() => EditCategory(c)">
                                                <i class="bi bi-pencil"></i> Edit
                                            </button>

                                            @if (c.IsActive)
                                            {
                                                <button class="btn btn-sm btn-outline-warning" @onclick="() => DeactivateCategory(c)">
                                                    <i class="bi bi-slash-circle"></i> Deactivate
                                                </button>
                                            }
                                            else
                                            {
                                                <button class="btn btn-sm btn-outline-success" @onclick="() => ActivateCategory(c)">
                                                    <i class="bi bi-check2-circle"></i> Activate
                                                </button>
                                            }
                                        </div>
                                    </td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }

    @if (showForm)
    {
        <div class="modal fade show" style="display:block; background: rgba(0,0,0,0.5);" tabindex="-1">
            <div class="modal-dialog modal-lg">
                <div class="modal-content">
                    <div class="modal-header">
                        <h5 class="modal-title">
                            @if (editingId == 0)
                            {
                                <span><i class="bi bi-plus-lg"></i> New Category</span>
                            }
                            else
                            {
                                <span><i class="bi bi-pencil"></i> Edit Category</span>
                            }
                        </h5>
                        <button type="button" class="btn-close" @onclick="CloseForm"></button>
                    </div>
                    <div class="modal-body">
                        <EditForm Model="formModel" OnValidSubmit="SaveCategory">
                            <DataAnnotationsValidator />
                            <ValidationSummary />

                            <div class="row g-3">
                                <div class="col-md-6">
                                    <label class="form-label">Name</label>
                                    <InputText class="form-control" @bind-Value="formModel.Name" />
                                </div>
                                <div class="col-md-6">
                                    <label class="form-label">Rating (e.g. 5-Star)</label>
                                    <InputText class="form-control" @bind-Value="formModel.Rating" />
                                </div>
                                <div class="col-md-6">
                                    <label class="form-label">Service Fee (KES)</label>
                                    <InputNumber class="form-control" @bind-Value="formModel.ServiceFee" />
                                </div>
                                <div class="col-md-6">
                                    <label class="form-label">Active</label>
                                    <div class="form-check" style="margin-top:0.5rem;">
                                        <InputCheckbox class="form-check-input" @bind-Value="formModel.IsActive" />
                                        <label class="form-check-label">Enabled</label>
                                    </div>
                                </div>
                                <div class="col-12">
                                    <label class="form-label">Description</label>
                                    <InputTextArea class="form-control" @bind-Value="formModel.Description" rows="3" />
                                </div>
                            </div>

                            <div class="mt-4" style="display:flex;justify-content:flex-end;gap:0.5rem;">
                                <button type="button" class="btn btn-outline-secondary" @onclick="CloseForm">Cancel</button>
                                <button type="submit" class="btn btn-primary" disabled="@isSaving">
                                    @if (isSaving)
                                    {
                                        <span>Saving...</span>
                                    }
                                    else
                                    {
                                        <span>Save</span>
                                    }
                                </button>
                            </div>
                        </EditForm>
                    </div>
                </div>
            </div>
        </div>
        <div class="modal-backdrop fade show"></div>
    }
</div>

@code {
    private bool isLoading = true;
    private bool isSaving = false;

    private List<HotelCategory> categories = new();
    private string searchTerm = "";
    private bool showInactive = false;

    private string? errorMessage;
    private string? successMessage;

    private bool showForm = false;
    private int editingId = 0;
    private HotelCategory formModel = new();

    private List<BreadcrumbItem> breadcrumbItems = new()
    {
        new BreadcrumbItem { Text = "Home", Url = "/" },
        new BreadcrumbItem { Text = "Admin Dashboard", Url = "/admin/dashboard" },
        new BreadcrumbItem { Text = "Hotel Categories", IsActive = true }
    };

    private IEnumerable<HotelCategory> FilteredCategories => categories.Where(c =>
    {
        if (!showInactive && !c.IsActive) return false;

        if (!string.IsNullOrWhiteSpace(searchTerm))
        {
            var term = searchTerm.Trim().ToLower();
            return (c.Name?.ToLower().Contains(term) ?? false)
                || (c.Rating?.ToLower().Contains(term) ?? false);
        }

        return true;
    });

    protected override async Task OnInitializedAsync()
    {
        await LoadData();
    }

    private async Task LoadData()
    {
        try
        {
            isLoading = true;
            errorMessage = null;
            successMessage = null;

            categories = await DbContext.HotelCategories
                .OrderBy(c => c.ServiceFee)
                .ThenBy(c => c.Name)
                .ToListAsync();
        }
        catch (Exception ex)
        {
            errorMessage = $"Failed to load categories: {ex.Message}";
        }
        finally
        {
            isLoading = false;
        }
    }

    private void NewCategory()
    {
        editingId = 0;
        formModel = new HotelCategory
        {
            IsActive = true,
            CreatedAt = DateTime.UtcNow
        };
        showForm = true;
    }

    private void EditCategory(HotelCategory c)
    {
        editingId = c.Id;
        formModel = new HotelCategory
        {
            Id = c.Id,
            Name = c.Name,
            Rating = c.Rating,
            ServiceFee = c.ServiceFee,
            Description = c.Description,
            IsActive = c.IsActive,
            CreatedAt = c.CreatedAt
        };
        showForm = true;
    }

    private void CloseForm()
    {
        showForm = false;
        editingId = 0;
        formModel = new HotelCategory();
    }

    private async Task SaveCategory()
    {
        try
        {
            isSaving = true;
            errorMessage = null;
            successMessage = null;

            if (editingId == 0)
            {
                var entity = new HotelCategory
                {
                    Name = formModel.Name?.Trim() ?? "",
                    Rating = formModel.Rating?.Trim() ?? "",
                    ServiceFee = formModel.ServiceFee,
                    Description = formModel.Description,
                    IsActive = formModel.IsActive,
                    CreatedAt = DateTime.UtcNow
                };

                DbContext.HotelCategories.Add(entity);
                await DbContext.SaveChangesAsync();
                successMessage = "Category created.";
            }
            else
            {
                var entity = await DbContext.HotelCategories.FirstOrDefaultAsync(x => x.Id == editingId);
                if (entity == null)
                {
                    errorMessage = "Category not found.";
                    return;
                }

                entity.Name = formModel.Name?.Trim() ?? "";
                entity.Rating = formModel.Rating?.Trim() ?? "";
                entity.ServiceFee = formModel.ServiceFee;
                entity.Description = formModel.Description;
                entity.IsActive = formModel.IsActive;

                await DbContext.SaveChangesAsync();
                successMessage = "Category updated.";
            }

            showForm = false;
            await LoadData();
        }
        catch (Exception ex)
        {
            errorMessage = $"Save failed: {ex.Message}";
        }
        finally
        {
            isSaving = false;
        }
    }

    private async Task DeactivateCategory(HotelCategory c)
    {
        try
        {
            errorMessage = null;
            successMessage = null;

            var entity = await DbContext.HotelCategories.FirstOrDefaultAsync(x => x.Id == c.Id);
            if (entity == null)
            {
                errorMessage = "Category not found.";
                return;
            }

            entity.IsActive = false;
            await DbContext.SaveChangesAsync();
            successMessage = "Category deactivated.";
            await LoadData();
        }
        catch (Exception ex)
        {
            errorMessage = $"Action failed: {ex.Message}";
        }
    }

    private async Task ActivateCategory(HotelCategory c)
    {
        try
        {
            errorMessage = null;
            successMessage = null;

            var entity = await DbContext.HotelCategories.FirstOrDefaultAsync(x => x.Id == c.Id);
            if (entity == null)
            {
                errorMessage = "Category not found.";
                return;
            }

            entity.IsActive = true;
            await DbContext.SaveChangesAsync();
            successMessage = "Category activated.";
            await LoadData();
        }
        catch (Exception ex)
        {
            errorMessage = $"Action failed: {ex.Message}";
        }
    }
}
