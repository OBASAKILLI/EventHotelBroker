@page "/admin/hotels"
@rendermode InteractiveServer
@using EventHotelBroker.Models
@using EventHotelBroker.Services
@inject IHotelService HotelService
@inject NavigationManager NavigationManager

<PageTitle>Manage Hotels - Admin</PageTitle>

<link href="/css/admin-hotels.css?v=1" rel="stylesheet" />

<div class="ah">
    <Breadcrumb Items="@breadcrumbItems" />

    <!-- Header -->
    <div class="ah-header">
        <div>
            <h1 class="ah-header-title"><i class="bi bi-building"></i> Hotel Management</h1>
            <p class="ah-header-sub">Review and manage all hotel listings</p>
        </div>
        <button class="ah-btn ah-btn-refresh" @onclick="LoadHotels">
            <i class="bi bi-arrow-clockwise"></i> Refresh
        </button>
    </div>

    <!-- Stats -->
    <div class="ah-stats">
        <div class="ah-stat">
            <div>
                <div class="ah-stat-value">@allHotels.Count()</div>
                <div class="ah-stat-label">Total Hotels</div>
            </div>
            <div class="ah-stat-icon ah-icon-terracotta"><i class="bi bi-building"></i></div>
        </div>
        <div class="ah-stat">
            <div>
                <div class="ah-stat-value">@pendingCount</div>
                <div class="ah-stat-label">Pending</div>
            </div>
            <div class="ah-stat-icon ah-icon-bronze"><i class="bi bi-clock-history"></i></div>
        </div>
        <div class="ah-stat">
            <div>
                <div class="ah-stat-value">@approvedCount</div>
                <div class="ah-stat-label">Approved</div>
            </div>
            <div class="ah-stat-icon ah-icon-teal"><i class="bi bi-check-circle"></i></div>
        </div>
        <div class="ah-stat">
            <div>
                <div class="ah-stat-value">@rejectedCount</div>
                <div class="ah-stat-label">Rejected</div>
            </div>
            <div class="ah-stat-icon ah-icon-charcoal"><i class="bi bi-x-circle"></i></div>
        </div>
    </div>

    <!-- Filter Tabs -->
    <div class="ah-tabs">
        <span class="ah-tab @(filterStatus == "all" ? "active" : "")" @onclick="@(() => SetFilter("all"))"><i class="bi bi-grid"></i> All</span>
        <span class="ah-tab @(filterStatus == "pending" ? "active" : "")" @onclick="@(() => SetFilter("pending"))"><i class="bi bi-clock-history"></i> Pending</span>
        <span class="ah-tab @(filterStatus == "approved" ? "active" : "")" @onclick="@(() => SetFilter("approved"))"><i class="bi bi-check-circle"></i> Approved</span>
        <span class="ah-tab @(filterStatus == "rejected" ? "active" : "")" @onclick="@(() => SetFilter("rejected"))"><i class="bi bi-x-circle"></i> Rejected</span>
    </div>

    <!-- Search -->
    <div class="ah-search-bar">
        <div class="ah-search-wrap">
            <i class="bi bi-search"></i>
            <input type="text" class="ah-search-input" placeholder="Search by name, city, country, or owner..." @bind="searchTerm" @bind:event="oninput" />
        </div>
        <select class="ah-filter-select" @bind="categoryFilter" @bind:event="onchange">
            <option value="">All Categories</option>
            <option value="Hotel">Hotels</option>
            <option value="Airbnb">Airbnb</option>
            <option value="Restaurant">Restaurants</option>
            <option value="Venue">Venues</option>
            <option value="Resort">Resorts</option>
            <option value="Lodge">Lodges</option>
            <option value="Guest House">Guest Houses</option>
            <option value="Apartment">Apartments</option>
        </select>
        <span class="ah-search-count">@searchedHotels.Count() of @filteredHotels.Count()</span>
    </div>

    @if (isLoading)
    {
        <div class="ah-card">
            <div class="ah-loading">
                <div class="ah-spinner"></div>
                <div class="ah-loading-text">Loading hotels...</div>
            </div>
        </div>
    }
    else if (!searchedHotels.Any())
    {
        <div class="ah-card">
            <div class="ah-empty">
                <div class="ah-empty-icon"><i class="bi bi-inbox"></i></div>
                <div class="ah-empty-title">No Hotels Found</div>
                <div class="ah-empty-text">There are no hotels matching your criteria.</div>
            </div>
        </div>
    }
    else
    {
        <div class="ah-card">
            <div class="ah-card-header">
                <h5 class="ah-card-title"><i class="bi bi-table"></i> Hotel Listings</h5>
                <span class="ah-card-count">@searchedHotels.Count() records</span>
            </div>
            <div style="overflow-x:auto;">
                <table class="ah-table">
                    <thead>
                        <tr>
                            <th>ID</th>
                            <th>Hotel</th>
                            <th>Location</th>
                            <th>Owner</th>
                            <th>Capacity</th>
                            <th>Price/Night</th>
                            <th>Status</th>
                            <th>Created</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var hotel in searchedHotels)
                        {
                            <tr>
                                <td><span class="ah-id">#@hotel.Id</span></td>
                                <td>
                                    <div class="ah-hotel-cell">
                                        <div class="ah-hotel-icon"><i class="bi bi-building"></i></div>
                                        <div>
                                            <div class="ah-hotel-name">@hotel.Name</div>
                                            @if (hotel.IsPublished)
                                            {
                                                <div class="ah-hotel-pub"><i class="bi bi-globe2"></i> Published</div>
                                            }
                                        </div>
                                    </div>
                                </td>
                                <td><span class="ah-loc"><i class="bi bi-geo-alt"></i> @hotel.City, @hotel.Country</span></td>
                                <td><span class="ah-owner">@(hotel.Owner?.FullName ?? "N/A")</span></td>
                                <td><span class="ah-badge ah-badge-capacity"><i class="bi bi-people"></i> @hotel.Capacity</span></td>
                                <td>
                                    <div class="ah-price">@hotel.Currency @hotel.PricePerNight.ToString("N0")</div>
                                    <div class="ah-price-sub">per night</div>
                                </td>
                                <td>
                                    @if (hotel.IsApproved)
                                    {
                                        <span class="ah-badge ah-badge-approved"><i class="bi bi-check-circle"></i> Approved</span>
                                    }
                                    else if (hotel.IsPublished)
                                    {
                                        <span class="ah-badge ah-badge-pending"><i class="bi bi-clock-history"></i> Pending Review</span>
                                    }
                                    else
                                    {
                                        <span class="ah-badge ah-badge-rejected"><i class="bi bi-file-earmark"></i> Draft</span>
                                    }
                                </td>
                                <td><span class="ah-date"><i class="bi bi-calendar3"></i> @hotel.CreatedAt.ToString("MMM dd, yyyy")</span></td>
                                <td>
                                    <div class="ah-actions">
                                        <button class="ah-btn ah-btn-sm ah-btn-view" @onclick="() => ViewHotel(hotel.Id)" title="View">
                                            <i class="bi bi-eye"></i>
                                        </button>
                                        @if (!hotel.IsApproved)
                                        {
                                            <button class="ah-btn ah-btn-sm ah-btn-approve" @onclick="() => ApproveHotel(hotel.Id)" title="Approve">
                                                <i class="bi bi-check-lg"></i>
                                            </button>
                                        }
                                        @if (hotel.IsApproved || hotel.IsPublished)
                                        {
                                            <button class="ah-btn ah-btn-sm ah-btn-reject" @onclick="() => RejectHotel(hotel.Id)" title="Reject">
                                                <i class="bi bi-x-lg"></i>
                                            </button>
                                        }
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }

    @if (!string.IsNullOrEmpty(message))
    {
        <div class="ah-toast @(messageType == "success" ? "ah-toast-success" : "ah-toast-error")">
            <i class="bi @(messageType == "success" ? "bi-check-circle-fill" : "bi-exclamation-triangle-fill")"></i>
            <span>@message</span>
            <button class="ah-toast-close" @onclick="() => message = null"><i class="bi bi-x-lg"></i></button>
        </div>
    }
</div>

@code {
    private bool isLoading = true;
    private List<Hotel> allHotels = new();
    private IEnumerable<Hotel> filteredHotels = new List<Hotel>();
    private string filterStatus = "all";
    private string searchTerm = "";
    private string categoryFilter = "";
    private int pendingCount = 0;

    private List<BreadcrumbItem> breadcrumbItems = new()
    {
        new BreadcrumbItem { Text = "Home", Url = "/" },
        new BreadcrumbItem { Text = "Admin Dashboard", Url = "/admin/dashboard" },
        new BreadcrumbItem { Text = "Hotels", IsActive = true }
    };

    private IEnumerable<Hotel> searchedHotels => filteredHotels.Where(h =>
    {
        if (!string.IsNullOrWhiteSpace(searchTerm))
        {
            var term = searchTerm.Trim().ToLower();
            return (h.Name?.ToLower().Contains(term) ?? false)
                || (h.City?.ToLower().Contains(term) ?? false)
                || (h.Country?.ToLower().Contains(term) ?? false)
                || (h.Owner?.FullName?.ToLower().Contains(term) ?? false);
        }
        if (!string.IsNullOrWhiteSpace(categoryFilter))
        {
            return h.Category == categoryFilter;
        }
        return true;
    });
    private int approvedCount = 0;
    private int rejectedCount = 0;
    private string? message;
    private string messageType = "success";

    protected override async Task OnInitializedAsync()
    {
        await LoadHotels();
    }

    private async Task LoadHotels()
    {
        isLoading = true;
        try
        {
            allHotels = (await HotelService.GetAllHotelsAsync()).ToList();
            pendingCount = allHotels.Count(h => !h.IsApproved && h.IsPublished);
            approvedCount = allHotels.Count(h => h.IsApproved);
            rejectedCount = allHotels.Count(h => !h.IsApproved && !h.IsPublished);
            ApplyFilter();
        }
        catch (Exception ex)
        {
            ShowMessage($"Error loading hotels: {ex.Message}", "error");
        }
        finally
        {
            isLoading = false;
        }
    }

    private void SetFilter(string status)
    {
        filterStatus = status;
        ApplyFilter();
    }

    private void ApplyFilter()
    {
        filteredHotels = filterStatus switch
        {
            "pending" => allHotels.Where(h => !h.IsApproved && h.IsPublished),
            "approved" => allHotels.Where(h => h.IsApproved),
            "rejected" => allHotels.Where(h => !h.IsApproved && !h.IsPublished),
            _ => allHotels
        };
        
        // Apply category filter
        if (!string.IsNullOrWhiteSpace(categoryFilter))
        {
            filteredHotels = filteredHotels.Where(h => h.Category == categoryFilter);
        }
    }

    private void ViewHotel(int id)
    {
        NavigationManager.NavigateTo($"/hotels/{id}");
    }

    private async Task ApproveHotel(int id)
    {
        try
        {
            var hotel = allHotels.FirstOrDefault(h => h.Id == id);
            var result = await HotelService.ApproveHotelAsync(id);
            if (result)
            {
                ShowMessage($"Hotel '{hotel?.Name}' has been approved successfully! It is now visible to all users.", "success");
                await LoadHotels();
            }
            else
            {
                ShowMessage("Failed to approve hotel.", "error");
            }
        }
        catch (Exception ex)
        {
            ShowMessage($"Error: {ex.Message}", "error");
        }
    }

    private async Task RejectHotel(int id)
    {
        try
        {
            var hotel = allHotels.FirstOrDefault(h => h.Id == id);
            var result = await HotelService.RejectHotelAsync(id);
            if (result)
            {
                ShowMessage($"Hotel '{hotel?.Name}' has been rejected. The owner will be notified.", "success");
                await LoadHotels();
            }
            else
            {
                ShowMessage("Failed to reject hotel.", "error");
            }
        }
        catch (Exception ex)
        {
            ShowMessage($"Error: {ex.Message}", "error");
        }
    }

    private async void ShowMessage(string msg, string type)
    {
        message = msg;
        messageType = type;
        StateHasChanged();
        
        // Auto-dismiss after 5 seconds
        await Task.Delay(5000);
        message = null;
        StateHasChanged();
    }
}
