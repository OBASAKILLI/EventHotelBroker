@page "/search"
@using EventHotelBroker.Models
@using EventHotelBroker.Services
@using Microsoft.AspNetCore.Components.Authorization
@inject IHotelService HotelService
@inject NavigationManager Navigation
@inject AuthenticationStateProvider AuthStateProvider
@inject IJSRuntime JSRuntime
@rendermode InteractiveServer

<PageTitle>Search Hotels - EventHotelBroker</PageTitle>

<div class="search-page">
    <!-- Search Header -->
    <div class="search-header">
        <div class="container-fluid px-4">
            <!-- Navigation breadcrumb for unauthenticated users -->
            @if (!isAuthenticated)
            {
                <div style="margin-bottom: 12px;">
                    <a href="/" style="display: inline-flex; align-items: center; gap: 6px; color: rgba(255,255,255,0.8); text-decoration: none; font-size: 0.88rem; font-weight: 500; transition: color 0.2s;"
                       onmouseover="this.style.color='white'" onmouseout="this.style.color='rgba(255,255,255,0.8)'">
                        <i class="bi bi-arrow-left"></i> Back to Home
                    </a>
                    <span style="color: rgba(255,255,255,0.4); margin: 0 10px;">|</span>
                    <a href="/login" style="display: inline-flex; align-items: center; gap: 6px; color: rgba(255,255,255,0.8); text-decoration: none; font-size: 0.88rem; font-weight: 500; transition: color 0.2s;"
                       onmouseover="this.style.color='white'" onmouseout="this.style.color='rgba(255,255,255,0.8)'">
                        <i class="bi bi-box-arrow-in-right"></i> Log in to book
                    </a>
                </div>
            }
            <div class="d-flex align-items-center">
                <button class="btn-back-circle me-3" @onclick="GoBack" title="Go Back">
                    <i class="bi bi-arrow-left"></i>
                </button>
                <div>
                    <h1 class="search-title mb-0">
                        <i class="bi bi-search me-2"></i>Discover Hotels
                    </h1>
                    <p class="search-subtitle">Find the perfect venue for your next event</p>
                </div>
            </div>
        </div>
    </div>

    <div class="container-fluid px-4 py-4">
        <div class="row g-4">
            <!-- Advanced Filters Sidebar (narrowed) -->
            <div class="col-lg-2">
                <div class="filter-panel">
                    <div class="d-flex justify-content-between align-items-center mb-4">
                        <h5 class="mb-0" style="font-weight: 700;">
                            <i class="bi bi-funnel me-2"></i>Filters
                        </h5>
                        <button type="button" class="btn-system-ghost btn-system-sm" @onclick="ClearFilters">
                            <i class="bi bi-x-circle me-1"></i>Clear
                        </button>
                    </div>

                    <!-- Search Keyword -->
                    <div class="filter-section">
                        <div class="filter-section-title">
                            <i class="bi bi-search"></i> Search
                        </div>
                        <input type="text" class="form-control-system" @bind="searchFilters.Keyword" 
                               placeholder="Search by name..." @bind:event="oninput" @bind:after="HandleSearch" />
                    </div>

                    <!-- Location -->
                    <div class="filter-section">
                        <div class="filter-section-title">
                            <i class="bi bi-geo-alt"></i> Location
                        </div>
                        <input type="text" class="form-control-system" @bind="searchFilters.City" 
                               placeholder="City or region" @bind:event="oninput" @bind:after="HandleSearch" />
                    </div>

                    <!-- Price Range -->
                    <div class="filter-section">
                        <div class="filter-section-title">
                            <i class="bi bi-currency-dollar"></i> Price Range
                        </div>
                        <div class="filter-range">
                            <input type="range" min="0" max="100000" step="1000" 
                                   @bind="searchFilters.MaxPrice" @bind:event="oninput" 
                                   @bind:after="HandleSearch" />
                            <div class="filter-range-inputs">
                                <input type="number" class="form-control-system" 
                                       @bind="searchFilters.MinPrice" placeholder="Min" 
                                       @bind:event="oninput" @bind:after="HandleSearch" />
                                <span class="filter-range-separator">-</span>
                                <input type="number" class="form-control-system" 
                                       @bind="searchFilters.MaxPrice" placeholder="Max" 
                                       @bind:event="oninput" @bind:after="HandleSearch" />
                            </div>
                            <small class="text-system-secondary mt-2 d-block">
                                KES @((searchFilters.MinPrice ?? 0).ToString("N0")) - @((searchFilters.MaxPrice ?? 100000).ToString("N0"))
                            </small>
                        </div>
                    </div>

                    <!-- Capacity Range -->
                    <div class="filter-section">
                        <div class="filter-section-title">
                            <i class="bi bi-people"></i> Guest Capacity
                        </div>
                        <div class="filter-range">
                            <input type="range" min="0" max="1000" step="10" 
                                   @bind="searchFilters.MaxCapacity" @bind:event="oninput" 
                                   @bind:after="HandleSearch" />
                            <div class="filter-range-inputs">
                                <input type="number" class="form-control-system" 
                                       @bind="searchFilters.MinCapacity" placeholder="Min" 
                                       @bind:event="oninput" @bind:after="HandleSearch" />
                                <span class="filter-range-separator">-</span>
                                <input type="number" class="form-control-system" 
                                       @bind="searchFilters.MaxCapacity" placeholder="Max" 
                                       @bind:event="oninput" @bind:after="HandleSearch" />
                            </div>
                            <small class="text-system-secondary mt-2 d-block">
                                @((searchFilters.MinCapacity ?? 0)) - @((searchFilters.MaxCapacity ?? 1000)) guests
                            </small>
                        </div>
                    </div>

                    <!-- Category -->
                    <div class="filter-section">
                        <div class="filter-section-title">
                            <i class="bi bi-tag"></i> Category
                        </div>
                        <select class="form-control-system" @bind="searchFilters.Category" @bind:event="onchange" @bind:after="HandleSearch">
                            <option value="">All Categories</option>
                            <option value="Hotel">Hotels</option>
                            <option value="Airbnb">Airbnb</option>
                            <option value="Restaurant">Restaurants</option>
                            <option value="Venue">Venues</option>
                            <option value="Resort">Resorts</option>
                            <option value="Lodge">Lodges</option>
                            <option value="Guest House">Guest Houses</option>
                            <option value="Apartment">Apartments</option>
                        </select>
                    </div>

                    <!-- Amenities -->
                    <div class="filter-section">
                        <div class="filter-section-title">
                            <i class="bi bi-star"></i> Amenities
                        </div>
                        <div class="filter-checkbox-group">
                            <label class="filter-checkbox-item">
                                <input type="checkbox" @bind="searchFilters.HasWifi" @bind:after="HandleSearch" />
                                <span class="filter-checkbox-label">WiFi</span>
                                <span class="filter-checkbox-count">@GetAmenityCount("WiFi")</span>
                            </label>
                            <label class="filter-checkbox-item">
                                <input type="checkbox" @bind="searchFilters.HasParking" @bind:after="HandleSearch" />
                                <span class="filter-checkbox-label">Parking</span>
                                <span class="filter-checkbox-count">@GetAmenityCount("Parking")</span>
                            </label>
                            <label class="filter-checkbox-item">
                                <input type="checkbox" @bind="searchFilters.HasPool" @bind:after="HandleSearch" />
                                <span class="filter-checkbox-label">Swimming Pool</span>
                                <span class="filter-checkbox-count">@GetAmenityCount("Pool")</span>
                            </label>
                            <label class="filter-checkbox-item">
                                <input type="checkbox" @bind="searchFilters.HasRestaurant" @bind:after="HandleSearch" />
                                <span class="filter-checkbox-label">Restaurant</span>
                                <span class="filter-checkbox-count">@GetAmenityCount("Restaurant")</span>
                            </label>
                            <label class="filter-checkbox-item">
                                <input type="checkbox" @bind="searchFilters.HasGym" @bind:after="HandleSearch" />
                                <span class="filter-checkbox-label">Gym/Fitness</span>
                                <span class="filter-checkbox-count">@GetAmenityCount("Gym")</span>
                            </label>
                            <label class="filter-checkbox-item">
                                <input type="checkbox" @bind="searchFilters.HasConferenceRoom" @bind:after="HandleSearch" />
                                <span class="filter-checkbox-label">Conference Room</span>
                                <span class="filter-checkbox-count">@GetAmenityCount("Conference")</span>
                            </label>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Results Section -->
            <div class="col-lg-10">
                <div class="results-header">
                    <div class="results-info">
                        <h3 class="results-title">Available Hotels</h3>
                        <span class="results-count">@hotels.Count() properties found</span>
                        
                        <!-- Active Filter Chips -->
                        @if (HasActiveFilters())
                        {
                            <div class="active-filters">
                                @if (!string.IsNullOrEmpty(searchFilters.Keyword))
                                {
                                    <div class="filter-chip">
                                        <span>Search: @searchFilters.Keyword</span>
                                        <button class="filter-chip-remove" @onclick='() => RemoveFilter("keyword")'>&times;</button>
                                    </div>
                                }
                                @if (!string.IsNullOrEmpty(searchFilters.City))
                                {
                                    <div class="filter-chip">
                                        <span>Location: @searchFilters.City</span>
                                        <button class="filter-chip-remove" @onclick='() => RemoveFilter("city")'>&times;</button>
                                    </div>
                                }
                                @if (searchFilters.MinPrice.HasValue || searchFilters.MaxPrice.HasValue)
                                {
                                    <div class="filter-chip">
                                        <span>Price: KES @((searchFilters.MinPrice ?? 0).ToString("N0")) - @((searchFilters.MaxPrice ?? 100000).ToString("N0"))</span>
                                        <button class="filter-chip-remove" @onclick='() => RemoveFilter("price")'>&times;</button>
                                    </div>
                                }
                                @if (searchFilters.MinCapacity.HasValue || searchFilters.MaxCapacity.HasValue)
                                {
                                    <div class="filter-chip">
                                        <span>Capacity: @((searchFilters.MinCapacity ?? 0)) - @((searchFilters.MaxCapacity ?? 1000)) guests</span>
                                        <button class="filter-chip-remove" @onclick='() => RemoveFilter("capacity")'>&times;</button>
                                    </div>
                                }
                            </div>
                        }
                    </div>
                    <div class="view-toggle">
                        <button class="view-toggle-btn @(viewMode == "grid" ? "active" : "")" @onclick='() => viewMode = "grid"' title="Grid View">
                            <i class="bi bi-grid-3x3"></i>
                        </button>
                        <button class="view-toggle-btn @(viewMode == "list" ? "active" : "")" @onclick='() => viewMode = "list"' title="List View">
                            <i class="bi bi-list"></i>
                        </button>
                    </div>
                </div>

                @if (isLoading)
                {
                    <!-- Skeleton Loading -->
                    <div class="@(viewMode == "grid" ? "hotel-grid" : "hotel-list")">
                        @for (int i = 0; i < 6; i++)
                        {
                            <div class="skeleton-card">
                                <div class="skeleton-image"></div>
                                <div class="skeleton-content">
                                    <div class="skeleton-line"></div>
                                    <div class="skeleton-line short"></div>
                                    <div class="skeleton-line"></div>
                                    <div class="skeleton-line short"></div>
                                </div>
                            </div>
                        }
                    </div>
                }
                else if (!hotels.Any())
                {
                    <div class="empty-state">
                        <i class="bi bi-search empty-state-icon"></i>
                        <h3 class="empty-state-title">No Hotels Found</h3>
                        <p class="empty-state-text">Try adjusting your filters or search criteria</p>
                        <button class="btn-modern btn-gradient-primary" @onclick="ClearFilters">
                            <i class="bi bi-arrow-clockwise me-2"></i>Clear Filters
                        </button>
                    </div>
                }
                else
                {
                    <div class="@(viewMode == "grid" ? "hotel-grid" : "hotel-list")">
                        @foreach (var hotel in hotels)
                        {
                            <div class="hotel-card @(viewMode == "list" ? "list-view" : "")" @onclick="() => NavigateToHotel(hotel.Id)">
                                <div class="hotel-image">
                                    <!-- Favorite Button -->
                                    <button class="hotel-favorite @(favoriteHotels.Contains(hotel.Id) ? "active" : "")" 
                                            @onclick="(e) => ToggleFavorite(hotel.Id, e)" 
                                            @onclick:stopPropagation="true"
                                            title="Add to favorites">
                                        <i class="bi @(favoriteHotels.Contains(hotel.Id) ? "bi-heart-fill" : "bi-heart")"></i>
                                    </button>
                                    
                                    @if (hotel.Images?.Any() == true)
                                    {
                                        <img src="@hotel.Images.First().Url" alt="@hotel.Name" />
                                    }
                                    else
                                    {
                                        <div class="hotel-placeholder">
                                            <i class="bi bi-building"></i>
                                        </div>
                                    }
                                    @if (hotel.IsApproved)
                                    {
                                        <div class="hotel-badge">
                                            <i class="bi bi-patch-check-fill"></i>
                                            <span>Verified</span>
                                        </div>
                                    }
                                    <div class="hotel-overlay">
                                        <a href="/hotels/@hotel.Id" class="hotel-view-btn" @onclick:stopPropagation="true">
                                            <i class="bi bi-eye me-2"></i>View Details
                                        </a>
                                    </div>
                                </div>
                                <div class="hotel-content">
                                    <h5 class="hotel-name">@hotel.Name</h5>
                                    <span class="hotel-location"><i class="bi bi-geo-alt-fill"></i> @hotel.City, @hotel.Country</span>

                                    <div class="hotel-meta-row">
                                        <div class="hotel-rating">
                                            <i class="bi bi-star-fill"></i>
                                            <span class="hotel-rating-text">4.5</span>
                                        </div>
                                        <span class="meta-dot"></span>
                                        <div class="hotel-price-inline">
                                            <span class="price-amount">@hotel.Currency @hotel.PricePerNight.ToString("N0")</span>
                                            <span class="price-period">/night</span>
                                        </div>
                                    </div>

                                    @if (!string.IsNullOrEmpty(hotel.Description))
                                    {
                                        <p class="hotel-description">@hotel.Description</p>
                                    }

                                    <div class="hotel-footer">
                                        <a href="/hotels/@hotel.Id" class="hotel-book-btn" @onclick:stopPropagation="true">
                                            View <i class="bi bi-arrow-right"></i>
                                        </a>
                                    </div>
                                </div>
                            </div>
                        }
                    </div>
                }
            </div>
        </div>
    </div>
</div>

@code {
    [SupplyParameterFromForm]
    private SearchFilters searchFilters { get; set; } = new();

    private IEnumerable<Hotel> hotels = new List<Hotel>();
    private bool isLoading = true;
    private string viewMode = "grid"; // grid or list
    private HashSet<int> favoriteHotels = new HashSet<int>();
    private bool isAuthenticated = false;

    private List<BreadcrumbItem> breadcrumbItems = new()
    {
        new BreadcrumbItem { Text = "Home", Url = "/" },
        new BreadcrumbItem { Text = "Search Hotels", IsActive = true }
    };

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        isAuthenticated = authState.User.Identity?.IsAuthenticated == true;

        await LoadHotels();
    }

    private async Task GoBack()
    {
        await JSRuntime.InvokeVoidAsync("history.back");
    }

    private async Task LoadHotels()
    {
        isLoading = true;
        try
        {
            hotels = await HotelService.GetPublishedHotelsAsync();
        }
        catch (Exception)
        {
            hotels = new List<Hotel>();
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task HandleSearch()
    {
        isLoading = true;
        try
        {
            hotels = await HotelService.SearchHotelsAsync(
                searchFilters.Keyword,
                searchFilters.City,
                searchFilters.MinCapacity,
                searchFilters.MaxPrice,
                searchFilters.Category
            );
        }
        catch (Exception)
        {
            hotels = new List<Hotel>();
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task ClearFilters()
    {
        searchFilters = new SearchFilters();
        await LoadHotels();
    }

    private bool HasActiveFilters()
    {
        return !string.IsNullOrEmpty(searchFilters.Keyword) ||
               !string.IsNullOrEmpty(searchFilters.City) ||
               searchFilters.MinPrice.HasValue ||
               searchFilters.MaxPrice.HasValue ||
               searchFilters.MinCapacity.HasValue ||
               searchFilters.MaxCapacity.HasValue ||
               searchFilters.HasWifi ||
               searchFilters.HasParking ||
               searchFilters.HasPool ||
               searchFilters.HasRestaurant ||
               searchFilters.HasGym ||
               searchFilters.HasConferenceRoom;
    }

    private async Task RemoveFilter(string filterType)
    {
        switch (filterType)
        {
            case "keyword":
                searchFilters.Keyword = null;
                break;
            case "city":
                searchFilters.City = null;
                break;
            case "price":
                searchFilters.MinPrice = null;
                searchFilters.MaxPrice = null;
                break;
            case "capacity":
                searchFilters.MinCapacity = null;
                searchFilters.MaxCapacity = null;
                break;
        }
        await HandleSearch();
    }

    private void ToggleFavorite(int hotelId, MouseEventArgs e)
    {
        if (favoriteHotels.Contains(hotelId))
        {
            favoriteHotels.Remove(hotelId);
        }
        else
        {
            favoriteHotels.Add(hotelId);
        }
    }

    private void NavigateToHotel(int hotelId)
    {
        Navigation.NavigateTo($"/hotels/{hotelId}");
    }

    private int GetAmenityCount(string amenity)
    {
        // This would normally query the database for count
        // For now, returning placeholder values
        return amenity switch
        {
            "WiFi" => 45,
            "Parking" => 38,
            "Pool" => 22,
            "Restaurant" => 31,
            "Gym" => 18,
            "Conference" => 27,
            _ => 0
        };
    }

    public class SearchFilters
    {
        public string? Keyword { get; set; }
        public string? City { get; set; }
        public int? MinCapacity { get; set; }
        public int? MaxCapacity { get; set; }
        public decimal? MinPrice { get; set; }
        public decimal? MaxPrice { get; set; }
        public string? Category { get; set; }
        
        // Amenities
        public bool HasWifi { get; set; }
        public bool HasParking { get; set; }
        public bool HasPool { get; set; }
        public bool HasRestaurant { get; set; }
        public bool HasGym { get; set; }
        public bool HasConferenceRoom { get; set; }
    }
}
