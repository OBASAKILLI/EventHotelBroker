                DepositAmount = 260000,
                Status = EventBookingStatus.Confirmed,
                SpecialRequests = "Full day event with breakfast, lunch, and evening cocktails. Need demo area and product display stands.",
                CreatedAt = DateTime.Now.AddDays(-8)
            },
            new EventBooking
            {
                Id = 4,
                UserId = currentUserId,
                EventName = "Team Building Retreat",
                EventType = "Team Building",
