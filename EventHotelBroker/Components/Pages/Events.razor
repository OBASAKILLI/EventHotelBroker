@page "/events"
@rendermode InteractiveServer
@using EventHotelBroker.Models
@using EventHotelBroker.Services
@inject IEventService EventService
@inject NavigationManager Navigation

<PageTitle>Event Services - EventHotelBroker</PageTitle>

<link href="/css/events-page.css" rel="stylesheet" />

<div class="events-page">
    <div class="events-header">
        <h1><i class="bi bi-calendar-event"></i>Plan Your Perfect Event</h1>
        <p>From equipment rentals to complete event packages</p>
    </div>

    <div class="events-type-selector">
        <div class="events-type-card @(selectedEventType == "Wedding" ? "active" : "")" @onclick='() => SelectEventType("Wedding")'>
            <div class="icon">💒</div>
            <div class="label">Wedding</div>
        </div>
        <div class="events-type-card @(selectedEventType == "Corporate" ? "active" : "")" @onclick='() => SelectEventType("Corporate")'>
            <div class="icon">💼</div>
            <div class="label">Corporate</div>
        </div>
        <div class="events-type-card @(selectedEventType == "Birthday" ? "active" : "")" @onclick='() => SelectEventType("Birthday")'>
            <div class="icon">🎂</div>
            <div class="label">Birthday</div>
        </div>
        <div class="events-type-card @(selectedEventType == "Conference" ? "active" : "")" @onclick='() => SelectEventType("Conference")'>
            <div class="icon">🎤</div>
            <div class="label">Conference</div>
        </div>
        <div class="events-type-card @(selectedEventType == "Party" ? "active" : "")" @onclick='() => SelectEventType("Party")'>
            <div class="icon">🎉</div>
            <div class="label">Party</div>
        </div>
    </div>

    <div class="events-tabs">
        <button class="events-tab @(activeTab == "packages" ? "active" : "")" @onclick='() => activeTab = "packages"'>
            <i class="bi bi-gift"></i> Event Packages
        </button>
        <button class="events-tab @(activeTab == "equipment" ? "active" : "")" @onclick='() => activeTab = "equipment"'>
            <i class="bi bi-box-seam"></i> Equipment Rental
        </button>
    </div>

    @if (isLoading)
    {
        <div class="events-loading">
            <div class="spinner-border" role="status">
                <span class="visually-hidden">Loading...</span>
            </div>
            <p>Loading event services...</p>
        </div>
    }
    else
    {
        @if (activeTab == "packages")
        {
            @if (filteredPackages.Any())
            {
                <div class="packages-grid">
                    @foreach (var package in filteredPackages)
                    {
                        <div class="package-card" @onclick="() => ViewPackageDetails(package.Id)">
                            <div class="package-card-img">
                                @if (package.IsFeatured)
                                {
                                    <span class="package-featured-badge"><i class="bi bi-star-fill"></i> Featured</span>
                                }
                                @if (!string.IsNullOrEmpty(package.ImageUrl))
                                {
                                    <img src="@package.ImageUrl" alt="@package.Name" />
                                }
                                else
                                {
                                    <div class="placeholder-img"><i class="bi bi-gift"></i></div>
                                }
                            </div>
                            <div class="package-card-body">
                                <span class="package-type-badge"><i class="bi bi-tag"></i> @package.PackageType</span>
                                <h4>@package.Name</h4>
                                <p class="package-desc">@package.Description</p>

                                <div class="package-meta">
                                    <div class="package-price">
                                        @if (package.DiscountedPrice.HasValue)
                                        {
                                            <span class="original">KES @package.TotalPrice.ToString("N0")</span>
                                        }
                                        <span class="current">KES @((package.DiscountedPrice ?? package.TotalPrice).ToString("N0"))</span>
                                    </div>
                                    <span class="package-guests"><i class="bi bi-people"></i> @package.MinGuests–@package.MaxGuests</span>
                                </div>

                                <div class="package-actions">
                                    <button class="pkg-btn-book" @onclick="() => BookPackage(package.Id)" @onclick:stopPropagation="true">
                                        <i class="bi bi-calendar-check"></i> Book Now
                                    </button>
                                    <button class="pkg-btn-view" @onclick="() => ViewPackageDetails(package.Id)" @onclick:stopPropagation="true">
                                        <i class="bi bi-eye"></i>
                                    </button>
                                </div>
                            </div>
                        </div>
                    }
                </div>
            }
            else
            {
                <div class="events-empty">
                    <i class="bi bi-inbox"></i>
                    <p>No packages available for this event type</p>
                </div>
            }
        }
        else
        {
            <div class="equipment-category-filter">
                <button class="cat-filter-btn @(selectedCategory == "" ? "active" : "")" @onclick='() => FilterCategory("")'>All</button>
                <button class="cat-filter-btn @(selectedCategory == "Tents" ? "active" : "")" @onclick='() => FilterCategory("Tents")'><i class="bi bi-house"></i> Tents</button>
                <button class="cat-filter-btn @(selectedCategory == "Chairs" ? "active" : "")" @onclick='() => FilterCategory("Chairs")'><i class="bi bi-chair"></i> Chairs</button>
                <button class="cat-filter-btn @(selectedCategory == "Sound System" ? "active" : "")" @onclick='() => FilterCategory("Sound System")'><i class="bi bi-speaker"></i> Sound</button>
                <button class="cat-filter-btn @(selectedCategory == "Lighting" ? "active" : "")" @onclick='() => FilterCategory("Lighting")'><i class="bi bi-lightbulb"></i> Lighting</button>
                <button class="cat-filter-btn @(selectedCategory == "Catering" ? "active" : "")" @onclick='() => FilterCategory("Catering")'><i class="bi bi-cup-hot"></i> Catering</button>
                <button class="cat-filter-btn @(selectedCategory == "Decoration" ? "active" : "")" @onclick='() => FilterCategory("Decoration")'><i class="bi bi-flower1"></i> Decor</button>
            </div>

            @if (filteredEquipments.Any())
            {
                <div class="equipment-grid">
                    @foreach (var equipment in filteredEquipments)
                    {
                        <div class="equip-card">
                            <div class="equip-card-img">
                                @{ var eqImg = equipment.Images?.OrderBy(i => i.DisplayOrder).FirstOrDefault(); }
                                @if (eqImg != null && !string.IsNullOrEmpty(eqImg.ImageUrl))
                                {
                                    <img src="@eqImg.ImageUrl" alt="@equipment.Name" />
                                }
                                else
                                {
                                    <div class="equip-placeholder" style="background: @GetCategoryGradient(equipment.Category)">
                                        <i class="bi @GetCategoryIcon(equipment.Category)"></i>
                                    </div>
                                }
                            </div>
                            <div class="equip-card-body">
                                <div class="equip-icon @equipment.Category.ToLower().Replace(" ", "")">
                                    <i class="bi @GetCategoryIcon(equipment.Category)"></i>
                                </div>
                                <h5>@equipment.Name</h5>
                                <p class="equip-desc">@equipment.Description</p>

                                <div class="equip-footer">
                                    <div class="equip-price">KES @equipment.PricePerUnit.ToString("N0") <small>/@equipment.Unit</small></div>
                                    <span class="equip-avail">@equipment.AvailableQuantity avail</span>
                                </div>

                                <button class="equip-add-btn" @onclick="() => AddToCart(equipment.Id)">
                                    <i class="bi bi-cart-plus"></i> Add to Cart
                                </button>
                            </div>
                        </div>
                    }
                </div>
            }
            else
            {
                <div class="events-empty">
                    <i class="bi bi-inbox"></i>
                    <p>No equipment available in this category</p>
                </div>
            }
        }
    }
</div>

@code {
    [SupplyParameterFromQuery(Name = "tab")]
    public string? TabParam { get; set; }

    private bool isLoading = true;
    private string activeTab = "packages";
    private string selectedEventType = "";
    private string selectedCategory = "";
    
    private List<EventPackage> packages = new();
    private List<EventPackage> filteredPackages = new();
    private List<EventEquipment> equipments = new();
    private List<EventEquipment> filteredEquipments = new();

    protected override async Task OnInitializedAsync()
    {
        if (!string.IsNullOrEmpty(TabParam))
        {
            activeTab = TabParam;
        }
        await LoadData();
    }

    private async Task LoadData()
    {
        isLoading = true;
        try
        {
            var allPackages = await EventService.GetAllPackagesAsync();
            packages = allPackages.Where(p => p.IsApproved && p.IsActive).ToList();
            
            var allEquipments = await EventService.GetAllEquipmentsAsync();
            equipments = allEquipments.Where(e => e.IsApproved && e.IsAvailable).ToList();
            
            FilterData();
        }
        catch (Exception ex)
        {
            // Log error
        }
        finally
        {
            isLoading = false;
        }
    }

    private void SelectEventType(string eventType)
    {
        selectedEventType = selectedEventType == eventType ? "" : eventType;
        FilterData();
    }

    private void FilterData()
    {
        // Filter packages
        if (string.IsNullOrEmpty(selectedEventType))
        {
            filteredPackages = packages;
        }
        else
        {
            filteredPackages = packages.Where(p => p.PackageType == selectedEventType).ToList();
        }

        // Filter equipment
        if (string.IsNullOrEmpty(selectedCategory))
        {
            filteredEquipments = equipments;
        }
        else
        {
            filteredEquipments = equipments.Where(e => e.Category == selectedCategory).ToList();
        }
    }

    private void FilterCategory(string category)
    {
        selectedCategory = category;
        FilterData();
    }

    private void ViewPackageDetails(int packageId)
    {
        Navigation.NavigateTo($"/events/package/{packageId}");
    }

    private void BookPackage(int packageId)
    {
        Navigation.NavigateTo($"/book-event?packageId={packageId}");
    }

    private void AddToCart(int equipmentId)
    {
        // Implement cart functionality
        Navigation.NavigateTo($"/book-event?equipmentId={equipmentId}");
    }

    private string GetCategoryIcon(string category)
    {
        return category switch
        {
            "Tents" => "bi-house",
            "Chairs" => "bi-chair",
            "Sound System" => "bi-speaker",
            "Lighting" => "bi-lightbulb",
            "Catering" => "bi-cup-hot",
            "Decoration" => "bi-flower1",
            _ => "bi-box-seam"
        };
    }

    private string GetCategoryGradient(string category)
    {
        return category switch
        {
            "Tents" => "linear-gradient(135deg, #2A2A2A, #4a4a4a)",
            "Chairs" => "linear-gradient(135deg, #9E8B63, #b8a584)",
            "Sound System" => "linear-gradient(135deg, #6366f1, #818cf8)",
            "Lighting" => "linear-gradient(135deg, #d97706, #f59e0b)",
            "Catering" => "linear-gradient(135deg, #059669, #10B981)",
            "Decoration" => "linear-gradient(135deg, #ec4899, #f472b6)",
            _ => "linear-gradient(135deg, #9E8B63, #b8a584)"
        };
    }
}
