@page "/owner/edit-package/{PackageId:int}"
@rendermode InteractiveServer
@using EventHotelBroker.Models
@using EventHotelBroker.Services
@using EventHotelBroker.Utils
@using System.Security.Claims
@using Microsoft.AspNetCore.Components.Authorization
@inject IEventService EventService
@inject NavigationManager Navigation
@inject IJSRuntime JSRuntime
@inject AuthenticationStateProvider AuthStateProvider
@inject IWebHostEnvironment Environment

<PageTitle>Edit Package - Owner</PageTitle>

<link href="/css/create-package.css?v=1" rel="stylesheet" />

<div class="cp">
    <Breadcrumb Items="@breadcrumbItems" />

    <!-- Header -->
    <div class="cp-header">
        <div>
            <h1 class="cp-header-title"><i class="bi bi-pencil-square"></i> Edit Package</h1>
            <p class="cp-header-sub">Update your event package details</p>
        </div>
        <button class="cp-btn cp-btn-cancel" @onclick="Cancel">
            <i class="bi bi-arrow-left"></i> Back
        </button>
    </div>

    @if (isLoading)
    {
        <div style="text-align: center; padding: 3rem;">
            <div class="cp-spinner" style="width: 32px; height: 32px; border-width: 3px; margin: 0 auto 1rem;"></div>
            <p style="color: #8a8177; font-size: 0.8rem;">Loading package...</p>
        </div>
    }
    else if (package == null)
    {
        <div style="text-align: center; padding: 3rem;">
            <i class="bi bi-exclamation-triangle" style="font-size: 2.5rem; color: #C87941;"></i>
            <h5 style="margin-top: 1rem; color: #2A2A2A;">Package Not Found</h5>
            <p style="color: #8a8177; font-size: 0.8rem;">The package you're looking for doesn't exist or you don't have permission to edit it.</p>
            <a href="/owner/event-packages" class="cp-btn cp-btn-submit" style="display: inline-flex;">
                <i class="bi bi-arrow-left"></i> Back to My Packages
            </a>
        </div>
    }
    else
    {
        <div class="row justify-content-center">
            <div class="col-lg-9">
                <div class="cp-card">
                    <div class="cp-card-body">

                        @if (!string.IsNullOrEmpty(successMessage))
                        {
                            <div style="background: rgba(72,140,130,0.1); border: 1px solid rgba(72,140,130,0.3); border-radius: 8px; padding: 12px 16px; margin-bottom: 1rem; display: flex; align-items: center; gap: 10px; font-size: 0.8rem; color: #488C82;">
                                <i class="bi bi-check-circle-fill"></i>
                                <span><strong>Success!</strong> @successMessage</span>
                            </div>
                        }

                        @if (!string.IsNullOrEmpty(errorMessage))
                        {
                            <div style="background: rgba(220,53,69,0.08); border: 1px solid rgba(220,53,69,0.25); border-radius: 8px; padding: 12px 16px; margin-bottom: 1rem; display: flex; align-items: center; gap: 10px; font-size: 0.8rem; color: #dc3545;">
                                <i class="bi bi-exclamation-triangle-fill"></i>
                                <span><strong>Error!</strong> @errorMessage</span>
                            </div>
                        }

                        <!-- Status Badge -->
                        <div style="margin-bottom: 1rem; display: flex; align-items: center; gap: 0.5rem;">
                            <span style="font-size: 0.7rem; font-weight: 600; color: #8a8177;">STATUS:</span>
                            @if (package.IsApproved && package.IsActive)
                            {
                                <span style="font-size: 0.65rem; font-weight: 700; padding: 0.15rem 0.5rem; border-radius: 6px; background: rgba(72,140,130,0.1); color: #488C82;">
                                    <i class="bi bi-check-circle"></i> Approved & Active
                                </span>
                            }
                            else if (package.IsApproved)
                            {
                                <span style="font-size: 0.65rem; font-weight: 700; padding: 0.15rem 0.5rem; border-radius: 6px; background: rgba(72,140,130,0.1); color: #488C82;">
                                    <i class="bi bi-check-circle"></i> Approved
                                </span>
                            }
                            else
                            {
                                <span style="font-size: 0.65rem; font-weight: 700; padding: 0.15rem 0.5rem; border-radius: 6px; background: rgba(200,121,65,0.1); color: #C87941;">
                                    <i class="bi bi-clock-history"></i> Pending Review
                                </span>
                            }
                        </div>

                        <EditForm Model="@package" OnValidSubmit="@HandleSubmit">
                            <DataAnnotationsValidator />
                            <ValidationSummary class="validation-errors" />

                            <!-- Package Information -->
                            <div class="cp-section">
                                <div class="cp-section-icon cp-icon-terracotta"><i class="bi bi-gift"></i></div>
                                <h5 class="cp-section-title">Package Information</h5>
                            </div>

                            <div class="cp-field">
                                <label class="cp-label">Package Name <span class="req">*</span></label>
                                <InputText @bind-Value="package.Name" class="cp-input" placeholder="e.g., Premium Wedding Package" />
                                <ValidationMessage For="@(() => package.Name)" />
                            </div>

                            <div class="cp-field">
                                <label class="cp-label">Package Type <span class="req">*</span></label>
                                <InputSelect @bind-Value="package.PackageType" class="cp-select">
                                    <option value="">-- Select Type --</option>
                                    <option value="Wedding">Wedding</option>
                                    <option value="Corporate">Corporate Event</option>
                                    <option value="Birthday">Birthday Party</option>
                                    <option value="Conference">Conference</option>
                                    <option value="Party">Party</option>
                                    <option value="Festival">Festival</option>
                                    <option value="Exhibition">Exhibition</option>
                                    <option value="Custom">Custom Event</option>
                                </InputSelect>
                                <ValidationMessage For="@(() => package.PackageType)" />
                            </div>

                            <div class="cp-field">
                                <label class="cp-label">Description <span class="req">*</span></label>
                                <InputTextArea @bind-Value="package.Description" class="cp-input" rows="3"
                                    placeholder="Describe what's included in this package..." />
                                <ValidationMessage For="@(() => package.Description)" />
                            </div>

                            <hr class="cp-divider" />

                            <!-- Pricing -->
                            <div class="cp-section">
                                <div class="cp-section-icon cp-icon-teal"><i class="bi bi-currency-dollar"></i></div>
                                <h5 class="cp-section-title">Pricing</h5>
                            </div>

                            <div class="row">
                                <div class="col-md-6">
                                    <div class="cp-field">
                                        <label class="cp-label">Total Price <span class="req">*</span></label>
                                        <div class="cp-input-group">
                                            <span class="cp-input-prefix">$</span>
                                            <InputNumber @bind-Value="package.TotalPrice" class="cp-input" placeholder="0.00" step="0.01" />
                                        </div>
                                        <ValidationMessage For="@(() => package.TotalPrice)" />
                                    </div>
                                </div>
                                <div class="col-md-6">
                                    <div class="cp-field">
                                        <label class="cp-label">Discounted Price</label>
                                        <div class="cp-input-group">
                                            <span class="cp-input-prefix">$</span>
                                            <InputNumber @bind-Value="package.DiscountedPrice" class="cp-input" placeholder="0.00" step="0.01" />
                                        </div>
                                        <span class="cp-hint">Optional: Offer a special discounted price</span>
                                    </div>
                                </div>
                            </div>

                            @if (package.DiscountedPrice.HasValue && package.TotalPrice > 0)
                            {
                                var savings = package.TotalPrice - package.DiscountedPrice.Value;
                                var percentage = (savings / package.TotalPrice) * 100;
                                <div class="cp-savings">
                                    <i class="bi bi-tag-fill"></i>
                                    Customers save <strong>$@savings.ToString("N2")</strong> (@percentage.ToString("N0")% off)
                                </div>
                            }

                            <hr class="cp-divider" />

                            <!-- Guest Capacity -->
                            <div class="cp-section">
                                <div class="cp-section-icon cp-icon-bronze"><i class="bi bi-people"></i></div>
                                <h5 class="cp-section-title">Guest Capacity</h5>
                            </div>

                            <div class="row">
                                <div class="col-md-6">
                                    <div class="cp-field">
                                        <label class="cp-label">Minimum Guests <span class="req">*</span></label>
                                        <InputNumber @bind-Value="package.MinGuests" class="cp-input" placeholder="0" min="1" />
                                        <ValidationMessage For="@(() => package.MinGuests)" />
                                    </div>
                                </div>
                                <div class="col-md-6">
                                    <div class="cp-field">
                                        <label class="cp-label">Maximum Guests <span class="req">*</span></label>
                                        <InputNumber @bind-Value="package.MaxGuests" class="cp-input" placeholder="0" min="1" />
                                        <ValidationMessage For="@(() => package.MaxGuests)" />
                                    </div>
                                </div>
                            </div>

                            <hr class="cp-divider" />

                            <!-- Features -->
                            <div class="cp-section">
                                <div class="cp-section-icon cp-icon-olive"><i class="bi bi-list-check"></i></div>
                                <h5 class="cp-section-title">Package Features</h5>
                            </div>

                            <div class="cp-field">
                                <label class="cp-label">Features (one per line)</label>
                                <textarea @bind="featuresText" class="cp-input" rows="5"
                                    placeholder="Enter each feature on a new line..."></textarea>
                                <span class="cp-hint">List all items and services included in this package</span>
                            </div>

                            @if (!string.IsNullOrWhiteSpace(featuresText))
                            {
                                var features = featuresText.Split('\n', StringSplitOptions.RemoveEmptyEntries);
                                <div class="cp-preview">
                                    <div class="cp-preview-title">Preview</div>
                                    <ul class="cp-preview-list">
                                        @foreach (var feature in features)
                                        {
                                            <li>@feature.Trim()</li>
                                        }
                                    </ul>
                                </div>
                            }

                            <hr class="cp-divider" />

                            <!-- Package Settings -->
                            <div class="cp-section">
                                <div class="cp-section-icon cp-icon-charcoal"><i class="bi bi-gear"></i></div>
                                <h5 class="cp-section-title">Package Settings</h5>
                            </div>

                            <div class="cp-toggles">
                                <div class="cp-toggle-item">
                                    <InputCheckbox @bind-Value="package.IsFeatured" id="isFeatured" />
                                    <div>
                                        <div class="cp-toggle-label">Featured</div>
                                        <div class="cp-toggle-hint">Highlight this package</div>
                                    </div>
                                </div>
                                <div class="cp-toggle-item">
                                    <InputCheckbox @bind-Value="package.IsCustomizable" id="isCustomizable" />
                                    <div>
                                        <div class="cp-toggle-label">Customizable</div>
                                        <div class="cp-toggle-hint">Allow modifications</div>
                                    </div>
                                </div>
                            </div>

                            <hr class="cp-divider" />

                            <!-- Package Image -->
                            <div class="cp-section">
                                <div class="cp-section-icon cp-icon-terracotta"><i class="bi bi-image"></i></div>
                                <h5 class="cp-section-title">Package Image</h5>
                            </div>

                            <!-- Existing Image -->
                            @if (!string.IsNullOrEmpty(package.ImageUrl) && !removeExistingImage)
                            {
                                <div class="cp-field">
                                    <label class="cp-label">Current Image</label>
                                    <div style="position: relative; display: inline-block; margin-top: 4px;">
                                        <img src="@package.ImageUrl" alt="Package image" style="max-width: 200px; max-height: 150px; border-radius: 8px; border: 2px solid #488C82;" />
                                        <button type="button" @onclick="() => removeExistingImage = true"
                                            style="position: absolute; top: 4px; right: 4px; background: rgba(0,0,0,0.6); color: white; border: none; border-radius: 50%; width: 22px; height: 22px; font-size: 0.7rem; cursor: pointer; display: flex; align-items: center; justify-content: center;">
                                            <i class="bi bi-x"></i>
                                        </button>
                                    </div>
                                </div>
                            }

                            <!-- Upload New Image -->
                            <div class="cp-field">
                                <label class="cp-label">@(string.IsNullOrEmpty(package.ImageUrl) || removeExistingImage ? "Upload Image" : "Replace Image") (Max 5MB)</label>
                                <div style="border: 2px dashed #c4b5a0; border-radius: 8px; padding: 24px; text-align: center; background: #faf8f5; cursor: pointer; position: relative;">
                                    <InputFile OnChange="OnImageSelected" accept="image/*"
                                        style="position: absolute; inset: 0; opacity: 0; cursor: pointer;" />
                                    <i class="bi bi-cloud-arrow-up" style="font-size: 2rem; color: #8a8177;"></i>
                                    <div style="color: #5c5550; margin-top: 8px; font-size: 0.85rem;">Click or drag an image here to upload</div>
                                    <div style="color: #8a8177; font-size: 0.75rem; margin-top: 4px;">Supported: JPG, PNG, WebP</div>
                                </div>
                            </div>

                            @if (!string.IsNullOrEmpty(newImagePreviewUrl))
                            {
                                <div style="position: relative; display: inline-block; margin-top: 8px;">
                                    <img src="@newImagePreviewUrl" alt="New image preview" style="max-width: 200px; max-height: 150px; border-radius: 8px; border: 1px solid #dee2e6;" />
                                    <span style="position: absolute; bottom: 4px; left: 4px; background: #488C82; color: white; font-size: 0.6rem; font-weight: 700; padding: 1px 6px; border-radius: 4px;">NEW</span>
                                    <button type="button" @onclick="RemoveNewImage"
                                        style="position: absolute; top: 4px; right: 4px; background: rgba(0,0,0,0.6); color: white; border: none; border-radius: 50%; width: 22px; height: 22px; font-size: 0.7rem; cursor: pointer; display: flex; align-items: center; justify-content: center;">
                                        <i class="bi bi-x"></i>
                                    </button>
                                </div>
                            }

                            <hr class="cp-divider" />

                            <!-- Info Box -->
                            <div style="background: rgba(72,140,130,0.06); border: 1px solid rgba(72,140,130,0.15); border-radius: 10px; padding: 0.75rem 1rem; display: flex; gap: 0.75rem; align-items: flex-start;">
                                <i class="bi bi-info-circle" style="color: #488C82; font-size: 1rem; margin-top: 2px;"></i>
                                <div>
                                    <div style="font-size: 0.75rem; font-weight: 700; color: #488C82;">Note</div>
                                    <div style="font-size: 0.7rem; color: #5c5550;">Changes to approved packages will keep their current status. Major changes may trigger a re-review by admin.</div>
                                </div>
                            </div>

                            <!-- Footer -->
                            <div class="cp-footer">
                                <button type="button" class="cp-btn cp-btn-muted" @onclick="Cancel">
                                    <i class="bi bi-x-lg"></i> Cancel
                                </button>
                                <button type="button" class="cp-btn cp-btn-muted" style="color: #dc3545;" @onclick="() => showDeleteConfirm = true">
                                    <i class="bi bi-trash"></i> Delete
                                </button>
                                <button type="submit" class="cp-btn cp-btn-submit" disabled="@isSubmitting">
                                    @if (isSubmitting)
                                    {
                                        <span class="cp-spinner"></span>
                                        <span>Saving...</span>
                                    }
                                    else
                                    {
                                        <i class="bi bi-check-lg"></i>
                                        <span>Save Changes</span>
                                    }
                                </button>
                            </div>
                        </EditForm>

                    </div>
                </div>
            </div>
        </div>
    }
</div>

@if (showDeleteConfirm)
{
    <div style="position: fixed; inset: 0; background: rgba(0,0,0,0.45); z-index: 1050; display: flex; align-items: center; justify-content: center;"
         @onclick="() => showDeleteConfirm = false">
        <div style="background: #fff; border-radius: 14px; padding: 1.75rem; max-width: 400px; width: 92%; box-shadow: 0 12px 40px rgba(0,0,0,0.18);"
             @onclick:stopPropagation="true">
            <div style="text-align: center;">
                <div style="width: 56px; height: 56px; border-radius: 50%; display: flex; align-items: center; justify-content: center; margin: 0 auto 1rem; font-size: 1.5rem; background: rgba(220,53,69,0.1); color: #dc3545;">
                    <i class="bi bi-trash"></i>
                </div>
                <h5 style="margin: 0 0 0.4rem; font-size: 1rem; color: #2A2A2A; font-weight: 700;">Delete Package?</h5>
                <p style="font-size: 0.8rem; color: #8a8177; margin: 0 0 0.25rem;">
                    Are you sure you want to delete <strong>@package?.Name</strong>? This action cannot be undone.
                </p>
            </div>
            <div style="display: flex; gap: 0.5rem; justify-content: center; margin-top: 1.25rem;">
                <button style="padding: 0.45rem 1.1rem; border-radius: 8px; border: 1px solid #dee2e6; background: #fff; color: #5c5550; font-size: 0.78rem; font-weight: 600; cursor: pointer;"
                        @onclick="() => showDeleteConfirm = false">
                    Cancel
                </button>
                <button style="padding: 0.45rem 1.1rem; border-radius: 8px; border: none; background: #dc3545; color: #fff; font-size: 0.78rem; font-weight: 600; cursor: pointer; display: flex; align-items: center; gap: 6px;"
                        @onclick="DeletePackage">
                    <i class="bi bi-trash"></i> Delete
                </button>
            </div>
        </div>
    </div>
}

@code {
    [Parameter]
    public int PackageId { get; set; }

    private EventPackage? package;
    private string featuresText = string.Empty;
    private bool isLoading = true;
    private bool isSubmitting = false;
    private bool showDeleteConfirm = false;
    private string? currentProviderId;
    private string? errorMessage;
    private string? successMessage;

    private bool removeExistingImage = false;
    private IBrowserFile? selectedNewImage;
    private string? newImagePreviewUrl;
    private string? originalImageUrl;
    private const long MaxFileSize = 5 * 1024 * 1024;

    private List<BreadcrumbItem> breadcrumbItems = new()
    {
        new BreadcrumbItem { Text = "Home", Url = "/" },
        new BreadcrumbItem { Text = "Event Packages", Url = "/owner/event-packages" },
        new BreadcrumbItem { Text = "Edit Package", IsActive = true }
    };

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            try
            {
                var token = await JSRuntime.InvokeAsync<string>("authHelpers.getCookie", "JWToken");
                if (!string.IsNullOrEmpty(token))
                {
                    var customAuth = (CustomAuthenticationStateProvider)AuthStateProvider;
                    await customAuth.MarkUserAsAuthenticated(token);
                    currentProviderId = await GetCurrentUserIdAsync();
                }

                if (string.IsNullOrEmpty(currentProviderId))
                {
                    errorMessage = "You must be logged in to edit a package.";
                    isLoading = false;
                    StateHasChanged();
                    return;
                }

                package = await EventService.GetPackageByIdAsync(PackageId);

                if (package == null || package.ProviderId != currentProviderId)
                {
                    package = null;
                    isLoading = false;
                    StateHasChanged();
                    return;
                }

                originalImageUrl = package.ImageUrl;

                // Parse features JSON to text
                if (!string.IsNullOrEmpty(package.Features))
                {
                    try
                    {
                        var features = System.Text.Json.JsonSerializer.Deserialize<List<string>>(package.Features);
                        if (features != null)
                            featuresText = string.Join("\n", features);
                    }
                    catch { featuresText = package.Features; }
                }
            }
            catch (Exception ex)
            {
                errorMessage = $"Error loading package: {ex.Message}";
            }
            finally
            {
                isLoading = false;
            }
            StateHasChanged();
        }
    }

    private async Task<string?> GetCurrentUserIdAsync()
    {
        try
        {
            var authState = await AuthStateProvider.GetAuthenticationStateAsync();
            var user = authState?.User;
            if (user?.Identity?.IsAuthenticated == true)
            {
                var nameClaim = user.FindFirst(ClaimTypes.Name)?.Value;
                if (!string.IsNullOrEmpty(nameClaim))
                {
                    var parts = nameClaim.Split(',');
                    if (parts.Length > 0) return parts[0];
                }
            }
        }
        catch { }
        return null;
    }

    private async Task OnImageSelected(InputFileChangeEventArgs e)
    {
        var file = e.File;
        if (file.Size > MaxFileSize) { errorMessage = "File exceeds 5MB limit."; return; }
        if (!file.ContentType.StartsWith("image/")) { errorMessage = "Only image files are allowed."; return; }

        selectedNewImage = file;
        try
        {
            var resized = await file.RequestImageFileAsync(file.ContentType, 200, 150);
            var buffer = new byte[resized.Size];
            await resized.OpenReadStream(MaxFileSize).ReadAsync(buffer);
            newImagePreviewUrl = $"data:{file.ContentType};base64,{Convert.ToBase64String(buffer)}";
        }
        catch { }
        StateHasChanged();
    }

    private void RemoveNewImage()
    {
        selectedNewImage = null;
        newImagePreviewUrl = null;
        StateHasChanged();
    }

    private async Task HandleSubmit()
    {
        if (package == null || string.IsNullOrEmpty(currentProviderId)) return;

        isSubmitting = true;
        errorMessage = null;
        successMessage = null;

        try
        {
            // Convert features text to JSON
            if (!string.IsNullOrWhiteSpace(featuresText))
            {
                var features = featuresText.Split('\n', StringSplitOptions.RemoveEmptyEntries)
                    .Select(f => f.Trim())
                    .Where(f => !string.IsNullOrEmpty(f))
                    .ToList();
                package.Features = System.Text.Json.JsonSerializer.Serialize(features);
            }
            else
            {
                package.Features = null;
            }

            // Handle image changes
            if (selectedNewImage != null)
            {
                // Delete old image file if exists
                if (!string.IsNullOrEmpty(originalImageUrl))
                {
                    var oldPath = Path.Combine(Environment.WebRootPath, originalImageUrl.TrimStart('/').Replace('/', Path.DirectorySeparatorChar));
                    if (File.Exists(oldPath)) File.Delete(oldPath);
                }

                // Save new image
                var uploadsPath = Path.Combine(Environment.WebRootPath, "uploads", "packages");
                Directory.CreateDirectory(uploadsPath);
                var ext = Path.GetExtension(selectedNewImage.Name);
                var fileName = $"{package.Id}_{Guid.NewGuid():N}{ext}";
                var filePath = Path.Combine(uploadsPath, fileName);

                await using var stream = new FileStream(filePath, FileMode.Create);
                await selectedNewImage.OpenReadStream(MaxFileSize).CopyToAsync(stream);

                package.ImageUrl = $"/uploads/packages/{fileName}";
            }
            else if (removeExistingImage)
            {
                // Remove existing image
                if (!string.IsNullOrEmpty(originalImageUrl))
                {
                    var oldPath = Path.Combine(Environment.WebRootPath, originalImageUrl.TrimStart('/').Replace('/', Path.DirectorySeparatorChar));
                    if (File.Exists(oldPath)) File.Delete(oldPath);
                }
                package.ImageUrl = null;
            }

            await EventService.UpdatePackageAsync(package);

            successMessage = "Package updated successfully! Redirecting...";
            StateHasChanged();
            await Task.Delay(2000);
            Navigation.NavigateTo("/owner/event-packages");
        }
        catch (Exception ex)
        {
            errorMessage = $"Error updating package: {ex.Message}";
            if (ex.InnerException != null) errorMessage += $" | {ex.InnerException.Message}";
        }
        finally
        {
            isSubmitting = false;
        }
    }

    private async Task DeletePackage()
    {
        if (package == null) return;
        try
        {
            // Delete image file
            if (!string.IsNullOrEmpty(package.ImageUrl))
            {
                var imgPath = Path.Combine(Environment.WebRootPath, package.ImageUrl.TrimStart('/').Replace('/', Path.DirectorySeparatorChar));
                if (File.Exists(imgPath)) File.Delete(imgPath);
            }
            await EventService.DeletePackageAsync(package.Id);
            Navigation.NavigateTo("/owner/event-packages");
        }
        catch (Exception ex)
        {
            errorMessage = $"Error deleting package: {ex.Message}";
            showDeleteConfirm = false;
        }
    }

    private void Cancel()
    {
        Navigation.NavigateTo("/owner/event-packages");
    }
}
