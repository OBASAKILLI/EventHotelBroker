@page "/owner/bookings"
@rendermode InteractiveServer
@using EventHotelBroker.Models
@using EventHotelBroker.Services
@using EventHotelBroker.Utils
@using System.Security.Claims
@using Microsoft.AspNetCore.Components.Authorization
@inject IHotelService HotelService
@inject IBookingService BookingService
@inject IJSRuntime JSRuntime
@inject AuthenticationStateProvider AuthStateProvider

<PageTitle>Booking Requests - EventHotelBroker</PageTitle>

<link href="/css/owner-bookings.css?v=2" rel="stylesheet" />

<div class="ob">
    <Breadcrumb Items="@breadcrumbItems" />

    <!-- Header -->
    <div class="ob-header">
        <div>
            <h1 class="ob-header-title"><i class="bi bi-journal-bookmark"></i> Booking Requests</h1>
            <p class="ob-header-sub">Manage booking requests for your hotels</p>
        </div>
        <button class="ob-btn ob-btn-refresh" @onclick="RefreshData">
            <i class="bi bi-arrow-clockwise"></i> Refresh
        </button>
    </div>

    <!-- Stats -->
    <div class="ob-stats">
        <div class="ob-stat">
            <div>
                <div class="ob-stat-value">@bookings.Count</div>
                <div class="ob-stat-label">Total Bookings</div>
            </div>
            <div class="ob-stat-icon ob-icon-terracotta"><i class="bi bi-journal-bookmark"></i></div>
        </div>
        <div class="ob-stat">
            <div>
                <div class="ob-stat-value">@bookings.Count(b => b.Status == BookingStatus.Pending)</div>
                <div class="ob-stat-label">Pending</div>
            </div>
            <div class="ob-stat-icon ob-icon-bronze"><i class="bi bi-clock-history"></i></div>
        </div>
        <div class="ob-stat">
            <div>
                <div class="ob-stat-value">@bookings.Count(b => b.Status == BookingStatus.Confirmed)</div>
                <div class="ob-stat-label">Confirmed</div>
            </div>
            <div class="ob-stat-icon ob-icon-teal"><i class="bi bi-check-circle"></i></div>
        </div>
        <div class="ob-stat">
            <div>
                <div class="ob-stat-value">@bookings.Count(b => b.Status == BookingStatus.Rejected || b.Status == BookingStatus.Cancelled)</div>
                <div class="ob-stat-label">Rejected / Cancelled</div>
            </div>
            <div class="ob-stat-icon ob-icon-charcoal"><i class="bi bi-x-circle"></i></div>
        </div>
    </div>

    <!-- Search & Filter -->
    <div class="ob-search-bar">
        <div class="ob-search-wrap">
            <i class="bi bi-search"></i>
            <input type="text" class="ob-search-input" placeholder="Search by hotel, guest, or booking ID..." @bind="searchTerm" @bind:event="oninput" />
        </div>
        <select class="ob-filter-select" @bind="statusFilter" @bind:event="onchange">
            <option value="">All Status</option>
            <option value="Pending">Pending</option>
            <option value="Confirmed">Confirmed</option>
            <option value="Rejected">Rejected</option>
            <option value="Cancelled">Cancelled</option>
        </select>
        <span class="ob-search-count">@filteredBookings.Count() of @bookings.Count</span>
    </div>

    @if (isLoading)
    {
        <div class="ob-card">
            <div class="ob-loading">
                <div class="ob-spinner"></div>
                <div class="ob-loading-text">Loading bookings...</div>
            </div>
        </div>
    }
    else if (!bookings.Any())
    {
        <div class="ob-card">
            <div class="ob-empty">
                <div class="ob-empty-icon"><i class="bi bi-journal-x"></i></div>
                <div class="ob-empty-title">No Booking Requests</div>
                <div class="ob-empty-text">No booking requests yet for your hotels.</div>
            </div>
        </div>
    }
    else if (!filteredBookings.Any())
    {
        <div class="ob-card">
            <div class="ob-empty">
                <div class="ob-empty-icon"><i class="bi bi-search"></i></div>
                <div class="ob-empty-title">No Results</div>
                <div class="ob-empty-text">No bookings match your search criteria.</div>
            </div>
        </div>
    }
    else
    {
        <div class="ob-card">
            <div class="ob-card-header">
                <h5 class="ob-card-title"><i class="bi bi-table"></i> Booking Requests</h5>
                <span class="ob-card-count">@filteredBookings.Count() records</span>
            </div>
            <div style="overflow-x:auto;">
                <table class="ob-table">
                    <thead>
                        <tr>
                            <th>ID</th>
                            <th>Hotel</th>
                            <th>Guest</th>
                            <th>Dates</th>
                            <th>Guests</th>
                            <th>Status</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var booking in filteredBookings)
                        {
                            <tr>
                                <td><span class="ob-id">#@booking.Id</span></td>
                                <td><span class="ob-hotel">@booking.Hotel?.Name</span></td>
                                <td>
                                    <span class="ob-guest"><i class="bi bi-person"></i> @booking.User?.FullName</span>
                                </td>
                                <td>
                                    <div class="ob-date-range">
                                        <span class="ob-date">@booking.StartDate.ToString("MMM dd")</span>
                                        <i class="bi bi-arrow-right"></i>
                                        <span class="ob-date">@booking.EndDate.ToString("MMM dd, yyyy")</span>
                                    </div>
                                </td>
                                <td>
                                    <span class="ob-headcount"><i class="bi bi-people"></i> @booking.HeadCount</span>
                                </td>
                                <td>
                                    <span class="ob-badge @GetObStatusBadge(booking.Status)">
                                        <i class="bi @GetStatusIcon(booking.Status)"></i> @booking.Status
                                    </span>
                                </td>
                                <td>
                                    <div class="ob-actions">
                                        <button class="ob-btn ob-btn-sm ob-btn-view" @onclick="() => ViewBooking(booking)" title="View Details">
                                            <i class="bi bi-eye"></i>
                                        </button>
                                        @if (booking.Status == BookingStatus.Pending)
                                        {
                                            <button class="ob-btn ob-btn-sm ob-btn-confirm" @onclick="() => OpenConfirmModal(booking)" title="Confirm">
                                                <i class="bi bi-check-lg"></i>
                                            </button>
                                            <button class="ob-btn ob-btn-sm ob-btn-reject" @onclick="() => OpenRejectModal(booking)" title="Reject">
                                                <i class="bi bi-x-lg"></i>
                                            </button>
                                        }
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }

    @if (!string.IsNullOrEmpty(message))
    {
        <div class="ob-toast @(messageType == "success" ? "ob-toast-success" : "ob-toast-error")">
            <div class="ob-toast-header">
                <span class="ob-toast-label">@(messageType == "success" ? "Success" : "Error")</span>
                <button class="ob-toast-close" @onclick="() => message = null"><i class="bi bi-x"></i></button>
            </div>
            <div class="ob-toast-body">@message</div>
        </div>
    }
</div>

@* ── Modals (outside .ob container to avoid overflow clip) ── *@

<div class="modal-overlay" style="display:@(showViewModal ? "flex" : "none")">
    <div class="modal-dialog">
        <div class="modal-header-custom">
            <h5><i class="bi bi-eye"></i> Booking Details</h5>
            <button class="modal-close" @onclick="CloseModals"><i class="bi bi-x-lg"></i></button>
        </div>
        <div class="modal-body-custom">
            @if (selectedBooking != null)
            {
                <div class="detail-grid">
                    <div class="detail-item">
                        <span class="detail-label">Booking ID</span>
                        <span class="detail-value">#@selectedBooking.Id</span>
                    </div>
                    <div class="detail-item">
                        <span class="detail-label">Status</span>
                        <span class="ob-badge @GetObStatusBadge(selectedBooking.Status)"><i class="bi @GetStatusIcon(selectedBooking.Status)"></i> @selectedBooking.Status</span>
                    </div>
                    <div class="detail-item">
                        <span class="detail-label">Hotel</span>
                        <span class="detail-value">@(selectedBooking.Hotel?.Name ?? "N/A")</span>
                    </div>
                    <div class="detail-item">
                        <span class="detail-label">Location</span>
                        <span class="detail-value">@(selectedBooking.Hotel?.City ?? "N/A"), @(selectedBooking.Hotel?.Country ?? "")</span>
                    </div>
                    <div class="detail-item">
                        <span class="detail-label">Guest</span>
                        <span class="detail-value">@(selectedBooking.User?.FullName ?? "N/A")</span>
                    </div>
                    <div class="detail-item">
                        <span class="detail-label">Email</span>
                        <span class="detail-value">@(selectedBooking.User?.Email ?? "N/A")</span>
                    </div>
                    <div class="detail-item">
                        <span class="detail-label">Check-In</span>
                        <span class="detail-value">@selectedBooking.StartDate.ToString("MMM dd, yyyy")</span>
                    </div>
                    <div class="detail-item">
                        <span class="detail-label">Check-Out</span>
                        <span class="detail-value">@selectedBooking.EndDate.ToString("MMM dd, yyyy")</span>
                    </div>
                    <div class="detail-item">
                        <span class="detail-label">Guests</span>
                        <span class="detail-value">@selectedBooking.HeadCount</span>
                    </div>
                    <div class="detail-item">
                        <span class="detail-label">Booked On</span>
                        <span class="detail-value">@selectedBooking.CreatedAt.ToString("MMM dd, yyyy HH:mm")</span>
                    </div>
                </div>
                @if (!string.IsNullOrEmpty(selectedBooking.Notes))
                {
                    <div class="detail-notes">
                        <span class="detail-label">Notes</span>
                        <p>@selectedBooking.Notes</p>
                    </div>
                }
                @if (selectedBooking.Status == BookingStatus.Rejected)
                {
                    <div class="detail-rejection">
                        <span class="detail-label"><i class="bi bi-x-circle"></i> Rejection Info</span>
                        <p class="rejection-reason">@(selectedBooking.RejectionReason ?? "No reason provided")</p>
                        @if (selectedBooking.RejectedAt.HasValue)
                        {
                            <small class="rejection-date">Rejected on @selectedBooking.RejectedAt.Value.ToString("MMM dd, yyyy HH:mm")</small>
                        }
                    </div>
                }
            }
        </div>
        <div class="modal-footer-custom">
            <button class="ob-btn ob-btn-outline" @onclick="CloseModals">Close</button>
        </div>
    </div>
</div>

<div class="modal-overlay" style="display:@(showConfirmModal ? "flex" : "none")">
    <div class="modal-dialog modal-sm">
        <div class="modal-body-custom text-center" style="padding:2rem;">
            <div class="modal-alert-icon confirm-icon"><i class="bi bi-check-circle"></i></div>
            <h4 style="margin:1rem 0 0.5rem;">Confirm Booking?</h4>
            <p style="color:#8a8177;margin-bottom:0.5rem;">You are about to confirm the booking for:</p>
            <div class="modal-alert-detail">
                <strong>@(selectedBooking?.Hotel?.Name ?? "N/A")</strong><br/>
                <span>@(selectedBooking?.User?.FullName ?? "Guest") &middot; @(selectedBooking?.StartDate.ToString("MMM dd") ?? "") - @(selectedBooking?.EndDate.ToString("MMM dd, yyyy") ?? "")</span>
            </div>
        </div>
        <div class="modal-footer-custom">
            <button class="ob-btn ob-btn-outline" @onclick="CloseModals">Cancel</button>
            <button class="ob-btn ob-btn-confirm" @onclick="ConfirmBooking" disabled="@isProcessing">
                @if (isProcessing) { <span class="spinner-border spinner-border-sm me-1"></span> }
                <i class="bi bi-check-lg"></i> Confirm
            </button>
        </div>
    </div>
</div>

<div class="modal-overlay" style="display:@(showRejectModal ? "flex" : "none")">
    <div class="modal-dialog modal-sm">
        <div class="modal-body-custom text-center" style="padding:2rem;">
            <div class="modal-alert-icon reject-icon"><i class="bi bi-x-circle"></i></div>
            <h4 style="margin:1rem 0 0.5rem;">Reject Booking?</h4>
            <p style="color:#8a8177;margin-bottom:0.5rem;">You are about to reject the booking for:</p>
            <div class="modal-alert-detail">
                <strong>@(selectedBooking?.Hotel?.Name ?? "N/A")</strong><br/>
                <span>@(selectedBooking?.User?.FullName ?? "Guest") &middot; @(selectedBooking?.StartDate.ToString("MMM dd") ?? "") - @(selectedBooking?.EndDate.ToString("MMM dd, yyyy") ?? "")</span>
            </div>
            <div class="mt-3" style="text-align:left;">
                <label class="detail-label">Reason for rejection (optional)</label>
                <textarea class="modal-textarea" @bind="rejectionReason" @bind:event="oninput" placeholder="Enter reason for rejection..."></textarea>
            </div>
        </div>
        <div class="modal-footer-custom">
            <button class="ob-btn ob-btn-outline" @onclick="CloseModals">Cancel</button>
            <button class="ob-btn ob-btn-reject" @onclick="RejectBooking" disabled="@isProcessing">
                @if (isProcessing) { <span class="spinner-border spinner-border-sm me-1"></span> }
                <i class="bi bi-x-lg"></i> Reject
            </button>
        </div>
    </div>
</div>

@code {
    private bool isLoading = true;
    private List<Booking> bookings = new();
    private string? currentUserId;
    private string? message;
    private string messageType = "success";
    private string searchTerm = "";
    private string statusFilter = "";

    // Modal state
    private bool showViewModal = false;
    private bool showConfirmModal = false;
    private bool showRejectModal = false;
    private Booking? selectedBooking;
    private string rejectionReason = "";
    private bool isProcessing = false;

    private List<BreadcrumbItem> breadcrumbItems = new()
    {
        new BreadcrumbItem { Text = "Home", Url = "/" },
        new BreadcrumbItem { Text = "Owner Dashboard", Url = "/owner/dashboard" },
        new BreadcrumbItem { Text = "Booking Requests", IsActive = true }
    };

    private IEnumerable<Booking> filteredBookings => bookings.Where(b =>
    {
        if (!string.IsNullOrEmpty(statusFilter))
        {
            if (Enum.TryParse<BookingStatus>(statusFilter, out var status))
            {
                if (b.Status != status) return false;
            }
        }
        if (!string.IsNullOrWhiteSpace(searchTerm))
        {
            var term = searchTerm.Trim().ToLower();
            return (b.Hotel?.Name?.ToLower().Contains(term) ?? false)
                || (b.User?.FullName?.ToLower().Contains(term) ?? false)
                || b.Id.ToString().Contains(term);
        }
        return true;
    });

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            currentUserId = await GetCurrentUserIdAsync();
            await LoadBookings();
            StateHasChanged();
        }
    }

    private async Task LoadBookings()
    {
        isLoading = true;
        try
        {
            if (!string.IsNullOrEmpty(currentUserId))
            {
                var myHotels = await HotelService.GetHotelsByOwnerAsync(currentUserId);
                bookings = new List<Booking>();
                
                foreach (var hotel in myHotels)
                {
                    var hotelBookings = await BookingService.GetBookingsByHotelAsync(hotel.Id);
                    bookings.AddRange(hotelBookings);
                }
                
                bookings = bookings.OrderByDescending(b => b.CreatedAt).ToList();
            }
        }
        catch (Exception)
        {
            // Handle error
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task<string?> GetCurrentUserIdAsync()
    {
        try
        {
            string? token = null;
            try { token = await JSRuntime.InvokeAsync<string>("authHelpers.getCookie", "JWToken"); } catch { }
            if (!string.IsNullOrEmpty(token))
            {
                var customAuth = (CustomAuthenticationStateProvider)AuthStateProvider;
                await customAuth.MarkUserAsAuthenticated(token);
            }
            var authState = await AuthStateProvider.GetAuthenticationStateAsync();
            var user = authState?.User;
            if (user?.Identity?.IsAuthenticated == true)
            {
                var nameClaim = user.FindFirst(ClaimTypes.Name)?.Value;
                if (!string.IsNullOrEmpty(nameClaim))
                {
                    var parts = nameClaim.Split(',');
                    if (parts.Length > 0) return parts[0];
                }
            }
        }
        catch { }
        return null;
    }

    private async Task RefreshData()
    {
        await LoadBookings();
    }

    private void ViewBooking(Booking booking)
    {
        selectedBooking = booking;
        showViewModal = true;
    }

    private void OpenConfirmModal(Booking booking)
    {
        selectedBooking = booking;
        showConfirmModal = true;
    }

    private void OpenRejectModal(Booking booking)
    {
        selectedBooking = booking;
        rejectionReason = "";
        showRejectModal = true;
    }

    private void CloseModals()
    {
        showViewModal = false;
        showConfirmModal = false;
        showRejectModal = false;
        selectedBooking = null;
        rejectionReason = "";
    }

    private async Task ConfirmBooking()
    {
        if (selectedBooking == null) return;
        isProcessing = true;
        try
        {
            var result = await BookingService.ConfirmBookingAsync(selectedBooking.Id);
            if (result)
            {
                ShowMessage("Booking confirmed successfully!", "success");
                CloseModals();
                await LoadBookings();
            }
            else
            {
                ShowMessage("Failed to confirm booking.", "error");
            }
        }
        catch (Exception ex)
        {
            ShowMessage($"Error: {ex.Message}", "error");
        }
        finally { isProcessing = false; }
    }

    private async Task RejectBooking()
    {
        if (selectedBooking == null) return;
        isProcessing = true;
        try
        {
            var result = await BookingService.RejectBookingAsync(selectedBooking.Id, string.IsNullOrWhiteSpace(rejectionReason) ? null : rejectionReason.Trim());
            if (result)
            {
                ShowMessage("Booking rejected.", "success");
                CloseModals();
                await LoadBookings();
            }
            else
            {
                ShowMessage("Failed to reject booking.", "error");
            }
        }
        catch (Exception ex)
        {
            ShowMessage($"Error: {ex.Message}", "error");
        }
        finally { isProcessing = false; }
    }

    private void ShowMessage(string msg, string type)
    {
        message = msg;
        messageType = type;
        StateHasChanged();
    }

    private string GetObStatusBadge(BookingStatus status)
    {
        return status switch
        {
            BookingStatus.Pending => "ob-badge-pending",
            BookingStatus.Confirmed => "ob-badge-confirmed",
            BookingStatus.Rejected => "ob-badge-rejected",
            BookingStatus.Cancelled => "ob-badge-cancelled",
            _ => "ob-badge-cancelled"
        };
    }

    private string GetStatusIcon(BookingStatus status)
    {
        return status switch
        {
            BookingStatus.Pending => "bi-clock-history",
            BookingStatus.Confirmed => "bi-check-circle",
            BookingStatus.Rejected => "bi-x-circle",
            BookingStatus.Cancelled => "bi-dash-circle",
            _ => "bi-circle"
        };
    }
}
