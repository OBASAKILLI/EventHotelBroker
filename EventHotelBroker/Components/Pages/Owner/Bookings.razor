@page "/owner/bookings"
@rendermode InteractiveServer
@using EventHotelBroker.Models
@using EventHotelBroker.Services
@inject IHotelService HotelService
@inject IBookingService BookingService

<PageTitle>Booking Requests - EventHotelBroker</PageTitle>

<link href="/css/owner-bookings.css?v=1" rel="stylesheet" />

<div class="ob">
    <Breadcrumb Items="@breadcrumbItems" />

    <!-- Header -->
    <div class="ob-header">
        <div>
            <h1 class="ob-header-title"><i class="bi bi-journal-bookmark"></i> Booking Requests</h1>
            <p class="ob-header-sub">Manage booking requests for your hotels</p>
        </div>
        <button class="ob-btn ob-btn-refresh" @onclick="RefreshData">
            <i class="bi bi-arrow-clockwise"></i> Refresh
        </button>
    </div>

    <!-- Stats -->
    <div class="ob-stats">
        <div class="ob-stat">
            <div>
                <div class="ob-stat-value">@bookings.Count</div>
                <div class="ob-stat-label">Total Bookings</div>
            </div>
            <div class="ob-stat-icon ob-icon-terracotta"><i class="bi bi-journal-bookmark"></i></div>
        </div>
        <div class="ob-stat">
            <div>
                <div class="ob-stat-value">@bookings.Count(b => b.Status == BookingStatus.Pending)</div>
                <div class="ob-stat-label">Pending</div>
            </div>
            <div class="ob-stat-icon ob-icon-bronze"><i class="bi bi-clock-history"></i></div>
        </div>
        <div class="ob-stat">
            <div>
                <div class="ob-stat-value">@bookings.Count(b => b.Status == BookingStatus.Confirmed)</div>
                <div class="ob-stat-label">Confirmed</div>
            </div>
            <div class="ob-stat-icon ob-icon-teal"><i class="bi bi-check-circle"></i></div>
        </div>
        <div class="ob-stat">
            <div>
                <div class="ob-stat-value">@bookings.Count(b => b.Status == BookingStatus.Rejected || b.Status == BookingStatus.Cancelled)</div>
                <div class="ob-stat-label">Rejected / Cancelled</div>
            </div>
            <div class="ob-stat-icon ob-icon-charcoal"><i class="bi bi-x-circle"></i></div>
        </div>
    </div>

    <!-- Search & Filter -->
    <div class="ob-search-bar">
        <div class="ob-search-wrap">
            <i class="bi bi-search"></i>
            <input type="text" class="ob-search-input" placeholder="Search by hotel, guest, or booking ID..." @bind="searchTerm" @bind:event="oninput" />
        </div>
        <select class="ob-filter-select" @bind="statusFilter" @bind:event="onchange">
            <option value="">All Status</option>
            <option value="Pending">Pending</option>
            <option value="Confirmed">Confirmed</option>
            <option value="Rejected">Rejected</option>
            <option value="Cancelled">Cancelled</option>
        </select>
        <span class="ob-search-count">@filteredBookings.Count() of @bookings.Count</span>
    </div>

    @if (isLoading)
    {
        <div class="ob-card">
            <div class="ob-loading">
                <div class="ob-spinner"></div>
                <div class="ob-loading-text">Loading bookings...</div>
            </div>
        </div>
    }
    else if (!bookings.Any())
    {
        <div class="ob-card">
            <div class="ob-empty">
                <div class="ob-empty-icon"><i class="bi bi-journal-x"></i></div>
                <div class="ob-empty-title">No Booking Requests</div>
                <div class="ob-empty-text">No booking requests yet for your hotels.</div>
            </div>
        </div>
    }
    else if (!filteredBookings.Any())
    {
        <div class="ob-card">
            <div class="ob-empty">
                <div class="ob-empty-icon"><i class="bi bi-search"></i></div>
                <div class="ob-empty-title">No Results</div>
                <div class="ob-empty-text">No bookings match your search criteria.</div>
            </div>
        </div>
    }
    else
    {
        <div class="ob-card">
            <div class="ob-card-header">
                <h5 class="ob-card-title"><i class="bi bi-table"></i> Booking Requests</h5>
                <span class="ob-card-count">@filteredBookings.Count() records</span>
            </div>
            <div style="overflow-x:auto;">
                <table class="ob-table">
                    <thead>
                        <tr>
                            <th>ID</th>
                            <th>Hotel</th>
                            <th>Guest</th>
                            <th>Dates</th>
                            <th>Guests</th>
                            <th>Status</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var booking in filteredBookings)
                        {
                            <tr>
                                <td><span class="ob-id">#@booking.Id</span></td>
                                <td><span class="ob-hotel">@booking.Hotel?.Name</span></td>
                                <td>
                                    <span class="ob-guest"><i class="bi bi-person"></i> @booking.User?.FullName</span>
                                </td>
                                <td>
                                    <div class="ob-date-range">
                                        <span class="ob-date">@booking.StartDate.ToString("MMM dd")</span>
                                        <i class="bi bi-arrow-right"></i>
                                        <span class="ob-date">@booking.EndDate.ToString("MMM dd, yyyy")</span>
                                    </div>
                                </td>
                                <td>
                                    <span class="ob-headcount"><i class="bi bi-people"></i> @booking.HeadCount</span>
                                </td>
                                <td>
                                    <span class="ob-badge @GetObStatusBadge(booking.Status)">
                                        <i class="bi @GetStatusIcon(booking.Status)"></i> @booking.Status
                                    </span>
                                </td>
                                <td>
                                    @if (booking.Status == BookingStatus.Pending)
                                    {
                                        <div class="ob-actions">
                                            <button class="ob-btn ob-btn-sm ob-btn-confirm" @onclick="() => ConfirmBooking(booking.Id)" title="Confirm">
                                                <i class="bi bi-check-lg"></i> Confirm
                                            </button>
                                            <button class="ob-btn ob-btn-sm ob-btn-reject" @onclick="() => RejectBooking(booking.Id)" title="Reject">
                                                <i class="bi bi-x-lg"></i> Reject
                                            </button>
                                        </div>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }

    @if (!string.IsNullOrEmpty(message))
    {
        <div class="ob-toast @(messageType == "success" ? "ob-toast-success" : "ob-toast-error")">
            <div class="ob-toast-header">
                <span class="ob-toast-label">@(messageType == "success" ? "Success" : "Error")</span>
                <button class="ob-toast-close" @onclick="() => message = null"><i class="bi bi-x"></i></button>
            </div>
            <div class="ob-toast-body">@message</div>
        </div>
    }
</div>

@code {
    private bool isLoading = true;
    private List<Booking> bookings = new();
    private string currentUserId = "1"; // Default owner ID
    private string? message;
    private string messageType = "success";
    private string searchTerm = "";
    private string statusFilter = "";

    private List<BreadcrumbItem> breadcrumbItems = new()
    {
        new BreadcrumbItem { Text = "Home", Url = "/" },
        new BreadcrumbItem { Text = "Owner Dashboard", Url = "/owner/dashboard" },
        new BreadcrumbItem { Text = "Booking Requests", IsActive = true }
    };

    private IEnumerable<Booking> filteredBookings => bookings.Where(b =>
    {
        if (!string.IsNullOrEmpty(statusFilter))
        {
            if (Enum.TryParse<BookingStatus>(statusFilter, out var status))
            {
                if (b.Status != status) return false;
            }
        }
        if (!string.IsNullOrWhiteSpace(searchTerm))
        {
            var term = searchTerm.Trim().ToLower();
            return (b.Hotel?.Name?.ToLower().Contains(term) ?? false)
                || (b.User?.FullName?.ToLower().Contains(term) ?? false)
                || b.Id.ToString().Contains(term);
        }
        return true;
    });

    protected override async Task OnInitializedAsync()
    {
        await LoadBookings();
    }

    private async Task LoadBookings()
    {
        isLoading = true;
        try
        {
            var myHotels = await HotelService.GetHotelsByOwnerAsync(currentUserId);
            bookings = new List<Booking>();
            
            foreach (var hotel in myHotels)
            {
                var hotelBookings = await BookingService.GetBookingsByHotelAsync(hotel.Id);
                bookings.AddRange(hotelBookings);
            }
            
            bookings = bookings.OrderByDescending(b => b.CreatedAt).ToList();
        }
        catch (Exception)
        {
            // Handle error
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task RefreshData()
    {
        await LoadBookings();
    }

    private async Task ConfirmBooking(int bookingId)
    {
        try
        {
            var result = await BookingService.ConfirmBookingAsync(bookingId);
            if (result)
            {
                ShowMessage("Booking confirmed successfully!", "success");
                await LoadBookings();
            }
            else
            {
                ShowMessage("Failed to confirm booking.", "error");
            }
        }
        catch (Exception ex)
        {
            ShowMessage($"Error: {ex.Message}", "error");
        }
    }

    private async Task RejectBooking(int bookingId)
    {
        try
        {
            var result = await BookingService.RejectBookingAsync(bookingId);
            if (result)
            {
                ShowMessage("Booking rejected.", "success");
                await LoadBookings();
            }
            else
            {
                ShowMessage("Failed to reject booking.", "error");
            }
        }
        catch (Exception ex)
        {
            ShowMessage($"Error: {ex.Message}", "error");
        }
    }

    private void ShowMessage(string msg, string type)
    {
        message = msg;
        messageType = type;
        StateHasChanged();
    }

    private string GetObStatusBadge(BookingStatus status)
    {
        return status switch
        {
            BookingStatus.Pending => "ob-badge-pending",
            BookingStatus.Confirmed => "ob-badge-confirmed",
            BookingStatus.Rejected => "ob-badge-rejected",
            BookingStatus.Cancelled => "ob-badge-cancelled",
            _ => "ob-badge-cancelled"
        };
    }

    private string GetStatusIcon(BookingStatus status)
    {
        return status switch
        {
            BookingStatus.Pending => "bi-clock-history",
            BookingStatus.Confirmed => "bi-check-circle",
            BookingStatus.Rejected => "bi-x-circle",
            BookingStatus.Cancelled => "bi-dash-circle",
            _ => "bi-circle"
        };
    }
}
