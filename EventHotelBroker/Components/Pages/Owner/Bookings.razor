@code {
    private bool isLoading = true;
    private string activeTab = "hotel";

    // Hotel bookings
    private List<Booking> bookings = new();
    private string searchTerm = "";
    private string statusFilter = "";

    // Event bookings
    private List<EventPackage> packages = new();
    private List<EventBooking> eventBookings = new();
    private string evtSearchTerm = "";
    private string evtStatusFilter = "";

    private string? currentUserId;
    private string? message;
    private string messageType = "success";
    private bool isProcessing = false;

    // Hotel modal state
    private bool showViewModal = false;
    private bool showConfirmModal = false;
    private bool showRejectModal = false;
    private Booking? selectedBooking;
    private string rejectionReason = "";

    // Event modal state
    private bool showEvtViewModal = false;
    private bool showEvtConfirmModal = false;
    private bool showEvtRejectModal = false;
    private bool showEvtCompleteModal = false;
    private EventBooking? selectedEventBooking;
    private string evtRejectionReason = "";

    private List<BreadcrumbItem> breadcrumbItems = new()
    {
        new BreadcrumbItem { Text = "Home", Url = "/" },
        new BreadcrumbItem { Text = "Owner Dashboard", Url = "/owner/dashboard" },
        new BreadcrumbItem { Text = "Booking Requests", IsActive = true }
    };

    // Filtered hotel bookings
    private IEnumerable<Booking> filteredBookings => bookings.Where(b =>
    {
        if (!string.IsNullOrEmpty(statusFilter))
            if (Enum.TryParse<BookingStatus>(statusFilter, out var s) && b.Status != s) return false;
        if (!string.IsNullOrWhiteSpace(searchTerm))
        {
            var term = searchTerm.Trim().ToLower();
            return (b.Hotel?.Name?.ToLower().Contains(term) ?? false)
                || (b.User?.FullName?.ToLower().Contains(term) ?? false)
                || b.Id.ToString().Contains(term);
        }
        return true;
    });

    // Filtered event bookings
    private IEnumerable<EventBooking> filteredEventBookings => eventBookings.Where(b =>
    {
        if (!string.IsNullOrEmpty(evtStatusFilter))
            if (Enum.TryParse<EventBookingStatus>(evtStatusFilter, out var s) && b.Status != s) return false;
        if (!string.IsNullOrWhiteSpace(evtSearchTerm))
        {
            var term = evtSearchTerm.Trim().ToLower();
            return (b.EventName?.ToLower().Contains(term) ?? false)
                || (b.ContactName?.ToLower().Contains(term) ?? false)
                || (b.Venue?.ToLower().Contains(term) ?? false)
                || b.Id.ToString().Contains(term);
        }
        return true;
    });

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            currentUserId = await GetCurrentUserIdAsync();
            await LoadAllData();
            StateHasChanged();
        }
    }

    private async Task LoadAllData()
    {
        isLoading = true;
        try
        {
            await Task.WhenAll(LoadHotelBookings(), LoadEventBookings());
        }
        finally { isLoading = false; }
    }

    private async Task LoadHotelBookings()
    {
        if (string.IsNullOrEmpty(currentUserId)) return;
        try
        {
            var myHotels = await HotelService.GetHotelsByOwnerAsync(currentUserId);
            bookings = new List<Booking>();
            foreach (var hotel in myHotels)
            {
                var hb = await BookingService.GetBookingsByHotelAsync(hotel.Id);
                bookings.AddRange(hb);
            }
            bookings = bookings.OrderByDescending(b => b.CreatedAt).ToList();
        }
        catch { }
    }

    private async Task LoadEventBookings()
    {
        if (string.IsNullOrEmpty(currentUserId)) return;
        try
        {
            var myPackages = await EventService.GetPackagesByProviderAsync(currentUserId);
            packages = myPackages.ToList();
            var myPackageIds = packages.Select(p => p.Id).ToHashSet();
            var allEvtBookings = await EventService.GetAllBookingsAsync();
            eventBookings = allEvtBookings
                .Where(b => b.PackageId.HasValue && myPackageIds.Contains(b.PackageId.Value))
                .OrderByDescending(b => b.CreatedAt)
                .ToList();
        }
        catch { }
    }

    private void SwitchTab(string tab) { activeTab = tab; message = null; }

    private async Task RefreshData()
    {
        currentUserId = await GetCurrentUserIdAsync();
        await LoadAllData();
    }

    // ── Hotel modal openers ──
    private void ViewBooking(Booking b)       { selectedBooking = b; showViewModal = true; }
    private void OpenConfirmModal(Booking b)  { selectedBooking = b; showConfirmModal = true; }
    private void OpenRejectModal(Booking b)   { selectedBooking = b; rejectionReason = ""; showRejectModal = true; }

    // ── Event modal openers ──
    private void ViewEventBooking(EventBooking b)      { selectedEventBooking = b; showEvtViewModal = true; }
    private void OpenEvtConfirmModal(EventBooking b)   { selectedEventBooking = b; showEvtConfirmModal = true; }
    private void OpenEvtRejectModal(EventBooking b)    { selectedEventBooking = b; evtRejectionReason = ""; showEvtRejectModal = true; }
    private void OpenEvtCompleteModal(EventBooking b)  { selectedEventBooking = b; showEvtCompleteModal = true; }

    private async Task CloseModals()
    {
        showViewModal = showConfirmModal = showRejectModal = false;
        showEvtViewModal = showEvtConfirmModal = showEvtRejectModal = showEvtCompleteModal = false;
        selectedBooking = null; rejectionReason = "";
        selectedEventBooking = null; evtRejectionReason = "";
        await InvokeAsync(StateHasChanged);
    }

    // ── Hotel actions ──
    private async Task ConfirmBooking()
    {
        if (selectedBooking == null) return;
        isProcessing = true;
        try
        {
            var result = await BookingService.ConfirmBookingAsync(selectedBooking.Id);
            message = result ? "Booking confirmed!" : "Failed to confirm.";
            messageType = result ? "success" : "error";
            if (result) { await CloseModals(); await LoadHotelBookings(); }
        }
        catch (Exception ex) { message = $"Error: {ex.Message}"; messageType = "error"; }
        finally { isProcessing = false; }
    }

    private async Task RejectBooking()
    {
        if (selectedBooking == null) return;
        isProcessing = true;
        try
        {
            var result = await BookingService.RejectBookingAsync(selectedBooking.Id, string.IsNullOrWhiteSpace(rejectionReason) ? null : rejectionReason.Trim());
            message = result ? "Booking rejected." : "Failed to reject.";
            messageType = result ? "success" : "error";
            if (result) { await CloseModals(); await LoadHotelBookings(); }
        }
        catch (Exception ex) { message = $"Error: {ex.Message}"; messageType = "error"; }
        finally { isProcessing = false; }
    }

    // ── Event actions ──
    private async Task ConfirmEventBooking()
    {
        if (selectedEventBooking == null) return;
        isProcessing = true;
        try
        {
            var result = await EventService.ConfirmBookingAsync(selectedEventBooking.Id);
            message = result ? "Event booking confirmed!" : "Failed to confirm.";
            messageType = result ? "success" : "error";
            if (result) { await CloseModals(); await LoadEventBookings(); }
        }
        catch (Exception ex) { message = $"Error: {ex.Message}"; messageType = "error"; }
        finally { isProcessing = false; }
    }

    private async Task RejectEventBooking()
    {
        if (selectedEventBooking == null) return;
        isProcessing = true;
        try
        {
            var reason = string.IsNullOrWhiteSpace(evtRejectionReason) ? "" : evtRejectionReason.Trim();
            var result = await EventService.RejectBookingAsync(selectedEventBooking.Id, reason);
            message = result ? "Event booking rejected." : "Failed to reject.";
            messageType = result ? "success" : "error";
            if (result) { await CloseModals(); await LoadEventBookings(); }
        }
        catch (Exception ex) { message = $"Error: {ex.Message}"; messageType = "error"; }
        finally { isProcessing = false; }
    }

    private async Task CompleteEventBooking()
    {
        if (selectedEventBooking == null) return;
        isProcessing = true;
        try
        {
            var result = await EventService.CompleteBookingAsync(selectedEventBooking.Id);
            message = result ? "Event marked as complete!" : "Failed to complete.";
            messageType = result ? "success" : "error";
            if (result) { await CloseModals(); await LoadEventBookings(); }
        }
        catch (Exception ex) { message = $"Error: {ex.Message}"; messageType = "error"; }
        finally { isProcessing = false; }
    }

    // ── Helpers ──
    private async Task<string?> GetCurrentUserIdAsync()
    {
        try
        {
            string? token = null;
            try { token = await JSRuntime.InvokeAsync<string>("authHelpers.getCookie", "JWToken"); } catch { }
            if (!string.IsNullOrEmpty(token))
            {
                var customAuth = (CustomAuthenticationStateProvider)AuthStateProvider;
                await customAuth.MarkUserAsAuthenticated(token);
            }
            var authState = await AuthStateProvider.GetAuthenticationStateAsync();
            var user = authState?.User;
            if (user?.Identity?.IsAuthenticated == true)
            {
                var nameClaim = user.FindFirst(ClaimTypes.Name)?.Value;
                if (!string.IsNullOrEmpty(nameClaim))
                {
                    var parts = nameClaim.Split(',');
                    if (parts.Length > 0) return parts[0];
                }
            }
        }
        catch { }
        return null;
    }

    private string GetObStatusBadge(BookingStatus s) => s switch
    {
        BookingStatus.Pending => "ob-badge-pending", BookingStatus.Confirmed => "ob-badge-confirmed",
        BookingStatus.Rejected => "ob-badge-rejected", BookingStatus.Cancelled => "ob-badge-cancelled",
        _ => "ob-badge-cancelled"
    };

    private string GetStatusIcon(BookingStatus s) => s switch
    {
        BookingStatus.Pending => "bi-clock-history", BookingStatus.Confirmed => "bi-check-circle",
        BookingStatus.Rejected => "bi-x-circle", BookingStatus.Cancelled => "bi-dash-circle",
        _ => "bi-circle"
    };

    private string GetEvtStatusBadge(EventBookingStatus s) => s switch
    {
        EventBookingStatus.Pending => "ob-badge-pending", EventBookingStatus.Confirmed => "ob-badge-confirmed",
        EventBookingStatus.Rejected => "ob-badge-rejected", EventBookingStatus.Cancelled => "ob-badge-cancelled",
        EventBookingStatus.Completed => "ob-badge-completed",
        _ => "ob-badge-cancelled"
    };

    private string GetEvtStatusIcon(EventBookingStatus s) => s switch
    {
        EventBookingStatus.Pending => "bi-clock-history", EventBookingStatus.Confirmed => "bi-check-circle",
        EventBookingStatus.Rejected => "bi-x-circle", EventBookingStatus.Cancelled => "bi-dash-circle",
        EventBookingStatus.Completed => "bi-check-circle-fill",
        _ => "bi-circle"
    };
}
