@page "/owner/hotels/create"
@page "/owner/create-hotel"
@rendermode InteractiveServer
@using EventHotelBroker.Models
@using EventHotelBroker.Services
@using EventHotelBroker.Repositories
@using System.Security.Claims
@inject IHotelService HotelService
@inject IUnitOfWork UnitOfWork
@inject NavigationManager NavigationManager
@inject IHttpContextAccessor HttpContextAccessor

<PageTitle>Create Hotel - EventHotelBroker</PageTitle>

<link href="/css/create-hotel.css?v=1" rel="stylesheet" />

<div class="ch">
    <Breadcrumb Items="@breadcrumbItems" />

    <!-- Header -->
    <div class="ch-header">
        <div>
            <h1 class="ch-header-title"><i class="bi bi-plus-circle"></i> Add New Hotel</h1>
            <p class="ch-header-sub">Create a new hotel listing for your property</p>
        </div>
        <button class="ch-btn ch-btn-cancel" @onclick="Cancel">
            <i class="bi bi-x-lg"></i> Cancel
        </button>
    </div>

    <!-- Form Card -->
    <div class="row justify-content-center">
        <div class="col-lg-9">
            <div class="ch-card">
                <div class="ch-card-body">

                    @if (!string.IsNullOrEmpty(successMessage))
                    {
                        <div class="ch-alert ch-alert-success">
                            <div class="ch-alert-icon"><i class="bi bi-check-circle-fill"></i></div>
                            <span><strong>Success!</strong> @successMessage</span>
                            <button class="ch-alert-close" @onclick="() => successMessage = null"><i class="bi bi-x"></i></button>
                        </div>
                    }

                    @if (!string.IsNullOrEmpty(errorMessage))
                    {
                        <div class="ch-alert ch-alert-error">
                            <div class="ch-alert-icon"><i class="bi bi-exclamation-triangle-fill"></i></div>
                            <span><strong>Error!</strong> @errorMessage</span>
                            <button class="ch-alert-close" @onclick="() => errorMessage = null"><i class="bi bi-x"></i></button>
                        </div>
                    }

                    <EditForm Model="hotel" OnValidSubmit="HandleSubmit" FormName="createHotelForm">
                        <DataAnnotationsValidator />

                        <!-- Basic Information -->
                        <div class="ch-section">
                            <div class="ch-section-icon ch-icon-terracotta"><i class="bi bi-info-circle"></i></div>
                            <h5 class="ch-section-title">Basic Information</h5>
                        </div>

                        <div class="ch-field">
                            <label class="ch-label" for="name">Hotel Name *</label>
                            <InputText @bind-Value="hotel.Name" class="ch-input" id="name" placeholder="e.g., Grand Plaza Hotel" />
                            <ValidationMessage For="@(() => hotel.Name)" />
                        </div>

                        <div class="ch-field">
                            <label class="ch-label" for="description">Description *</label>
                            <InputTextArea @bind-Value="hotel.Description" class="ch-input" id="description" rows="3"
                                placeholder="Describe your hotel, amenities, and what makes it special..." />
                            <ValidationMessage For="@(() => hotel.Description)" />
                        </div>

                        <div class="row">
                            <div class="col-md-6">
                                <div class="ch-field">
                                    <label class="ch-label" for="capacity">Guest Capacity *</label>
                                    <InputNumber @bind-Value="hotel.Capacity" class="ch-input" id="capacity" />
                                    <ValidationMessage For="@(() => hotel.Capacity)" />
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="ch-field">
                                    <label class="ch-label" for="price">Price per Night (KES) *</label>
                                    <InputNumber @bind-Value="hotel.PricePerNight" class="ch-input" id="price" />
                                    <ValidationMessage For="@(() => hotel.PricePerNight)" />
                                </div>
                            </div>
                        </div>

                        <hr class="ch-divider" />

                        <!-- Location -->
                        <div class="ch-section">
                            <div class="ch-section-icon ch-icon-teal"><i class="bi bi-geo-alt"></i></div>
                            <h5 class="ch-section-title">Location Details</h5>
                        </div>

                        <div class="ch-field">
                            <label class="ch-label" for="address">Address *</label>
                            <InputText @bind-Value="hotel.Address" class="ch-input" id="address" placeholder="Street address" />
                            <ValidationMessage For="@(() => hotel.Address)" />
                        </div>

                        <div class="row">
                            <div class="col-md-6">
                                <div class="ch-field">
                                    <label class="ch-label" for="city">City *</label>
                                    <InputText @bind-Value="hotel.City" class="ch-input" id="city" />
                                    <ValidationMessage For="@(() => hotel.City)" />
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="ch-field">
                                    <label class="ch-label" for="country">Country *</label>
                                    <InputText @bind-Value="hotel.Country" class="ch-input" id="country" />
                                    <ValidationMessage For="@(() => hotel.Country)" />
                                </div>
                            </div>
                        </div>

                        <div class="row">
                            <div class="col-md-6">
                                <div class="ch-field">
                                    <label class="ch-label" for="latitude">Latitude (Optional)</label>
                                    <InputNumber @bind-Value="hotel.Latitude" class="ch-input" id="latitude" placeholder="e.g., -1.286389" />
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="ch-field">
                                    <label class="ch-label" for="longitude">Longitude (Optional)</label>
                                    <InputNumber @bind-Value="hotel.Longitude" class="ch-input" id="longitude" placeholder="e.g., 36.817223" />
                                </div>
                            </div>
                        </div>

                        <hr class="ch-divider" />

                        <!-- Amenities -->
                        <div class="ch-section">
                            <div class="ch-section-icon ch-icon-bronze"><i class="bi bi-star"></i></div>
                            <h5 class="ch-section-title">Amenities & Features</h5>
                        </div>

                        @if (availableAmenities.Any())
                        {
                            <div class="ch-chips">
                                @foreach (var amenity in availableAmenities)
                                {
                                    <label class="ch-chip @(selectedAmenityIds.Contains(amenity.Id) ? "selected" : "")">
                                        <input type="checkbox"
                                            @onchange="@((e) => ToggleAmenity(amenity.Id, (bool)e.Value!))" />
                                        @if (selectedAmenityIds.Contains(amenity.Id))
                                        {
                                            <i class="bi bi-check-lg"></i>
                                        }
                                        @amenity.Name
                                    </label>
                                }
                            </div>
                        }
                        else
                        {
                            <p style="font-size: 0.6875rem; color: #8a8177;">Loading amenities...</p>
                        }

                        <hr class="ch-divider" />

                        <!-- Publish Toggle -->
                        <label class="ch-toggle">
                            <InputCheckbox @bind-Value="hotel.IsPublished" id="isPublished" />
                            Publish immediately (will be pending admin approval)
                        </label>

                        <!-- Info Box -->
                        <div class="ch-info" style="margin-top: 0.75rem;">
                            <div class="ch-info-icon"><i class="bi bi-info-circle"></i></div>
                            <div>
                                <div class="ch-info-title">Review Process</div>
                                <div class="ch-info-text">Your hotel listing will be reviewed by our admin team before it becomes visible to users. This typically takes 24-48 hours.</div>
                            </div>
                        </div>

                        <!-- Footer -->
                        <div class="ch-footer">
                            <button type="button" class="ch-btn ch-btn-muted" @onclick="Cancel">
                                <i class="bi bi-x-lg"></i> Cancel
                            </button>
                            <button type="submit" class="ch-btn ch-btn-submit" disabled="@isSubmitting">
                                @if (isSubmitting)
                                {
                                    <span class="ch-spinner"></span>
                                    <span>Creating...</span>
                                }
                                else
                                {
                                    <i class="bi bi-check-lg"></i>
                                    <span>Create Hotel</span>
                                }
                            </button>
                        </div>
                    </EditForm>

                </div>
            </div>
        </div>
    </div>
</div>

@code {
    [SupplyParameterFromForm]
    private Hotel hotel { get; set; } = new() { Currency = "KES", Country = "Kenya" };

    private List<Amenity> availableAmenities = new();
    private List<int> selectedAmenityIds = new();
    private string? errorMessage;
    private string? successMessage;
    private bool isSubmitting = false;
    private string? currentUserId;

    private List<BreadcrumbItem> breadcrumbItems = new()
    {
        new BreadcrumbItem { Text = "Home", Url = "/" },
        new BreadcrumbItem { Text = "Owner Dashboard", Url = "/owner/dashboard" },
        new BreadcrumbItem { Text = "Create Hotel", IsActive = true }
    };

    protected override async Task OnInitializedAsync()
    {
        // Get current user ID from JWT token
        currentUserId = GetCurrentUserId();
        
        // Fallback for testing: if no user ID found, use default
        if (string.IsNullOrEmpty(currentUserId))
        {
            System.Diagnostics.Debug.WriteLine("[CreateHotel] No user ID found, using fallback '1' for testing");
            currentUserId = "1";
        }
        else
        {
            System.Diagnostics.Debug.WriteLine($"[CreateHotel] Using user ID: {currentUserId}");
        }

        try
        {
            availableAmenities = (await UnitOfWork.Amenities.GetAllAsync()).ToList();
        }
        catch (Exception ex)
        {
            errorMessage = "Failed to load amenities.";
        }
    }

    private string? GetCurrentUserId()
    {
        try
        {
            var token = HttpContextAccessor.HttpContext?.Session?.GetString("JWToken");
            System.Diagnostics.Debug.WriteLine($"[CreateHotel] Token from session: {(token != null ? "YES (" + token.Length + " chars)" : "NO")}");
            
            if (!string.IsNullOrEmpty(token))
            {
                var parts = token.Split('.');
                if (parts.Length >= 2)
                {
                    var payload = parts[1];
                    switch (payload.Length % 4)
                    {
                        case 2: payload += "=="; break;
                        case 3: payload += "="; break;
                    }
                    var jsonBytes = Convert.FromBase64String(payload);
                    var json = System.Text.Encoding.UTF8.GetString(jsonBytes);
                    var claims = System.Text.Json.JsonSerializer.Deserialize<Dictionary<string, object>>(json);

                    System.Diagnostics.Debug.WriteLine($"[CreateHotel] Claims parsed: {claims?.Count ?? 0} claims");

                    if (claims != null && claims.TryGetValue(ClaimTypes.Name, out var nameClaim))
                    {
                        // Name claim contains: "userId,accountType,isTwoFAEnabled"
                        var nameValue = nameClaim.ToString();
                        System.Diagnostics.Debug.WriteLine($"[CreateHotel] Name claim value: '{nameValue}'");
                        
                        if (!string.IsNullOrEmpty(nameValue))
                        {
                            var nameParts = nameValue.Split(',');
                            if (nameParts.Length > 0)
                            {
                                var userId = nameParts[0];
                                System.Diagnostics.Debug.WriteLine($"[CreateHotel] Extracted userId: '{userId}'");
                                return userId;
                            }
                        }
                    }
                }
            }
        }
        catch (Exception ex)
        {
            System.Diagnostics.Debug.WriteLine($"[CreateHotel] Error parsing user ID: {ex.Message}");
        }
        
        System.Diagnostics.Debug.WriteLine("[CreateHotel] Returning null user ID");
        return null;
    }

    private void ToggleAmenity(int amenityId, bool isChecked)
    {
        if (isChecked)
        {
            if (!selectedAmenityIds.Contains(amenityId))
                selectedAmenityIds.Add(amenityId);
        }
        else
        {
            selectedAmenityIds.Remove(amenityId);
        }
    }

    private async Task HandleSubmit()
    {
        // Debug: Log current user ID
        System.Diagnostics.Debug.WriteLine($"[CreateHotel] currentUserId: '{currentUserId}'");
        
        if (string.IsNullOrEmpty(currentUserId))
        {
            errorMessage = "User not authenticated. Please log in again.";
            return;
        }

        isSubmitting = true;
        errorMessage = null;
        successMessage = null;

        try
        {
            hotel.OwnerId = currentUserId;
            hotel.IsApproved = false; // Requires admin approval
            hotel.IsPublished = hotel.IsPublished; // Use checkbox value
            
            var createdHotel = await HotelService.CreateHotelAsync(hotel);

            // Add selected amenities
            if (selectedAmenityIds.Any())
            {
                foreach (var amenityId in selectedAmenityIds)
                {
                    await UnitOfWork.HotelAmenities.AddAsync(new HotelAmenity
                    {
                        HotelId = createdHotel.Id,
                        AmenityId = amenityId
                    });
                }
                await UnitOfWork.SaveChangesAsync();
            }

            if (hotel.IsPublished)
            {
                successMessage = $"Hotel '{createdHotel.Name}' created successfully and submitted for admin approval! You will be notified once it's reviewed. Redirecting...";
            }
            else
            {
                successMessage = $"Hotel '{createdHotel.Name}' saved as draft successfully! You can publish it later for admin approval. Redirecting...";
            }
            
            StateHasChanged();
            
            // Redirect after 3 seconds to allow user to read the message
            await Task.Delay(3000);
            NavigationManager.NavigateTo("/owner/hotels");
        }
        catch (Exception ex)
        {
            errorMessage = $"Error creating hotel: {ex.Message}";
            // Log the full exception for debugging
            Console.WriteLine($"Hotel creation error: {ex}");
            if (ex.InnerException != null)
            {
                Console.WriteLine($"Inner exception: {ex.InnerException}");
                errorMessage += $" | Inner: {ex.InnerException.Message}";
            }
        }
        finally
        {
            isSubmitting = false;
        }
    }

    private void Cancel()
    {
        NavigationManager.NavigateTo("/owner/dashboard");
    }
}
