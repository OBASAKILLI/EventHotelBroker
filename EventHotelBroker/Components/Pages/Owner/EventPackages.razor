@page "/owner/event-packages"
@rendermode InteractiveServer
@using EventHotelBroker.Models
@using EventHotelBroker.Services
@using EventHotelBroker.Utils
@using System.Security.Claims
@using Microsoft.AspNetCore.Components.Authorization
@inject IEventService EventService
@inject NavigationManager Navigation
@inject IJSRuntime JSRuntime
@inject AuthenticationStateProvider AuthStateProvider

<PageTitle>My Event Packages - Owner</PageTitle>

<link href="/css/event-packages.css?v=1" rel="stylesheet" />

<div class="ep">
    <Breadcrumb Items="@breadcrumbItems" />

    <!-- Header -->
    <div class="ep-header">
        <div>
            <h1 class="ep-header-title"><i class="bi bi-gift"></i> My Event Packages</h1>
            <p class="ep-header-sub">Create and manage your event packages</p>
        </div>
        <button class="ep-btn ep-btn-primary" @onclick="CreatePackage">
            <i class="bi bi-plus-lg"></i> Create Package
        </button>
    </div>

    @if (isLoading)
    {
        <div class="ep-card">
            <div class="ep-loading">
                <div class="ep-spinner"></div>
                <div class="ep-loading-text">Loading your packages...</div>
            </div>
        </div>
    }
    else
    {
        <!-- Stats -->
        <div class="ep-stats">
            <div class="ep-stat">
                <div>
                    <div class="ep-stat-value">@packages.Count()</div>
                    <div class="ep-stat-label">Total Packages</div>
                </div>
                <div class="ep-stat-icon ep-icon-terracotta"><i class="bi bi-gift"></i></div>
            </div>
            <div class="ep-stat">
                <div>
                    <div class="ep-stat-value">@packages.Count(p => p.IsActive && p.IsApproved)</div>
                    <div class="ep-stat-label">Active</div>
                </div>
                <div class="ep-stat-icon ep-icon-teal"><i class="bi bi-check-circle"></i></div>
            </div>
            <div class="ep-stat">
                <div>
                    <div class="ep-stat-value">@packages.Count(p => !p.IsApproved)</div>
                    <div class="ep-stat-label">Pending</div>
                </div>
                <div class="ep-stat-icon ep-icon-bronze"><i class="bi bi-clock-history"></i></div>
            </div>
            <div class="ep-stat">
                <div>
                    <div class="ep-stat-value">@packages.Count(p => p.IsFeatured)</div>
                    <div class="ep-stat-label">Featured</div>
                </div>
                <div class="ep-stat-icon ep-icon-charcoal"><i class="bi bi-star"></i></div>
            </div>
        </div>

        <!-- Packages Grid -->
        @if (packages.Any())
        {
            <div class="ep-card">
                <div class="ep-card-header">
                    <h5 class="ep-card-title"><i class="bi bi-grid-3x2-gap"></i> Package Inventory</h5>
                    <span class="ep-card-count">@packages.Count() items</span>
                </div>
                <div class="ep-card-body">
                    <div class="ep-grid">
                        @foreach (var package in packages)
                        {
                            <div class="ep-item">
                                <!-- Image -->
                                <div class="ep-item-img">
                                    @if (package.IsFeatured)
                                    {
                                        <span class="ep-featured"><i class="bi bi-star-fill"></i> Featured</span>
                                    }
                                    @if (!string.IsNullOrEmpty(package.ImageUrl))
                                    {
                                        <img src="@package.ImageUrl" alt="@package.Name" />
                                    }
                                    else
                                    {
                                        <div class="ep-item-img-placeholder"><i class="bi bi-gift"></i></div>
                                    }
                                </div>

                                <div class="ep-item-body">
                                    <!-- Badges -->
                                    <div class="ep-badges">
                                        <span class="ep-badge ep-badge-type">@package.PackageType</span>
                                        <div style="display:flex;gap:0.25rem;">
                                            @if (package.IsApproved)
                                            {
                                                <span class="ep-badge ep-badge-approved">Approved</span>
                                            }
                                            else
                                            {
                                                <span class="ep-badge ep-badge-pending">Pending</span>
                                            }
                                            @if (package.IsActive)
                                            {
                                                <span class="ep-badge ep-badge-active">Active</span>
                                            }
                                            else
                                            {
                                                <span class="ep-badge ep-badge-inactive">Inactive</span>
                                            }
                                        </div>
                                    </div>

                                    <h6 class="ep-item-name">@package.Name</h6>
                                    <p class="ep-item-desc">@package.Description</p>

                                    <!-- Price -->
                                    <div class="ep-price-row">
                                        <div>
                                            @if (package.DiscountedPrice.HasValue)
                                            {
                                                <span class="ep-price-old">KES @package.TotalPrice.ToString("N2")</span>
                                                <span class="ep-price">KES @package.DiscountedPrice.Value.ToString("N2")</span>
                                            }
                                            else
                                            {
                                                <span class="ep-price">KES @package.TotalPrice.ToString("N2")</span>
                                            }
                                        </div>
                                        <span class="ep-guests"><i class="bi bi-people"></i> @package.MinGuests-@package.MaxGuests</span>
                                    </div>

                                    <!-- Actions -->
                                    <div class="ep-actions">
                                        <button class="ep-btn ep-btn-sm ep-btn-edit" @onclick="() => EditPackage(package.Id)">
                                            <i class="bi bi-pencil"></i> Edit
                                        </button>
                                        <button class="ep-btn ep-btn-sm ep-btn-toggle" @onclick="() => ToggleActive(package.Id)">
                                            <i class="bi @(package.IsActive ? "bi-pause" : "bi-play")"></i>
                                        </button>
                                        <button class="ep-btn ep-btn-sm ep-btn-delete" @onclick="() => DeletePackage(package.Id)">
                                            <i class="bi bi-trash"></i>
                                        </button>
                                    </div>
                                </div>
                            </div>
                        }
                    </div>
                </div>
            </div>
        }
        else
        {
            <div class="ep-card">
                <div class="ep-empty">
                    <div class="ep-empty-icon"><i class="bi bi-inbox"></i></div>
                    <div class="ep-empty-title">No Packages Created Yet</div>
                    <div class="ep-empty-text">Create attractive event packages to boost your bookings</div>
                    <button class="ep-btn ep-btn-primary" @onclick="CreatePackage">
                        <i class="bi bi-plus-lg"></i> Create Your First Package
                    </button>
                </div>
            </div>
        }
    }
</div>

@code {
    private bool isLoading = true;
    private List<EventPackage> packages = new();
    private string? currentProviderId;

    private List<BreadcrumbItem> breadcrumbItems = new()
    {
        new BreadcrumbItem { Text = "Home", Url = "/" },
        new BreadcrumbItem { Text = "Owner Dashboard", Url = "/owner/dashboard" },
        new BreadcrumbItem { Text = "Event Packages", IsActive = true }
    };

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            try
            {
                var token = await JSRuntime.InvokeAsync<string>("authHelpers.getCookie", "JWToken");
                if (!string.IsNullOrEmpty(token))
                {
                    var customAuth = (CustomAuthenticationStateProvider)AuthStateProvider;
                    await customAuth.MarkUserAsAuthenticated(token);
                    currentProviderId = await GetCurrentUserIdAsync();
                }

                if (!string.IsNullOrEmpty(currentProviderId))
                {
                    var allPackages = await EventService.GetPackagesByProviderAsync(currentProviderId);
                    packages = allPackages.ToList();
                }
            }
            catch (Exception ex)
            {
                System.Diagnostics.Debug.WriteLine($"[EventPackages] Error: {ex.Message}");
            }
            finally
            {
                isLoading = false;
            }
            StateHasChanged();
        }
    }

    private async Task<string?> GetCurrentUserIdAsync()
    {
        try
        {
            var authState = await AuthStateProvider.GetAuthenticationStateAsync();
            var user = authState?.User;
            if (user?.Identity?.IsAuthenticated == true)
            {
                var nameClaim = user.FindFirst(ClaimTypes.Name)?.Value;
                if (!string.IsNullOrEmpty(nameClaim))
                {
                    var parts = nameClaim.Split(',');
                    if (parts.Length > 0) return parts[0];
                }
            }
        }
        catch { }
        return null;
    }

    private void CreatePackage()
    {
        Navigation.NavigateTo("/owner/create-package");
    }

    private void EditPackage(int id)
    {
        Navigation.NavigateTo($"/owner/edit-package/{id}");
    }

    private async Task ToggleActive(int id)
    {
        var package = packages.FirstOrDefault(p => p.Id == id);
        if (package != null)
        {
            package.IsActive = !package.IsActive;
            await EventService.UpdatePackageAsync(package);
            if (!string.IsNullOrEmpty(currentProviderId))
            {
                var allPackages = await EventService.GetPackagesByProviderAsync(currentProviderId);
                packages = allPackages.ToList();
                StateHasChanged();
            }
        }
    }

    private async Task DeletePackage(int id)
    {
        var confirmed = await JSRuntime.InvokeAsync<bool>("confirm", "Are you sure you want to delete this package?");
        if (confirmed)
        {
            await EventService.DeletePackageAsync(id);
            if (!string.IsNullOrEmpty(currentProviderId))
            {
                var allPackages = await EventService.GetPackagesByProviderAsync(currentProviderId);
                packages = allPackages.ToList();
                StateHasChanged();
            }
        }
    }
}
