@page "/owner/hotels/{HotelId:int}/edit"
@rendermode InteractiveServer
@using EventHotelBroker.Models
@using EventHotelBroker.Services
@using EventHotelBroker.Repositories
@using EventHotelBroker.Utils
@using System.Security.Claims
@using Microsoft.AspNetCore.Components.Authorization
@inject IHotelService HotelService
@inject IUnitOfWork UnitOfWork
@inject NavigationManager NavigationManager
@inject AuthenticationStateProvider AuthStateProvider
@inject IJSRuntime JSRuntime
@inject IWebHostEnvironment Environment
@implements IDisposable

<PageTitle>Edit Hotel - EventHotelBroker</PageTitle>

<link href="/css/create-hotel.css?v=1" rel="stylesheet" />
<script src="https://maps.googleapis.com/maps/api/js?key=AIzaSyA7eRAscqIJa-F2uUfvyS-rg7dAg02sXCk&libraries=places,geometry"></script>

<div class="ch">
    <Breadcrumb Items="@breadcrumbItems" />

    <!-- Header -->
    <div class="ch-header">
        <div>
            <h1 class="ch-header-title"><i class="bi bi-pencil-square"></i> Edit Hotel</h1>
            <p class="ch-header-sub">Update your hotel listing details</p>
        </div>
        <button class="ch-btn ch-btn-cancel" @onclick="Cancel">
            <i class="bi bi-arrow-left"></i> Back
        </button>
    </div>

    @if (isLoading)
    {
        <div style="text-align: center; padding: 3rem;">
            <div class="ch-spinner" style="width: 32px; height: 32px; border-width: 3px; margin: 0 auto 1rem;"></div>
            <p style="color: #8a8177; font-size: 0.8rem;">Loading hotel...</p>
        </div>
    }
    else if (hotel == null)
    {
        <div style="text-align: center; padding: 3rem;">
            <i class="bi bi-exclamation-triangle" style="font-size: 2.5rem; color: #C87941;"></i>
            <h5 style="margin-top: 1rem; color: #2A2A2A;">Hotel Not Found</h5>
            <p style="color: #8a8177; font-size: 0.8rem;">The hotel you're looking for doesn't exist or you don't have permission to edit it.</p>
            <a href="/owner/hotels" class="ch-btn ch-btn-submit" style="display: inline-flex;">
                <i class="bi bi-arrow-left"></i> Back to My Hotels
            </a>
        </div>
    }
    else
    {
        <!-- Form Card -->
        <div class="row justify-content-center">
            <div class="col-lg-9">
                <div class="ch-card">
                    <div class="ch-card-body">

                        @if (!string.IsNullOrEmpty(successMessage))
                        {
                            <div class="ch-alert ch-alert-success">
                                <div class="ch-alert-icon"><i class="bi bi-check-circle-fill"></i></div>
                                <span><strong>Success!</strong> @successMessage</span>
                                <button class="ch-alert-close" @onclick="() => successMessage = null"><i class="bi bi-x"></i></button>
                            </div>
                        }

                        @if (!string.IsNullOrEmpty(errorMessage))
                        {
                            <div class="ch-alert ch-alert-error">
                                <div class="ch-alert-icon"><i class="bi bi-exclamation-triangle-fill"></i></div>
                                <span><strong>Error!</strong> @errorMessage</span>
                                <button class="ch-alert-close" @onclick="() => errorMessage = null"><i class="bi bi-x"></i></button>
                            </div>
                        }

                        <!-- Status Badge -->
                        <div style="margin-bottom: 1rem; display: flex; align-items: center; gap: 0.5rem;">
                            <span style="font-size: 0.7rem; font-weight: 600; color: #8a8177;">STATUS:</span>
                            @if (hotel.IsApproved)
                            {
                                <span style="font-size: 0.65rem; font-weight: 700; padding: 0.15rem 0.5rem; border-radius: 6px; background: rgba(72,140,130,0.1); color: #488C82;">
                                    <i class="bi bi-check-circle"></i> Approved
                                </span>
                            }
                            else if (hotel.IsPublished)
                            {
                                <span style="font-size: 0.65rem; font-weight: 700; padding: 0.15rem 0.5rem; border-radius: 6px; background: rgba(200,121,65,0.1); color: #C87941;">
                                    <i class="bi bi-clock-history"></i> Pending Review
                                </span>
                            }
                            else
                            {
                                <span style="font-size: 0.65rem; font-weight: 700; padding: 0.15rem 0.5rem; border-radius: 6px; background: rgba(42,42,42,0.06); color: #8a8177;">
                                    <i class="bi bi-pencil-square"></i> Draft
                                </span>
                            }
                        </div>

                        <EditForm Model="hotel" OnValidSubmit="HandleSubmit" OnInvalidSubmit="HandleInvalidSubmit" FormName="editHotelForm">
                            <DataAnnotationsValidator />
                            <ValidationSummary />

                            <!-- Basic Information -->
                            <div class="ch-section">
                                <div class="ch-section-icon ch-icon-terracotta"><i class="bi bi-info-circle"></i></div>
                                <h5 class="ch-section-title">Basic Information</h5>
                            </div>

                            <div class="ch-field">
                                <label class="ch-label" for="name">Hotel Name *</label>
                                <InputText @bind-Value="hotel.Name" class="ch-input" id="name" placeholder="e.g., Grand Plaza Hotel" />
                                <ValidationMessage For="@(() => hotel.Name)" />
                            </div>

                            <div class="ch-field">
                                <label class="ch-label" for="description">Description *</label>
                                <InputTextArea @bind-Value="hotel.Description" class="ch-input" id="description" rows="3"
                                    placeholder="Describe your hotel, amenities, and what makes it special..." />
                                <ValidationMessage For="@(() => hotel.Description)" />
                            </div>

                            <div class="row">
                                <div class="col-md-6">
                                    <div class="ch-field">
                                        <label class="ch-label" for="capacity">Guest Capacity *</label>
                                        <InputNumber @bind-Value="hotel.Capacity" class="ch-input" id="capacity" />
                                        <ValidationMessage For="@(() => hotel.Capacity)" />
                                    </div>
                                </div>
                                <div class="col-md-6">
                                    <div class="ch-field">
                                        <label class="ch-label" for="price">Price per Night (KES) *</label>
                                        <InputNumber @bind-Value="hotel.PricePerNight" class="ch-input" id="price" />
                                        <ValidationMessage For="@(() => hotel.PricePerNight)" />
                                    </div>
                                </div>
                            </div>

                            <div class="ch-field">
                                <label class="ch-label" for="category">Category *</label>
                                <InputSelect @bind-Value="hotel.Category" class="ch-input" id="category">
                                    <option value="">Select Category</option>
                                    <option value="Hotel">Hotel</option>
                                    <option value="Airbnb">Airbnb</option>
                                    <option value="Restaurant">Restaurant</option>
                                    <option value="Venue">Venue</option>
                                    <option value="Resort">Resort</option>
                                    <option value="Lodge">Lodge</option>
                                    <option value="Guest House">Guest House</option>
                                    <option value="Apartment">Apartment</option>
                                </InputSelect>
                                <ValidationMessage For="@(() => hotel.Category)" />
                            </div>

                            <div class="ch-field">
                                <label class="ch-label" for="hotelCategory">Hotel Category *</label>
                                <InputSelect @bind-Value="hotel.HotelCategoryId" class="ch-input" id="hotelCategory">
                                    <option value="0">Select hotel category</option>
                                    @if (availableHotelCategories != null)
                                    {
                                        @foreach (var cat in availableHotelCategories)
                                        {
                                            <option value="@cat.Id">@cat.Name (@cat.Rating) - KES @cat.ServiceFee service fee</option>
                                        }
                                    }
                                </InputSelect>
                                <ValidationMessage For="@(() => hotel.HotelCategoryId)" />
                            </div>

                            <div class="ch-field">
                                <label class="ch-label" for="phone">Phone Number *</label>
                                <InputText @bind-Value="hotel.Phone" class="ch-input" id="phone" placeholder="+254 7XX XXX XXX" />
                                <ValidationMessage For="@(() => hotel.Phone)" />
                            </div>

                            <div class="ch-field">
                                <label class="ch-label" for="email">Email *</label>
                                <InputText @bind-Value="hotel.Email" class="ch-input" id="email" placeholder="hotel@example.com" />
                                <ValidationMessage For="@(() => hotel.Email)" />
                            </div>

                            <hr class="ch-divider" />

                            <!-- Location -->
                            <div class="ch-section">
                                <div class="ch-section-icon ch-icon-teal"><i class="bi bi-geo-alt"></i></div>
                                <h5 class="ch-section-title">Location Details</h5>
                            </div>

                            <div class="ch-field">
                                <label class="ch-label" for="address">Address *</label>
                                <InputText @bind-Value="hotel.Address" class="ch-input" id="address" placeholder="Street address" />
                                <ValidationMessage For="@(() => hotel.Address)" />
                            </div>

                            <!-- Google Maps Search & Preview -->
                            <div class="ch-field">
                                <label class="ch-label">Search Location & Pin on Map</label>
                                <div class="map-search-container">
                                    <p style="font-size: 0.65rem; color: #8a8177; margin-bottom: 0.5rem;"><i class="bi bi-info-circle"></i> Type and select from the dropdown to automatically fill details.</p>
                                    <input id="mapSearchInput" type="text" class="ch-input mb-2" placeholder="Start typing hotel location..." autocomplete="off" />
                                    <div id="hotelMap" style="height: 400px; width: 100%; border-radius: 12px; border: 1px solid #dee2e6; display: none; margin-bottom: 1.5rem;"></div>
                                </div>
                            </div>

                            <div class="row">
                                <div class="col-md-6">
                                    <div class="ch-field">
                                        <label class="ch-label" for="city">City *</label>
                                        <InputText @bind-Value="hotel.City" class="ch-input" id="city" />
                                        <ValidationMessage For="@(() => hotel.City)" />
                                    </div>
                                </div>
                                <div class="col-md-6">
                                    <div class="ch-field">
                                        <label class="ch-label" for="country">Country *</label>
                                        <InputText @bind-Value="hotel.Country" class="ch-input" id="country" />
                                        <ValidationMessage For="@(() => hotel.Country)" />
                                    </div>
                                </div>
                            </div>

                            <div class="row">
                                <div class="col-md-6">
                                    <div class="ch-field">
                                        <label class="ch-label" for="latitude">Latitude (Optional)</label>
                                        <InputNumber @bind-Value="hotel.Latitude" class="ch-input" id="latitude" placeholder="e.g., -1.286389" />
                                    </div>
                                </div>
                                <div class="col-md-6">
                                    <div class="ch-field">
                                        <label class="ch-label" for="longitude">Longitude (Optional)</label>
                                        <InputNumber @bind-Value="hotel.Longitude" class="ch-input" id="longitude" placeholder="e.g., 36.817223" />
                                    </div>
                                </div>
                            </div>

                            <hr class="ch-divider" />

                            <!-- Amenities -->
                            <div class="ch-section">
                                <div class="ch-section-icon ch-icon-bronze"><i class="bi bi-star"></i></div>
                                <h5 class="ch-section-title">Amenities & Features</h5>
                            </div>

                            @if (availableAmenities.Any())
                            {
                                <div class="ch-chips">
                                    @foreach (var amenity in availableAmenities)
                                    {
                                        <label class="ch-chip @(selectedAmenityIds.Contains(amenity.Id) ? "selected" : "")">
                                            <input type="checkbox"
                                                checked="@selectedAmenityIds.Contains(amenity.Id)"
                                                @onchange="@((e) => ToggleAmenity(amenity.Id, (bool)e.Value!))" />
                                            @if (selectedAmenityIds.Contains(amenity.Id))
                                            {
                                                <i class="bi bi-check-lg"></i>
                                            }
                                            @amenity.Name
                                        </label>
                                    }
                                </div>
                            }
                            else
                            {
                                <p style="font-size: 0.6875rem; color: #8a8177;">Loading amenities...</p>
                            }

                            <hr class="ch-divider" />

                            <!-- Hotel Images -->
                            <div class="ch-section">
                                <div class="ch-section-icon ch-icon-terracotta"><i class="bi bi-images"></i></div>
                                <h5 class="ch-section-title">Hotel Images</h5>
                            </div>

                            <!-- Existing Images -->
                            @if (existingImages.Any())
                            {
                                <div class="ch-field">
                                    <label class="ch-label">Current Images</label>
                                    <div style="display: flex; flex-wrap: wrap; gap: 12px; margin-top: 4px;">
                                        @foreach (var img in existingImages)
                                        {
                                            <div style="position: relative; border: 1px solid @(img.IsPrimary ? "#488C82" : "#dee2e6"); border-radius: 8px; overflow: hidden; width: 120px; border-width: @(img.IsPrimary ? "2px" : "1px");">
                                                <img src="@img.Url" style="width: 120px; height: 90px; object-fit: cover;" />
                                                <div style="padding: 4px 6px; font-size: 0.7rem; color: #5c5550; white-space: nowrap; overflow: hidden; text-overflow: ellipsis;">
                                                    @img.FileName
                                                </div>
                                                <div style="padding: 0 6px 4px; display: flex; align-items: center; gap: 4px;">
                                                    <input type="radio" name="primaryExistingImage" checked="@img.IsPrimary"
                                                        @onchange="() => SetExistingPrimary(img.Id)" />
                                                    <span style="font-size: 0.65rem; color: @(img.IsPrimary ? "#488C82" : "#8a8177"); font-weight: @(img.IsPrimary ? "700" : "400");">Primary</span>
                                                </div>
                                                <button type="button" @onclick="() => RemoveExistingImage(img.Id)"
                                                    style="position: absolute; top: 4px; right: 4px; background: rgba(0,0,0,0.6); color: white; border: none; border-radius: 50%; width: 22px; height: 22px; font-size: 0.7rem; cursor: pointer; display: flex; align-items: center; justify-content: center;">
                                                    <i class="bi bi-x"></i>
                                                </button>
                                            </div>
                                        }
                                    </div>
                                </div>
                            }

                            <!-- Upload New Images -->
                            <div class="ch-field">
                                <label class="ch-label">Add New Images (Max 5 total, up to 5MB each)</label>
                                <div style="border: 2px dashed #c4b5a0; border-radius: 8px; padding: 24px; text-align: center; background: #faf8f5; cursor: pointer; position: relative;">
                                    <InputFile OnChange="OnImagesSelected" multiple accept="image/*"
                                        style="position: absolute; inset: 0; opacity: 0; cursor: pointer;" />
                                    <i class="bi bi-cloud-arrow-up" style="font-size: 2rem; color: #8a8177;"></i>
                                    <div style="color: #5c5550; margin-top: 8px; font-size: 0.85rem;">
                                        Click or drag images here to upload
                                    </div>
                                    <div style="color: #8a8177; font-size: 0.75rem; margin-top: 4px;">
                                        Supported: JPG, PNG, WebP
                                    </div>
                                </div>

                                @if (newImages.Any())
                                {
                                    <div style="display: flex; flex-wrap: wrap; gap: 12px; margin-top: 12px;">
                                        @foreach (var img in newImages)
                                        {
                                            <div style="position: relative; border: 1px solid #dee2e6; border-radius: 8px; overflow: hidden; width: 120px;">
                                                @if (newImagePreviews.ContainsKey(img.Name))
                                                {
                                                    <img src="@newImagePreviews[img.Name]" style="width: 120px; height: 90px; object-fit: cover;" />
                                                }
                                                else
                                                {
                                                    <div style="width: 120px; height: 90px; display: flex; align-items: center; justify-content: center; background: #f0ebe4;">
                                                        <i class="bi bi-image" style="font-size: 1.5rem; color: #8a8177;"></i>
                                                    </div>
                                                }
                                                <div style="padding: 4px 6px; font-size: 0.7rem; color: #5c5550; white-space: nowrap; overflow: hidden; text-overflow: ellipsis;">
                                                    @img.Name
                                                </div>
                                                <div style="padding: 0 6px 4px; display: flex; align-items: center; justify-content: center;">
                                                    <span style="font-size: 0.6rem; color: #488C82; font-weight: 600;">NEW</span>
                                                </div>
                                                <button type="button" @onclick="() => RemoveNewImage(img.Name)"
                                                    style="position: absolute; top: 4px; right: 4px; background: rgba(0,0,0,0.6); color: white; border: none; border-radius: 50%; width: 22px; height: 22px; font-size: 0.7rem; cursor: pointer; display: flex; align-items: center; justify-content: center;">
                                                    <i class="bi bi-x"></i>
                                                </button>
                                            </div>
                                        }
                                    </div>
                                }
                            </div>

                            <hr class="ch-divider" />

                            <!-- Publish Toggle -->
                            <label class="ch-toggle">
                                <InputCheckbox @bind-Value="hotel.IsPublished" id="isPublished" />
                                Publish listing (submit for admin approval)
                            </label>

                            <!-- Info Box -->
                            <div class="ch-info" style="margin-top: 0.75rem;">
                                <div class="ch-info-icon"><i class="bi bi-info-circle"></i></div>
                                <div>
                                    <div class="ch-info-title">Note</div>
                                    <div class="ch-info-text">Editing an approved hotel will keep its current status. If you need to make major changes, the admin may re-review it.</div>
                                </div>
                            </div>

                            <!-- Footer -->
                            <div class="ch-footer">
                                <button type="button" class="ch-btn ch-btn-muted" @onclick="Cancel">
                                    <i class="bi bi-x-lg"></i> Cancel
                                </button>
                                <button type="button" class="ch-btn ch-btn-muted" style="color: #dc3545;" @onclick="ConfirmDelete">
                                    <i class="bi bi-trash"></i> Delete
                                </button>
                                <button type="submit" class="ch-btn ch-btn-submit" disabled="@isSubmitting">
                                    @if (isSubmitting)
                                    {
                                        <span class="ch-spinner"></span>
                                        <span>Saving...</span>
                                    }
                                    else
                                    {
                                        <i class="bi bi-check-lg"></i>
                                        <span>Save Changes</span>
                                    }
                                </button>
                            </div>
                        </EditForm>

                    </div>
                </div>
            </div>
        </div>
    }
</div>

@if (showDeleteConfirm)
{
    <div style="position: fixed; inset: 0; background: rgba(0,0,0,0.5); z-index: 1000; display: flex; align-items: center; justify-content: center;"
         @onclick="() => showDeleteConfirm = false">
        <div style="background: #fff; border-radius: 14px; padding: 1.5rem; max-width: 400px; width: 90%; box-shadow: 0 8px 32px rgba(0,0,0,0.15);"
             @onclick:stopPropagation="true">
            <div style="text-align: center;">
                <i class="bi bi-exclamation-triangle" style="font-size: 2rem; color: #dc3545;"></i>
                <h5 style="margin: 0.75rem 0 0.5rem; font-size: 1rem; color: #2A2A2A;">Delete Hotel?</h5>
                <p style="font-size: 0.8rem; color: #8a8177; margin-bottom: 1.25rem;">
                    Are you sure you want to delete <strong>@hotel?.Name</strong>? This action cannot be undone.
                </p>
            </div>
            <div style="display: flex; gap: 0.5rem; justify-content: center;">
                <button class="ch-btn ch-btn-muted" @onclick="() => showDeleteConfirm = false">
                    Cancel
                </button>
                <button class="ch-btn ch-btn-submit" style="background: #dc3545;" @onclick="DeleteHotel">
                    <i class="bi bi-trash"></i> Delete
                </button>
            </div>
        </div>
    </div>
}

@code {
    [Parameter]
    public int HotelId { get; set; }

    private Hotel? hotel;
    private bool isLoading = true;
    private bool isSubmitting = false;
    private bool showDeleteConfirm = false;
    private string? currentUserId;
    private string? errorMessage;
    private string? successMessage;

    private List<Amenity> availableAmenities = new();
    private List<int> selectedAmenityIds = new();
    private List<HotelCategory>? availableHotelCategories;
    private List<HotelImage> existingImages = new();
    private List<int> imagesToRemove = new();

    private List<IBrowserFile> newImages = new();
    private Dictionary<string, string> newImagePreviews = new();
    private const long MaxFileSize = 5 * 1024 * 1024;

    private List<BreadcrumbItem> breadcrumbItems = new()
    {
        new BreadcrumbItem { Text = "Home", Url = "/" },
        new BreadcrumbItem { Text = "Owner Dashboard", Url = "/owner/dashboard" },
        new BreadcrumbItem { Text = "My Hotels", Url = "/owner/hotels" },
        new BreadcrumbItem { Text = "Edit Hotel", IsActive = true }
    };

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            try
            {
                // Auth
                var token = await JSRuntime.InvokeAsync<string>("authHelpers.getCookie", "JWToken");
                if (!string.IsNullOrEmpty(token))
                {
                    var customAuth = (CustomAuthenticationStateProvider)AuthStateProvider;
                    await customAuth.MarkUserAsAuthenticated(token);
                    currentUserId = await GetCurrentUserIdAsync();
                }

                if (string.IsNullOrEmpty(currentUserId))
                {
                    errorMessage = "You must be logged in to edit a hotel.";
                    isLoading = false;
                    StateHasChanged();
                    return;
                }

                // Load hotel with details
                hotel = await HotelService.GetHotelWithDetailsAsync(HotelId);

                if (hotel == null || hotel.OwnerId != currentUserId)
                {
                    hotel = null; // Not found or not the owner
                    isLoading = false;
                    StateHasChanged();
                    return;
                }

                // Load existing images
                existingImages = hotel.Images?.ToList() ?? new();

                // Load existing amenities
                selectedAmenityIds = hotel.HotelAmenities?.Select(ha => ha.AmenityId).ToList() ?? new();

                // Load all available amenities
                availableAmenities = (await UnitOfWork.Amenities.GetAllAsync()).ToList();

                // Load hotel categories
                availableHotelCategories = (await UnitOfWork.HotelCategories.GetAllAsync()).ToList();
            }
            catch (Exception ex)
            {
                errorMessage = $"Error loading hotel: {ex.Message}";
                System.Diagnostics.Debug.WriteLine($"[EditHotel] Error: {ex.Message}");
            }
            finally
            {
                isLoading = false;
            }

            StateHasChanged();

            // Initialize Map Autocomplete
            objRef = DotNetObjectReference.Create(this);
            await JSRuntime.InvokeVoidAsync("mapHelper.initAutocomplete", objRef, "mapSearchInput", "hotelMap");

            // If hotel has location data, show the map and pre-fill autocomplete
            if (hotel != null && hotel.Latitude.HasValue && hotel.Longitude.HasValue)
            {
                Console.WriteLine($"Hotel has location: Lat={hotel.Latitude}, Lng={hotel.Longitude}, Address={hotel.Address}");
                var lat = (double)hotel.Latitude.Value;
                var lng = (double)hotel.Longitude.Value;
                try
                {
                    await JSRuntime.InvokeVoidAsync("mapHelper.showMapWithExistingLocation", "hotelMap", lat, lng, objRef);
                    Console.WriteLine("Map shown successfully");
                }
                catch (Exception ex)
                {
                    Console.WriteLine($"Error showing map: {ex.Message}");
                }
            }
            else
            {
                Console.WriteLine("Hotel has no location data");
            }
        }
    }

    private DotNetObjectReference<EditHotel>? objRef;

    public void Dispose()
    {
        objRef?.Dispose();
    }

    [JSInvokable]
    public async Task UpdateLocationFromJS(string address, string city, string country, double lat, double lng)
    {
        hotel.Address = address;
        hotel.City = city;
        hotel.Country = country;
        hotel.Latitude = (decimal?)lat;
        hotel.Longitude = (decimal?)lng;
        StateHasChanged();
    }

    [JSInvokable]
    public string GetHotelAddress()
    {
        return hotel?.Address ?? "";
    }

    private async Task<string?> GetCurrentUserIdAsync()
    {
        try
        {
            var authState = await AuthStateProvider.GetAuthenticationStateAsync();
            var user = authState?.User;
            if (user?.Identity?.IsAuthenticated == true)
            {
                var nameClaim = user.FindFirst(ClaimTypes.Name)?.Value;
                if (!string.IsNullOrEmpty(nameClaim))
                {
                    var parts = nameClaim.Split(',');
                    if (parts.Length > 0) return parts[0];
                }
            }
        }
        catch { }
        return null;
    }

    private void ToggleAmenity(int amenityId, bool isChecked)
    {
        if (isChecked)
        {
            if (!selectedAmenityIds.Contains(amenityId))
                selectedAmenityIds.Add(amenityId);
        }
        else
        {
            selectedAmenityIds.Remove(amenityId);
        }
    }

    private void SetExistingPrimary(int imageId)
    {
        foreach (var img in existingImages)
        {
            img.IsPrimary = img.Id == imageId;
        }
        StateHasChanged();
    }

    private void RemoveExistingImage(int imageId)
    {
        imagesToRemove.Add(imageId);
        existingImages.RemoveAll(i => i.Id == imageId);
        StateHasChanged();
    }

    private async Task OnImagesSelected(InputFileChangeEventArgs e)
    {
        var totalCount = existingImages.Count + newImages.Count;
        var files = e.GetMultipleFiles(5);
        foreach (var file in files)
        {
            if (totalCount + newImages.Count >= 5) break;
            if (file.Size > MaxFileSize)
            {
                errorMessage = $"File '{file.Name}' exceeds 5MB limit.";
                continue;
            }
            if (!file.ContentType.StartsWith("image/")) continue;

            newImages.Add(file);

            try
            {
                var resized = await file.RequestImageFileAsync(file.ContentType, 200, 150);
                var buffer = new byte[resized.Size];
                await resized.OpenReadStream(MaxFileSize).ReadAsync(buffer);
                var base64 = Convert.ToBase64String(buffer);
                newImagePreviews[file.Name] = $"data:{file.ContentType};base64,{base64}";
            }
            catch { }
        }
        StateHasChanged();
    }

    private void RemoveNewImage(string name)
    {
        newImages.RemoveAll(f => f.Name == name);
        newImagePreviews.Remove(name);
        StateHasChanged();
    }

    private async Task HandleSubmit()
    {
        Console.WriteLine("HandleSubmit called");
        if (hotel == null || string.IsNullOrEmpty(currentUserId)) return;

        isSubmitting = true;
        errorMessage = null;
        successMessage = null;

        try
        {
            Console.WriteLine("Starting hotel update...");
            Console.WriteLine($"Hotel data: Name={hotel.Name}, Category={hotel.Category}, Phone={hotel.Phone}, Lat={hotel.Latitude}, Lng={hotel.Longitude}");
            // Fix lat/lng precision
            if (hotel.Latitude == 0) hotel.Latitude = null;
            if (hotel.Longitude == 0) hotel.Longitude = null;

            // Update hotel
            await HotelService.UpdateHotelAsync(hotel);

            // Remove deleted images from DB and disk
            foreach (var imgId in imagesToRemove)
            {
                var img = await UnitOfWork.HotelImages.GetByIdAsync(imgId);
                if (img != null)
                {
                    // Delete file from disk
                    var filePath = Path.Combine(Environment.WebRootPath, img.Url.TrimStart('/').Replace('/', Path.DirectorySeparatorChar));
                    if (File.Exists(filePath))
                    {
                        File.Delete(filePath);
                    }
                    UnitOfWork.HotelImages.Remove(img);
                }
            }

            // Update primary image flags for existing images
            foreach (var img in existingImages)
            {
                var dbImg = await UnitOfWork.HotelImages.GetByIdAsync(img.Id);
                if (dbImg != null)
                {
                    dbImg.IsPrimary = img.IsPrimary;
                    UnitOfWork.HotelImages.Update(dbImg);
                }
            }

            // Save new images to disk and DB
            if (newImages.Any())
            {
                var uploadsPath = Path.Combine(Environment.WebRootPath, "uploads", "hotels");
                Directory.CreateDirectory(uploadsPath);

                foreach (var file in newImages)
                {
                    var ext = Path.GetExtension(file.Name);
                    var fileName = $"{hotel.Id}_{Guid.NewGuid():N}{ext}";
                    var filePath = Path.Combine(uploadsPath, fileName);

                    await using var stream = new FileStream(filePath, FileMode.Create);
                    await file.OpenReadStream(MaxFileSize).CopyToAsync(stream);

                    await UnitOfWork.HotelImages.AddAsync(new HotelImage
                    {
                        HotelId = hotel.Id,
                        FileName = fileName,
                        Url = $"/uploads/hotels/{fileName}",
                        IsPrimary = false,
                        CreatedAt = DateTime.UtcNow
                    });
                }
            }

            // Update amenities: remove old, add new
            var currentAmenities = await UnitOfWork.HotelAmenities.FindAsync(ha => ha.HotelId == hotel.Id);
            UnitOfWork.HotelAmenities.RemoveRange(currentAmenities);

            foreach (var amenityId in selectedAmenityIds)
            {
                await UnitOfWork.HotelAmenities.AddAsync(new HotelAmenity
                {
                    HotelId = hotel.Id,
                    AmenityId = amenityId
                });
            }

            await UnitOfWork.SaveChangesAsync();

            Console.WriteLine("Hotel updated successfully!");
            successMessage = "Hotel updated successfully! Redirecting...";
            StateHasChanged();

            await Task.Delay(2000);
            NavigationManager.NavigateTo("/owner/hotels");
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error updating hotel: {ex.Message}");
            Console.WriteLine($"Stack trace: {ex.StackTrace}");
            if (ex.InnerException != null)
            {
                Console.WriteLine($"Inner exception: {ex.InnerException.Message}");
            }
            errorMessage = $"Error updating hotel: {ex.Message}";
            if (ex.InnerException != null)
                errorMessage += $" | {ex.InnerException.Message}";
        }
        finally
        {
            isSubmitting = false;
        }
    }

    private void HandleInvalidSubmit()
    {
        Console.WriteLine("Form validation failed!");
        errorMessage = "Please fix the validation errors before submitting.";
    }

    private void ConfirmDelete()
    {
        showDeleteConfirm = true;
    }

    private async Task DeleteHotel()
    {
        if (hotel == null) return;
        try
        {
            await HotelService.DeleteHotelAsync(hotel.Id);
            NavigationManager.NavigateTo("/owner/hotels");
        }
        catch (Exception ex)
        {
            errorMessage = $"Error deleting hotel: {ex.Message}";
            showDeleteConfirm = false;
        }
    }

    private void Cancel()
    {
        NavigationManager.NavigateTo("/owner/hotels");
    }
}

