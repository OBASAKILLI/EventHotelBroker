@page "/owner/analytics"
@rendermode InteractiveServer
@inject NavigationManager Navigation
@inject ToastService ToastService

<PageTitle>Analytics Dashboard - EventHotelBroker</PageTitle>

<link href="/css/owner-analytics.css?v=1" rel="stylesheet" />

<div class="oa">
    <Breadcrumb Items="@breadcrumbItems" />

    <!-- Header -->
    <div class="oa-header">
        <div>
            <h1 class="oa-header-title"><i class="bi bi-graph-up"></i> Analytics Dashboard</h1>
            <p class="oa-header-sub">Track your performance and revenue</p>
        </div>
        <div class="oa-header-actions">
            <select class="oa-select" @bind="selectedPeriod">
                <option value="7">Last 7 Days</option>
                <option value="30">Last 30 Days</option>
                <option value="90">Last 3 Months</option>
                <option value="365">Last Year</option>
            </select>
            <button type="button" class="oa-btn oa-btn-primary" @onclick="ExportReport">
                <i class="bi bi-download"></i> Export
            </button>
        </div>
    </div>

    <!-- Metric Cards -->
    <div class="oa-metrics">
        <div class="oa-metric">
            <div class="oa-metric-icon oa-icon-teal"><i class="bi bi-cash-stack"></i></div>
            <div>
                <div class="oa-metric-label">Total Revenue</div>
                <div class="oa-metric-value">KES 2.5M</div>
                <div class="oa-metric-change up"><i class="bi bi-arrow-up"></i> 12.5% from last month</div>
            </div>
        </div>
        <div class="oa-metric">
            <div class="oa-metric-icon oa-icon-terracotta"><i class="bi bi-calendar-check"></i></div>
            <div>
                <div class="oa-metric-label">Total Bookings</div>
                <div class="oa-metric-value">145</div>
                <div class="oa-metric-change up"><i class="bi bi-arrow-up"></i> 8.3% from last month</div>
            </div>
        </div>
        <div class="oa-metric">
            <div class="oa-metric-icon oa-icon-bronze"><i class="bi bi-pie-chart"></i></div>
            <div>
                <div class="oa-metric-label">Occupancy Rate</div>
                <div class="oa-metric-value">78%</div>
                <div class="oa-metric-change up"><i class="bi bi-arrow-up"></i> 5.2% from last month</div>
            </div>
        </div>
        <div class="oa-metric">
            <div class="oa-metric-icon oa-icon-charcoal"><i class="bi bi-wallet2"></i></div>
            <div>
                <div class="oa-metric-label">Avg Booking Value</div>
                <div class="oa-metric-value">KES 17.2K</div>
                <div class="oa-metric-change down"><i class="bi bi-arrow-down"></i> 2.1% from last month</div>
            </div>
        </div>
    </div>

    <div class="row g-3">
        <!-- Revenue Chart -->
        <div class="col-lg-8">
            <div class="oa-card">
                <div class="oa-card-header">
                    <h5 class="oa-card-title"><i class="bi bi-graph-up"></i> Revenue Trend</h5>
                    <div class="oa-chart-toggle">
                        <button type="button" class="oa-btn oa-btn-ghost @(chartView == "daily" ? "active" : "")" @onclick='() => chartView = "daily"'>Daily</button>
                        <button type="button" class="oa-btn oa-btn-ghost @(chartView == "weekly" ? "active" : "")" @onclick='() => chartView = "weekly"'>Weekly</button>
                        <button type="button" class="oa-btn oa-btn-ghost @(chartView == "monthly" ? "active" : "")" @onclick='() => chartView = "monthly"'>Monthly</button>
                    </div>
                </div>
                <div class="oa-card-body">
                    <div class="oa-chart">
                        <svg viewBox="0 0 800 220" style="width: 100%; height: 220px;">
                            <defs>
                                <linearGradient id="oaGrad" x1="0%" y1="0%" x2="0%" y2="100%">
                                    <stop offset="0%" style="stop-color:#C87941;stop-opacity:0.2" />
                                    <stop offset="100%" style="stop-color:#C87941;stop-opacity:0" />
                                </linearGradient>
                            </defs>
                            <polyline points="0,180 100,145 200,130 300,155 400,105 500,118 600,82 700,96 800,65"
                                      fill="url(#oaGrad)" stroke="#C87941" stroke-width="2.5" fill-opacity="1"/>
                            <circle cx="100" cy="145" r="3.5" fill="#C87941"/>
                            <circle cx="200" cy="130" r="3.5" fill="#C87941"/>
                            <circle cx="300" cy="155" r="3.5" fill="#C87941"/>
                            <circle cx="400" cy="105" r="3.5" fill="#C87941"/>
                            <circle cx="500" cy="118" r="3.5" fill="#C87941"/>
                            <circle cx="600" cy="82" r="3.5" fill="#C87941"/>
                            <circle cx="700" cy="96" r="3.5" fill="#C87941"/>
                            <circle cx="800" cy="65" r="3.5" fill="#C87941"/>
                        </svg>
                    </div>
                </div>
            </div>
        </div>

        <!-- Booking Sources -->
        <div class="col-lg-4">
            <div class="oa-card">
                <div class="oa-card-header">
                    <h5 class="oa-card-title"><i class="bi bi-pie-chart"></i> Booking Sources</h5>
                </div>
                <div class="oa-card-body">
                    <div class="oa-chart" style="text-align:center;">
                        <svg viewBox="0 0 200 200" style="width: 140px; height: 140px;">
                            <circle cx="100" cy="100" r="80" fill="none" stroke="rgba(158,139,99,0.08)" stroke-width="30"/>
                            <circle cx="100" cy="100" r="80" fill="none" stroke="#C87941" stroke-width="30"
                                    stroke-dasharray="251.2 502.4" transform="rotate(-90 100 100)"/>
                            <circle cx="100" cy="100" r="80" fill="none" stroke="#488C82" stroke-width="30"
                                    stroke-dasharray="125.6 502.4" stroke-dashoffset="-251.2" transform="rotate(-90 100 100)"/>
                            <circle cx="100" cy="100" r="80" fill="none" stroke="#9E8B63" stroke-width="30"
                                    stroke-dasharray="62.8 502.4" stroke-dashoffset="-376.8" transform="rotate(-90 100 100)"/>
                        </svg>
                    </div>
                    <div class="oa-legend">
                        <div class="oa-legend-item">
                            <span class="oa-legend-dot" style="background:#C87941;"></span>
                            <span class="oa-legend-label">Direct</span>
                            <span class="oa-legend-value">50%</span>
                        </div>
                        <div class="oa-legend-item">
                            <span class="oa-legend-dot" style="background:#488C82;"></span>
                            <span class="oa-legend-label">Platform</span>
                            <span class="oa-legend-value">30%</span>
                        </div>
                        <div class="oa-legend-item">
                            <span class="oa-legend-dot" style="background:#9E8B63;"></span>
                            <span class="oa-legend-label">Referral</span>
                            <span class="oa-legend-value">20%</span>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Top Performing Hotels -->
        <div class="col-lg-6">
            <div class="oa-card">
                <div class="oa-card-header">
                    <h5 class="oa-card-title"><i class="bi bi-trophy"></i> Top Performing Hotels</h5>
                </div>
                <div class="oa-card-body">
                    @foreach (var hotel in topHotels)
                    {
                        <div class="oa-perf-item">
                            <div class="oa-perf-row">
                                <div class="oa-perf-rank">@hotel.Rank</div>
                                <div style="flex:1;">
                                    <h6 class="oa-perf-name">@hotel.Name</h6>
                                    <span class="oa-perf-bookings">@hotel.Bookings bookings</span>
                                </div>
                                <div class="oa-perf-right">
                                    <div class="oa-perf-revenue">KES @hotel.Revenue.ToString("N0")</div>
                                    <span class="oa-perf-occ">@hotel.OccupancyRate% occupied</span>
                                </div>
                            </div>
                            <div class="oa-progress">
                                <div class="oa-progress-bar" style="width: @hotel.OccupancyRate%"></div>
                            </div>
                        </div>
                    }
                </div>
            </div>
        </div>

        <!-- Recent Activity -->
        <div class="col-lg-6">
            <div class="oa-card">
                <div class="oa-card-header">
                    <h5 class="oa-card-title"><i class="bi bi-clock-history"></i> Recent Activity</h5>
                </div>
                <div class="oa-card-body">
                    @foreach (var activity in recentActivities)
                    {
                        <div class="oa-activity">
                            <div class="oa-activity-icon @activity.Type">
                                <i class="bi bi-@activity.Icon"></i>
                            </div>
                            <div>
                                <p class="oa-activity-msg">@activity.Message</p>
                                <span class="oa-activity-time">@activity.Time</span>
                            </div>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

@code {
    private List<BreadcrumbItem> breadcrumbItems = new()
    {
        new BreadcrumbItem { Text = "Home", Url = "/" },
        new BreadcrumbItem { Text = "Owner Dashboard", Url = "/owner/dashboard" },
        new BreadcrumbItem { Text = "Analytics", IsActive = true }
    };

    private string selectedPeriod = "30";
    private string chartView = "daily";

    private List<TopHotel> topHotels = new()
    {
        new() { Rank = 1, Name = "Grand Plaza Hotel", Bookings = 45, Revenue = 850000, OccupancyRate = 92 },
        new() { Rank = 2, Name = "Sunset Resort", Bookings = 38, Revenue = 720000, OccupancyRate = 85 },
        new() { Rank = 3, Name = "City Center Inn", Bookings = 32, Revenue = 580000, OccupancyRate = 78 },
        new() { Rank = 4, Name = "Beach View Hotel", Bookings = 30, Revenue = 520000, OccupancyRate = 72 }
    };

    private List<Activity> recentActivities = new()
    {
        new() { Icon = "calendar-check", Type = "booking", Message = "New booking for Grand Plaza Hotel", Time = "5 minutes ago" },
        new() { Icon = "cash", Type = "payment", Message = "Payment received - KES 45,000", Time = "12 minutes ago" },
        new() { Icon = "star-fill", Type = "review", Message = "New 5-star review for Sunset Resort", Time = "1 hour ago" },
        new() { Icon = "calendar-check", Type = "booking", Message = "Booking confirmed for City Center Inn", Time = "2 hours ago" },
        new() { Icon = "x-circle", Type = "cancellation", Message = "Booking cancelled - Refund processed", Time = "3 hours ago" }
    };

    private void ExportReport()
    {
        ToastService.ShowSuccess("Export Started", "Your analytics report is being generated");
    }

    public class TopHotel
    {
        public int Rank { get; set; }
        public string Name { get; set; } = "";
        public int Bookings { get; set; }
        public decimal Revenue { get; set; }
        public int OccupancyRate { get; set; }
    }

    public class Activity
    {
        public string Icon { get; set; } = "";
        public string Type { get; set; } = "";
        public string Message { get; set; } = "";
        public string Time { get; set; } = "";
    }
}
