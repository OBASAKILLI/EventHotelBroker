<script src="/js/home-helpers.js"></script>

@code {
    private List<Hotel>? featuredHotels;
    private List<EventPackage>? featuredPackages;
    private List<EventEquipment>? featuredEquipments;
    private List<Hotel> filteredHotels = new();
    private string selectedCategory = "All";
    private DotNetObjectReference<Home>? objRef;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            // Load hotels
            var hotels = await HotelService.GetPublishedHotelsAsync();
            featuredHotels = hotels.ToList();
            filteredHotels = featuredHotels.ToList();
            
            // Load featured event packages
            var allPackages = await EventService.GetApprovedPackagesAsync();
            featuredPackages = allPackages.Where(p => p.IsFeatured || p.IsActive).Take(6).ToList();

            // Load featured equipment
            var allEquipments = await EventService.GetAllEquipmentsAsync();
            featuredEquipments = allEquipments.Where(e => e.IsApproved && e.IsAvailable).Take(8).ToList();
        }
        catch
        {
            featuredHotels = new List<Hotel>();
            filteredHotels = new List<Hotel>();
            featuredPackages = new List<EventPackage>();
            featuredEquipments = new List<EventEquipment>();
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            objRef = DotNetObjectReference.Create(this);
            await JSRuntime.InvokeVoidAsync("homeHelpers.init", objRef);
        }
    }

    [JSInvokable]
    public async Task SwitchTab(string tabName)
    {
        // Hide all tabs
        await JSRuntime.InvokeVoidAsync("eval", @"
            document.getElementById('tabAllHotels').style.display = 'none';
            document.getElementById('tabHotelsContent').style.display = 'none';
            document.getElementById('tabAirbnbContent').style.display = 'none';
            document.getElementById('tabRestaurantContent').style.display = 'none';
            document.getElementById('tabEventsContent').style.display = 'none';
            document.getElementById('tabEquipmentContent').style.display = 'none';
        ");

        // Show selected tab and filter if needed
        switch (tabName)
        {
            case "all-hotels":
                await JSRuntime.InvokeVoidAsync("eval", "document.getElementById('tabAllHotels').style.display = '';");
                break;
            case "hotels":
                selectedCategory = "Hotel";
                if (featuredHotels != null)
                {
                    filteredHotels = featuredHotels.Where(h => h.Category == "Hotel").ToList();
                }
                await JSRuntime.InvokeVoidAsync("eval", "document.getElementById('tabHotelsContent').style.display = '';");
                break;
            case "airbnb":
                selectedCategory = "Airbnb";
                if (featuredHotels != null)
                {
                    filteredHotels = featuredHotels.Where(h => h.Category == "Airbnb").ToList();
                }
                await JSRuntime.InvokeVoidAsync("eval", "document.getElementById('tabAirbnbContent').style.display = '';");
                break;
            case "restaurant":
                selectedCategory = "Restaurant";
                if (featuredHotels != null)
                {
                    filteredHotels = featuredHotels.Where(h => h.Category == "Restaurant").ToList();
                }
                await JSRuntime.InvokeVoidAsync("eval", "document.getElementById('tabRestaurantContent').style.display = '';");
                break;
            case "events":
                await JSRuntime.InvokeVoidAsync("eval", "document.getElementById('tabEventsContent').style.display = '';");
                break;
            case "equipment":
                await JSRuntime.InvokeVoidAsync("eval", "document.getElementById('tabEquipmentContent').style.display = '';");
                break;
        }
        
        StateHasChanged();
    }

    public void Dispose()
    {
        objRef?.Dispose();
    }

    private string GetCategoryIcon(string category)
    {
        return category switch
        {
            "Hotel" => "bi-building",
            "Airbnb" => "bi-house",
            "Restaurant" => "bi-cup-hot",
            "Venue" => "bi-geo-alt",
            "Resort" => "bi-stars",
            "Lodge" => "bi-tree",
            "Guest House" => "bi-house-door",
            "Apartment" => "bi-building-check",
            "Tents" => "bi-house",
            "Chairs" => "bi-chair",
            "Sound System" => "bi-speaker",
            "Lighting" => "bi-lightbulb",
            "Catering" => "bi-cup-hot",
            "Decoration" => "bi-flower1",
            _ => "bi-box-seam"
        };
    }

    private string GetCategoryGradient(string category)
    {
        return category switch
        {
            "Hotel" => "linear-gradient(135deg, #9E8B63, #b8a584)",
            "Airbnb" => "linear-gradient(135deg, #f59e0b, #fbbf24)",
            "Restaurant" => "linear-gradient(135deg, #dc2626, #ef4444)",
            "Venue" => "linear-gradient(135deg, #7c3aed, #8b5cf6)",
            "Resort" => "linear-gradient(135deg, #059669, #10B981)",
            "Lodge" => "linear-gradient(135deg, #78350f, #92400e)",
            "Guest House" => "linear-gradient(135deg, #1e40af, #3b82f6)",
            "Apartment" => "linear-gradient(135deg, #475569, #64748b)",
            "Tents" => "linear-gradient(135deg, #2A2A2A, #4a4a4a)",
            "Chairs" => "linear-gradient(135deg, #9E8B63, #b8a584)",
            "Sound System" => "linear-gradient(135deg, #6366f1, #818cf8)",
            "Lighting" => "linear-gradient(135deg, #d97706, #f59e0b)",
            "Catering" => "linear-gradient(135deg, #059669, #10B981)",
            "Decoration" => "linear-gradient(135deg, #ec4899, #f472b6)",
            _ => "linear-gradient(135deg, #9E8B63, #b8a584)"
        };
    }
}
