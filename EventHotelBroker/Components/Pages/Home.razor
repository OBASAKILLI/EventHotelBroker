            </div>

            <!-- Events Tab (hidden by default) -->
            <div id="tabEventsContent" class="tab-pane-content" style="display:none;">
                @if (featuredPackages == null)
                {
                    <div class="text-center py-5">
                        <div class="spinner-border spinner-modern text-primary" role="status">
                            <span class="visually-hidden">Loading...</span>
                        </div>
                        <p class="mt-3 text-muted">Loading event packages...</p>
                    </div>
                }
                else if (!featuredPackages.Any())
                {
                    <div class="modern-card">
                        <div class="empty-state">
                            <i class="bi bi-gift empty-state-icon"></i>
                            <h3 class="empty-state-title">No Event Packages Available</h3>
                            <p class="empty-state-text">Check back soon for amazing event packages!</p>
                        </div>
                    </div>
                }
                else
                {
                    <div class="row g-4">
                        @foreach (var package in featuredPackages.Take(6))
                        {
                            <div class="col-md-6 col-lg-3">
                                <a href="/events/package/@package.Id" class="package-card-home" style="text-decoration:none;color:inherit;display:block;">
                                    <div class="package-image">
                                        @if (!string.IsNullOrEmpty(package.ImageUrl))
                                        {
                                            <img src="@package.ImageUrl" alt="@package.Name" />
                                        }
                                        else
                                        {
                                            <div class="package-placeholder">
                                                <i class="bi bi-gift"></i>
                                            </div>
                                        }
                                        @if (package.IsFeatured)
                                        {
                                            <div class="package-badge">
                                                <i class="bi bi-star-fill"></i>
                                                <span>Featured</span>
                                            </div>
                                        }
                                        @if (package.DiscountedPrice.HasValue)
                                        {
                                            var savings = package.TotalPrice > 0
                                                ? ((package.TotalPrice - package.DiscountedPrice.Value) / package.TotalPrice) * 100
                                                : 0;
                                            <div class="discount-badge">
                                                @savings.ToString("N0")% OFF
                                            </div>
                                        }
                                    </div>
                                    <div class="package-content">
                                        <span class="package-type-badge">
                                            <i class="bi bi-tag me-1"></i>@(package.PackageType ?? "Package")
                                        </span>
                                        <h5 class="package-title">@package.Name</h5>
                                        <p class="package-description">
                                            @((package.Description ?? "").Length > 80 ? (package.Description ?? "").Substring(0, 80) + "..." : (package.Description ?? ""))
                                        </p>
                                        <div class="package-meta">
                                            <span class="meta-item">
                                                <i class="bi bi-people"></i>
                                                @package.MinGuests - @package.MaxGuests guests
                                            </span>
                                            @if (package.IsCustomizable)
                                            {
                                                <span class="meta-item">
                                                    <i class="bi bi-sliders text-success"></i>
                                                    Customizable
                                                </span>
                                            }
                                        </div>
                                        <div class="package-footer">
                                            <div class="package-price">
                                                @if (package.DiscountedPrice.HasValue)
                                                {
                                                    <span class="price-original">KES @package.TotalPrice.ToString("N0")</span>
                                                    <span class="price-discounted">KES @package.DiscountedPrice.Value.ToString("N0")</span>
                                                }
                                                else
                                                {
                                                    <span class="price-amount">KES @package.TotalPrice.ToString("N0")</span>
                                                }
                                            </div>
                                            <span class="btn btn-sm btn-outline-primary">
                                                View Details
                                            </span>
                                        </div>
                                    </div>
                                </a>
                            </div>
                        }
                    </div>
                    <div class="text-center mt-4">
                        <a href="/events?tab=packages" class="btn-modern btn-gradient-accent">
                            <i class="bi bi-gift me-2"></i>Explore All Event Packages
                        </a>
                    </div>
                }
            </div>

            <!-- Equipment Tab (hidden by default) -->
            <div id="tabEquipmentContent" class="tab-pane-content" style="display:none;">
                @if (featuredEquipments == null)
                {
                    <div class="text-center py-5">
                        <div class="spinner-border spinner-modern text-primary" role="status">
                            <span class="visually-hidden">Loading...</span>
                        </div>
                        <p class="mt-3 text-muted">Loading equipment...</p>
                    </div>
                }
                else if (!featuredEquipments.Any())
                {
                    <div class="modern-card">
                        <div class="empty-state">
                            <i class="bi bi-box-seam empty-state-icon"></i>
                            <h3 class="empty-state-title">No Equipment Available</h3>
                            <p class="empty-state-text">Check back soon for amazing rental equipment!</p>
                        </div>
                    </div>
                }
                else
                {
                    <div class="row g-4">
                        @foreach (var equipment in featuredEquipments.Take(8))
                        {
                            <div class="col-md-6 col-lg-3">
                                <a href="/events?tab=equipment" class="equip-card-home" style="text-decoration:none;color:inherit;display:block;">
                                    <div class="equip-card-img-home">
                                        @{ var eqImg = equipment.Images?.OrderBy(i => i.DisplayOrder).FirstOrDefault(); }
                                        @if (eqImg != null && !string.IsNullOrEmpty(eqImg.ImageUrl))
                                        {
                                            <img src="@eqImg.ImageUrl" alt="@equipment.Name" />
                                        }
                                        else
                                        {
                                            <div class="equip-placeholder-home" style="background: @GetCategoryGradient(equipment.Category)">
                                                <i class="bi @GetCategoryIcon(equipment.Category)"></i>
                                            </div>
                                        }
                                        <div class="equip-category-badge">
                                            <i class="bi @GetCategoryIcon(equipment.Category)"></i>
                                        </div>
                                    </div>
                                    <div class="equip-card-body-home">
                                        <h5 class="equip-title-home">@equipment.Name</h5>
                                        <p class="equip-desc-home">
                                            @((equipment.Description ?? "").Length > 70 ? (equipment.Description ?? "").Substring(0, 70) + "..." : (equipment.Description ?? ""))
                                        </p>
                                        <div class="equip-footer-home">
                                            <div class="equip-price-home">
                                                <span class="price-amount">KES @equipment.PricePerUnit.ToString("N0")</span>
                                                <span class="price-unit">/@equipment.Unit</span>
                                            </div>
                                            <span class="equip-avail-home">@equipment.AvailableQuantity avail</span>
                                        </div>
                                    </div>
                                </a>
                            </div>
                        }
                    </div>
                    <div class="text-center mt-4">
                        <a href="/events?tab=equipment" class="btn-modern btn-gradient-accent">
                            <i class="bi bi-box-seam me-2"></i>Explore All Equipment
                        </a>
                    </div>
                }
            </div>
        </div>
    </div>
</div>

