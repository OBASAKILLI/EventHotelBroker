                            <i class="bi bi-house empty-state-icon"></i>
                            <h3 class="empty-state-title">No Airbnb Listings Available</h3>
                            <p class="empty-state-text">Check back soon for amazing Airbnb listings!</p>
                        </div>
                    </div>
                }
                else
                {
                    <div class="row g-4">
                        @foreach (var hotel in filteredHotels.Take(6))
                        {
                            <div class="col-md-6 col-lg-3">
                                <a href="/hotels/@hotel.Id" class="hotel-card" style="text-decoration:none;color:inherit;display:block;">
                                    <div class="hotel-image">
                                        @if (hotel.Images?.Any() == true)
                                        {
                                            <img src="@hotel.Images.First().Url" alt="@hotel.Name" />
                                        }
                                        else
                                        {
                                            <div class="hotel-placeholder">
                                                <i class="bi bi-house"></i>
                                            </div>
                                        }
                                        @if (hotel.IsApproved)
                                        {
                                            <div class="hotel-badge">
                                                <i class="bi bi-patch-check-fill"></i>
                                                <span>Verified</span>
                                            </div>
                                        }
                                        <div class="hotel-category-badge">
                                            <i class="bi @GetCategoryIcon(hotel.Category)"></i>
                                            <span>@hotel.Category</span>
                                        </div>
                                        <div class="hotel-overlay">
                                            <span class="hotel-view-btn">
                                                <i class="bi bi-eye me-2"></i>View Details
                                            </span>
                                        </div>
                                    </div>
                                    <div class="hotel-content">
                                        <h5 class="hotel-name">@hotel.Name</h5>
                                        <span class="hotel-location"><i class="bi bi-geo-alt-fill"></i> @hotel.City, @hotel.Country</span>

                                        <div class="hotel-meta-row">
                                            <div class="hotel-rating">
                                                <i class="bi bi-star-fill"></i>
                                                <span class="hotel-rating-text">4.5</span>
                                            </div>
                                            <span class="meta-dot"></span>
                                            <div class="hotel-price-inline">
                                                <span class="price-amount">@hotel.Currency @hotel.PricePerNight.ToString("N0")</span>
                                                <span class="price-period">/night</span>
                                            </div>
                                        </div>

                                        @if (!string.IsNullOrWhiteSpace(hotel.Description))
                                        {
                                            <p class="hotel-description">@hotel.Description</p>
