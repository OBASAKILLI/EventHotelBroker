@page "/"
@layout EventHotelBroker.Components.Layout.HomeLayout
@rendermode InteractiveServer
@using EventHotelBroker.Services
@using EventHotelBroker.Models
@inject IHotelService HotelService
@inject IEventService EventService
@inject NavigationManager Navigation
@inject IJSRuntime JSRuntime
@implements IDisposable

<PageTitle>Home - EventHotelBroker</PageTitle>

<!-- Modern Hero Section -->
<div class="modern-hero">
    <div class="hero-background"></div>
    <div class="hero-content">
        <div class="container">
            <div class="row align-items-center">
                <div class="col-lg-6 animate-fade-in">
                    <div class="hero-badge">
                        <i class="bi bi-star-fill"></i>
                        <span>Trusted by 10,000+ Event Planners</span>
                    </div>
                    <h1 class="hero-title">
                        Find Your Perfect
                        <span class="gradient-text">Event Venue</span>
                    </h1>
                    <p class="hero-subtitle">
                        Connect with premium hotels, venues, and service providers for your next event.
                        From weddings to conferences, we've got you covered.
                    </p>
                    <div class="hero-search">
                        <div class="search-box">
                            <i class="bi bi-search"></i>
                            <input type="text" placeholder="Search venues, hotels, locations..." />
                            <button class="btn-modern btn-gradient-primary">Search</button>
                        </div>
                    </div>
                    <div class="hero-stats">
                        <div class="stat-item">
                            <div class="stat-number">500+</div>
                            <div class="stat-label">Venues</div>
                        </div>
                        <div class="stat-item">
                            <div class="stat-number">50+</div>
                            <div class="stat-label">Cities</div>
                        </div>
                        <div class="stat-item">
                            <div class="stat-number">10K+</div>
                            <div class="stat-label">Happy Clients</div>
                        </div>
                    </div>
                </div>
                <div class="col-lg-6 d-none d-lg-block">
                    <div class="hero-image">
                        <div class="floating-card card-1">
                            <i class="bi bi-building"></i>
                            <div>
                                <div class="card-title">Premium Hotels</div>
                                <div class="card-subtitle">200+ Venues</div>
                            </div>
                        </div>
                        <div class="floating-card card-2">
                            <i class="bi bi-calendar-check"></i>
                            <div>
                                <div class="card-title">Easy Booking</div>
                                <div class="card-subtitle">Instant Confirmation</div>
                            </div>
                        </div>
                        <div class="floating-card card-3">
                            <i class="bi bi-star-fill"></i>
                            <div>
                                <div class="card-title">Top Rated</div>
                                <div class="card-subtitle">4.9/5 Average</div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>


<!-- How It Works Section -->
<div class="how-it-works-section">
    <div class="container">
        <div class="section-header text-center">
            <span class="section-badge">Simple Process</span>
            <h2 class="section-title">How It Works</h2>
            <p class="section-subtitle">Book your perfect venue in three easy steps</p>
        </div>
        <div class="row g-4">
            <div class="col-md-4">
                <div class="feature-card">
                    <div class="feature-number">01</div>
                    <div class="feature-icon">
                        <i class="bi bi-search"></i>
                    </div>
                    <h5 class="feature-title">Search & Discover</h5>
                    <p class="feature-text">Browse through hundreds of verified venues and service providers in your area.</p>
                </div>
            </div>
            <div class="col-md-4">
                <div class="feature-card">
                    <div class="feature-number">02</div>
                    <div class="feature-icon">
                        <i class="bi bi-chat-dots"></i>
                    </div>
                    <h5 class="feature-title">Connect & Inquire</h5>
                    <p class="feature-text">Message venue owners directly and get instant responses to your questions.</p>
                </div>
            </div>
            <div class="col-md-4">
                <div class="feature-card">
                    <div class="feature-number">03</div>
                    <div class="feature-icon">
                        <i class="bi bi-calendar-check"></i>
                    </div>
                    <h5 class="feature-title">Book with Confidence</h5>
                    <p class="feature-text">Send booking requests and manage everything from your dashboard.</p>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Explore Hotels & Events Section with Tabs -->
<div class="explore-section py-5">
    <div class="container">
        <div class="section-header text-center mb-4">
            <span class="section-badge">Explore Our Services</span>
            <h2 class="section-title">Hotels & Event Packages</h2>
            <p class="section-subtitle">Everything you need for your perfect event in one place</p>
        </div>

        <!-- Modern Tabs -->
        <div class="modern-tabs-container mb-4">
            <div class="modern-tabs" style="display:inline-flex;">
                <button id="tabBtnAllHotels" class="nav-link active" type="button"
                        onclick="switchTab('all-hotels');this.classList.add('active');document.getElementById('tabBtnHotels').classList.remove('active');document.getElementById('tabBtnAirbnb').classList.remove('active');document.getElementById('tabBtnRestaurant').classList.remove('active');document.getElementById('tabBtnEvents').classList.remove('active');document.getElementById('tabBtnEquipment').classList.remove('active');">
                    <i class="bi bi-building me-2"></i>
                    <span>All Hotels</span>
                    <span class="tab-count">@(featuredHotels?.Count ?? 0)</span>
                </button>
                <button id="tabBtnHotels" class="nav-link" type="button"
                        onclick="switchTab('hotels');this.classList.add('active');document.getElementById('tabBtnAllHotels').classList.remove('active');document.getElementById('tabBtnAirbnb').classList.remove('active');document.getElementById('tabBtnRestaurant').classList.remove('active');document.getElementById('tabBtnEvents').classList.remove('active');document.getElementById('tabBtnEquipment').classList.remove('active');">
                    <i class="bi bi-building me-2"></i>
                    <span>Hotels</span>
                    <span class="tab-count">@(featuredHotels?.Count(h => h.Category == "Hotel") ?? 0)</span>
                </button>
                <button id="tabBtnAirbnb" class="nav-link" type="button"
                        onclick="switchTab('airbnb');this.classList.add('active');document.getElementById('tabBtnAllHotels').classList.remove('active');document.getElementById('tabBtnHotels').classList.remove('active');document.getElementById('tabBtnRestaurant').classList.remove('active');document.getElementById('tabBtnEvents').classList.remove('active');document.getElementById('tabBtnEquipment').classList.remove('active');">
                    <i class="bi bi-house me-2"></i>
                    <span>Airbnb</span>
                    <span class="tab-count">@(featuredHotels?.Count(h => h.Category == "Airbnb") ?? 0)</span>
                </button>
                <button id="tabBtnRestaurant" class="nav-link" type="button"
                        onclick="switchTab('restaurant');this.classList.add('active');document.getElementById('tabBtnAllHotels').classList.remove('active');document.getElementById('tabBtnHotels').classList.remove('active');document.getElementById('tabBtnAirbnb').classList.remove('active');document.getElementById('tabBtnEvents').classList.remove('active');document.getElementById('tabBtnEquipment').classList.remove('active');">
                    <i class="bi bi-cup-hot me-2"></i>
                    <span>Restaurants</span>
                    <span class="tab-count">@(featuredHotels?.Count(h => h.Category == "Restaurant") ?? 0)</span>
                </button>
                <button id="tabBtnEvents" class="nav-link" type="button"
                        onclick="switchTab('events');this.classList.add('active');document.getElementById('tabBtnAllHotels').classList.remove('active');document.getElementById('tabBtnHotels').classList.remove('active');document.getElementById('tabBtnAirbnb').classList.remove('active');document.getElementById('tabBtnRestaurant').classList.remove('active');document.getElementById('tabBtnEquipment').classList.remove('active');">
                    <i class="bi bi-gift me-2"></i>
                    <span>Event Packages</span>
                    <span class="tab-count">@(featuredPackages?.Count ?? 0)</span>
                </button>
                <button id="tabBtnEquipment" class="nav-link" type="button"
                        onclick="switchTab('equipment');this.classList.add('active');document.getElementById('tabBtnAllHotels').classList.remove('active');document.getElementById('tabBtnHotels').classList.remove('active');document.getElementById('tabBtnAirbnb').classList.remove('active');document.getElementById('tabBtnRestaurant').classList.remove('active');document.getElementById('tabBtnEvents').classList.remove('active');">
                    <i class="bi bi-box-seam me-2"></i>
                    <span>Equipment Rental</span>
                    <span class="tab-count">@(featuredEquipments?.Count ?? 0)</span>
                </button>
            </div>
        </div>

        <!-- Tab Content -->
        <div class="tab-content">
            <!-- All Hotels Tab -->
            <div id="tabAllHotels" class="tab-pane-content">
                @if (featuredHotels == null)
                {
                    <div class="text-center py-5">
                        <div class="spinner-border spinner-modern text-primary" role="status">
                            <span class="visually-hidden">Loading...</span>
                        </div>
                        <p class="mt-3 text-muted">Loading venues...</p>
                    </div>
                }
                else if (!featuredHotels.Any())
                {
                    <div class="modern-card">
                        <div class="empty-state">
                            <i class="bi bi-building empty-state-icon"></i>
                            <h3 class="empty-state-title">No Venues Available</h3>
                            <p class="empty-state-text">Check back soon for amazing venues!</p>
                        </div>
                    </div>
                }
                else
                {
                    <div class="row g-4">
                        @foreach (var hotel in featuredHotels.Take(6))
                        {
                            <div class="col-md-6 col-lg-3">
                                <a href="/hotels/@hotel.Id" class="hotel-card" style="text-decoration:none;color:inherit;display:block;">
                                    <div class="hotel-image">
                                        @if (hotel.Images?.Any() == true)
                                        {
                                            <img src="@hotel.Images.First().Url" alt="@hotel.Name" />
                                        }
                                        else
                                        {
                                            <div class="hotel-placeholder">
                                                <i class="bi bi-building"></i>
                                            </div>
                                        }
                                        @if (hotel.IsApproved)
                                        {
                                            <div class="hotel-badge">
                                                <i class="bi bi-patch-check-fill"></i>
                                                <span>Verified</span>
                                            </div>
                                        }
                                        <div class="hotel-category-badge">
                                            <i class="bi @GetCategoryIcon(hotel.Category)"></i>
                                            <span>@hotel.Category</span>
                                        </div>
                                        <div class="hotel-overlay">
                                            <span class="hotel-view-btn">
                                                <i class="bi bi-eye me-2"></i>View Details
                                            </span>
                                        </div>
                                    </div>
                                    <div class="hotel-content">
                                        <h5 class="hotel-name">@hotel.Name</h5>
                                        <span class="hotel-location"><i class="bi bi-geo-alt-fill"></i> @hotel.City, @hotel.Country</span>

                                        <div class="hotel-meta-row">
                                            <div class="hotel-rating">
                                                <i class="bi bi-star-fill"></i>
                                                <span class="hotel-rating-text">4.5</span>
                                            </div>
                                            <span class="meta-dot"></span>
                                            <div class="hotel-price-inline">
                                                <span class="price-amount">@hotel.Currency @hotel.PricePerNight.ToString("N0")</span>
                                                <span class="price-period">/night</span>
                                            </div>
                                        </div>

                                        @if (!string.IsNullOrWhiteSpace(hotel.Description))
                                        {
                                            <p class="hotel-description">@hotel.Description</p>
                                        }

                                        <div class="hotel-footer">
                                            <span class="hotel-book-btn">
                                                View <i class="bi bi-arrow-right"></i>
                                            </span>
                                        </div>
                                    </div>
                                </a>
                            </div>
                        }
                    </div>
                    <div class="text-center mt-4">
                        <a href="/search" class="btn-modern btn-gradient-primary">
                            <i class="bi bi-search me-2"></i>Explore All Hotels
                        </a>
                    </div>
                }
            </div>

            <!-- Hotels Category Tab (hidden by default) -->
            <div id="tabHotelsContent" class="tab-pane-content" style="display:none;">
                @if (featuredHotels == null)
