                    },
                    new Booking
                    {
                        Id = 3,
                        HotelId = 7,
                        Hotel = new Hotel { Id = 7, Name = "City Center Inn", PricePerNight = 12000 },
                        StartDate = DateTime.Now.AddDays(-5),
                        EndDate = DateTime.Now.AddDays(-3),
                        HeadCount = 2,
                        Status = BookingStatus.Confirmed,
                        UserId = currentUserId ?? "guest"
