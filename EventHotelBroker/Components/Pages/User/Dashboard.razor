@page "/user/dashboard"
@rendermode InteractiveServer
@using EventHotelBroker.Models
@using EventHotelBroker.Services
@using Microsoft.AspNetCore.Components.Authorization
@using System.Security.Claims
@using EventHotelBroker.Utils
@inject IBookingService BookingService
@inject IEventService EventService
@inject NavigationManager Navigation
@inject ToastService ToastService
@inject AuthenticationStateProvider AuthStateProvider
@inject IJSRuntime JSRuntime

<PageTitle>My Dashboard - EventHotelBroker</PageTitle>

<link href="/css/design-system.css" rel="stylesheet" />

<div class="ud-shell">
    <Breadcrumb Items="@breadcrumbItems" />

    @if (isLoading)
    {
        <div class="row g-3 mb-3">
            @for (int i = 0; i < 4; i++)
            {
                <div class="col-lg-3 col-md-6">
                    <LoadingSkeleton Type="LoadingSkeleton.SkeletonType.Custom" Height="80px" />
                </div>
            }
        </div>
        <div class="row g-3">
            <div class="col-lg-8">
                <LoadingSkeleton Type="LoadingSkeleton.SkeletonType.Card" />
            </div>
            <div class="col-lg-4">
                <LoadingSkeleton Type="LoadingSkeleton.SkeletonType.Card" />
            </div>
        </div>
    }
    else
    {
        <!-- Welcome Banner -->
        <div class="ud-welcome">
            <div class="ud-welcome-left">
                <h1 class="ud-title">Welcome back!</h1>
                <p class="ud-subtitle">@DateTime.Now.ToString("dddd, MMMM dd yyyy")</p>
            </div>
            <div class="ud-welcome-right">
                <a href="/search" class="ud-btn ud-btn-primary"><i class="bi bi-plus-lg"></i> New Booking</a>
                <a href="/events" class="ud-btn ud-btn-outline"><i class="bi bi-gift"></i> Book Event</a>
            </div>
        </div>

        <!-- Statistics Cards -->
        <div class="row g-3 mb-3">
            <div class="col-lg-3 col-md-6">
                <div class="ud-stat">
                    <div class="ud-stat-icon ud-icon-terracotta"><i class="bi bi-building"></i></div>
                    <div>
                        <div class="ud-stat-value">@hotelBookings.Count()</div>
                        <div class="ud-stat-label">Hotel Bookings</div>
                    </div>
                </div>
            </div>
            <div class="col-lg-3 col-md-6">
                <div class="ud-stat">
                    <div class="ud-stat-icon ud-icon-olive"><i class="bi bi-calendar-event"></i></div>
                    <div>
                        <div class="ud-stat-value">@eventBookings.Count()</div>
                        <div class="ud-stat-label">Event Bookings</div>
                    </div>
                </div>
            </div>
            <div class="col-lg-3 col-md-6">
                <div class="ud-stat">
                    <div class="ud-stat-icon ud-icon-teal"><i class="bi bi-wallet2"></i></div>
                    <div>
                        <div class="ud-stat-value">KES @GetTotalSpend().ToString("N0")</div>
                        <div class="ud-stat-label">Total Spent</div>
                    </div>
                </div>
            </div>
            <div class="col-lg-3 col-md-6">
                <div class="ud-stat">
                    <div class="ud-stat-icon ud-icon-bronze"><i class="bi bi-clock-history"></i></div>
                    <div>
                        <div class="ud-stat-value">@GetPendingCount()</div>
                        <div class="ud-stat-label">Pending</div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Upcoming Booking Highlight -->
        var nextBooking = GetNextUpcomingBooking();
        @if (nextBooking != null)
        {
            <div class="ud-upcoming mb-3">
                <div class="ud-upcoming-label"><i class="bi bi-lightning-fill"></i> UPCOMING</div>
                <div class="ud-upcoming-body">
                    <div class="ud-upcoming-info">
                        <span class="ud-upcoming-name">@nextBooking.Hotel?.Name</span>
                        <span class="ud-upcoming-meta">@nextBooking.StartDate.ToString("MMM dd") – @nextBooking.EndDate.ToString("MMM dd, yyyy") · @nextBooking.HeadCount guests</span>
                    </div>
                    <div class="ud-upcoming-countdown">
                        <span class="ud-countdown-value">@((nextBooking.StartDate - DateTime.Now).Days)</span>
                        <span class="ud-countdown-label">days away</span>
                    </div>
                </div>
            </div>
        }

        <!-- Main Row: 8:4 layout -->
        <div class="row g-3">
            <!-- Left Column: Tabbed Bookings -->
            <div class="col-lg-8">
                <div class="ud-card">
                    <div class="ud-tab-bar">
                        <button class="ud-tab @(activeTab == "hotels" ? "ud-tab-active" : "")" @onclick='() => activeTab = "hotels"'>
                            <i class="bi bi-building"></i> Hotel Bookings
                            <span class="ud-tab-count">@hotelBookings.Count()</span>
                        </button>
                        <button class="ud-tab @(activeTab == "events" ? "ud-tab-active" : "")" @onclick='() => activeTab = "events"'>
                            <i class="bi bi-calendar-event"></i> Event Bookings
                            <span class="ud-tab-count">@eventBookings.Count()</span>
                        </button>
                        <div class="ud-tab-spacer"></div>
                        <a href="@(activeTab == "hotels" ? "/my-bookings" : "/my-event-bookings")" class="ud-link">View All <i class="bi bi-arrow-right"></i></a>
                    </div>
                    <div class="ud-card-body">
                        @if (activeTab == "hotels")
                        {
                            @if (hotelBookings.Any())
                            {
                                @foreach (var booking in hotelBookings.Take(5))
                                {
                                    <div class="ud-row" @onclick="() => ViewHotelBooking(booking.Id)">
                                        <div class="ud-row-left">
                                            <span class="ud-row-name">@booking.Hotel?.Name</span>
                                            <span class="ud-row-meta">@booking.StartDate.ToString("MMM dd") – @booking.EndDate.ToString("MMM dd") · @booking.HeadCount guests · @((booking.EndDate - booking.StartDate).Days) nights</span>
                                            <span class="ud-badge ud-badge-@(booking.Status == BookingStatus.Confirmed ? "ok" : booking.Status == BookingStatus.Pending ? "warn" : "muted")">@booking.Status</span>
                                        </div>
                                        <div class="ud-row-right">
                                            <span class="ud-row-amount">KES @CalculateBookingTotal(booking).ToString("N0")</span>
                                            <i class="bi bi-chevron-right ud-chevron"></i>
                                        </div>
                                    </div>
                                }
                            }
                            else
                            {
                                <EmptyState 
                                    Icon="building"
                                    Title="No hotel bookings yet"
                                    Description="Start exploring amazing hotels and make your first booking!"
                                    ActionText="Browse Hotels"
                                    ActionIcon="search"
                                    OnActionClick="@(() => Navigation.NavigateTo("/search"))" />
                            }
                        }
                        else
                        {
                            @if (eventBookings.Any())
                            {
                                @foreach (var booking in eventBookings.Take(5))
                                {
                                    <div class="ud-row" @onclick="() => ViewEventBooking(booking.Id)">
                                        <div class="ud-row-left">
                                            <span class="ud-row-name">@booking.EventName</span>
                                            <span class="ud-row-meta">@booking.EventDate.ToString("MMM dd, yyyy") · @booking.ExpectedGuests guests · @booking.Venue</span>
                                            <span class="ud-badge ud-badge-@(booking.Status == EventBookingStatus.Confirmed ? "ok" : booking.Status == EventBookingStatus.Pending ? "warn" : "muted")">@booking.Status</span>
                                        </div>
                                        <div class="ud-row-right">
                                            <span class="ud-row-amount">KES @booking.TotalAmount.ToString("N0")</span>
                                            <i class="bi bi-chevron-right ud-chevron"></i>
                                        </div>
                                    </div>
                                }
                            }
                            else
                            {
                                <EmptyState 
                                    Icon="calendar-event"
                                    Title="No event bookings yet"
                                    Description="Discover amazing event packages for your special occasions!"
                                    ActionText="Browse Event Packages"
                                    ActionIcon="gift"
                                    OnActionClick="@(() => Navigation.NavigateTo("/events"))" />
                            }
                        }
                    </div>
                </div>
            </div>

            <!-- Right Column: Quick Action Cards -->
            <div class="col-lg-4">
                <div class="ud-qaction-stack">
                    <a href="/search" class="ud-qaction">
                        <div class="ud-qaction-icon ud-icon-terracotta"><i class="bi bi-search"></i></div>
                        <span class="ud-qaction-text">Search Hotels</span>
                        <i class="bi bi-arrow-right ud-qaction-arrow"></i>
                    </a>
                    <a href="/events" class="ud-qaction">
                        <div class="ud-qaction-icon ud-icon-olive"><i class="bi bi-gift"></i></div>
                        <span class="ud-qaction-text">Event Packages</span>
                        <i class="bi bi-arrow-right ud-qaction-arrow"></i>
                    </a>
                    <a href="/my-bookings" class="ud-qaction">
                        <div class="ud-qaction-icon ud-icon-teal"><i class="bi bi-calendar-check"></i></div>
                        <span class="ud-qaction-text">My Bookings</span>
                        <i class="bi bi-arrow-right ud-qaction-arrow"></i>
                    </a>
                    <a href="/my-event-bookings" class="ud-qaction">
                        <div class="ud-qaction-icon ud-icon-bronze"><i class="bi bi-calendar2-event"></i></div>
                        <span class="ud-qaction-text">Event Bookings</span>
                        <i class="bi bi-arrow-right ud-qaction-arrow"></i>
                    </a>
                </div>
            </div>
        </div>
    }
</div>

<style>
    /* ── Shell ── */
    .ud-shell {
        padding: 1.25rem 1.5rem;
        font-family: -apple-system, BlinkMacSystemFont, 'SF Pro Text', 'Segoe UI', Roboto, Helvetica, Arial, sans-serif;
        -webkit-font-smoothing: antialiased;
        color: #2A2A2A;
        background: radial-gradient(circle at 15% 30%, rgba(200, 121, 65, 0.12) 0%, transparent 60%), radial-gradient(circle at 85% 70%, rgba(72, 140, 130, 0.12) 0%, transparent 60%), linear-gradient(135deg, #f5f3ef 0%, #eef0eb 100%);
        min-height: 100%;
    }

    /* ── Welcome Banner ── */
    .ud-welcome {
        display: flex;
        align-items: center;
        justify-content: space-between;
        margin-bottom: 1.25rem;
        flex-wrap: wrap;
        gap: 0.75rem;
    }
    .ud-title {
        font-size: 1.375rem;
        font-weight: 700;
        letter-spacing: -0.025em;
        color: #2A2A2A;
        margin: 0 0 0.125rem;
    }
    .ud-subtitle {
        font-size: 0.75rem;
        color: #9E8B63;
        margin: 0;
        font-weight: 500;
    }
    .ud-welcome-right {
        display: flex;
        gap: 0.5rem;
    }
    .ud-btn {
        display: inline-flex;
        align-items: center;
        gap: 0.375rem;
        padding: 0.5rem 1rem;
        border-radius: 8px;
        font-size: 0.75rem;
        font-weight: 600;
        text-decoration: none;
        transition: all 0.15s ease;
        cursor: pointer;
        border: none;
    }
    .ud-btn-primary {
        background: #2A2A2A;
        color: #fff;
    }
    .ud-btn-primary:hover {
        background: #9E8B63;
        color: #fff;
        text-decoration: none;
    }
    .ud-btn-outline {
        background: #fff;
        color: #2A2A2A;
        border: 1px solid rgba(158, 139, 99, 0.2);
    }
    .ud-btn-outline:hover {
        background: rgba(158, 139, 99, 0.06);
        color: #2A2A2A;
        text-decoration: none;
    }

    /* ── Upcoming Booking ── */
    .ud-upcoming {
        background: linear-gradient(135deg, #2A2A2A 0%, #1a1a1a 100%);
        border-radius: 14px;
        padding: 1.25rem 1.5rem;
        color: #fff;
        box-shadow: 0 12px 32px rgba(42, 42, 42, 0.15);
        border: 1px solid rgba(255, 255, 255, 0.1);
        position: relative;
        overflow: hidden;
    }
    .ud-upcoming::after {
        content: '\F4B4'; /* lightning icon */
        font-family: 'Bootstrap-icons';
        position: absolute;
        right: -20px;
        bottom: -40px;
        font-size: 8rem;
        color: rgba(200, 121, 65, 0.08); /* faint terracotta */
        pointer-events: none;
    }
    .ud-upcoming-label {
        font-size: 0.625rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.08em;
        color: #C87941;
        margin-bottom: 0.5rem;
    }
    .ud-upcoming-body {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 1rem;
    }
    .ud-upcoming-name {
        display: block;
        font-size: 1rem;
        font-weight: 700;
        color: #fff;
    }
    .ud-upcoming-meta {
        display: block;
        font-size: 0.75rem;
        color: rgba(255,255,255,0.6);
        margin-top: 0.125rem;
    }
    .ud-upcoming-countdown {
        text-align: center;
        flex-shrink: 0;
    }
    .ud-countdown-value {
        display: block;
        font-size: 1.75rem;
        font-weight: 800;
        color: #C87941;
        line-height: 1;
    }
    .ud-countdown-label {
        display: block;
        font-size: 0.625rem;
        color: rgba(255,255,255,0.5);
        text-transform: uppercase;
        letter-spacing: 0.05em;
        margin-top: 0.125rem;
    }

    /* ── Stat Cards ── */
    .ud-stat {
        background: #fff;
        border: none;
        border-radius: 16px;
        padding: 1.25rem 1.25rem;
        display: flex;
        align-items: center;
        gap: 0.875rem;
        transition: all 0.25s ease;
        color: #fff;
        box-shadow: 0 8px 24px rgba(42, 42, 42, 0.06);
    }
    /* Colorful backgrounds for the 4 stats! */
    .row > div:nth-child(1) > .ud-stat { background: linear-gradient(135deg, #C87941 0%, #B86530 100%); box-shadow: 0 8px 24px rgba(200, 121, 65, 0.25); }
    .row > div:nth-child(2) > .ud-stat { background: linear-gradient(135deg, #6B7028 0%, #5A5E22 100%); box-shadow: 0 8px 24px rgba(107, 112, 40, 0.25); }
    .row > div:nth-child(3) > .ud-stat { background: linear-gradient(135deg, #488C82 0%, #357A70 100%); box-shadow: 0 8px 24px rgba(72, 140, 130, 0.25); }
    .row > div:nth-child(4) > .ud-stat { background: linear-gradient(135deg, #9E8B63 0%, #8A7750 100%); box-shadow: 0 8px 24px rgba(158, 139, 99, 0.25); }
    
    .ud-stat:hover {
        transform: translateY(-2px);
    }
    .row > div:nth-child(1) > .ud-stat:hover { box-shadow: 0 12px 32px rgba(200, 121, 65, 0.35); }
    .row > div:nth-child(2) > .ud-stat:hover { box-shadow: 0 12px 32px rgba(107, 112, 40, 0.35); }
    .row > div:nth-child(3) > .ud-stat:hover { box-shadow: 0 12px 32px rgba(72, 140, 130, 0.35); }
    .row > div:nth-child(4) > .ud-stat:hover { box-shadow: 0 12px 32px rgba(158, 139, 99, 0.35); }

    .ud-stat-icon {
        width: 44px;
        height: 44px;
        border-radius: 12px;
        background: rgba(255, 255, 255, 0.25) !important;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.125rem;
        color: #fff !important;
        flex-shrink: 0;
        border: 1px solid rgba(255, 255, 255, 0.2);
    }
    .ud-stat-value {
        font-size: 1.375rem;
        font-weight: 800;
        letter-spacing: -0.02em;
        color: #fff !important;
        line-height: 1;
    }
    .ud-stat-label {
        font-size: 0.6875rem;
        color: rgba(255, 255, 255, 0.85);
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 0.05em;
        margin-top: 0.1875rem;
    }

    /* ── Cards ── */
    .ud-card {
        background: rgba(255, 255, 255, 0.95);
        backdrop-filter: blur(10px);
        border: 1px solid rgba(158, 139, 99, 0.15);
        border-radius: 16px;
        box-shadow: 0 16px 40px rgba(42, 42, 42, 0.05); /* Soft, elegant shadow */
        overflow: hidden;
    }
    .ud-card-head {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 0.75rem 1rem;
        border-bottom: 1px solid rgba(158, 139, 99, 0.1);
    }
    .ud-card-title {
        font-size: 0.8125rem;
        font-weight: 600;
        color: #2A2A2A;
    }
    .ud-link {
        font-size: 0.6875rem;
        font-weight: 600;
        color: #C87941;
        text-decoration: none;
        letter-spacing: 0.01em;
    }
    .ud-link:hover { text-decoration: underline; color: #a8612f; }
    .ud-card-body { padding: 0; }

    /* ── Tab Bar ── */
    .ud-tab-bar {
        display: flex;
        align-items: center;
        gap: 0;
        padding: 0 1rem;
        border-bottom: 1px solid rgba(158, 139, 99, 0.1);
    }
    .ud-tab {
        display: inline-flex;
        align-items: center;
        gap: 0.375rem;
        padding: 0.75rem 0.875rem;
        font-size: 0.75rem;
        font-weight: 500;
        color: #8a8177;
        background: none;
        border: none;
        border-bottom: 2px solid transparent;
        cursor: pointer;
        transition: all 0.15s ease;
        white-space: nowrap;
    }
    .ud-tab:hover { color: #2A2A2A; }
    .ud-tab-active {
        color: #2A2A2A;
        font-weight: 600;
        border-bottom-color: #C87941;
    }
    .ud-tab-count {
        font-size: 0.625rem;
        font-weight: 600;
        background: rgba(158, 139, 99, 0.1);
        color: #8a8177;
        padding: 0.0625rem 0.375rem;
        border-radius: 10px;
        min-width: 1.25rem;
        text-align: center;
    }
    .ud-tab-active .ud-tab-count {
        background: #C87941;
        color: #fff;
    }
    .ud-tab-spacer { flex: 1; }

    /* ── Booking Rows ── */
    .ud-row {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 0.75rem 1rem;
        border-bottom: 1px solid rgba(158, 139, 99, 0.08);
        cursor: pointer;
        transition: background 0.15s ease;
    }
    .ud-row:last-child { border-bottom: none; }
    .ud-row:hover { background: rgba(158, 139, 99, 0.04); }
    .ud-row:active { background: rgba(158, 139, 99, 0.08); }
    .ud-row-left {
        display: flex;
        flex-direction: column;
        gap: 0.125rem;
        min-width: 0;
        flex: 1;
    }
    .ud-row-name {
        font-size: 0.8125rem;
        font-weight: 600;
        color: #2A2A2A;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
    }
    .ud-row-meta {
        font-size: 0.6875rem;
        color: #8a8177;
        font-weight: 400;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
    }
    .ud-row-right {
        display: flex;
        align-items: center;
        gap: 0.5rem;
        flex-shrink: 0;
        margin-left: 0.75rem;
    }
    .ud-row-amount {
        font-size: 0.8125rem;
        font-weight: 700;
        color: #2A2A2A;
    }
    .ud-chevron {
        font-size: 0.625rem;
        color: #c4b99a;
    }

    /* ── Badges ── */
    .ud-badge {
        display: inline-block;
        font-size: 0.5625rem;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 0.04em;
        padding: 0.125rem 0.4rem;
        border-radius: 4px;
        margin-top: 0.1875rem;
        width: fit-content;
    }
    .ud-badge-ok { background: rgba(72, 140, 130, 0.1); color: #488C82; }
    .ud-badge-warn { background: rgba(200, 121, 65, 0.1); color: #C87941; }
    .ud-badge-muted { background: rgba(42, 42, 42, 0.06); color: #8a8177; }

    /* ── Quick Action Cards ── */
    .ud-qaction-stack {
        display: flex;
        flex-direction: column;
        gap: 0.75rem;
    }
    .ud-qaction {
        display: flex;
        align-items: center;
        gap: 0.875rem;
        background: rgba(255, 255, 255, 0.95);
        backdrop-filter: blur(10px);
        border: 1px solid rgba(158, 139, 99, 0.15);
        border-radius: 16px;
        padding: 1rem 1.125rem;
        text-decoration: none;
        color: #2A2A2A;
        transition: all 0.25s ease;
        box-shadow: 0 4px 16px rgba(42, 42, 42, 0.04);
        position: relative;
        overflow: hidden;
        z-index: 1;
    }
    .ud-qaction::before {
        content: '';
        position: absolute;
        top: 0; left: 0; right: 0; bottom: 0;
        z-index: -1;
        opacity: 0;
        transition: opacity 0.25s ease;
    }
    /* Let the hover state bloom in different colors! */
    .ud-qaction:nth-child(1)::before { background: linear-gradient(135deg, #C87941 0%, #B86530 100%); }
    .ud-qaction:nth-child(2)::before { background: linear-gradient(135deg, #6B7028 0%, #5A5E22 100%); }
    .ud-qaction:nth-child(3)::before { background: linear-gradient(135deg, #488C82 0%, #357A70 100%); }
    .ud-qaction:nth-child(4)::before { background: linear-gradient(135deg, #9E8B63 0%, #8A7750 100%); }

    .ud-qaction:hover {
        transform: translateY(-2px);
        border-color: transparent;
        color: #fff;
    }
    .ud-qaction:hover::before {
        opacity: 1;
    }
    .ud-qaction:nth-child(1):hover { box-shadow: 0 12px 32px rgba(200, 121, 65, 0.3); }
    .ud-qaction:nth-child(2):hover { box-shadow: 0 12px 32px rgba(107, 112, 40, 0.3); }
    .ud-qaction:nth-child(3):hover { box-shadow: 0 12px 32px rgba(72, 140, 130, 0.3); }
    .ud-qaction:nth-child(4):hover { box-shadow: 0 12px 32px rgba(158, 139, 99, 0.3); }

    .ud-qaction-icon {
        width: 40px;
        height: 40px;
        border-radius: 10px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1rem;
        flex-shrink: 0;
        transition: all 0.25s ease;
    }
    .ud-qaction:hover .ud-qaction-icon {
        background: rgba(255, 255, 255, 0.25) !important;
        color: #fff !important;
        border: 1px solid rgba(255, 255, 255, 0.2);
    }
    .ud-qaction-text {
        flex: 1;
        font-size: 0.8125rem;
        font-weight: 600;
    }
    .ud-qaction-arrow {
        font-size: 0.875rem;
        color: #c4b99a;
        transition: all 0.25s ease;
    }
    .ud-qaction:hover .ud-qaction-arrow {
        transform: translateX(4px);
        color: #fff;
    }


</style>

@code {
    private bool isLoading = true;
    private string activeTab = "hotels";
    private List<Booking> hotelBookings = new();
    private List<EventBooking> eventBookings = new();
