@page "/reset-password"
@using EventHotelBroker.Components.Layout
@using EventHotelBroker.Services
@layout AuthLayout
@rendermode InteractiveServer
@inject NavigationManager Navigation
@inject ToastService ToastService
@inject IAuthService AuthService

<PageTitle>Reset Password - Safari Vents</PageTitle>

<link href="/css/auth-login.css?v=2" rel="stylesheet" />

<div class="lg-page">
    <a href="/login" class="lg-back"><i class="bi bi-arrow-left"></i> Back to Login</a>

    <div class="lg-card">
        <div class="lg-header">
            @if (!resetSuccess)
            {
                <div class="lg-logo" style="background: linear-gradient(135deg, #f59e0b, #d97706);"><i class="bi bi-shield-lock-fill"></i></div>
                <h2 class="lg-title">Reset Your Password</h2>
                <p class="lg-subtitle">Enter a new password for your account</p>
            }
            else
            {
                <div class="lg-logo" style="background: linear-gradient(135deg, #10b981, #059669);"><i class="bi bi-check-circle-fill"></i></div>
                <h2 class="lg-title">Password Reset!</h2>
                <p class="lg-subtitle">Your password has been changed successfully</p>
            }
        </div>

        <div class="lg-body">
            @if (isLoading)
            {
                <div style="text-align: center; padding: 40px 0;">
                    <div class="spinner-border" style="color: #9E8B63;" role="status"></div>
                    <p style="color: #6c757d; margin-top: 12px; font-size: 0.9rem;">Validating your reset link...</p>
                </div>
            }
            else if (!string.IsNullOrEmpty(errorMessage))
            {
                <div style="text-align: center; padding: 20px 0;">
                    <div style="width: 64px; height: 64px; border-radius: 50%; background: #fff5f5; display: flex; align-items: center; justify-content: center; margin: 0 auto 16px;">
                        <i class="bi bi-exclamation-triangle-fill" style="font-size: 1.8rem; color: #dc3545;"></i>
                    </div>
                    <h3 style="color: #dc3545; font-size: 1.1rem; margin: 0 0 8px;">Invalid Reset Link</h3>
                    <p style="color: #6c757d; font-size: 0.9rem; margin: 0 0 24px;">@errorMessage</p>
                    <button type="button" class="lg-btn lg-btn-primary" onclick="window.location.href='/forgot-password'">
                        <i class="bi bi-envelope"></i>
                        <span>Request New Reset Link</span>
                    </button>
                </div>
            }
            else if (!resetSuccess)
            {
                <div class="lg-field">
                    <label class="lg-label">New Password</label>
                    <input type="password" class="lg-input" @bind="newPassword" placeholder="Enter new password" />
                </div>

                <div class="lg-field">
                    <label class="lg-label">Confirm New Password</label>
                    <input type="password" class="lg-input" @bind="confirmPassword" placeholder="Confirm new password" />
                </div>

                <button type="button" class="lg-btn lg-btn-primary" @onclick="HandleResetPassword" disabled="@isSubmitting">
                    @if (isSubmitting)
                    {
                        <span class="spinner-border spinner-border-sm me-1"></span>
                        <span>Resetting...</span>
                    }
                    else
                    {
                        <i class="bi bi-check-lg"></i>
                        <span>Reset Password</span>
                    }
                </button>
            }
            else
            {
                <div style="text-align: center; padding: 16px 0;">
                    <div style="background: #f0fdf4; border-radius: 12px; padding: 20px; margin-bottom: 20px;">
                        <p style="color: #166534; font-size: 0.9rem; margin: 0;">
                            Your password has been reset successfully. You can now sign in with your new password.
                        </p>
                    </div>
                </div>

                <button type="button" class="lg-btn lg-btn-primary" onclick="window.location.href='/login'">
                    <i class="bi bi-box-arrow-in-right"></i>
                    <span>Sign In</span>
                </button>
            }
        </div>
    </div>
</div>

@code {
    [SupplyParameterFromQuery(Name = "token")]
    public string? Token { get; set; }

    [SupplyParameterFromQuery(Name = "email")]
    public string? EmailParam { get; set; }

    private string newPassword = "";
    private string confirmPassword = "";
    private bool isLoading = true;
    private bool isSubmitting = false;
    private bool resetSuccess = false;
    private string? errorMessage = null;

    protected override async Task OnInitializedAsync()
    {
        await Task.Delay(300);

        if (string.IsNullOrEmpty(Token) || string.IsNullOrEmpty(EmailParam))
        {
            errorMessage = "Missing or invalid reset link parameters.";
        }

        isLoading = false;
    }

    private async Task HandleResetPassword()
    {
        if (string.IsNullOrWhiteSpace(newPassword))
        {
            ToastService.ShowWarning("Missing Password", "Please enter a new password");
            return;
        }

        if (newPassword.Length < 8)
        {
            ToastService.ShowWarning("Weak Password", "Password must be at least 8 characters long");
            return;
        }

        if (newPassword != confirmPassword)
        {
            ToastService.ShowError("Mismatch", "Passwords do not match");
            return;
        }

        isSubmitting = true;
        StateHasChanged();

        try
        {
            var decodedEmail = Uri.UnescapeDataString(EmailParam!);
            var (success, message) = await AuthService.ResetPasswordAsync(decodedEmail, Token!, newPassword);

            if (success)
            {
                resetSuccess = true;
                ToastService.ShowSuccess("Success", message);
            }
            else
            {
                errorMessage = message;
                ToastService.ShowError("Reset Failed", message);
            }
        }
        catch (Exception ex)
        {
            ToastService.ShowError("Error", $"An error occurred: {ex.Message}");
        }
        finally
        {
            isSubmitting = false;
            StateHasChanged();
        }
    }
}
