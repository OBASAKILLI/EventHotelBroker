@page "/enroll-as-owner"
@using EventHotelBroker.Services
@using EventHotelBroker.Utils
@using EventHotelBroker.Data
@using Microsoft.EntityFrameworkCore
@using Microsoft.AspNetCore.Components.Authorization
@inject IAuthService AuthService
@inject ApplicationDbContext DbContext
@inject NavigationManager Navigation
@inject IJSRuntime JSRuntime
@inject AuthenticationStateProvider AuthStateProvider
@rendermode InteractiveServer

<PageTitle>Enroll as Business Owner - Safari Vents</PageTitle>

<div style="display:flex;justify-content:center;align-items:center;min-height:100vh;background:linear-gradient(135deg,#f0f2f5,#e8eaed);padding:20px;">
    <div style="background:white;border-radius:20px;padding:48px 40px;max-width:480px;width:100%;box-shadow:0 20px 60px rgba(0,0,0,0.1);text-align:center;">
        <div style="width:80px;height:80px;background:linear-gradient(135deg,#f59e0b,#d97706);border-radius:50%;display:flex;align-items:center;justify-content:center;margin:0 auto 24px;">
            <i class="bi bi-shop" style="font-size:2.2rem;color:white;"></i>
        </div>

        @if (!done)
        {
            <h2 style="font-weight:800;color:#1a1a1a;margin-bottom:8px;">Become a Business Owner</h2>
            <p style="color:#6c757d;font-size:0.95rem;line-height:1.6;margin-bottom:32px;">
                List your hotels, venues, and equipment on Safari Vents and reach thousands of event planners and travelers.
            </p>

            @if (!string.IsNullOrEmpty(errorMessage))
            {
                <div style="background:#fff5f5;border:1px solid #fed7d7;border-radius:10px;padding:14px 18px;margin-bottom:20px;color:#c53030;font-size:0.88rem;text-align:left;">
                    <i class="bi bi-exclamation-circle me-2"></i>@errorMessage
                </div>
            }

            <button @onclick="DoEnroll" disabled="@isLoading"
                style="width:100%;padding:16px;border:none;border-radius:12px;background:linear-gradient(135deg,#f59e0b,#d97706);color:white;font-weight:700;font-size:1rem;cursor:pointer;transition:opacity 0.2s;">
                @if (isLoading)
                {
                    <span class="spinner-border spinner-border-sm me-2"></span>
                }
                Enroll My Business Now
            </button>
            <a href="/" style="display:block;margin-top:16px;color:#6c757d;font-size:0.88rem;text-decoration:none;">← Not now, go back</a>
        }
        else
        {
            <div>
                <div style="width:64px;height:64px;background:#d1fae5;border-radius:50%;display:flex;align-items:center;justify-content:center;margin:0 auto 20px;">
                    <i class="bi bi-check-lg" style="font-size:2rem;color:#059669;"></i>
                </div>
                <h2 style="font-weight:800;color:#1a1a1a;margin-bottom:8px;">You're Now an Owner!</h2>
                <p style="color:#6c757d;font-size:0.95rem;line-height:1.6;margin-bottom:28px;">
                    Your account has been upgraded. You can now create and manage your properties.
                    Redirecting you now...
                </p>
                <div style="width:100%;height:4px;background:#e2e8f0;border-radius:2px;overflow:hidden;">
                    <div style="height:100%;background:linear-gradient(90deg,#f59e0b,#d97706);animation:progress 2s linear forwards;"></div>
                </div>
            </div>
        }
    </div>
</div>

<style>
    @@keyframes progress { from { width: 0%; } to { width: 100%; } }
</style>

@code {
    [SupplyParameterFromQuery] public string? userId { get; set; }

    private bool isLoading = false;
    private bool done = false;
    private string errorMessage = "";

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender && string.IsNullOrEmpty(userId))
        {
            // Try to get userId from auth state
            var auth = await AuthStateProvider.GetAuthenticationStateAsync();
            var nameClaim = auth.User.FindFirst(System.Security.Claims.ClaimTypes.Name)?.Value ?? "";
            userId = nameClaim.Split(',').FirstOrDefault();
        }
    }

    private async Task DoEnroll()
    {
        if (string.IsNullOrEmpty(userId)) { errorMessage = "Unable to identify your account. Please log in again."; return; }

        isLoading = true;
        StateHasChanged();

        var result = await AuthService.EnrollAsOwnerAsync(userId);

        if (result.Success)
        {
            // Get the updated user and regenerate the JWT
            var user = await DbContext.Users.FirstOrDefaultAsync(u => u.strid == userId);
            if (user != null)
            {
                // Regenerate token with updated AccountType
                // We navigate to the login page to refresh the session cleanly
                done = true;
                StateHasChanged();

                // Clear old cookie then re-login by redirecting to login
                await JSRuntime.InvokeVoidAsync("authHelpers.deleteCookie", "JWToken");
                await Task.Delay(2500);
                Navigation.NavigateTo("/login?enrolled=true", forceLoad: true);
            }
        }
        else
        {
            errorMessage = result.Message;
            isLoading = false;
            StateHasChanged();
        }
    }
}
