@page "/login"
@using EventHotelBroker.Components.Layout
@using EventHotelBroker.Services
@layout AuthLayout
@rendermode InteractiveServer
@inject NavigationManager Navigation
@inject ToastService ToastService
@inject IAuthService AuthService

<PageTitle>Login - EventHotelBroker</PageTitle>

<link href="/css/auth-login.css?v=1" rel="stylesheet" />

<div class="lg-page">
    <a href="/" class="lg-back"><i class="bi bi-arrow-left"></i> Back to Home</a>

    <div class="lg-card">
        <div class="lg-header">
            <div class="lg-logo"><i class="bi bi-building-fill"></i></div>
            <h2 class="lg-title">Welcome Back</h2>
            <p class="lg-subtitle">Sign in to your EventHotelBroker account</p>
        </div>

        <div class="lg-body">
            <div class="lg-field">
                <label class="lg-label">Email Address</label>
                <input type="email" class="lg-input" @bind="email" placeholder="you@example.com" />
            </div>

            <div class="lg-field">
                <label class="lg-label">Password</label>
                <input type="password" class="lg-input" @bind="password" placeholder="Enter your password" />
            </div>

            <div class="lg-options">
                <label class="lg-check">
                    <input type="checkbox" @bind="rememberMe" />
                    <span class="lg-check-label">Remember me</span>
                </label>
                <a href="/forgot-password" class="lg-forgot">Forgot password?</a>
            </div>

            <button type="button" class="lg-btn lg-btn-primary" @onclick="HandleLogin" disabled="@isLoggingIn">
                @if (isLoggingIn)
                {
                    <span class="lg-spinner"></span>
                    <span>Signing In...</span>
                }
                else
                {
                    <i class="bi bi-box-arrow-in-right"></i>
                    <span>Sign In</span>
                }
            </button>

            <div class="lg-divider">
                <span class="lg-divider-text">or continue with</span>
            </div>

            <div class="lg-socials">
                <button type="button" class="lg-btn-social" @onclick="GoogleLogin">
                    <i class="bi bi-google"></i> Google
                </button>
                <button type="button" class="lg-btn-social" @onclick="FacebookLogin">
                    <i class="bi bi-facebook"></i> Facebook
                </button>
            </div>

            <div class="lg-footer">
                Don't have an account? <a href="/register">Sign up</a>
            </div>
        </div>
    </div>
</div>

@code {
    private string email = "";
    private string password = "";
    private bool rememberMe = false;
    private bool isLoggingIn = false;

    private async Task HandleLogin()
    {
        if (string.IsNullOrEmpty(email) || string.IsNullOrEmpty(password))
        {
            ToastService.ShowWarning("Missing Information", "Please enter your email and password");
            return;
        }

        isLoggingIn = true;

        var (success, message, user) = await AuthService.LoginAsync(email, password);

        if (success && user != null)
        {
            // Check if 2FA is enabled for this user
            if (user.TwoFactorEnabled)
            {
                // Generate and send 2FA code
                var codeSent = await AuthService.GenerateAndSendTwoFactorCodeAsync(user.Id);

                if (codeSent)
                {
                    ToastService.ShowSuccess("Verification Code Sent", "Please check your email for the verification code");
                    await Task.Delay(1000);
                    Navigation.NavigateTo($"/verify-2fa?UserId={user.Id}");
                }
                else
                {
                    ToastService.ShowError("Error", "Failed to send verification code. Please try again.");
                }
            }
            else
            {
                // No 2FA, redirect directly to dashboard
                ToastService.ShowSuccess("Login Successful!", "Welcome back to EventHotelBroker");
                await Task.Delay(1000);
                
                if (user.Role == "Admin")
                {
                    Navigation.NavigateTo("/admin/dashboard");
                }
                else if (user.Role == "HotelOwner")
                {
                    Navigation.NavigateTo("/owner/dashboard");
                }
                else
                {
                    Navigation.NavigateTo("/user/dashboard");
                }
            }
        }
        else
        {
            ToastService.ShowError("Login Failed", message);
        }

        isLoggingIn = false;
    }

    private void GoogleLogin()
    {
        ToastService.ShowInfo("Google Login", "Google authentication would be integrated here");
    }

    private void FacebookLogin()
    {
        ToastService.ShowInfo("Facebook Login", "Facebook authentication would be integrated here");
    }
}
