@page "/register"
@using EventHotelBroker.Components.Layout
@using EventHotelBroker.Services
@using EventHotelBroker.Models
@using EventHotelBroker.Data
@using EventHotelBroker.Utils
@using Microsoft.EntityFrameworkCore
@layout AuthLayout
@rendermode InteractiveServer
@inject NavigationManager Navigation
@inject ToastService ToastService
@inject ApplicationDbContext DbContext
@inject EventHotelBroker.Services.IEmailService EmailService

<PageTitle>Register - EventHotelBroker</PageTitle>

<link href="/css/auth-register.css?v=1" rel="stylesheet" />

<div class="rg-page">
    <a href="/" class="rg-back"><i class="bi bi-arrow-left"></i> Back to Home</a>

    <div class="rg-card">
        <div class="rg-header">
            <div class="rg-logo"><i class="bi bi-person-plus-fill"></i></div>
            <h2 class="rg-title">Create Account</h2>
            <p class="rg-subtitle">Join EventHotelBroker today</p>
        </div>

        <div class="rg-body">
            <div class="rg-field">
                <label class="rg-label">Full Name</label>
                <input type="text" class="rg-input" @bind="fullName" placeholder="John Doe" />
            </div>

            <div class="rg-field">
                <label class="rg-label">Email Address</label>
                <input type="email" class="rg-input" @bind="email" placeholder="you@example.com" />
            </div>

            <div class="rg-field">
                <label class="rg-label">Phone Number</label>
                <input type="tel" class="rg-input" @bind="phone" placeholder="+254 712 345 678" />
            </div>

            <div class="rg-row">
                <div class="rg-field">
                    <label class="rg-label">Password</label>
                    <input type="password" class="rg-input" @bind="password" placeholder="Strong password" />
                </div>
                <div class="rg-field">
                    <label class="rg-label">Confirm Password</label>
                    <input type="password" class="rg-input" @bind="confirmPassword" placeholder="Confirm password" />
                </div>
            </div>

            <div class="rg-field">
                <label class="rg-label">Register as</label>
                <select class="rg-select" @bind="userRole">
                    <option value="client">Client (Book hotels & events)</option>
                    <option value="owner">Hotel / Venue Owner</option>
                </select>
            </div>

            <label class="rg-terms">
                <input type="checkbox" @bind="acceptTerms" />
                <span class="rg-terms-label">I agree to the <a href="/terms">Terms & Conditions</a> and <a href="/privacy">Privacy Policy</a></span>
            </label>

            <button type="button" class="rg-btn rg-btn-primary" @onclick="HandleRegister" disabled="@isSubmitting">
                @if (isSubmitting)
                {
                    <span class="spinner-border spinner-border-sm me-1"></span> <span>Creating Account...</span>
                }
                else
                {
                    <i class="bi bi-person-check"></i> <span>Create Account</span>
                }
            </button>

            <div class="rg-divider">
                <span class="rg-divider-text">or sign up with</span>
            </div>

            <div class="rg-socials">
                <button type="button" class="rg-btn-social" @onclick="GoogleSignup">
                    <i class="bi bi-google"></i> Google
                </button>
                <button type="button" class="rg-btn-social" @onclick="FacebookSignup">
                    <i class="bi bi-facebook"></i> Facebook
                </button>
            </div>

            <div class="rg-footer">
                Already have an account? <a href="/login">Sign in</a>
            </div>
        </div>
    </div>
</div>

@code {
    private string fullName = "";
    private string email = "";
    private string phone = "";
    private string password = "";
    private string confirmPassword = "";
    private string userRole = "client";
    private bool acceptTerms = false;
    private bool isSubmitting = false;

    private async Task HandleRegister()
    {
        if (isSubmitting) return;

        // Validation
        if (string.IsNullOrWhiteSpace(fullName) || string.IsNullOrWhiteSpace(email) || string.IsNullOrWhiteSpace(password))
        {
            ToastService.ShowWarning("Missing Information", "Please fill in all required fields");
            return;
        }

        if (password != confirmPassword)
        {
            ToastService.ShowError("Password Mismatch", "Passwords do not match");
            return;
        }

        if (password.Length < 8)
        {
            ToastService.ShowWarning("Weak Password", "Password must be at least 8 characters long");
            return;
        }

        if (!acceptTerms)
        {
            ToastService.ShowWarning("Terms Required", "Please accept the terms and conditions");
            return;
        }

        isSubmitting = true;
        StateHasChanged();

        try
        {
            // Check if email already exists
            var existingUser = await DbContext.Users.FirstOrDefaultAsync(u => u.Email == email.Trim());
            if (existingUser != null)
            {
                ToastService.ShowError("Email Taken", "An account with this email address already exists");
                isSubmitting = false;
                return;
            }

            // Encrypt the password
            var encryption = new Encryption();
            var encryptedPassword = encryption.Encryptstring(password);

            // Parse full name
            var nameParts = fullName.Trim().Split(' ', StringSplitOptions.RemoveEmptyEntries);
            var firstName = nameParts.Length > 0 ? nameParts[0] : fullName.Trim();
            var lastName = nameParts.Length > 1 ? nameParts[^1] : ".";
            var middleName = nameParts.Length > 2 ? string.Join(" ", nameParts[1..^1]) : ".";

            // Generate email verification token
            var verificationToken = Guid.NewGuid().ToString("N");
            var tokenExpiry = DateTime.UtcNow.AddHours(24);

            // Determine role
            var role = userRole == "owner" ? "HotelOwner" : "User";

            // Create new user
            var newUser = new EventHotelBroker.Models.Users
            {
                FirstName = firstName,
                MiddleName = middleName,
                LastName = lastName,
                FullName = fullName.Trim(),
                Email = email.Trim(),
                PhoneNumber = phone?.Trim() ?? "",
                password_hash = encryptedPassword,
                Role = role,
                AccountType = role,
                IsActive = false,
                IsEmailVerified = false,
                EmailVerificationToken = verificationToken,
                EmailVerificationTokenExpiry = tokenExpiry,
                IsTwoFAEnabled = false,
                CreatedAt = DateTime.UtcNow
            };

            await DbContext.Users.AddAsync(newUser);
            await DbContext.SaveChangesAsync();

            // Build verification link
            var baseUrl = Navigation.BaseUri.TrimEnd('/');
            var verificationLink = $"{baseUrl}/activate-account?token={verificationToken}&email={Uri.EscapeDataString(email.Trim())}";

            // Send verification email
            try
            {
                await EmailService.SendVerificationEmailAsync(email.Trim(), fullName.Trim(), verificationLink);
            }
            catch (Exception)
            {
                // Email sending may fail if SMTP is not configured, but user is still created
            }

            ToastService.ShowSuccess("Registration Successful!", "A verification email has been sent to your inbox. Please check your email and click the activation link to activate your account.");
        }
        catch (Exception ex)
        {
            ToastService.ShowError("Registration Failed", $"An error occurred: {ex.Message}");
        }
        finally
        {
            isSubmitting = false;
            StateHasChanged();
        }
    }

    private void GoogleSignup()
    {
        ToastService.ShowInfo("Google Signup", "Google authentication would be integrated here");
    }

    private void FacebookSignup()
    {
        ToastService.ShowInfo("Facebook Signup", "Facebook authentication would be integrated here");
    }
}
