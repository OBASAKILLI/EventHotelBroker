@page "/forgot-password"
@using EventHotelBroker.Components.Layout
@using EventHotelBroker.Services
@layout AuthLayout
@rendermode InteractiveServer
@inject NavigationManager Navigation
@inject ToastService ToastService
@inject IAuthService AuthService

<PageTitle>Forgot Password - Safari Vents</PageTitle>

<link href="/css/auth-login.css?v=1" rel="stylesheet" />

<div class="lg-page">
    <a href="/login" class="lg-back"><i class="bi bi-arrow-left"></i> Back to Login</a>

    <div class="lg-card">
        <div class="lg-header">
            @if (!emailSent)
            {
                <div class="lg-logo" style="background: linear-gradient(135deg, #f59e0b, #d97706);"><i class="bi bi-key-fill"></i></div>
                <h2 class="lg-title">Forgot Password?</h2>
                <p class="lg-subtitle">Enter your email and we'll send you a reset link</p>
            }
            else
            {
                <div class="lg-logo" style="background: linear-gradient(135deg, #10b981, #059669);"><i class="bi bi-envelope-check-fill"></i></div>
                <h2 class="lg-title">Check Your Email</h2>
                <p class="lg-subtitle">We've sent a password reset link to your inbox</p>
            }
        </div>

        <div class="lg-body">
            @if (!emailSent)
            {
                <div class="lg-field">
                    <label class="lg-label">Email Address</label>
                    <input type="email" class="lg-input" @bind="email" placeholder="you@example.com" />
                </div>

                <button type="button" class="lg-btn lg-btn-primary" @onclick="HandleForgotPassword" disabled="@isSubmitting">
                    @if (isSubmitting)
                    {
                        <span class="spinner-border spinner-border-sm me-1"></span>
                        <span>Sending...</span>
                    }
                    else
                    {
                        <i class="bi bi-envelope"></i>
                        <span>Send Reset Link</span>
                    }
                </button>

                <div class="lg-footer">
                    Remember your password? <a href="/login">Sign in</a>
                </div>
            }
            else
            {
                <div style="text-align: center; padding: 16px 0;">
                    <div style="background: #f0fdf4; border-radius: 12px; padding: 20px; margin-bottom: 20px;">
                        <p style="color: #166534; font-size: 0.9rem; margin: 0;">
                            If an account exists for <strong>@email</strong>, you will receive a password reset email shortly.
                        </p>
                    </div>
                    <p style="color: #6c757d; font-size: 0.85rem;">
                        Didn't receive the email? Check your spam folder or
                        <button type="button" style="background: none; border: none; color: #667eea; cursor: pointer; font-size: 0.85rem; text-decoration: underline;" @onclick="ResetForm">try again</button>
                    </p>
                </div>

                <button type="button" class="lg-btn lg-btn-primary" onclick="window.location.href='/login'">
                    <i class="bi bi-box-arrow-in-right"></i>
                    <span>Back to Sign In</span>
                </button>
            }
        </div>
    </div>
</div>

@code {
    private string email = "";
    private bool isSubmitting = false;
    private bool emailSent = false;

    private async Task HandleForgotPassword()
    {
        if (string.IsNullOrWhiteSpace(email))
        {
            ToastService.ShowWarning("Missing Email", "Please enter your email address");
            return;
        }

        isSubmitting = true;
        StateHasChanged();

        try
        {
            var (success, message) = await AuthService.ForgotPasswordAsync(email.Trim(), Navigation.BaseUri);

            if (success)
            {
                emailSent = true;
                ToastService.ShowSuccess("Email Sent", message);
            }
            else
            {
                ToastService.ShowError("Error", message);
            }
        }
        catch (Exception ex)
        {
            ToastService.ShowError("Error", $"An error occurred: {ex.Message}");
        }
        finally
        {
            isSubmitting = false;
            StateHasChanged();
        }
    }

    private void ResetForm()
    {
        emailSent = false;
        email = "";
    }
}
